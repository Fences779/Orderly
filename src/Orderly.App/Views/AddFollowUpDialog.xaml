<Window x:Class="Orderly.App.Views.AddFollowUpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增跟进"
        Width="480"
        Height="420"
        MinWidth="440"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PageBackgroundBrush}"
        AutomationProperties.AutomationId="AddFollowUpDialog">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/AppContentScrollResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题区 -->
        <Border Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="新增跟进" Style="{StaticResource DialogSectionTitleStyle}" Margin="0" />
                <TextBlock Text="设置跟进任务的标题、时间和内容" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <Grid Grid.Row="1" Margin="22,18,22,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 跟进标题 -->
            <TextBlock Grid.Row="0" Text="跟进标题 *" Style="{StaticResource DialogFieldLabelStyle}" />
            <TextBox x:Name="TitleTextBox"
                     Grid.Row="1"
                     Margin="0,0,0,14"
                     AutomationProperties.AutomationId="AddFollowUpDialog_Title" />

            <!-- 计划跟进时间 -->
            <TextBlock Grid.Row="2"
                       Style="{StaticResource DialogFieldLabelStyle}">
                <Run Text="计划跟进时间" />
                <Run Text="（格式：2026-04-28 14:30）" Foreground="{DynamicResource MutedBrush}" FontWeight="Normal" />
            </TextBlock>
            <TextBox x:Name="ScheduledAtTextBox"
                     Grid.Row="3"
                     Margin="0,0,0,14"
                     AutomationProperties.AutomationId="AddFollowUpDialog_ScheduledAt" />

            <!-- 跟进内容 -->
            <StackPanel Grid.Row="4">
                <TextBlock Text="跟进内容（可选）" Style="{StaticResource DialogFieldLabelStyle}" />
                <TextBox x:Name="ContentTextBox"
                         Margin="0,0,0,0"
                         MinHeight="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         AutomationProperties.AutomationId="AddFollowUpDialog_Content" />
            </StackPanel>
        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2"
                Background="#FFFDF8"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Style="{StaticResource DialogSecondaryButtonStyle}"
                        IsCancel="True"
                        Margin="0,0,10,0"
                        AutomationProperties.AutomationId="AddFollowUpDialog_Cancel" />
                <Button Content="确认保存"
                        Style="{StaticResource DialogPrimaryButtonStyle}"
                        IsDefault="True"
                        Click="ConfirmButton_Click"
                        AutomationProperties.AutomationId="AddFollowUpDialog_Confirm" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
