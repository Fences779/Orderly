<Window x:Class="Orderly.App.Views.AddFollowUpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增跟进"
        Width="460"
        Height="380"
        MinWidth="420"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        AutomationProperties.AutomationId="AddFollowUpDialog">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="跟进标题" FontWeight="SemiBold" />
        <TextBox x:Name="TitleTextBox" Grid.Row="1" Margin="0,8,0,14"
                 AutomationProperties.AutomationId="AddFollowUpDialog_Title" />

        <TextBlock Grid.Row="2" Text="计划跟进时间（如 2026-04-28 14:30）" FontWeight="SemiBold" />
        <TextBox x:Name="ScheduledAtTextBox" Grid.Row="3" Margin="0,8,0,14"
                 AutomationProperties.AutomationId="AddFollowUpDialog_ScheduledAt" />

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="跟进内容" FontWeight="SemiBold" />
            <TextBox x:Name="ContentTextBox"
                     Grid.Row="1"
                     Margin="0,8,0,0"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     AutomationProperties.AutomationId="AddFollowUpDialog_Content" />
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="78" Margin="0,0,8,0" IsCancel="True"
                    AutomationProperties.AutomationId="AddFollowUpDialog_Cancel" />
            <Button Content="确认" Width="78" IsDefault="True" Click="ConfirmButton_Click"
                    AutomationProperties.AutomationId="AddFollowUpDialog_Confirm" />
        </StackPanel>
    </Grid>
</Window>
