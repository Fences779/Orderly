<UserControl x:Class="Orderly.App.Views.Sections.BusinessAdviceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="Page_BusinessAdvice">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="Transparent" DataContext="{Binding BusinessAdvicePage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="经营建议" FontSize="29" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" />
                <TextBlock Text="基于本地数据生成的经营洞察" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshCommand}" VerticalAlignment="Center"
                    Foreground="{DynamicResource BlueTextBrush}" Padding="14,6" />
        </Grid>

        <!-- 加载中 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding ShowLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="正在生成经营建议…" Foreground="{DynamicResource MutedBrush}" FontSize="15" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 加载失败 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="#D12E9F" HorizontalAlignment="Center" />
            <TextBlock Text="经营建议生成失败" Foreground="{DynamicResource HeadingBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,0" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,6,0,0" MaxWidth="420" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" />
            <Button Content="重试" Command="{Binding RefreshCommand}" Margin="0,14,0,0" Padding="18,7" HorizontalAlignment="Center"
                    Foreground="{DynamicResource BlueTextBrush}" />
        </StackPanel>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="暂无经营建议" Foreground="{DynamicResource MutedBrush}" FontSize="15" Margin="0,14,0,0" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 数据 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowContent, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Insights}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFF" BorderBrush="#E5E7EC" BorderThickness="1" CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border CornerRadius="6" Padding="8,2" Background="#F2EEFC" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Severity, Converter={StaticResource CommerceEnumLabelConverter}}" FontSize="11" Foreground="#7A3EDB" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding Message}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Category}" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
