<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabDataSecurity"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ===== 派生 Thickness 布局令牌（分量对齐 Shape.xaml 的 4pt 栅格 4/8/12/16/24/32，消除散落 Margin/Padding 字面量，Req 9.1/1.12） ===== -->
            <Thickness x:Key="SettingsCardSpacing">0,16,0,0</Thickness>            <!-- 上 UiSpaceMd(16)，卡片顶部间距 -->
            <Thickness x:Key="SettingsRowDescMargin">0,4,0,0</Thickness>           <!-- 上 UiSpaceXxs(4)，说明文字间距 -->
            <Thickness x:Key="SettingsInlineLabelMargin">8,0,0,0</Thickness>        <!-- 左 UiSpaceXs(8)，行内单位标签间隔 -->
            <Thickness x:Key="SettingsUpdateStatusMargin">0,8,0,0</Thickness>       <!-- 上 UiSpaceXs(8)，更新状态间距 -->
            <Thickness x:Key="SettingsFieldHeaderMargin">0,0,0,8</Thickness>
            <Thickness x:Key="SettingsInlineButtonMargin">0,0,8,0</Thickness>
            <Thickness x:Key="SettingsSmallActionButtonPadding">10,0</Thickness>
            <Thickness x:Key="SettingsPathPanelPadding">12,10</Thickness>
            <Thickness x:Key="SettingsStatusBadgePadding">10,4</Thickness>
            <Thickness x:Key="SettingsLogPanelPadding">12</Thickness>
            <CornerRadius x:Key="SettingsPathPanelRadius">8</CornerRadius>
            <CornerRadius x:Key="SettingsStatusBadgeRadius">6</CornerRadius>

            <!-- 异步操作按钮专用的现代化微动画与 Loading 样式 -->
            <Style x:Key="AsyncLoadingActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsRowActionButtonStyle}">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- 旋转加载环 -->
                                        <Grid x:Name="LoadingSpinner"
                                              Width="0"
                                              Height="14"
                                              Opacity="0"
                                              Margin="0"
                                              RenderTransformOrigin="0.5,0.5"
                                              VerticalAlignment="Center">
                                            <Grid.RenderTransform>
                                                <RotateTransform x:Name="SpinnerTransform" Angle="0" />
                                            </Grid.RenderTransform>
                                            <!-- 背景淡环 -->
                                            <Ellipse Stroke="{DynamicResource BorderBrushSoft}" StrokeThickness="2" Width="12" Height="12" Opacity="0.3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <!-- 主色前景弧 -->
                                            <Ellipse Stroke="{TemplateBinding Foreground}" StrokeThickness="2" StrokeDashArray="3 1.5" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        
                                        <!-- 按钮内容 -->
                                        <ContentPresenter x:Name="Presenter"
                                                          Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#ECECF1" />
                                    <Setter Property="Cursor" Value="Hand" />
                                </Trigger>
                                
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#E2E2E7" />
                                </Trigger>
                                
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Chrome" Property="Background" Value="#F5F2EA" />
                                    <Setter Property="Foreground" Value="#8B908B" />
                                    <Setter Property="Cursor" Value="Arrow" />
                                </Trigger>
                                
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Command.IsRunning}" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="#F5F2EA" />
                                    <Setter Property="Foreground" Value="#8B908B" />
                                    <Setter Property="IsEnabled" Value="False" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="StartLoading">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                                                                 Storyboard.TargetProperty="Width"
                                                                 To="14" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation Storyboard.TargetName="LoadingSpinner"
                                                                    Storyboard.TargetProperty="Margin"
                                                                    To="0,0,6,0" Duration="0:0:0.25">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                                <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.2" />
                                                <DoubleAnimation Storyboard.TargetName="SpinnerTransform"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:1.0"
                                                                 RepeatBehavior="Forever" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <RemoveStoryboard BeginStoryboardName="StartLoading" />
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                                                                 Storyboard.TargetProperty="Width"
                                                                 To="0" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseIn" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation Storyboard.TargetName="LoadingSpinner"
                                                                    Storyboard.TargetProperty="Margin"
                                                                    To="0" Duration="0:0:0.2">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseIn" />
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                                <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.15" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="0.94" Duration="0:0:0.1">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="0.94" Duration="0:0:0.1">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1.0" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <BackEase EasingMode="EaseOut" Amplitude="0.5" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1.0" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <BackEase EasingMode="EaseOut" Amplitude="0.5" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <!--
        宿主归类（任务 17.3，设计 §7.1）：本子控件归「安全与日志」分类，承载
        「数据安全与隐私」+「本地数据库维护」+「系统日志记录」三张卡片
        （「系统日志记录」原属 SettingsTabDataAudit，按 §7.1 迁入此处的安全与日志宿主）。
    -->
    <StackPanel>
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                                <StackPanel>
                                    <TextBlock Text="数据安全与隐私" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开机后允许快速登录（PIN / Windows Hello）" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="使用主密码登录一次后，本次开机内重新启动软件可快速验证" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding Settings.QuickLoginEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_QuickLoginEnabled" />
                                        </Grid>
                                    </Border>

                                    <!-- 敏感电话默认遮蔽 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="敏感电话默认加星" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在客户列表与复制内容中遮蔽电话号码关键数字" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding MaskPhoneByDefaultInput}"
                                                      AutomationProperties.AutomationId="Chk_MaskPhoneByDefault" />
                                        </Grid>
                                    </Border>

                                    <!-- 敏感地址默认遮蔽 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="敏感地址默认加星" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在复制内容中识别并遮蔽联系地址关键详情" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding MaskAddressByDefaultInput}"
                                                      AutomationProperties.AutomationId="Chk_MaskAddressByDefault" />
                                        </Grid>
                                    </Border>

                                    <!-- 备份时包含明文敏感字段 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="备份导出明文敏感字段" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="导出数据时包含明文敏感信息（不推荐开启）" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding IncludeSensitiveInExportInput}"
                                                      AutomationProperties.AutomationId="Chk_IncludeSensitiveInExport" />
                                        </Grid>
                                    </Border>

                                    <!-- 复制订单摘要时脱敏 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="复制订单摘要时脱敏" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="一键复制订单时自动隐藏客户姓名、金额等隐私" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding MaskOrderSummaryOnCopyInput}"
                                                      AutomationProperties.AutomationId="Chk_MaskOrderSummaryOnCopy" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 数据库维护卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                                <StackPanel>
                                    <TextBlock Text="本地数据库维护" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 数据库路径 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="{StaticResource SettingsFieldHeaderMargin}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="数据库路径" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Content="复制路径" Style="{StaticResource SettingsRowActionButtonStyle}" Height="28" Padding="{StaticResource SettingsSmallActionButtonPadding}" Margin="{StaticResource SettingsInlineButtonMargin}" Command="{Binding CopyDatabasePathCommand}" />
                                                    <Button Content="打开文件夹" Style="{StaticResource SettingsRowActionButtonStyle}" Height="28" Padding="{StaticResource SettingsSmallActionButtonPadding}" Command="{Binding OpenDataDirectoryCommand}" />
                                                </StackPanel>
                                            </Grid>
                                            <Border Grid.Row="1" Background="{DynamicResource GreySoftBrush}" CornerRadius="{StaticResource SettingsPathPanelRadius}" Padding="{StaticResource SettingsPathPanelPadding}">
                                                <TextBlock Text="{Binding DatabasePath}" Style="{StaticResource SettingsStatusTextStyle}" TextWrapping="Wrap" Foreground="{DynamicResource HeadingBrush}" FontFamily="Consolas, Courier New" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- 数据库体积 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="数据体积" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="本地 SQLite 数据库文件占用磁盘空间大小" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding DatabaseSizeText}" FontSize="{DynamicResource UiFontSize14}" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <!-- 数据库优化与清理 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="数据库优化与压缩" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="整理碎片空间以提升性能" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                             <Button Grid.Column="1" Content="立即优化" Style="{StaticResource AsyncLoadingActionButtonStyle}"
                                                     Command="{Binding OptimizeDatabaseCommand}" />
                                        </Grid>
                                    </Border>

                                    <!-- 完整性检查 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="数据完整性校验" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="检测数据库结构是否受损、关键表是否存在" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border CornerRadius="{StaticResource SettingsStatusBadgeRadius}" Padding="{StaticResource SettingsStatusBadgePadding}" Margin="{StaticResource SettingsInlineButtonMargin}" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource GreySoftBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DatabaseHealthStatusText}" Value="正常">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DatabaseHealthStatusText}" Value="异常">
                                                                    <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding DatabaseHealthStatusText}" FontSize="{DynamicResource UiFontSize12}" FontWeight="SemiBold" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource GreyTextBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DatabaseHealthStatusText}" Value="正常">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DatabaseHealthStatusText}" Value="异常">
                                                                        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <Button Content="开始检查" Style="{StaticResource AsyncLoadingActionButtonStyle}"
                                                        Command="{Binding RunDatabaseHealthCheckCommand}"
                                                        AutomationProperties.AutomationId="Btn_CheckDatabaseHealth" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- 检查详细结果 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="校验日志详情" Style="{StaticResource SettingsItemTitleStyle}" Margin="{StaticResource SettingsFieldHeaderMargin}" />
                                            <Border Grid.Row="1"
                                                     Background="#141416"
                                                     BorderBrush="#252529"
                                                     BorderThickness="1"
                                                     CornerRadius="10"
                                                     ClipToBounds="True"
                                                     Margin="0,4,0,0">
                                                 <Grid>
                                                     <Grid.RowDefinitions>
                                                         <RowDefinition Height="30" />
                                                         <RowDefinition Height="Auto" />
                                                     </Grid.RowDefinitions>
                                                     
                                                     <!-- 终端顶部控制栏 -->
                                                     <Border Grid.Row="0" Background="#1B1B1F" BorderBrush="#252529" BorderThickness="0,0,0,1">
                                                         <Grid Margin="12,0">
                                                             <!-- Mac 三色按钮 -->
                                                             <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                 <Ellipse Width="8" Height="8" Fill="#FF5F56" Margin="0,0,6,0" />
                                                                 <Ellipse Width="8" Height="8" Fill="#FFBD2E" Margin="0,0,6,0" />
                                                                 <Ellipse Width="8" Height="8" Fill="#27C93F" />
                                                             </StackPanel>
                                                             
                                                             <!-- 标题小字 -->
                                                             <TextBlock Text="DATABASE VERIFICATION LOGS"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="10"
                                                                        FontWeight="Bold"
                                                                        FontFamily="Consolas, Monaco"
                                                                        Foreground="#6272A4"
                                                                        Opacity="0.8" />
                                                         </Grid>
                                                     </Border>
                                                     
                                                     <!-- 终端内容区 -->
                                                     <Border Grid.Row="1" Background="#141416" Padding="14,12">
                                                         <TextBlock FontFamily="Consolas, Cascadia Code, Monaco, monospace"
                                                                    FontSize="12"
                                                                    Foreground="#F8F8F2"
                                                                    TextWrapping="Wrap"
                                                                    LineHeight="18"
                                                                    VerticalAlignment="Center">
                                                             <Run Text="orderly-db:~ $ " Foreground="#FF79C6" FontWeight="SemiBold" />
                                                             <Run Text="{Binding DatabaseHealthDetailText, Mode=OneWay}" />
                                                             <InlineUIContainer>
                                                                 <Border x:Name="TermCursor"
                                                                         Width="6"
                                                                         Height="12"
                                                                         Background="#50FA7B"
                                                                         Margin="2,2,0,0"
                                                                         VerticalAlignment="Center">
                                                                     <Border.Triggers>
                                                                         <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                                             <BeginStoryboard>
                                                                                 <Storyboard>
                                                                                     <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                      From="1.0" To="0.0"
                                                                                                      Duration="0:0:0.8"
                                                                                                      AutoReverse="True"
                                                                                                      RepeatBehavior="Forever" />
                                                                                 </Storyboard>
                                                                             </BeginStoryboard>
                                                                         </EventTrigger>
                                                                     </Border.Triggers>
                                                                 </Border>
                                                             </InlineUIContainer>
                                                         </TextBlock>
                                                     </Border>
                                                 </Grid>
                                             </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                                <StackPanel>
                                    <TextBlock Text="应用更新" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="当前版本" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="安装版可从 GitHub Releases 检查 stable 更新" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding AppVersionText}"
                                                       FontSize="{DynamicResource UiFontSize14}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource HeadingBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="手动检查更新" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding UpdateCheckStatusText}"
                                                           Style="{StaticResource SettingsItemDescStyle}"
                                                           Margin="{StaticResource SettingsUpdateStatusMargin}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="检查更新"
                                                    Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding CheckForAppUpdateCommand}"
                                                    AutomationProperties.AutomationId="Btn_CheckForAppUpdate" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 系统日志记录卡片（任务 17.3：自 SettingsTabDataAudit 按 §7.1 迁入「安全与日志」宿主） -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                                <StackPanel>
                                    <TextBlock Text="系统日志记录" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="启用操作日志记录" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="系统会自动在本地审计记录重要的商家操作" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding OperationLogEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_OperationLogEnabled" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="日志自动清理周期" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动清理设定天数前的旧审计日志" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                             <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><TextBox Style="{StaticResource SettingsRowTextBoxStyle}" Width="80" Text="{Binding OperationLogRetentionDaysInput, UpdateSourceTrigger=PropertyChanged}" LostFocus="SettingsTextInput_LostFocus" AutomationProperties.AutomationId="Txt_OperationLogRetentionDays" /><TextBlock Text="&#x5929;" Margin="{StaticResource SettingsInlineLabelMargin}" VerticalAlignment="Center" Style="{StaticResource SettingsItemTitleStyle}" Foreground="{DynamicResource SecondaryTextBrush}" /></StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开发者调试模式" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="开启后系统将生成更详尽的诊断文件以备排查" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding DebugModeEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_DebugModeEnabled" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
    </StackPanel>
</UserControl>
