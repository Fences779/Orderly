<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabAiDiagnostics"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!--
        AI 诊断子 Tab（commerce-settings-ui-rebuild / 任务 14.3）
        ============================================================================
        作为 SettingsTabAi 内嵌的「AI Provider 环境状态」卡片宿主，呈现只读诊断字段
        （运行框架 / 链接状态 / 自检说明）与既有自检命令按钮。统一「标签-控件-说明」
        三段式行；按钮禁用态由令牌化 UiSecondaryButtonStyle 既有视觉承载。
        全部引用全局令牌，零硬编码视觉字面量；仅消费 MainViewModel 既有只读字段与命令，
        不新增、不重命名路径。设置卡片样式显式合并 MainWindowResources，与数据备份页保持一致。
    -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <!-- ===== 派生 Thickness 布局令牌（对齐 Shape.xaml 的 UiSpace 4pt 栅格） ===== -->
        <Thickness x:Key="SettingsCardSpacing">0,16,0,0</Thickness>
        <Thickness x:Key="SettingsRowPadding">0,12,0,12</Thickness>
        <Thickness x:Key="SettingsRowDescMargin">0,4,0,0</Thickness>
        <Thickness x:Key="SettingsControlLeftMargin">16,0,0,0</Thickness>
        <Thickness x:Key="SettingsSeparatorThickness">0,0,0,1</Thickness>
        <Thickness x:Key="SettingsZeroThickness">0</Thickness>

        <!-- ===== 行容器 ===== -->
        <Style x:Key="SettingsRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="{StaticResource SettingsSeparatorThickness}" />
            <Setter Property="Padding" Value="{StaticResource SettingsRowPadding}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="SettingsRowLastStyle" TargetType="Border" BasedOn="{StaticResource SettingsRowStyle}">
            <Setter Property="BorderThickness" Value="{StaticResource SettingsZeroThickness}" />
        </Style>

        <!-- ===== 标签 / 说明 ===== -->
        <Style x:Key="SettingsRowLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource UiFontBody}" />
            <Setter Property="FontWeight" Value="{StaticResource UiFontWeightMedium}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SettingsRowDescStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource UiFontCaption}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="{StaticResource SettingsRowDescMargin}" />
        </Style>

        <!-- ===== 只读状态值（右侧，次文字色） ===== -->
        <Style x:Key="SettingsRowValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource UiFontBody}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="{StaticResource SettingsControlLeftMargin}" />
        </Style>

        <!-- ===== 行内操作按钮（禁用态由 UiSecondaryButtonStyle 既有视觉承载） ===== -->
        <Style x:Key="SettingsRowActionButtonStyle" TargetType="Button" BasedOn="{StaticResource UiSecondaryButtonStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingsControlLeftMargin}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <!-- AI Provider 环境状态卡片 -->
        <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
            <StackPanel>
                <TextBlock Text="AI Provider 环境状态" Style="{StaticResource SettingsGroupTitleStyle}" />

                <!-- 核心运行框架 -->
                <Border Style="{StaticResource SettingsRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="核心运行框架" Style="{StaticResource SettingsRowLabelStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding AiRuntimeProviderText}" Style="{StaticResource SettingsRowValueStyle}" />
                    </Grid>
                </Border>

                <!-- 配置检查结果 -->
                <Border Style="{StaticResource SettingsRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="配置检查结果" Style="{StaticResource SettingsRowLabelStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding AiConnectionCheckStatusText}" Style="{StaticResource SettingsRowValueStyle}" />
                    </Grid>
                </Border>

                <!-- AI 接入服务自检 -->
                <Border Style="{StaticResource SettingsRowLastStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="AI 接入服务自检" Style="{StaticResource SettingsRowLabelStyle}" />
                            <TextBlock Text="{Binding AiModelPreferenceStatusText}" Style="{StaticResource SettingsRowDescStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="运行配置检查" Style="{StaticResource SettingsRowActionButtonStyle}"
                                Command="{Binding CheckAiConfigurationCommand}"
                                AutomationProperties.AutomationId="Btn_CheckAiConfiguration" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
