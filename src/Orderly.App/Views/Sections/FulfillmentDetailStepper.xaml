<UserControl x:Class="Orderly.App.Views.Sections.FulfillmentDetailStepper"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/FulfillmentStepperResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="12" Padding="14,12" Margin="0,0,0,14" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Node 1: 待确认 -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Cursor="Hand" Tag="paid_pending_confirm" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为待确认状态">
                <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center" Style="{StaticResource StepperNode1BorderStyle}">
                    <TextBlock Text="1" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="待确认" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Style="{StaticResource StepperNode1LabelStyle}" />
            </StackPanel>

            <!-- Line 1-2 -->
            <Rectangle Grid.Column="1" Height="2" Width="16" Fill="{DynamicResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12" Style="{StaticResource StepperConnector1Style}" />

            <!-- Node 2: 待制作 -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Cursor="Hand" Tag="pending_make" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为待制作状态">
                <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center" Style="{StaticResource StepperNode2BorderStyle}">
                    <TextBlock Text="2" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="待制作" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Style="{StaticResource StepperNode2LabelStyle}" />
            </StackPanel>

            <!-- Line 2-3 -->
            <Rectangle Grid.Column="3" Height="2" Width="16" Fill="{DynamicResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12" Style="{StaticResource StepperConnector2Style}" />

            <!-- Node 3: 制作中 -->
            <StackPanel Grid.Column="4" HorizontalAlignment="Center" Cursor="Hand" Tag="making" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为制作中状态">
                <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center" Style="{StaticResource StepperNode3BorderStyle}">
                    <TextBlock Text="3" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="制作中" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Style="{StaticResource StepperNode3LabelStyle}" />
            </StackPanel>

            <!-- Line 3-4 -->
            <Rectangle Grid.Column="5" Height="2" Width="16" Fill="{DynamicResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12" Style="{StaticResource StepperConnector3Style}" />

            <!-- Node 4: 待发货 -->
            <StackPanel Grid.Column="6" HorizontalAlignment="Center" Cursor="Hand" Tag="ready_to_ship" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为待发货状态">
                <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center" Style="{StaticResource StepperNode4BorderStyle}">
                    <TextBlock Text="4" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="待发货" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Style="{StaticResource StepperNode4LabelStyle}" />
            </StackPanel>

            <!-- Line 4-5 -->
            <Rectangle Grid.Column="7" Height="2" Width="16" Fill="{DynamicResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12" Style="{StaticResource StepperConnector4Style}" />

            <!-- Node 5: 已发货 -->
            <StackPanel Grid.Column="8" HorizontalAlignment="Center" Cursor="Hand" Tag="shipped" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为已发货状态">
                <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center" Style="{StaticResource StepperNode5BorderStyle}">
                    <TextBlock Text="5" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="已发货" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Style="{StaticResource StepperNode5LabelStyle}" />
            </StackPanel>

            <!-- Line 5-6 -->
            <Rectangle Grid.Column="9" Height="2" Width="16" Fill="{DynamicResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12" Style="{StaticResource StepperConnector5Style}" />

            <!-- Node 6: 已完成 -->
            <StackPanel Grid.Column="10" HorizontalAlignment="Center" Cursor="Hand" Tag="completed" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为已完成状态">
                <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center" Style="{StaticResource StepperNode6BorderStyle}">
                    <TextBlock Text="6" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="已完成" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Style="{StaticResource StepperNode6LabelStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
