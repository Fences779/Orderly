<UserControl x:Class="Orderly.App.Views.Sections.CashflowBreakdownCards"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainSharedResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainComponentStyles.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainComponentStyles.C.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UniformGrid Columns="2" Rows="1">
        <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,8,0" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12" LastChildFill="False">
                    <TextBlock Text="收入构成 (近30天)" Style="{StaticResource SectionHeaderTextStyle}" FontSize="14" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="总收入 " FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock Text="{Binding CashflowIncomeTotalText, FallbackValue='¥ 12,680.00'}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Canvas x:Name="CanvasIncomeDonut" Width="110" Height="110" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,0" SizeChanged="CanvasIncomeDonut_SizeChanged" />

                    <ItemsControl Grid.Column="1" ItemsSource="{Binding CashflowIncomeBreakdown.Items}" VerticalAlignment="Center" Margin="12,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="Bullet" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#4D96FF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Category}" Value="订单收入">
                                                        <Setter Property="Background" Value="#4D96FF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="定制收入">
                                                        <Setter Property="Background" Value="#FFD93D" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="尾款补款">
                                                        <Setter Property="Background" Value="#9B5DE5" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="其他收入">
                                                        <Setter Property="Background" Value="#FF6B6B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="12" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat={}{0:C0}}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" Margin="10,0" />
                                    <TextBlock Grid.Column="3" Text="{Binding Percent, StringFormat={}{0:0.0}%}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Button Grid.Row="2" Content="查看明细 >" Foreground="{StaticResource BlueTextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" />
            </Grid>
        </Border>

        <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="8,0,0,0" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12" LastChildFill="False">
                    <TextBlock Text="支出构成 (近30天)" Style="{StaticResource SectionHeaderTextStyle}" FontSize="14" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="总支出 " FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock Text="{Binding CashflowExpenseTotalText, FallbackValue='¥ 9,820.00'}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Canvas x:Name="CanvasExpenseDonut" Width="110" Height="110" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,0" SizeChanged="CanvasExpenseDonut_SizeChanged" />

                    <ItemsControl Grid.Column="1" ItemsSource="{Binding CashflowExpenseBreakdown.Items}" VerticalAlignment="Center" Margin="12,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="Bullet" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#4D96FF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Category}" Value="材料采购">
                                                        <Setter Property="Background" Value="#6BCB77" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="快递物流">
                                                        <Setter Property="Background" Value="#4D96FF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="包装耗材">
                                                        <Setter Property="Background" Value="#9B5DE5" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="平台/手续费">
                                                        <Setter Property="Background" Value="#FFD93D" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="其他支出">
                                                        <Setter Property="Background" Value="#FF6B6B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="12" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat={}{0:C0}}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" Margin="10,0" />
                                    <TextBlock Grid.Column="3" Text="{Binding Percent, StringFormat={}{0:0.0}%}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Button Grid.Row="2" Content="查看明细 >" Foreground="{StaticResource BlueTextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" />
            </Grid>
        </Border>
    </UniformGrid>
</UserControl>
