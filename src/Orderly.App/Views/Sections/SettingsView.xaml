<UserControl x:Class="Orderly.App.Views.Sections.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections"
             xmlns:conv="clr-namespace:Orderly.App.Converters"
             xmlns:helpers="clr-namespace:Orderly.App.Helpers"
             AutomationProperties.AutomationId="Page_Settings">
    <!--
        SettingsView.xaml — 设置页主框架（commerce-settings-ui-rebuild / 任务 13.1）
        ===============================================================================
        信息架构（保留现有结构，需求 9.3）：
          「左侧竖向分类导航 (ListBox 六分类) + 右侧内容区」——以 SettingsTab* 各子 View 作为
          内容区承载；右内容区可见性由 Settings.SelectedCategoryKey 经字符串相等转换器驱动切换。
          子 View 仍由任务 14.x 重建，本任务不改子 View，仅重建主框架视觉与承载方式。

        当前 Tab 高亮（需求 9.5）：导航项选中态使用主色弱底 + 左侧主色条 + 主色文字明确高亮。
        滚动位置保留（需求 9.5）：ViewModel 暴露的滚动定位字段为 Settings.PendingScrollAnchorId
          （锚点式），经既有 helpers:ScrollToAnchorBehavior.AnchorId 双向绑定保留切换/命中跳转定位，
          维持原有契约不变。

        令牌引用（需求 9.1，零硬编码视觉字面量）：
          - 颜色：一律 DynamicResource 语义画刷（支持亮/暗整体替换即时切换）。
          - 字号/字重/字体族：StaticResource 引用 Typography 令牌（UiFont* / UiFontFamily*）。
          - 圆角：StaticResource 引用 Shape 令牌（UiRadius*）；阴影用 UiElevationOverlay。
          - 间距（Thickness）：以本视图内派生的具名 Thickness（对齐 UiSpace 4pt 栅格）承载，
            消费侧引用具名令牌而非散落魔法数值（与 ControlStyles/StatePresenters 同一做法）。
          - 搜索框复用全局 UiTextBoxStyle；导航项样式于本视图内以令牌定义。
          令牌 / 控件样式 / 状态模板均由 App.xaml 全局合并，故本视图无需再合并样式字典。

        绑定契约（需求 9.2 / 10.4 / 10.5 / 10.6）：仅消费既有绑定，不新增/重命名路径；
          稳定锚点保持不变：Nav_SettingsCategories、Box_SettingsSearch、List_SettingsSearchResults、
          Text_SearchResultsTruncated、Pane_SettingsContent；代码后置文件保持不动。
    -->
    <UserControl.Resources>
        <!-- 复用字符串相等→可见性转换器，按分类 key 切换右内容区。 -->
        <conv:SectionVisibilityConverter x:Key="CategoryVisibilityConverter" />
        <!-- 搜索结果数量→可见性（驱动 Popup.IsOpen，空结果不弹出）。 -->
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- ==================== 派生间距令牌（Thickness 投影，对齐 UiSpace 4pt 栅格） ==================== -->
        <!-- 左导航外边距：左 UiSpaceMd(16) / 上 UiSpaceLg(24) / 右 UiSpaceXs(8) / 下 UiSpaceMd(16) -->
        <Thickness x:Key="UiSettingsLeftPaneMargin">16,24,8,16</Thickness>
        <!-- 搜索框下间距：UiSpaceMd(16) -->
        <Thickness x:Key="UiSettingsSearchGap">0,0,0,16</Thickness>
        <!-- 右内容区外边距：左 UiSpaceXs(8) / 上 UiSpaceSm(12) / 右 UiSpaceSm(12) / 下 UiSpaceSm(12) -->
        <Thickness x:Key="UiSettingsContentMargin">8,12,12,12</Thickness>
        <!-- 搜索结果浮层上间距：UiSpaceXxs(4) -->
        <Thickness x:Key="UiSettingsPopupMargin">0,4,0,0</Thickness>
        <!-- 搜索结果浮层内边距：UiSpaceXxs(4) -->
        <Thickness x:Key="UiSettingsPopupPadding">4</Thickness>
        <!-- 搜索结果项内边距：水平 UiSpaceSm(12) + 垂直 UiSpaceXs(8) -->
        <Thickness x:Key="UiSettingsResultPadding">12,8</Thickness>
        <!-- 结果项分类副文上间距：UiSpaceXxs(4) -->
        <Thickness x:Key="UiSettingsResultCategoryGap">0,4,0,0</Thickness>
        <!-- 超限提示边距：水平 UiSpaceSm(12) + 垂直 UiSpaceXs(8) -->
        <Thickness x:Key="UiSettingsTruncatedMargin">12,8,12,8</Thickness>
        <!-- 安全与日志内容右间距：UiSpaceLg(24) -->
        <Thickness x:Key="UiSettingsSecurityPanelMargin">0,0,24,0</Thickness>
        <!-- 导航项内边距：水平 / 垂直 UiSpaceSm(12) -->
        <Thickness x:Key="UiSettingsNavItemPadding">12,12</Thickness>
        <!-- 导航项上间距：UiSpaceXxs(4) -->
        <Thickness x:Key="UiSettingsNavItemMargin">0,4,0,0</Thickness>
        <!-- 导航图标右间距：UiSpaceSm(12) -->
        <Thickness x:Key="UiSettingsNavIconGap">0,0,12,0</Thickness>

        <!-- 导航图标字形尺寸（对齐 UiSpaceLg 24，用于图标列对齐） -->
        <sys:Double x:Key="UiSettingsNavIconSize">24</sys:Double>

        <!-- 搜索框与指示器微调令牌（避免硬编码字面量） -->
        <sys:Double x:Key="UiSettingsSearchIconFontSize">13</sys:Double>
        <Thickness x:Key="UiSettingsSearchIconMargin">10,0,0,0</Thickness>
        <Thickness x:Key="UiSettingsSearchPlaceholderMargin">32,0,8,0</Thickness>
        <Thickness x:Key="UiSettingsAccentBarMargin">4,0,0,0</Thickness>
        <Thickness x:Key="UiSettingsNavPresenterMargin">10,0,0,0</Thickness>
        <CornerRadius x:Key="UiSettingsAccentBarRadius">1.75</CornerRadius>

        <!-- 选择默认启动页提示遮罩微调令牌 -->
        <Thickness x:Key="UiSettingsPromptContentMargin">80,0,0,0</Thickness>
        <Thickness x:Key="UiSettingsPromptArrowMargin">0,0,122,0</Thickness>
        <Thickness x:Key="UiSettingsPromptSubtitleMargin">0,14,0,0</Thickness>
        <sys:Double x:Key="UiSettingsPromptTitleFontSize">40</sys:Double>
        <sys:Double x:Key="UiSettingsPromptSubtitleFontSize">20</sys:Double>

        <!-- 搜索框自定义水印与图标样式 -->
        <Style x:Key="SettingsSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="{StaticResource UiHairline}" />
            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="{StaticResource UiSettingsSearchPlaceholderMargin}" />
            <Setter Property="FontSize" Value="{DynamicResource UiFontBody}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource UiRadiusMd}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <!-- 搜索图标 -->
                                <TextBlock Text="&#xE721;" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="{StaticResource UiSettingsSearchIconFontSize}" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Left" 
                                           VerticalAlignment="Center" 
                                           Margin="{StaticResource UiSettingsSearchIconMargin}"
                                           IsHitTestVisible="False"/>
                                
                                <!-- 水印提示文字 -->
                                <TextBlock x:Name="PlaceholderText"
                                           Text="搜索系统设置..."
                                           Foreground="{DynamicResource MutedBrush}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource UiSettingsSearchPlaceholderMargin}"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource UiFocusBrush}" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="{StaticResource UiFocusThickness}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== 左侧分类导航项样式（当前 Tab 高亮：主色弱底 + 左侧主色条） ==================== -->
        <Style x:Key="UiSettingsNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource UiFontBody}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="FontWeight" Value="{StaticResource UiFontWeightMedium}" />
            <Setter Property="Padding" Value="{StaticResource UiSettingsNavItemPadding}" />
            <Setter Property="Margin" Value="{StaticResource UiSettingsNavItemMargin}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource UiFocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid x:Name="NavGrid">
                            <Border x:Name="NavBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource UiRadiusMd}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center" Margin="{StaticResource UiSettingsNavPresenterMargin}" />
                            </Border>
                            <!-- 左侧独立指示胶囊 -->
                            <Border x:Name="AccentBar"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Width="3.5"
                                    Height="16"
                                    CornerRadius="{StaticResource UiSettingsAccentBarRadius}"
                                    Background="Transparent"
                                    Margin="{StaticResource UiSettingsAccentBarMargin}"
                                    SnapsToDevicePixels="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="FontWeight" Value="{StaticResource UiFontWeightSemiBold}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UiSettingsNavListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource UiSettingsNavItemStyle}" />
        </Style>

        <!-- 搜索结果项按钮（左对齐铺满，令牌内边距，主色浅底悬停反馈） -->
        <Style x:Key="UiSettingsSearchResultButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="{StaticResource UiSettingsResultPadding}" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource UiFocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ResultBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource UiRadiusSm}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ==================== 左侧：搜索框 + 竖向分类导航 ==================== -->
        <DockPanel Grid.Column="0" Margin="{StaticResource UiSettingsLeftPaneMargin}" DataContext="{Binding Settings}">
            <DockPanel.Style>
                <Style TargetType="DockPanel">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding (helpers:SettingsHelper.IsSelectingStartupSection), RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="16" KernelType="Box"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DockPanel.Style>
            <TextBox x:Name="Box_SettingsSearch"
                     DockPanel.Dock="Top"
                     AutomationProperties.AutomationId="Box_SettingsSearch"
                     Style="{StaticResource SettingsSearchTextBoxStyle}"
                     Margin="{StaticResource UiSettingsSearchGap}"
                     Text="{Binding SettingsSearchQuery, UpdateSourceTrigger=PropertyChanged}" />

            <!--
                搜索结果浮层（需求 9.2，仅消费既有绑定）：
                · 仅当 SearchResults 有命中时弹出（CountToVisibilityConverter→bool，空结果不弹出）。
                · 每条命中项显示「标题 + 分类」，点击经既有 ActivateSearchResultCommand 触发命中跳转
                  （设 SelectedCategoryKey + PendingScrollAnchorId，由右内容区附加行为定位）。
                · 超限时显示提示，可见性由 IsSearchResultsTruncated 驱动。
            -->
            <Popup DockPanel.Dock="Top"
                   PlacementTarget="{Binding ElementName=Box_SettingsSearch}"
                   Placement="Bottom"
                   Width="{Binding ActualWidth, ElementName=Box_SettingsSearch}"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   IsOpen="{Binding SearchResults.Count, Converter={StaticResource CountToVisibilityConverter}, Mode=OneWay, FallbackValue=False}">
                <Border Background="{DynamicResource SurfaceRaisedBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="{StaticResource UiHairline}"
                        CornerRadius="{StaticResource UiRadiusMd}"
                        Margin="{StaticResource UiSettingsPopupMargin}"
                        Padding="{StaticResource UiSettingsPopupPadding}"
                        MaxHeight="420"
                        Effect="{StaticResource UiElevationOverlay}">
                    <StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
                            <ItemsControl x:Name="List_SettingsSearchResults"
                                          AutomationProperties.AutomationId="List_SettingsSearchResults"
                                          ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ActivateSearchResultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource UiSettingsSearchResultButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{DynamicResource HeadingBrush}"
                                                           FontFamily="{StaticResource UiFontFamilyCjk}"
                                                           FontSize="{DynamicResource UiFontBodySm}" />
                                                <TextBlock Text="{Binding CategoryKey}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontFamily="{StaticResource UiFontFamilyCjk}"
                                                           FontSize="{DynamicResource UiFontCaption}"
                                                           Margin="{StaticResource UiSettingsResultCategoryGap}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- 超限提示（命中超过上限时显示）。 -->
                        <TextBlock x:Name="Text_SearchResultsTruncated"
                                   AutomationProperties.AutomationId="Text_SearchResultsTruncated"
                                   Text="结果较多，请输入更精确的关键词"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="{StaticResource UiFontFamilyCjk}"
                                   FontSize="{DynamicResource UiFontCaption}"
                                   TextWrapping="Wrap"
                                   Margin="{StaticResource UiSettingsTruncatedMargin}"
                                   Visibility="{Binding IsSearchResultsTruncated, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>
            </Popup>

            <ListBox x:Name="Nav_SettingsCategories"
                     AutomationProperties.AutomationId="Nav_SettingsCategories"
                     Style="{StaticResource UiSettingsNavListStyle}"
                     SelectedValuePath="Tag"
                     SelectedValue="{Binding SelectedCategoryKey, Mode=TwoWay}">
                <ListBoxItem Tag="外观与启动">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource UiFontSubtitle}" Width="{StaticResource UiSettingsNavIconSize}" Margin="{StaticResource UiSettingsNavIconGap}" VerticalAlignment="Center" />
                        <TextBlock Text="外观与启动" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="数据与备份">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource UiFontSubtitle}" Width="{StaticResource UiSettingsNavIconSize}" Margin="{StaticResource UiSettingsNavIconGap}" VerticalAlignment="Center" />
                        <TextBlock Text="数据与备份" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="安全与日志">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource UiFontSubtitle}" Width="{StaticResource UiSettingsNavIconSize}" Margin="{StaticResource UiSettingsNavIconGap}" VerticalAlignment="Center" />
                        <TextBlock Text="安全与日志" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="AI 助手">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource UiFontSubtitle}" Width="{StaticResource UiSettingsNavIconSize}" Margin="{StaticResource UiSettingsNavIconGap}" VerticalAlignment="Center" />
                        <TextBlock Text="AI 助手" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="通知提醒">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource UiFontSubtitle}" Width="{StaticResource UiSettingsNavIconSize}" Margin="{StaticResource UiSettingsNavIconGap}" VerticalAlignment="Center" />
                        <TextBlock Text="通知提醒" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="快捷键">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource UiFontSubtitle}" Width="{StaticResource UiSettingsNavIconSize}" Margin="{StaticResource UiSettingsNavIconGap}" VerticalAlignment="Center" />
                        <TextBlock Text="快捷键" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </DockPanel>

        <!-- ==================== 右侧：分类内容区（承载 SettingsTab* 子 View） ==================== -->
        <ScrollViewer Grid.Column="1"
                x:Name="Pane_SettingsContent"
                AutomationProperties.AutomationId="Pane_SettingsContent"
                VerticalScrollBarVisibility="Disabled"
                HorizontalScrollBarVisibility="Disabled"
                helpers:ScrollToAnchorBehavior.AnchorId="{Binding Settings.PendingScrollAnchorId, Mode=TwoWay}"
                Margin="{StaticResource UiSettingsContentMargin}">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding (helpers:SettingsHelper.IsSelectingStartupSection), RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="16" KernelType="Box"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0.45"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <Grid>
                <!-- 外观与启动 -->
                <Sections:SettingsTabAppearance
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=外观与启动}" />

                <!-- 数据与备份 -->
                <Sections:SettingsTabData
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=数据与备份}" />

                <!-- 安全与日志（子 View 为裸 StackPanel，于此包裹滚动与居中容器） -->
                <ScrollViewer Style="{DynamicResource SettingsScrollViewerStyle}"
                              Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=安全与日志}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" Margin="{StaticResource UiSettingsSecurityPanelMargin}" HorizontalAlignment="Stretch">
                            <Sections:SettingsTabDataSecurity />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- AI 助手 -->
                <Sections:SettingsTabAi
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=AI 助手}" />

                <!-- 通知提醒 -->
                <Sections:SettingsTabNotify
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=通知提醒}" />

                <!-- 快捷键 -->
                <Sections:SettingsTabHotkeys
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=快捷键}" />
            </Grid>
        </ScrollViewer>

        <!-- 选择默认启动页时的提示遮罩层 -->
        <Border Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0"
                Background="Transparent"
                Panel.ZIndex="99"
                IsHitTestVisible="True"
                Visibility="{Binding (helpers:SettingsHelper.IsSelectingStartupSection), RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <!-- 精美微暗遮罩面 -->
                <Border Background="{DynamicResource PageBackgroundBrush}" Opacity="0.1" CornerRadius="{StaticResource UiRadiusLg}"/>
                
                <!-- 提示文案与缓动指引箭头 -->
                <Grid VerticalAlignment="Center" HorizontalAlignment="Left" Margin="{StaticResource UiSettingsPromptContentMargin}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- 指向左侧主导航栏的呼吸矢量箭头 -->
                    <Path Grid.Column="0"
                          Data="M 40,16 L 0,16 M 14,4 L 0,16 L 14,28" 
                          Stroke="{DynamicResource HeadingBrush}" 
                          StrokeThickness="3.5" 
                          StrokeStartLineCap="Round" 
                          StrokeEndLineCap="Round" 
                          StrokeLineJoin="Round"
                          VerticalAlignment="Center" 
                          Margin="{StaticResource UiSettingsPromptArrowMargin}">
                        <Path.RenderTransform>
                            <TranslateTransform x:Name="ArrowTranslate" X="0" Y="0" />
                        </Path.RenderTransform>
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="ArrowTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         From="0" To="-20" Duration="0:0:0.8"
                                                         DecelerationRatio="0.6" AccelerationRatio="0.4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                        <Path.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1.5" Color="Black" Opacity="0.12"/>
                        </Path.Effect>
                    </Path>

                    <!-- 大幅提升字号的提示文本 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="请选择您想要默认打开的页面"
                                   FontSize="{StaticResource UiSettingsPromptTitleFontSize}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource HeadingBrush}">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Color="Black" Opacity="0.18"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="点击左侧导航栏的任意标签进行设定"
                                   FontSize="{StaticResource UiSettingsPromptSubtitleFontSize}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="{StaticResource UiSettingsPromptSubtitleMargin}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
