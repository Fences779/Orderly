<UserControl x:Class="Orderly.App.Views.Sections.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections"
             xmlns:conv="clr-namespace:Orderly.App.Converters"
             xmlns:helpers="clr-namespace:Orderly.App.Helpers">
    <!--
        设置页信息架构重构（任务 17.1，设计 §4.2 / §7.1）：
        以「左侧竖向导航 (ListBox 六分类) + 右侧内容区 (ContentControl/分区 ScrollViewer)」替换原顶部 TabControl。

        · 左导航 / 搜索框子树 DataContext 绑定 {Binding Settings}（MainViewModel.Settings → SettingsViewModel），
          承载 SelectedCategoryKey（默认「外观与启动」）与 SettingsSearchQuery。
        · 右内容区按选中分类显示对应内容，可见性由 Settings.SelectedCategoryKey 经字符串相等转换器驱动。
        · 稳定锚点：Nav_SettingsCategories（左导航）、Box_SettingsSearch（搜索框）、Pane_SettingsContent（右内容区根）。

        说明（任务 17.3 已完成宿主归类）：SettingsTab* 子控件已按 §7.1 完成六大分类宿主归类——
        其中 SettingsTabDataAudit 拆分为「数据校验与导入恢复」(留在数据与备份) 与「系统日志记录」
        (已迁入安全与日志宿主 SettingsTabDataSecurity)。子控件设计令牌经共享卡片样式与本视图的
        DesignTokens.xaml 一致应用（柔和阴影 + 大圆角 + 充裕留白，Req 15.1），画刷统一 DynamicResource
        以保证深浅色主题切换无异常（Req 15.2）。
        DataContext 边界：子控件仍继承 MainViewModel 的 DataContext，其绑定路径整体相对化到
        SettingsViewModel 的切换与服务 DI 接线统一由任务 21.1「注册服务并接线 DataContext」处理，
        以避免与本任务（聚焦令牌/归类/注释清理）的回归风险叠加。
        搜索命中跳转与超限提示见任务 17.2。
    -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/DesignTokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- 复用字符串相等→可见性转换器，按分类 key 切换右内容区。 -->
            <conv:SectionVisibilityConverter x:Key="CategoryVisibilityConverter" />
            <!-- 搜索结果列表仅在有命中时显示（Req 2.7）；超限提示由布尔→可见性驱动（Req 2.8）。 -->
            <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ==================== 左侧：搜索框 + 竖向导航 ==================== -->
        <DockPanel Grid.Column="0" Margin="16,20,8,16" DataContext="{Binding Settings}">
            <TextBox x:Name="Box_SettingsSearch"
                     DockPanel.Dock="Top"
                     AutomationProperties.AutomationId="Box_SettingsSearch"
                     Style="{StaticResource RefineSearchBoxStyle}"
                     Margin="2,0,2,14"
                     Text="{Binding SettingsSearchQuery, UpdateSourceTrigger=PropertyChanged}" />

            <!--
                搜索结果下拉（任务 17.2，Req 2.3 / 2.7 / 2.8）：
                · 仅当 SearchResults 有命中时显示（CountToVisibilityConverter，空结果不显示列表）。
                · 每条命中项显示「标题 + 分类」，点击经 ActivateSearchResultCommand 触发命中跳转
                  （设 SelectedCategoryKey + PendingScrollAnchorId，由右内容区附加行为定位高亮）。
                · 超限（命中 > 12）时显示「结果较多，请输入更精确的关键词」提示。
                以 Popup 叠加于搜索框下方，避免挤占左导航布局。
            -->
            <Popup DockPanel.Dock="Top"
                   PlacementTarget="{Binding ElementName=Box_SettingsSearch}"
                   Placement="Bottom"
                   Width="{Binding ActualWidth, ElementName=Box_SettingsSearch}"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   IsOpen="{Binding SearchResults.Count, Converter={StaticResource CountToVisibilityConverter}, Mode=OneWay, FallbackValue=False}">
                <Border Background="{DynamicResource SurfaceRaisedBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}"
                        Margin="0,4,0,0"
                        Padding="4"
                        MaxHeight="420">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.10" Direction="270" />
                    </Border.Effect>
                    <StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
                            <ItemsControl x:Name="List_SettingsSearchResults"
                                          AutomationProperties.AutomationId="List_SettingsSearchResults"
                                          ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ActivateSearchResultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                HorizontalContentAlignment="Stretch"
                                                Cursor="Hand"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{DynamicResource HeadingBrush}"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding CategoryKey}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontSize="11"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- 超限提示（Req 2.8）：命中超过 12 条上限时显示。 -->
                        <TextBlock x:Name="Text_SearchResultsTruncated"
                                   AutomationProperties.AutomationId="Text_SearchResultsTruncated"
                                   Text="结果较多，请输入更精确的关键词"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="10,6,10,8"
                                   Visibility="{Binding IsSearchResultsTruncated, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>
            </Popup>

            <ListBox x:Name="Nav_SettingsCategories"
                     AutomationProperties.AutomationId="Nav_SettingsCategories"
                     Style="{StaticResource RefineNavListStyle}"
                     SelectedValuePath="Tag"
                     SelectedValue="{Binding SelectedCategoryKey, Mode=TwoWay}">
                <ListBoxItem Tag="外观与启动">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="26" VerticalAlignment="Center" />
                        <TextBlock Text="外观与启动" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="数据与备份">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="26" VerticalAlignment="Center" />
                        <TextBlock Text="数据与备份" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="安全与日志">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="26" VerticalAlignment="Center" />
                        <TextBlock Text="安全与日志" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="AI 助手">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="26" VerticalAlignment="Center" />
                        <TextBlock Text="AI 助手" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="通知提醒">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="26" VerticalAlignment="Center" />
                        <TextBlock Text="通知提醒" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="快捷键">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="26" VerticalAlignment="Center" />
                        <TextBlock Text="快捷键" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </DockPanel>

        <!-- ==================== 右侧：分类内容区 ==================== -->
        <Border Grid.Column="1"
                x:Name="Pane_SettingsContent"
                AutomationProperties.AutomationId="Pane_SettingsContent"
                helpers:ScrollToAnchorBehavior.AnchorId="{Binding Settings.PendingScrollAnchorId, Mode=TwoWay}"
                Margin="8,12,12,12">
            <Grid>
                <!-- 外观与启动 -->
                <Sections:SettingsTabAppearance
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=外观与启动}" />

                <!-- 数据与备份（本地备份策略 + 数据校验与导入恢复；「系统日志记录」已按 §7.1 迁至「安全与日志」） -->
                <Sections:SettingsTabData
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=数据与备份}" />

                <!-- 安全与日志（数据安全与隐私 + 本地数据库维护 + 系统日志记录；裸 StackPanel，于此包裹滚动与居中容器） -->
                <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}"
                              Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=安全与日志}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Stretch">
                            <Sections:SettingsTabDataSecurity />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- AI 助手 -->
                <Sections:SettingsTabAi
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=AI 助手}" />

                <!-- 通知提醒 -->
                <Sections:SettingsTabNotify
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=通知提醒}" />

                <!-- 快捷键 -->
                <Sections:SettingsTabHotkeys
                    Visibility="{Binding Settings.SelectedCategoryKey, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter=快捷键}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
