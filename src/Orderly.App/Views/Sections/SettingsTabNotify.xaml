<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabNotify"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!--
        通知子 Tab（commerce-settings-ui-rebuild / 任务 14.1）
        ============================================================================
        统一「标签-控件-说明」三段式行；阈值输入框校验失败时，以错误状态色（DangerTextBrush）
        在行级呈现既有校验错误（经 Validation.ErrorTemplate 消费 WPF 既有校验结果，不新增校验逻辑）。
        全部引用全局令牌，零硬编码视觉字面量；仅消费 MainViewModel 既有绑定与既有 LostFocus 自动保存钩子。
        Ui* 令牌与控件样式经 App.xaml 全局合并提供。
    -->
    <UserControl.Resources>
        <!-- ===== 派生 Thickness 布局令牌（对齐 Shape.xaml 的 UiSpace 4pt 栅格） ===== -->
        <Thickness x:Key="SettingsScrollPadding">0,24,0,24</Thickness>
        <Thickness x:Key="SettingsContentMargin">0,0,24,0</Thickness>
        <Thickness x:Key="SettingsCardPadding">24</Thickness>
        <Thickness x:Key="SettingsCardSpacing">0,16,0,0</Thickness>
        <Thickness x:Key="SettingsGroupTitleMargin">0,0,0,16</Thickness>
        <Thickness x:Key="SettingsRowPadding">0,12,0,12</Thickness>
        <Thickness x:Key="SettingsRowDescMargin">0,4,0,0</Thickness>
        <Thickness x:Key="SettingsControlLeftMargin">16,0,0,0</Thickness>
        <Thickness x:Key="SettingsSeparatorThickness">0,0,0,1</Thickness>
        <Thickness x:Key="SettingsZeroThickness">0</Thickness>

        <!-- ===== 控件尺寸令牌 ===== -->
        <sys:Double x:Key="SettingsControlMinWidthNarrow">80</sys:Double>
        <sys:Double x:Key="SettingsControlMinWidthWide">160</sys:Double>

        <!-- ===== 卡片容器 ===== -->
        <Style x:Key="SettingsGroupCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="{StaticResource UiHairline}" />
            <Setter Property="CornerRadius" Value="{StaticResource UiRadiusLg}" />
            <Setter Property="Padding" Value="{StaticResource SettingsCardPadding}" />
            <Setter Property="Effect" Value="{StaticResource UiElevationCard}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <!-- ===== 分组标题 ===== -->
        <Style x:Key="SettingsGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource UiFontSubtitle}" />
            <Setter Property="FontWeight" Value="{StaticResource UiFontWeightSemiBold}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
            <Setter Property="Margin" Value="{StaticResource SettingsGroupTitleMargin}" />
        </Style>

        <!-- ===== 行容器 ===== -->
        <Style x:Key="SettingsRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="{StaticResource SettingsSeparatorThickness}" />
            <Setter Property="Padding" Value="{StaticResource SettingsRowPadding}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="SettingsRowLastStyle" TargetType="Border" BasedOn="{StaticResource SettingsRowStyle}">
            <Setter Property="BorderThickness" Value="{StaticResource SettingsZeroThickness}" />
        </Style>

        <!-- ===== 标签 / 说明 ===== -->
        <Style x:Key="SettingsRowLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource UiFontBody}" />
            <Setter Property="FontWeight" Value="{StaticResource UiFontWeightMedium}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SettingsRowDescStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource UiFontCaption}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="{StaticResource SettingsRowDescMargin}" />
        </Style>

        <!-- ===== 行内开关 ===== -->
        <Style x:Key="SettingsRowCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource UiCheckBoxStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingsControlLeftMargin}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <!-- ===== 行级校验错误模板（消费 WPF 既有校验结果，以错误状态色呈现，不新增校验逻辑） ===== -->
        <ControlTemplate x:Key="SettingsFieldErrorTemplate">
            <StackPanel>
                <Border BorderBrush="{DynamicResource DangerTextBrush}"
                        BorderThickness="{StaticResource UiFocusThickness}"
                        CornerRadius="{StaticResource UiRadiusMd}"
                        SnapsToDevicePixels="True">
                    <AdornedElementPlaceholder x:Name="ErrorAdorner" />
                </Border>
                <ContentControl Style="{StaticResource UiFieldErrorStyle}"
                                HorizontalAlignment="Right"
                                Content="{Binding ElementName=ErrorAdorner, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}" />
            </StackPanel>
        </ControlTemplate>

        <!-- ===== 行内输入框（套用统一 TextBox 令牌样式 + 行级错误模板） ===== -->
        <Style x:Key="SettingsRowTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource UiTextBoxStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingsControlLeftMargin}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource SettingsFieldErrorTemplate}" />
        </Style>

        <!-- ===== 行内操作按钮 ===== -->
        <Style x:Key="SettingsRowActionButtonStyle" TargetType="Button" BasedOn="{StaticResource UiSecondaryButtonStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingsControlLeftMargin}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer Style="{DynamicResource SettingsScrollViewerStyle}" Padding="{StaticResource SettingsScrollPadding}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Margin="{StaticResource SettingsContentMargin}" HorizontalAlignment="Stretch">

                <!-- 系统事件提醒与通知卡片 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}">
                    <StackPanel>
                        <TextBlock Text="系统事件提醒与通知" Style="{StaticResource SettingsGroupTitleStyle}" />

                        <!-- 新订单事件 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="有新订单拉取成功时提醒" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="在桌面右下角推送新拉取到的订单气泡消息" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding NotifyNewOrderInput}"
                                          AutomationProperties.AutomationId="Chk_NotifyNewOrder" />
                            </Grid>
                        </Border>

                        <!-- 异常订单事件 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="发现异常订单时提醒" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="订单被标记为异常、缺货或支付异常时进行提醒" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding NotifyExceptionOrderInput}"
                                          AutomationProperties.AutomationId="Chk_NotifyExceptionOrder" />
                            </Grid>
                        </Border>

                        <!-- 超期未处理 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="待办任务超期未处理提醒" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="超过设定时限仍未流转状态时触发预警" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding NotifyOverdueUnhandledInput}"
                                          AutomationProperties.AutomationId="Chk_NotifyOverdueUnhandled" />
                            </Grid>
                        </Border>

                        <!-- 同步失败提醒 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="网关同步失败提醒" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="自动后台同步连接超时或网关授权过期时报错提醒" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding NotifySyncFailedInput}"
                                          AutomationProperties.AutomationId="Chk_NotifySyncFailed" />
                            </Grid>
                        </Border>

                        <!-- 已支付未确认阈值 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="未确认订单催促提醒 (小时)" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="已支付订单超此时间未由商家确认则发出提醒" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}"
                                         MinWidth="{StaticResource SettingsControlMinWidthNarrow}"
                                         Text="{Binding NotifyPaidUnconfirmedHoursInput, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="SettingsTextInput_LostFocus"
                                         AutomationProperties.AutomationId="Txt_NotifyPaidUnconfirmedHours" />
                            </Grid>
                        </Border>

                        <!-- 待制作工单阈值 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="待制作工单催促提醒 (小时)" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="已确认订单超此时间未制作出单则发出预警" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}"
                                         MinWidth="{StaticResource SettingsControlMinWidthNarrow}"
                                         Text="{Binding NotifyPendingProductionHoursInput, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="SettingsTextInput_LostFocus"
                                         AutomationProperties.AutomationId="Txt_NotifyPendingProductionHours" />
                            </Grid>
                        </Border>

                        <!-- 待发货阈值 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="待发货超时催促提醒 (小时)" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="工单完成后超此时间未录单发货则发出预警" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}"
                                         MinWidth="{StaticResource SettingsControlMinWidthNarrow}"
                                         Text="{Binding NotifyPendingShipmentHoursInput, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="SettingsTextInput_LostFocus"
                                         AutomationProperties.AutomationId="Txt_NotifyPendingShipmentHours" />
                            </Grid>
                        </Border>

                        <!-- 地址缺失提醒 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="收货联系地址缺失提醒" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="导入订单如无详细地址则立刻弹出提示" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding NotifyMissingAddressInput}"
                                          AutomationProperties.AutomationId="Chk_NotifyMissingAddress" />
                            </Grid>
                        </Border>

                        <!-- 免打扰时间段 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="系统免打扰时间段" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="免打扰期间将挂起非紧急气泡弹窗 (格式: HH:mm-HH:mm)" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}"
                                         MinWidth="{StaticResource SettingsControlMinWidthWide}"
                                         Text="{Binding NotifyDoNotDisturbRangeInput, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="SettingsTextInput_LostFocus"
                                         AutomationProperties.AutomationId="Txt_NotifyDoNotDisturbRange" />
                            </Grid>
                        </Border>

                        <!-- 仅推送高优先级 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="仅推送高优先级待办" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="仅对标红或最高优先级的事务触发气泡弹框" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding NotifyHighPriorityOnlyInput}"
                                          AutomationProperties.AutomationId="Chk_NotifyHighPriorityOnly" />
                            </Grid>
                        </Border>

                        <!-- 通知状态与测试按钮（IsEnabled 受既有字段约束，禁用态由令牌样式呈现） -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="桌面弹窗通知状态" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="{Binding NotificationStrategyStatusText}" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="发送测试通知"
                                        Style="{StaticResource SettingsRowActionButtonStyle}"
                                        Command="{Binding TestDesktopNotificationCommand}"
                                        IsEnabled="{Binding IsDesktopNotificationTestAvailable}"
                                        AutomationProperties.AutomationId="Btn_TestDesktopNotification" />
                            </Grid>
                        </Border>

                        <!-- 通知服务状态详情 -->
                        <Border Style="{StaticResource SettingsRowLastStyle}">
                            <StackPanel>
                                <TextBlock Text="通知调度状态详情" Style="{StaticResource SettingsRowLabelStyle}" />
                                <TextBlock Text="{Binding NotificationServiceStatusText}" Style="{StaticResource SettingsRowDescStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
