<UserControl x:Class="Orderly.App.Views.Sections.FulfillmentDetailShippingCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
        <StackPanel>
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="收货人与物流信息" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="24" Padding="8,0" DockPanel.Dock="Right" HorizontalAlignment="Right"
                        Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="receiverInfo" ToolTip="复制完整收货信息">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center" />
                        <TextBlock Text="复制整单" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="收件人" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverName}" Foreground="{DynamicResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="联系电话" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverPhone}" Foreground="{DynamicResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                <Button Grid.Column="2" Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="0,0,0,2" VerticalAlignment="Center"
                        Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="phone" ToolTip="复制电话">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Button>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="详细地址" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Top" Margin="0,3,0,0" />
                <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.FullAddressText}" Foreground="{DynamicResource HeadingBrush}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,3,0,0" />
                <Button Grid.Column="2" Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="0,1,0,0" VerticalAlignment="Top"
                        Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="address" ToolTip="复制地址">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Button>
            </Grid>

            <Border Background="{DynamicResource SurfaceSoftBrush}" Height="1" Margin="0,0,0,12" HorizontalAlignment="Stretch" />

            <!-- Logistics details inputs -->
            <StackPanel>
                <TextBlock Text="发货快递公司与单号" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationCarrierInput, Mode=TwoWay}"
                                 AutomationProperties.AutomationId="Input_FulfillmentCarrier" KeyDown="FulfillmentInput_KeyDown" />
                        <TextBlock Text="快递公司 (如 顺丰)" Foreground="{DynamicResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StringNarrationCarrierInput}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StringNarrationCarrierInput}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Grid.Column="2">
                        <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationTrackingNoInput, Mode=TwoWay}"
                                 AutomationProperties.AutomationId="Input_FulfillmentTrackingNo" KeyDown="FulfillmentInput_KeyDown" />
                        <TextBlock Text="快递单号" Foreground="{DynamicResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StringNarrationTrackingNoInput}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StringNarrationTrackingNoInput}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationAdminRemarkInput, Mode=TwoWay}"
                             AutomationProperties.AutomationId="Input_FulfillmentAdminRemark" KeyDown="FulfillmentInput_KeyDown" />
                    <TextBlock Text="后台备注 (如 加急制作)" Foreground="{DynamicResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StringNarrationAdminRemarkInput}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StringNarrationAdminRemarkInput}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" Height="36" Style="{StaticResource FulfillmentInputComboBoxStyle}"
                              ItemContainerStyle="{StaticResource FulfillmentComboBoxItemStyle}"
                              ItemsSource="{Binding StringNarrationFulfillmentStatusOptions}"
                              SelectedItem="{Binding StringNarrationFulfillmentStatusInput}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource FulfillmentStatusLabelConverter}}" VerticalAlignment="Center" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Grid.Column="2" Content="保存履约信息" Style="{StaticResource DialogPrimaryButtonStyle}" Height="36" Padding="14,0" Command="{Binding UpdateStringNarrationFulfillmentCommand}" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
