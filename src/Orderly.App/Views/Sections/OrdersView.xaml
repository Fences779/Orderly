<UserControl x:Class="Orderly.App.Views.Sections.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Orderly.App.Helpers"
             AutomationProperties.AutomationId="Page_Orders">
    <!--
        OrdersView.xaml — 订单页（commerce-settings-ui-rebuild / 任务 6.1）
        ================================================================================
        重建要点（需求 3.1–3.8）：
          - 全部引用令牌（颜色 DynamicResource 语义画刷；字号/圆角/字重/字体族/间距引用
            Typography / Shape / ControlStyles / StatePresenters 的具名令牌），零硬编码视觉字面量。
          - 仅消费 OrdersPageViewModel 既有绑定：Orders 集合、RefreshCommand、
            ShowLoading / HasError / ErrorMessage / IsEmpty / ShowContent 与行字段
            OrderNo / SalesStage / PaymentStage / FulfillmentStage / Total / PaidAmount /
            ReceivableAmount / OrderedAt。不新增、不重命名绑定路径，不改代码后置。
          - 套用统一状态机骨架（加载 / 空 / 错误 / 内容），错误区绑定既有 RefreshCommand 重试。
          - 主体以舒适表格密度（UiDataGridStyle，已启用 UI 虚拟化）展示订单；选中态由
            DataGrid 内建单行选择 + UiDataGridRowStyle 选中视觉表达（无需新增绑定）。
          - 订单三类阶段以状态色徽标着色（文字 + 颜色双载体）：
            绿 = 已完成 / 正常，黄 = 需关注，红 = 异常 / 逾期，蓝 = 信息 / 待处理。
            徽标样式经 DataTrigger 基于既有阶段字段切换底/前景画刷，不新增 VM 逻辑。
          - 加载中变更命令禁用：本页未暴露数据变更命令；RefreshCommand 为异步命令，
            执行期间自动禁用，故加载中刷新按钮自然禁用。

        说明（筛选 / 搜索区）：OrdersPageViewModel 及基类未暴露任何筛选项或搜索框绑定，
          设计文档订单页绑定清单亦未列搜索 / 筛选。依「仅消费既有绑定、不新增绑定路径」硬约束
          （需求 3.2 / 10.4 / 10.6），本页不臆造无后端支撑的筛选 / 搜索控件。
    -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 仅为复用既有转换器（BooleanToVisibilityConverter / CommerceEnumLabelConverter）；
                     令牌与控件样式经 App.xaml 全局合并，无需在此重复引用。 -->
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ============================================================================ -->
            <!-- 订单阶段状态徽标样式（基于 UiBadgeNeutralStyle，按既有阶段字段映射状态色）        -->
            <!--   绿=已完成/正常 · 黄=需关注 · 红=异常/逾期 · 蓝=信息/待处理 · 灰=默认           -->
            <!--   底色用 *SoftBrush、前景（圆点+文字）用 *TextBrush，文字+颜色双载体（需求 12.4） -->
            <!-- ============================================================================ -->

            <!-- 销售阶段：Draft/Quoted=蓝(待处理) · Confirmed/Completed=绿(正常/完成) · Cancelled=红(异常) -->
            <Style x:Key="SalesStageBadgeStyle" TargetType="ContentControl" BasedOn="{StaticResource UiBadgeNeutralStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SalesStage}" Value="Draft">
                        <Setter Property="Background" Value="{DynamicResource BlueSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource BlueTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SalesStage}" Value="Quoted">
                        <Setter Property="Background" Value="{DynamicResource BlueSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource BlueTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SalesStage}" Value="Confirmed">
                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SalesStage}" Value="Completed">
                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SalesStage}" Value="Cancelled">
                        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- 收款阶段：Unpaid=蓝(待处理) · PartiallyPaid=黄(需关注) · Paid=绿(完成) · Refunded=红(异常) -->
            <Style x:Key="PaymentStageBadgeStyle" TargetType="ContentControl" BasedOn="{StaticResource UiBadgeNeutralStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding PaymentStage}" Value="Unpaid">
                        <Setter Property="Background" Value="{DynamicResource BlueSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource BlueTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding PaymentStage}" Value="PartiallyPaid">
                        <Setter Property="Background" Value="{DynamicResource WarmSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource WarmTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding PaymentStage}" Value="Paid">
                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding PaymentStage}" Value="Refunded">
                        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- 履约阶段：NotStarted=蓝(待处理) · InProgress=黄(需关注) · Ready/Fulfilled=绿(正常/完成) · Returned=红(异常) -->
            <Style x:Key="FulfillmentStageBadgeStyle" TargetType="ContentControl" BasedOn="{StaticResource UiBadgeNeutralStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding FulfillmentStage}" Value="NotStarted">
                        <Setter Property="Background" Value="{DynamicResource BlueSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource BlueTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding FulfillmentStage}" Value="InProgress">
                        <Setter Property="Background" Value="{DynamicResource WarmSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource WarmTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding FulfillmentStage}" Value="Ready">
                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding FulfillmentStage}" Value="Fulfilled">
                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding FulfillmentStage}" Value="Returned">
                        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="Transparent" DataContext="{Binding OrdersPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ==================== 顶部标题 / 操作区 ==================== -->
        <Grid Grid.Row="0" Margin="{StaticResource UiPresenterGapBottomLg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="订单"
                           Foreground="{DynamicResource HeadingBrush}"
                           FontFamily="{StaticResource UiFontFamilyCjk}"
                           FontSize="{DynamicResource UiFontDisplay}"
                           FontWeight="{StaticResource UiFontWeightBold}"
                           Margin="{StaticResource UiPresenterGapBottom}" />
                <TextBlock Text="集中查看与管理全部订单"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="{StaticResource UiFontFamilyCjk}"
                           FontSize="{DynamicResource UiFontBodySm}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="刷新"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource UiSecondaryButtonStyle}"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- ==================== 加载占位（变更命令随异步命令执行自动禁用） ==================== -->
        <ContentControl Grid.Row="1"
                        Style="{StaticResource UiLoadingStateStyle}"
                        Visibility="{Binding ShowLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- ==================== 加载失败（错误提示 + 既有 RefreshCommand 重试） ==================== -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ContentControl Style="{StaticResource UiErrorNoticeStyle}"
                            Content="{Binding ErrorMessage}"
                            Margin="{StaticResource UiPresenterGapBottomLg}" />
            <Button Content="重试"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource UiSecondaryButtonStyle}"
                    HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ==================== 空状态 ==================== -->
        <ContentControl Grid.Row="1"
                        Style="{StaticResource UiEmptyStateStyle}"
                        Content="本页暂无可显示的订单"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- ==================== 数据（舒适表格 + UI 虚拟化 + 单行选中态） ==================== -->
        <DataGrid Grid.Row="1"
                  Style="{StaticResource UiDataGridStyle}"
                  ItemsSource="{Binding Orders}"
                  SelectedItem="{Binding SelectedOrder}"
                  Visibility="{Binding ShowContent, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DataGrid.Resources>
                <helpers:BindingProxy x:Key="OrdersPageProxy" Data="{Binding}" />
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="订单号" Binding="{Binding OrderNo}" Width="*" />

                <DataGridTemplateColumn Header="销售阶段" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Style="{StaticResource SalesStageBadgeStyle}"
                                            Content="{Binding SalesStage, Converter={StaticResource CommerceEnumLabelConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="收款阶段" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Style="{StaticResource PaymentStageBadgeStyle}"
                                            Content="{Binding PaymentStage, Converter={StaticResource CommerceEnumLabelConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="履约阶段" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Style="{StaticResource FulfillmentStageBadgeStyle}"
                                            Content="{Binding FulfillmentStage, Converter={StaticResource CommerceEnumLabelConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="总额" Binding="{Binding Total, StringFormat=¥{0}}" Width="Auto" />
                <DataGridTextColumn Header="已收" Binding="{Binding PaidAmount, StringFormat=¥{0}}" Width="Auto" />
                <DataGridTextColumn Header="应收" Binding="{Binding ReceivableAmount, StringFormat=¥{0}}" Width="Auto" />
                <DataGridTextColumn Header="下单时间" Binding="{Binding OrderedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="Auto" />
                <DataGridTemplateColumn Header="操作" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="归档"
                                    Style="{StaticResource UiTextButtonStyle}"
                                    Command="{Binding Data.ArchiveOrderCommand, Source={StaticResource OrdersPageProxy}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
