<UserControl x:Class="Orderly.App.Views.Sections.CashflowAdviceCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainSharedResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainComponentStyles.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainComponentStyles.C.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0" Padding="20,16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel LastChildFill="False" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💡" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="现金流建议" Style="{StaticResource SectionHeaderTextStyle}" FontSize="14" VerticalAlignment="Center" />
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="查看详情 >" Foreground="{StaticResource BlueTextBrush}" FontSize="11" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" />
            </DockPanel>

            <Border Grid.Row="1" Background="#EBF8F2" BorderBrush="#34C759" BorderThickness="4,0,0,0" CornerRadius="0,8,8,0" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding CashflowAdviceTitleText, FallbackValue='🟢 当前现金流健康，经营状况良好'}" FontSize="13" FontWeight="Bold" Foreground="#1F8B4C" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding CashflowAdviceDescriptionText, FallbackValue='近7日净现金流为正，可进行小额补货。建议单次补货金额不超过¥800，优先补充高动销材料。'}" FontSize="12" Foreground="#2B7A5C" Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="18" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2">
                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛍️" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="补货建议：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding CashflowAdvice.RestockSuggestionAmount, StringFormat=≤ ¥{0:N0}, TargetNullValue=≤ ¥800}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="风险提示：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding CashflowAdvice.RiskHint, TargetNullValue=无}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Margin="0,12" />

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🎯" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="下周关注：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding CashflowAdvice.NextFocus}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Ellipse Width="4" Height="4" Fill="#34C759" VerticalAlignment="Center" Margin="6,0,8,0" />
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="暂无关注事项" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="6,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCashflowAdviceFocusItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
