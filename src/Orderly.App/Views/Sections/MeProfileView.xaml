<UserControl x:Class="Orderly.App.Views.Sections.MeProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections"
             xmlns:conv="clr-namespace:Orderly.App.Converters"
             xmlns:helpers="clr-namespace:Orderly.App.Helpers"
             xmlns:vm="clr-namespace:Orderly.App.ViewModels">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/DesignTokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 安全审计事件类型 → 中文展示映射（任务 18.5 / Req 9.1），仅供我的页消费。 -->
            <conv:SecurityAuditKindLabelConverter x:Key="SecurityAuditKindLabelConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        我的页：「顶部身份头图 + 卡片堆叠」单列布局（design §4.3 / §5.2，任务 18.1）。
        - 根元素可见性已统一上移至 MainWindow.xaml 的 MeProfileView 实例（SelectedSection + SectionVisibilityConverter，任务 20.1 / design §8.2），本根 Grid 不再自带内联可见性绑定。
        - 内层内容区 DataContext 局部绑定到 MeProfileViewModel（MainViewModel.MeProfile），各卡片绑定其状态/命令。
        - 锁定/登出为壳层跨页能力，经 RelativeSource 绑定到根 MainViewModel 的既有命令。
        - 各卡 UI 细节（成员管理 18.2 / 凭证修改 18.3 / 头像 18.4 / 账户安全 18.5 / 紧急启用 18.6 / 令牌 18.7）后续完善。
    -->
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,24,24,32">
            <!-- 单列纵向堆叠，居中并约束最大宽度（沿用现有 MaxWidth 居中模式） -->
            <StackPanel HorizontalAlignment="Center"
                        MaxWidth="880"
                        DataContext="{Binding MeProfile}">

                <!-- ==================== 顶部身份头图 IdentityHeader ==================== -->
                <Border Style="{StaticResource RefineIdentityHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 头像（任务 18.4 / Req 6.1·6.5·6.6）：
                             - 整块为可点击按钮，点击触发 ChangeAvatarCommand 更换头像（Req 6.1）；hover 显示「更换」遮罩 + ToolTip。
                             - 无引用（AvatarImageSource 为 null）→ 渐变底色 + AvatarPlaceholderInitial 首字占位（Req 6.5）；
                               有图时 Image 以 UniformToFill 覆盖渐变底色与占位。 -->
                        <Button Grid.Column="0" Width="72" Height="72" Padding="0" Cursor="Hand"
                                VerticalAlignment="Center" Margin="0,0,18,0"
                                ToolTip="点击更换头像"
                                Command="{Binding ChangeAvatarCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="36" ClipToBounds="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#2B7A5C" Offset="0" />
                                                <GradientStop Color="#4E9B7B" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <!-- 占位首字（AvatarImageSource 为 null 时可见） -->
                                            <TextBlock Text="{Binding AvatarPlaceholderInitial}"
                                                       FontSize="30" FontWeight="SemiBold" Foreground="#FFFFFF"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AvatarImageSource}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- 头像图片（有引用时覆盖渐变底色） -->
                                            <Image Source="{Binding AvatarImageSource}" Stretch="UniformToFill" />
                                            <!-- hover 遮罩「更换」提示 -->
                                            <Border x:Name="HoverOverlay" Background="#80000000" Visibility="Collapsed">
                                                <TextBlock Text="更换" Foreground="#FFFFFF" FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HoverOverlay" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 显示名 + 角色徽章 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentAccountDisplayName}"
                                       FontSize="{StaticResource TypeTitleFontSize}"
                                       FontWeight="{StaticResource TypeTitleFontWeight}"
                                       Foreground="{DynamicResource HeadingBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Margin="0,8,0,0">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource RefineStatusBadgeStyle}">
                                        <Setter Property="Background" Value="{DynamicResource GreySoftBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrentUserOwner}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding RoleBadgeText}" FontWeight="SemiBold" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource GreyTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentUserOwner}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- 头像操作入口（任务 18.4 / Req 6.1）：更换头像 / 移除头像（无头像引用时隐藏「移除」）。
                                 链接型按钮采用内联无边框模板（下划线文字），避免引入额外资源依赖。 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="更换头像" Command="{Binding ChangeAvatarCommand}" Cursor="Hand"
                                        Foreground="{DynamicResource PrimaryBrush}" FontSize="12">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                                       FontSize="{TemplateBinding FontSize}" TextDecorations="Underline" />
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock Text="·" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="8,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <!-- 无头像引用时连同分隔点一并隐藏（与「移除头像」同步） -->
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AvatarImageSource}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Content="移除头像" Command="{Binding RemoveAvatarCommand}" Cursor="Hand"
                                        Foreground="{DynamicResource DangerTextBrush}" FontSize="12">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                                       FontSize="{TemplateBinding FontSize}" TextDecorations="Underline" />
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <!-- 无头像引用时隐藏「移除头像」（AvatarImageSource 为 null） -->
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AvatarImageSource}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- 就地反馈（任务 18.4 / Req 6.6）：AvatarStatus 非空时显示，如「图片无效或过大」。
                                 拒绝 / 失败用警示色，其余用次要文字色。 -->
                            <TextBlock Text="{Binding AvatarStatus}" FontSize="12" Margin="0,6,0,0"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AvatarStatus}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AvatarStatus}" Value="图片无效或过大">
                                                <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- 锁定 / 登出快捷操作（壳层命令，经 RelativeSource 绑定根 MainViewModel） -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="锁定工作台"
                                    Command="{Binding DataContext.LockSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                    Height="38" Padding="14,0" Margin="0,0,10,0" />
                            <Button Content="安全退出登录"
                                    Command="{Binding DataContext.LogoutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                    Height="38" Padding="14,0"
                                    Foreground="{DynamicResource DangerTextBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ==================== 受限权限模式提示横幅（任务 18.6 / Req 17.3·17.4） ====================
                     IsRestrictedPermissionMode=true（Owner 经紧急入口启用进入受限模式）时显示，
                     提示「仅数据备份/导入导出恢复等数据抢救操作可用」；其余入口（成员管理、设置内
                     安全与数据高危项、机密数据页面等）经能力门控只读属性同步禁用 / 隐藏。 -->
                <Border Margin="0,16,0,0" Padding="16,14"
                        Background="{DynamicResource WarmSoftBrush}" BorderBrush="{DynamicResource WarmTextBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}"
                        Visibility="{Binding IsRestrictedPermissionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   Foreground="{DynamicResource WarmTextBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="受限权限模式已启用" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource WarmTextBrush}" />
                            <TextBlock Text="{x:Static vm:MeProfileViewModel.RestrictedModeNotice}"
                                       FontSize="12" Foreground="{DynamicResource WarmTextBrush}" Margin="0,3,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ==================== 成员管理卡（仅 Owner 可见，Req 5.3） ==================== -->
                <!-- 任务 18.2：搜索框 + 启用/禁用状态徽章 + 空状态 + 创建/重置/停用/删除操作入口；
                     创建入口按权限矩阵显隐（Member 不显示，Req 7.5）；删除入口二次确认（Req 7.4）。
                     任务 18.6：受限权限模式下成员管理恒禁用（CanUseMemberManagement=false → 整卡隐藏，Req 17.4）。 -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource SettingsGroupCardStyle}">
                            <!-- 默认隐藏；仅当「可管理成员」且「受限模式允许成员管理」同时成立时显示 -->
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding CanManageAccounts}" Value="True" />
                                        <Condition Binding="{Binding CanUseMemberManagement}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="店员成员管理" Style="{StaticResource SettingsGroupTitleStyle}" />
                        <TextBlock Text="系统管理员可在此创建、搜索、管理其他成员账号" Style="{StaticResource SettingsItemDescStyle}" Margin="0,2,0,16" />

                        <!-- 创建新成员表单（创建入口仅 Owner 显示，Member 不显示，Req 7.5） -->
                        <Border Background="{DynamicResource SurfaceSoftBrush}"
                                BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}" Padding="14" Margin="0,0,0,18"
                                Visibility="{Binding CanCreateMember, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="新建店员账号" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="用户名" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                        <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberUsername, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="显示姓名" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                        <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <!-- 主密码：经 PasswordBoxBinder 绑定 NewMemberPassword（MVVM 附加行为，§8.3） -->
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="主密码" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                        <PasswordBox Height="30" helpers:PasswordBoxBinder.BoundPassword="{Binding NewMemberPassword, Mode=TwoWay}" />
                                    </StackPanel>

                                    <!-- PIN：经 PasswordBoxBinder 绑定 NewMemberPin -->
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="PIN 码 (6位)" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                        <PasswordBox Height="30" MaxLength="6" helpers:PasswordBoxBinder.BoundPassword="{Binding NewMemberPin, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>
                                <Button Content="创建账号" Command="{Binding CreateMemberCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" Margin="0,12,0,0" HorizontalAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <!-- 成员搜索框（Req 7.1，RefineSearchBoxStyle） -->
                        <Grid Margin="0,0,0,12">
                            <TextBox Style="{StaticResource RefineSearchBoxStyle}"
                                     Text="{Binding MemberSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="34,0,12,0" />
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False" />
                            <TextBlock Text="搜索成员（用户名 / 显示名）" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="12" VerticalAlignment="Center" Margin="34,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MemberSearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- 店员列表 -->
                        <TextBlock Text="已创建成员" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" Margin="0,0,0,10" />

                        <!-- 空状态提示（Req 7.3）：过滤后列表为空时显示 -->
                        <Border Visibility="{Binding IsMemberListEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="{DynamicResource SurfaceSoftBrush}"
                                CornerRadius="{StaticResource RadiusSm}" Padding="16,18">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                           Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                <TextBlock Text="没有匹配的成员账号" FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- 成员列表（绑定 ManagedAccountsView 搜索过滤视图） -->
                        <ListBox BorderThickness="1"
                                 BorderBrush="{DynamicResource BorderBrushSoft}"
                                 Background="{DynamicResource SurfaceRaisedBrush}"
                                 Padding="4"
                                 MaxHeight="200"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemsSource="{Binding ManagedAccountsView}"
                                 SelectedItem="{Binding SelectedManagedAccount}">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMemberListEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                                    <Setter Property="Padding" Value="8" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ContainerBorder" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ContainerBorder" Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ContainerBorder" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentSoftBrush}" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource HeadingBrush}" />
                                                <TextBlock Text="{Binding Username, StringFormat=({0})}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="6,1,0,0" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 启用/禁用状态徽章（Req 7.2）：随 IsEnabled 着色与文案切换 -->
                                        <Border Grid.Column="2" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource RefineStatusBadgeStyle}">
                                                    <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="已禁用" />
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Text" Value="已启用" />
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 选中店员的操作区（重置 / 停用 / 删除，命令 CanExecute 已接权限矩阵 §8.1.1） -->
                        <Border Margin="0,12,0,0" Padding="14" Background="{DynamicResource SurfaceSoftBrush}"
                                CornerRadius="{StaticResource RadiusSm}"
                                Visibility="{Binding CanOperateMember, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="选中成员控制：" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedManagedAccount.DisplayName}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedManagedAccount.Username, StringFormat=({0})}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,1,0,0" VerticalAlignment="Center" />
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 重置主密码：经 PasswordBoxBinder 绑定 ResetMemberPasswordInput -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="重置该店员主密码" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox Grid.Column="0" Height="30" helpers:PasswordBoxBinder.BoundPassword="{Binding ResetMemberPasswordInput, Mode=TwoWay}" />
                                            <Button Grid.Column="2" Content="重置密码" Command="{Binding ResetMemberPasswordCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="30" Padding="12,0" Margin="0" />
                                        </Grid>
                                    </StackPanel>

                                    <!-- 重置 PIN：经 PasswordBoxBinder 绑定 ResetMemberPinInput -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="重置店员 PIN 码" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox Grid.Column="0" Height="30" MaxLength="6" helpers:PasswordBoxBinder.BoundPassword="{Binding ResetMemberPinInput, Mode=TwoWay}" />
                                            <Button Grid.Column="2" Content="重置 PIN" Command="{Binding ResetMemberPinCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="30" Padding="12,0" Margin="0" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- 停用（保留账号，置 IsEnabled=false）与删除（移除登录账号，二次确认）两种独立能力（Req 7.10） -->
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="停用/禁用此店员账号" Command="{Binding DisableMemberCommand}" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="32" Padding="14,0" Margin="0,0,10,0" />
                                    <Button Content="删除此店员账号" Command="{Binding DeleteMemberCommand}" Style="{StaticResource ToolbarSecondaryButtonStyle}" Foreground="{DynamicResource DangerTextBrush}" Height="32" Padding="14,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding MemberManagementStatus}" Style="{StaticResource SettingsItemDescStyle}" Margin="0,10,0,0" HorizontalAlignment="Right" />
                    </StackPanel>
                </Border>

                <!-- ==================== 凭证修改卡（任务 18.3 / Req 8.1·8.3·8.5·8.6·8.7·8.10） ====================
                     - 6 个凭证输入框（当前/新/确认 × 主密码/PIN）全部经 PasswordBoxBinder.BoundPassword 双向绑定到
                       对应 *Input，取代 code-behind 同步（Req 10.3 / 10.4）。
                     - 每个输入框附密码显隐切换 ToggleButton（RefinePasswordRevealButtonStyle）：未选中显示 PasswordBox，
                       选中时切换到镜像 TextBox 显示明文，二者绑定同一 *Input，经 VM 保持同步（Req 8.6）。
                     - 实时校验文案绑定 MasterPasswordValidation.Message / PinValidation.Message（含「强度偏弱」中文警告，
                       Req 8.1 / 8.3 / 8.10）。
                     - 新主密码强度计用 RefineStrengthMeterStyle，按 NewMasterPasswordStrength 映射进度值与颜色
                       （弱=DangerTextBrush、中=暖色、良/强偏绿/PrimaryBrush，Req 8.5）。
                     - 长度达标但强度偏弱仅警告不禁用提交：提交按钮 IsEnabled 由命令 CanExecute（= *Validation.CanSubmit）
                       决定，强度不参与门槛（Req 8.10 / 8.2 / 8.4）。
                     - 结果就地反馈 CredentialChangeStatus，不使用离开页 Toast（Req 8.7）。
                     - 任务 18.6：凭证修改属设置内安全高危项，受限权限模式下恒禁用
                       （CanUseSecurityAndDataHighRiskSettings=false → 整卡隐藏，Req 17.4）。 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0"
                        Visibility="{Binding CanUseSecurityAndDataHighRiskSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="登录凭证修改" Style="{StaticResource SettingsGroupTitleStyle}" />
                        <TextBlock Text="保护您的账户安全，建议定期更换安全凭证" Style="{StaticResource SettingsItemDescStyle}" Margin="0,2,0,16" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- ───────────── 修改主密码 ───────────── -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="修改账户主密码" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" Margin="0,0,0,12" />

                                <!-- 当前主密码 -->
                                <TextBlock Text="当前密码验证" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox Height="30" VerticalContentAlignment="Center"
                                                     helpers:PasswordBoxBinder.BoundPassword="{Binding CurrentMasterPasswordInput, Mode=TwoWay}">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealCurMaster}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <TextBox Height="30" VerticalContentAlignment="Center"
                                                 Text="{Binding CurrentMasterPasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealCurMaster}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                    <ToggleButton x:Name="RevealCurMaster" Grid.Column="1" Margin="6,0,0,0"
                                                  ToolTip="显示 / 隐藏密码" Style="{StaticResource RefinePasswordRevealButtonStyle}" />
                                </Grid>

                                <!-- 新主密码 -->
                                <TextBlock Text="输入新主密码" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox Height="30" VerticalContentAlignment="Center"
                                                     helpers:PasswordBoxBinder.BoundPassword="{Binding NewCurrentMasterPasswordInput, Mode=TwoWay}">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealNewMaster}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <TextBox Height="30" VerticalContentAlignment="Center"
                                                 Text="{Binding NewCurrentMasterPasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealNewMaster}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                    <ToggleButton x:Name="RevealNewMaster" Grid.Column="1" Margin="6,0,0,0"
                                                  ToolTip="显示 / 隐藏密码" Style="{StaticResource RefinePasswordRevealButtonStyle}" />
                                </Grid>

                                <!-- 新主密码强度计（RefineStrengthMeterStyle，Req 8.5） -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="新密码强度" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="" />
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NewMasterPasswordStrength}" Value="Weak">
                                                        <Setter Property="Text" Value="弱" />
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NewMasterPasswordStrength}" Value="Fair">
                                                        <Setter Property="Text" Value="中" />
                                                        <Setter Property="Foreground" Value="{DynamicResource WarmTextBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NewMasterPasswordStrength}" Value="Good">
                                                        <Setter Property="Text" Value="良" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NewMasterPasswordStrength}" Value="Strong">
                                                        <Setter Property="Text" Value="强" />
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <ProgressBar Margin="0,0,0,10">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar" BasedOn="{StaticResource RefineStrengthMeterStyle}">
                                            <Setter Property="Value" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NewMasterPasswordStrength}" Value="Weak">
                                                    <Setter Property="Value" Value="25" />
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NewMasterPasswordStrength}" Value="Fair">
                                                    <Setter Property="Value" Value="50" />
                                                    <Setter Property="Foreground" Value="{DynamicResource WarmTextBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NewMasterPasswordStrength}" Value="Good">
                                                    <Setter Property="Value" Value="75" />
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NewMasterPasswordStrength}" Value="Strong">
                                                    <Setter Property="Value" Value="100" />
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>

                                <!-- 确认新主密码 -->
                                <TextBlock Text="确认新主密码" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox Height="30" VerticalContentAlignment="Center"
                                                     helpers:PasswordBoxBinder.BoundPassword="{Binding ConfirmNewMasterPasswordInput, Mode=TwoWay}">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealConfMaster}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <TextBox Height="30" VerticalContentAlignment="Center"
                                                 Text="{Binding ConfirmNewMasterPasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealConfMaster}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                    <ToggleButton x:Name="RevealConfMaster" Grid.Column="1" Margin="6,0,0,0"
                                                  ToolTip="显示 / 隐藏密码" Style="{StaticResource RefinePasswordRevealButtonStyle}" />
                                </Grid>

                                <!-- 主密码实时校验文案（含强度偏弱警告，Req 8.1 / 8.10） -->
                                <TextBlock Text="{Binding MasterPasswordValidation.Message}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MasterPasswordValidation.IsStrengthWeak}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarmTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Content="确认修改主密码" Command="{Binding ChangeCurrentMasterPasswordCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" HorizontalAlignment="Left" />
                            </StackPanel>

                            <!-- ───────────── 修改 PIN 码 ───────────── -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="修改安全 PIN 码" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" Margin="0,0,0,12" />

                                <!-- 当前 PIN -->
                                <TextBlock Text="当前 PIN 验证" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox Height="30" MaxLength="6" VerticalContentAlignment="Center"
                                                     helpers:PasswordBoxBinder.BoundPassword="{Binding CurrentPinInput, Mode=TwoWay}">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealCurPin}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <TextBox Height="30" MaxLength="6" VerticalContentAlignment="Center"
                                                 Text="{Binding CurrentPinInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealCurPin}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                    <ToggleButton x:Name="RevealCurPin" Grid.Column="1" Margin="6,0,0,0"
                                                  ToolTip="显示 / 隐藏 PIN" Style="{StaticResource RefinePasswordRevealButtonStyle}" />
                                </Grid>

                                <!-- 新 PIN -->
                                <TextBlock Text="输入新 PIN 码" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox Height="30" MaxLength="6" VerticalContentAlignment="Center"
                                                     helpers:PasswordBoxBinder.BoundPassword="{Binding NewCurrentPinInput, Mode=TwoWay}">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealNewPin}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <TextBox Height="30" MaxLength="6" VerticalContentAlignment="Center"
                                                 Text="{Binding NewCurrentPinInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealNewPin}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                    <ToggleButton x:Name="RevealNewPin" Grid.Column="1" Margin="6,0,0,0"
                                                  ToolTip="显示 / 隐藏 PIN" Style="{StaticResource RefinePasswordRevealButtonStyle}" />
                                </Grid>

                                <!-- 确认新 PIN -->
                                <TextBlock Text="确认新 PIN 码" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox Height="30" MaxLength="6" VerticalContentAlignment="Center"
                                                     helpers:PasswordBoxBinder.BoundPassword="{Binding ConfirmNewPinInput, Mode=TwoWay}">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealConfPin}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <TextBox Height="30" MaxLength="6" VerticalContentAlignment="Center"
                                                 Text="{Binding ConfirmNewPinInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RevealConfPin}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                    <ToggleButton x:Name="RevealConfPin" Grid.Column="1" Margin="6,0,0,0"
                                                  ToolTip="显示 / 隐藏 PIN" Style="{StaticResource RefinePasswordRevealButtonStyle}" />
                                </Grid>

                                <!-- PIN 实时校验文案（Req 8.3） -->
                                <TextBlock Text="{Binding PinValidation.Message}" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12" />

                                <Button Content="确认修改 PIN 码" Command="{Binding ChangeCurrentPinCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>

                        <!-- 命令完成就地反馈（Req 8.7，不使用离开页 Toast） -->
                        <TextBlock Text="{Binding CredentialChangeStatus}" Style="{StaticResource SettingsItemDescStyle}" Margin="0,12,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- ==================== 账户安全 / 登录记录卡（任务 18.5 / Req 9.1·9.3·9.4·9.5·9.6·9.7） ====================
                     - 最近登录时间：绑定 CurrentAccountLastLoginAt（格式化；null 显示「暂无登录记录」，Req 9.5）。
                     - 日期范围筛选：两个 DatePicker 绑定 AuditRangeStart/AuditRangeEnd（默认今天-30天/今天）+「应用」按钮绑定
                       ApplyAuditDateRangeCommand（Req 9.6/9.7），附「默认最近 30 天，可调整查看更早记录」提示。
                     - 审计列表：ItemsControl 绑定 SecurityAuditEntries，每项展示 OccurredAt（格式化）/ Kind（映射中文）/ Detail（Req 9.1）。
                     - 空状态（IsAuditEmpty）→ AuditStatus 文案；读取失败（IsAuditLoadFailed）→「安全记录读取失败」，不渲染半截列表（Req 9.3/9.4）。
                     - 服务不可用（IsSecurityAuditAvailable=false）→ 占位文案，隐藏筛选/列表（完整 DI 见 21.1）。 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="账户安全 / 登录记录" Style="{StaticResource SettingsGroupTitleStyle}" />
                        <TextBlock Text="查看真实的登录与安全记录，了解账户安全状况" Style="{StaticResource SettingsItemDescStyle}" Margin="0,2,0,12" />

                        <!-- 最近登录时间（Req 9.5）：直接展示 LocalAccount.LastLoginAt -->
                        <Border Background="{DynamicResource SurfaceSoftBrush}"
                                CornerRadius="{StaticResource RadiusSm}" Padding="14,12" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="最近登录时间：" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding CurrentAccountLastLoginAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentAccountLastLoginAt}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="暂无登录记录" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 服务不可用占位（IsSecurityAuditAvailable=false）：仅显示占位文案，隐藏筛选与列表 -->
                        <TextBlock Text="{Binding AuditStatus}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SettingsItemDescStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSecurityAuditAvailable}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 审计区（仅服务可用时渲染：筛选 + 列表 + 空/失败状态） -->
                        <StackPanel Visibility="{Binding IsSecurityAuditAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <!-- 日期范围筛选控件（Req 9.6/9.7） -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="起始" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <DatePicker Grid.Column="1" SelectedDate="{Binding AuditRangeStart, Mode=TwoWay}" VerticalContentAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="结束" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Center" Margin="12,0,8,0" />
                                <DatePicker Grid.Column="3" SelectedDate="{Binding AuditRangeEnd, Mode=TwoWay}" VerticalContentAlignment="Center" />
                                <Button Grid.Column="4" Content="应用" Command="{Binding ApplyAuditDateRangeCommand}"
                                        Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="16,0" Margin="12,0,0,0" />
                            </Grid>

                            <!-- 默认窗口提示（Req 9.6） -->
                            <TextBlock Text="默认显示最近 30 天的安全记录，可调整日期范围查看更早记录。"
                                       Style="{StaticResource SettingsItemDescStyle}" Margin="0,0,0,12" TextWrapping="Wrap" />

                            <!-- 空状态（IsAuditEmpty，Req 9.3）：所选范围内无记录，不臆造数据 -->
                            <Border Visibility="{Binding IsAuditEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Background="{DynamicResource SurfaceSoftBrush}"
                                    CornerRadius="{StaticResource RadiusSm}" Padding="16,18">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                               Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding AuditStatus}" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- 读取失败（IsAuditLoadFailed，Req 9.4）：统一降级文案，不渲染半截列表、不泄露异常细节 -->
                            <Border Visibility="{Binding IsAuditLoadFailed, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Background="{DynamicResource DangerSoftBrush}" BorderBrush="{DynamicResource DangerBorderBrush}" BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusSm}" Padding="16,14">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="{DynamicResource DangerTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="安全记录读取失败" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource DangerTextBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- 审计历史列表（Req 9.1）：每项展示时间 / 类型（中文）/ 详情 -->
                            <ItemsControl ItemsSource="{Binding SecurityAuditEntries}"
                                          BorderThickness="1" BorderBrush="{DynamicResource BorderBrushSoft}"
                                          Background="{DynamicResource SurfaceRaisedBrush}"
                                          Padding="4">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <!-- 列表仅在有记录时显示（空/失败时由上方降级块呈现） -->
                                            <DataTrigger Binding="{Binding SecurityAuditEntries.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="{StaticResource RadiusSm}"
                                                Padding="{TemplateBinding Padding}">
                                            <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </Border>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrushSoft}" Padding="8,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- 事件类型徽章（Kind 映射中文） -->
                                                <Border Grid.Column="0" Background="{DynamicResource AccentSoftBrush}"
                                                        CornerRadius="{StaticResource RadiusSm}" Padding="8,3" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Kind, Converter={StaticResource SecurityAuditKindLabelConverter}}"
                                                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" />
                                                </Border>

                                                <!-- 详情 + 账号标签 -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Detail}" FontSize="13"
                                                               Foreground="{DynamicResource HeadingBrush}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding AccountLabel}" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <!-- 发生时间（格式化） -->
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                                                           Text="{Binding OccurredAt, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ==================== Owner 紧急启用入口卡（任务 18.6 / Req 17.1·17.2·13.2） ====================
                     - 「紧急启用」入口为独立小卡，点击经「独立的紧急入口弹窗」采集 6 位 PIN 调 TryEmergencyEnableCommand
                       （PickEmergencyPin 委托在 code-behind 接线；不放在登录页，登录页保持不变）。
                     - EmergencyStatus 绑定显示结果（成功进入受限模式 / 失败中文提示，Req 17.2）。
                     - 已处于受限模式时（IsRestrictedPermissionMode=true）隐藏入口按钮，避免重复启用。 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="紧急启用入口" Style="{StaticResource SettingsGroupTitleStyle}" />
                        <TextBlock Text="当系统管理员（Owner）账号被停用而需临时抢救数据时，可在此输入 Owner 的 6 位安全 PIN 进入受限权限模式。受限模式下仅可执行数据备份 / 导入导出恢复等数据抢救操作。"
                                   Style="{StaticResource SettingsItemDescStyle}" Margin="0,2,0,14" TextWrapping="Wrap" LineHeight="20" />

                        <Button Content="紧急启用（输入 Owner PIN）"
                                Command="{Binding TryEmergencyEnableCommand}"
                                Foreground="{DynamicResource DangerTextBrush}"
                                Height="34" Padding="16,0" HorizontalAlignment="Left">
                            <Button.Style>
                                <!-- 已处于受限模式时隐藏入口，避免重复启用（Req 17.1） -->
                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarSecondaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRestrictedPermissionMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- 紧急启用结果就地反馈（EmergencyStatus，不含明文 PIN） -->
                        <TextBlock Text="{Binding EmergencyStatus}"
                                   Margin="0,12,0,0" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SettingsItemDescStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EmergencyStatus}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ==================== 关于 Orderly 卡 ==================== -->
                <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="关于 Orderly" Style="{StaticResource SettingsGroupTitleStyle}" />
                        <TextBlock Text="Orderly · 本地优先的 PC 端经营管理系统"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource HeadingBrush}"
                                   Margin="0,8,0,6" TextWrapping="Wrap" />
                        <TextBlock Text="面向小微商家，覆盖成交销售、订单、库存、客户、现金流、数据分析与经营建议七大能力。所有业务数据均保存在本机，默认不依赖云端。"
                                   Style="{StaticResource SettingsItemDescStyle}"
                                   TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,4" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
