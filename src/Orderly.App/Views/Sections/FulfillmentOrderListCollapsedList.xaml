<UserControl x:Class="Orderly.App.Views.Sections.FulfillmentOrderListCollapsedList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/FulfillmentOrderListResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

                                <Grid Visibility="{Binding IsStringNarrationOrderListVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <!-- Empty state UI -->
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding HasStringNarrationOrders}" Value="False" />
                                                            <Condition Binding="{Binding IsStringNarrationLoading}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </MultiDataTrigger.EnterActions>
                                                        <MultiDataTrigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15" Duration="0">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </MultiDataTrigger.ExitActions>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="64" Height="64" CornerRadius="32" Background="{DynamicResource SurfaceSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                                                <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{DynamicResource CaptionTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" HorizontalAlignment="Center" Margin="0,0,0,6">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="暂无订单数据" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                                <Setter Property="Text" Value="暂无已支付待确认的订单" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                                <Setter Property="Text" Value="暂无待制作订单" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                                                <Setter Property="Text" Value="暂无制作中订单" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                                                <Setter Property="Text" Value="暂无待发货订单" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                                                <Setter Property="Text" Value="暂无已发货订单" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                                                <Setter Property="Text" Value="暂无异常订单" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                                                <Setter Property="Text" Value="暂无已完成订单" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="切换分类卡片或重置筛选条件试试" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <ListBox ItemsSource="{Binding StringNarrationOrders}"
                                             SelectedItem="{Binding SelectedStringNarrationOrder}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             MouseDoubleClick="StringNarrationOrdersList_MouseDoubleClick"
                                             ItemContainerStyle="{StaticResource StringNarrationOrderCardListItemStyle}"
                                             ItemTemplate="{StaticResource StringNarrationOrderCardTemplate}"
                                             Padding="2,4,2,2"
                                             ClipToBounds="False">
                                        <ListBox.Style>
                                            <Style TargetType="ListBox">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasStringNarrationOrders}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.Style>
                                    </ListBox>
                                </Grid>
</UserControl>
