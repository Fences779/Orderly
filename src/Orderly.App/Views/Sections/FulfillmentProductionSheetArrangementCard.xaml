<UserControl x:Class="Orderly.App.Views.Sections.FulfillmentProductionSheetArrangementCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/FulfillmentOrderListResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

                                                 <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                                                     <StackPanel>
                                                         <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                             <TextBlock Text="&#xE1DA;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                             <TextBlock Text="排列方式" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                         </StackPanel>

                                                         <!-- 规格 Badge (手围/结构) -->
                                                         <Grid Margin="0,0,0,10">
                                                             <Grid.ColumnDefinitions>
                                                                 <ColumnDefinition Width="*" />
                                                                 <ColumnDefinition Width="*" />
                                                             </Grid.ColumnDefinitions>
                                                             <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="8,6" Margin="0,0,4,0">
                                                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                     <TextBlock Text="📏" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                                     <TextBlock Text="手围 " FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                                     <TextBlock Text="{Binding SelectedStringNarrationProductionSheet.WristSizeText}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                                 </StackPanel>
                                                             </Border>
                                                             <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="8,6" Margin="4,0,0,0">
                                                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                     <TextBlock Text="🔗" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                                     <TextBlock Text="结构 " FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                                     <TextBlock Text="{Binding SelectedStringNarrationProductionSheet.LoopTypeText}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                                 </StackPanel>
                                                             </Border>
                                                         </Grid>

                                                         <!-- 串珠顺序流 -->
                                                         <Border Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="10" MinHeight="42">
                                                             <Grid>
                                                                 <!-- 情况A：能解析出步骤流 -->
                                                                 <ItemsControl ItemsSource="{Binding SelectedStringNarrationProductionSheet.ArrangementFlowItems}">
                                                                     <ItemsControl.Style>
                                                                         <Style TargetType="ItemsControl">
                                                                             <Setter Property="Visibility" Value="Visible" />
                                                                             <Style.Triggers>
                                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.HasArrangementSteps}" Value="False">
                                                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                                                 </DataTrigger>
                                                                             </Style.Triggers>
                                                                         </Style>
                                                                     </ItemsControl.Style>
                                                                     <ItemsControl.ItemsPanel>
                                                                         <ItemsPanelTemplate>
                                                                             <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" />
                                                                         </ItemsPanelTemplate>
                                                                     </ItemsControl.ItemsPanel>
                                                                     <ItemsControl.ItemTemplate>
                                                                         <DataTemplate>
                                                                             <Grid Margin="0,2">
                                                                                 <!-- 胶囊样式 -->
                                                                                 <Border x:Name="CapsuleBorder" Background="{StaticResource AccentSoftBrush}" CornerRadius="6" Padding="6,3" Margin="2,2">
                                                                                     <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center" />
                                                                                 </Border>
                                                                                 <!-- 箭头样式 -->
                                                                                 <TextBlock x:Name="ArrowText" Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{StaticResource CaptionTextBrush}" VerticalAlignment="Center" Margin="4,0" Visibility="Collapsed" />
                                                                             </Grid>
                                                                             <DataTemplate.Triggers>
                                                                                 <DataTrigger Binding="{Binding}" Value="→">
                                                                                     <Setter TargetName="CapsuleBorder" Property="Visibility" Value="Collapsed" />
                                                                                     <Setter TargetName="ArrowText" Property="Visibility" Value="Visible" />
                                                                                 </DataTrigger>
                                                                             </DataTemplate.Triggers>
                                                                         </DataTemplate>
                                                                     </ItemsControl.ItemTemplate>
                                                                 </ItemsControl>

                                                                 <!-- 情况B：无法解析步骤流，直接显示原本的文本 -->
                                                                 <TextBlock Text="{Binding StringNarrationProductionSheetArrangementText}" FontSize="12" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" VerticalAlignment="Center">
                                                                     <TextBlock.Style>
                                                                         <Style TargetType="TextBlock">
                                                                             <Setter Property="Visibility" Value="Collapsed" />
                                                                             <Style.Triggers>
                                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.HasArrangementSteps}" Value="False">
                                                                                     <Setter Property="Visibility" Value="Visible" />
                                                                                 </DataTrigger>
                                                                             </Style.Triggers>
                                                                         </Style>
                                                                     </TextBlock.Style>
                                                                 </TextBlock>
                                                             </Grid>
                                                         </Border>
                                                     </StackPanel>
                                                 </Border>
</UserControl>
