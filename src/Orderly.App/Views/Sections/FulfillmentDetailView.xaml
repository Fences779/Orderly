<UserControl x:Class="Orderly.App.Views.Sections.FulfillmentDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border x:Name="DetailPanel" Grid.Column="1" Padding="18" Margin="0" RenderTransformOrigin="0.5,0.5"
            Visibility="{Binding IsStringNarrationDetailPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border.RenderTransform>
            <TranslateTransform X="40" />
        </Border.RenderTransform>
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource SettingsGroupCardStyle}">
                <Style.Triggers>
                    <Trigger Property="Visibility" Value="Visible">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="40" To="0" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header -->
                <Border BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="订单详情" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="订单号：" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.OrderNoText}" Foreground="{DynamicResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                <Button Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="6,0,0,2" VerticalAlignment="Center"
                                        Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="orderNo" ToolTip="复制订单号">
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="32" Height="32" Padding="0" VerticalAlignment="Top"
                                Click="CloseDetails_Click" ToolTip="关闭详情">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Stepper -->
                <Sections:FulfillmentDetailStepper />

                <!-- Overview Grid -->
                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="订单概览" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" Margin="0,0,0,10" />
                        <UniformGrid Columns="3">
                            <!-- Box 1: Receiver Name -->
                            <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="客户昵称" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverName, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>

                            <!-- Box 2: Amount -->
                            <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="订单金额" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.AmountText, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Box 3: Count -->
                            <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="商品数量" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ItemCountText, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Box 4: CreatedAt -->
                            <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="下单时间" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.CreatedAtText, FallbackValue='-'}" FontSize="11" Foreground="{DynamicResource HeadingBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>

                            <!-- Box 5: PaidAt -->
                            <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="支付时间" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.PaidAtText, FallbackValue='-'}" FontSize="11" Foreground="{DynamicResource HeadingBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>

                            <!-- Box 6: Channel -->
                            <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="支付通道" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Text="微信支付" FontSize="11" Foreground="{DynamicResource HeadingBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Product snap list -->
                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="商品快照" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding SelectedStringNarrationOrderDetail.ItemsSnapshot}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceSoftBrush}"
                                            BorderBrush="{DynamicResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="4"
                                            Padding="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" ClipToBounds="True" VerticalAlignment="Center">
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding TitleText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" MaxHeight="32" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding DesignIdText}" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Production Order section -->
                <Grid Margin="0,0,0,14">
                    <!-- Case A: Production Order Exists -->
                    <Border Padding="14">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.HasData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="生产工单信息" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                                <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8" Padding="6,2" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.StatusText}" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                                </Border>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="工单单号：" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.ProductionOrderNoText}" Foreground="{DynamicResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="制作来源：" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.SourceText}" Foreground="{DynamicResource HeadingBrush}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="制作备注：" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.RemarkText}" Foreground="{DynamicResource HeadingBrush}" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Case B: Generate Production Order Button -->
                    <Border BorderThickness="0" Background="Transparent" Padding="0" Cursor="Hand" Height="64">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.HasData}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Command="{Binding GenerateStringNarrationProductionOrderCommand}" Background="Transparent" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="BgRect" Stroke="{DynamicResource HeadingBrush}" StrokeThickness="1.5" StrokeDashArray="4 2" RadiusX="12" RadiusY="12" Fill="#FAFBFD" SnapsToDevicePixels="True" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="生成制作单" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BgRect" Property="Fill" Value="{DynamicResource SurfaceSoftBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>
                </Grid>

                <!-- Shipping Info -->
                <Sections:FulfillmentDetailShippingCard />

                <!-- Bottom Action buttons -->
                <Sections:FulfillmentDetailActionBar />
            </StackPanel>
            </ScrollViewer>

                <!-- Detail loading overlay -->
                <Sections:FulfillmentDetailLoadingOverlay />
        </Grid>
    </Border>
</UserControl>
