<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabDataAudit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ===== 派生 Thickness 布局令牌（分量对齐 Shape.xaml 的 4pt 栅格 4/8/12/16/24/32，消除散落 Margin/Padding 字面量，Req 9.1/1.12） ===== -->
            <Thickness x:Key="SettingsCardSpacing">0,16,0,0</Thickness>            <!-- 上 UiSpaceMd(16)，卡片/面板顶部间距（含原 0,14 归一） -->
            <Thickness x:Key="SettingsInlineButtonMargin">0,0,8,0</Thickness>       <!-- 右 UiSpaceXs(8)，行内按钮间隔 -->
            <Thickness x:Key="SettingsRowGapXs">0,8,0,0</Thickness>                <!-- 上 UiSpaceXs(8)，报告区字段行间距（含原 0,6 归一） -->
            <Thickness x:Key="SettingsSectionSpacingSm">0,12,0,0</Thickness>        <!-- 上 UiSpaceSm(12)，区块分隔间距（含原 0,10 归一） -->
            <Thickness x:Key="SettingsPrimaryButtonPadding">16,0,16,0</Thickness>   <!-- 左右 UiSpaceMd(16)，主操作按钮内边距 -->
        </ResourceDictionary>
    </UserControl.Resources>
    <!--
        宿主归类（任务 17.3，设计 §7.1）：本子控件仅承载「数据校验与导入恢复」卡片，归「数据与备份」分类
        （由 SettingsTabData 嵌套宿主）。原「系统日志记录」卡片已按 §7.1 迁至「安全与日志」分类宿主
        （SettingsTabDataSecurity）。
    -->
    <StackPanel>
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                                <StackPanel>
                                    <TextBlock Text="数据校验与导入恢复" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="选择备份文件" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SelectedBackupPath, StringFormat='已选：\{0\}'}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="选择文件" Style="{StaticResource SettingsRowActionButtonStyle}" Margin="{StaticResource SettingsInlineButtonMargin}"
                                                        Command="{Binding SelectBackupFileCommand}"
                                                        AutomationProperties.AutomationId="Btn_SelectBackupFile" />
                                                <Button Content="验证备份" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                        Command="{Binding ValidateBackupCommand}"
                                                        AutomationProperties.AutomationId="Btn_ValidateBackup" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- 恢复检查报告：套用令牌化具名样式 SettingsPanelStyle（背景/边框/圆角/内边距均经令牌），消除硬编码视觉字面量，保证深浅色主题切换无异常（Req 9.1, 9.4） -->
                                    <Border Style="{StaticResource SettingsPanelStyle}" Margin="{StaticResource SettingsCardSpacing}">
                                        <StackPanel>
                                            <TextBlock Text="数据恢复校验报告" Style="{StaticResource SettingsFieldLabelStyle}" />
                                            <Grid Margin="{StaticResource SettingsRowGapXs}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Text="文件名" Style="{StaticResource SettingsFieldLabelStyle}" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RestorePreviewFileName}" TextWrapping="Wrap" />

                                                <TextBlock Grid.Row="1" Text="导出时间" Style="{StaticResource SettingsFieldLabelStyle}" Margin="{StaticResource SettingsRowGapXs}" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RestorePreviewExportedAtText}" Margin="{StaticResource SettingsRowGapXs}" />

                                                <TextBlock Grid.Row="2" Text="校验状态" Style="{StaticResource SettingsFieldLabelStyle}" Margin="{StaticResource SettingsRowGapXs}" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RestorePreviewChecksumStatusText}" Margin="{StaticResource SettingsRowGapXs}" />

                                                <TextBlock Grid.Row="3" Text="允许恢复" Style="{StaticResource SettingsFieldLabelStyle}" Margin="{StaticResource SettingsRowGapXs}" />
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RestorePreviewCanRestoreText}" Margin="{StaticResource SettingsRowGapXs}" FontWeight="SemiBold" />

                                                <TextBlock Grid.Row="4" Text="风险警示" Style="{StaticResource SettingsFieldLabelStyle}" Margin="{StaticResource SettingsRowGapXs}" />
                                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RestoreRiskPromptText}" Margin="{StaticResource SettingsRowGapXs}" Foreground="{DynamicResource WarmTextBrush}" TextWrapping="Wrap" />
                                            </Grid>

                                            <CheckBox x:Name="Chk_RestoreRiskConfirm" Margin="{StaticResource SettingsSectionSpacingSm}"
                                                      Content="{Binding RestoreRiskConfirmationText}"
                                                      IsChecked="{Binding IsRestoreRiskConfirmed}"
                                                      IsEnabled="{Binding CanConfirmRestoreRisk}"
                                                      AutomationProperties.AutomationId="Chk_RestoreRiskConfirm" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 执行导入 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0" Margin="{StaticResource SettingsSectionSpacingSm}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开始执行数据恢复" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding RestoreStatusText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="执行安全恢复" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="34" Padding="{StaticResource SettingsPrimaryButtonPadding}"
                                                    Command="{Binding RestoreBackupCommand}"
                                                    AutomationProperties.AutomationId="Btn_RestoreBackup" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

    </StackPanel>
</UserControl>
