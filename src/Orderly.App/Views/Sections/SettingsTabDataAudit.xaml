<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabDataAudit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ===== 派生 Thickness 布局令牌（分量对齐 Shape.xaml 的 4pt 栅格 4/8/12/16/24/32，消除散落 Margin/Padding 字面量，Req 9.1/1.12） ===== -->
            <Thickness x:Key="SettingsCardSpacing">0,16,0,0</Thickness>            <!-- 上 UiSpaceMd(16)，卡片/面板顶部间距（含原 0,14 归一） -->
            <Thickness x:Key="SettingsInlineButtonMargin">0,0,8,0</Thickness>       <!-- 右 UiSpaceXs(8)，行内按钮间隔 -->
            <Thickness x:Key="SettingsRowGapXs">0,8,0,0</Thickness>                <!-- 上 UiSpaceXs(8)，报告区字段行间距（含原 0,6 归一） -->
            <Thickness x:Key="SettingsSectionSpacingSm">0,12,0,0</Thickness>        <!-- 上 UiSpaceSm(12)，区块分隔间距（含原 0,10 归一） -->
            <Thickness x:Key="SettingsPrimaryButtonPadding">16,0,16,0</Thickness>   <!-- 左右 UiSpaceMd(16)，主操作按钮内边距 -->
            <Thickness x:Key="SettingsHeaderGridMargin">0,8,0,4</Thickness>
            <Thickness x:Key="SettingsHeaderTitleMargin">0,0,0,2</Thickness>
            <Thickness x:Key="SettingsStatusBadgePadding">12,6</Thickness>
            <Thickness x:Key="SettingsStepBadgeMargin">0,2,10,0</Thickness>
            <Thickness x:Key="SettingsPreviewCellMarginWithRightGap">0,0,16,8</Thickness>
            <Thickness x:Key="SettingsPreviewCellMarginBottom">0,0,0,8</Thickness>
            <Thickness x:Key="SettingsPreviewCellMarginRight">0,0,16,0</Thickness>
            <CornerRadius x:Key="SettingsStatusBadgeRadius">14</CornerRadius>
            <CornerRadius x:Key="SettingsStepBadgeRadius">12</CornerRadius>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <!--
        宿主归类（任务 17.3，设计 §7.1）：本子控件仅承载「数据校验与导入恢复」卡片，归「数据与备份」分类
        （由 SettingsTabData 嵌套宿主）。原「系统日志记录」卡片已按 §7.1 迁至「安全与日志」分类宿主
        （SettingsTabDataSecurity）。
    -->
    <StackPanel>
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                                <StackPanel>
                                    <Grid Margin="{StaticResource SettingsHeaderGridMargin}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="数据校验与导入恢复" Style="{StaticResource SettingsGroupTitleStyle}" Margin="{StaticResource SettingsHeaderTitleMargin}" />
                                            <TextBlock Text="{Binding RestoreWorkflowStatusDetailText}" Style="{StaticResource SettingsItemDescStyle}" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="{StaticResource SettingsStatusBadgeRadius}" Padding="{StaticResource SettingsStatusBadgePadding}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding RestoreWorkflowStatusText}" Style="{StaticResource SettingsItemTitleStyle}" FontSize="{DynamicResource UiFontSize12_5}" />
                                        </Border>
                                    </Grid>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="{StaticResource SettingsStepBadgeRadius}" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" VerticalAlignment="Top" Margin="{StaticResource SettingsStepBadgeMargin}">
                                                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource UiFontSize12}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="选择备份文件" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding RestoreSelectedBackupFileNameText}" Style="{StaticResource SettingsItemDescStyle}" />
                                                <TextBlock Text="{Binding RestoreSelectedBackupPathText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="选择文件" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding SelectBackupFileCommand}"
                                                    AutomationProperties.AutomationId="Btn_SelectBackupFile" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="{StaticResource SettingsStepBadgeRadius}" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" VerticalAlignment="Top" Margin="{StaticResource SettingsStepBadgeMargin}">
                                                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource UiFontSize12}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="检查备份内容" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding RestoreCheckSummaryText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                                <UniformGrid Columns="2" Margin="{StaticResource SettingsSectionSpacingSm}">
                                                    <StackPanel Margin="{StaticResource SettingsPreviewCellMarginWithRightGap}">
                                                        <TextBlock Text="备份时间" Style="{StaticResource SettingsFieldLabelStyle}" />
                                                        <TextBlock Text="{Binding RestorePreviewExportedAtText}" Style="{StaticResource SettingsItemDescStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="{StaticResource SettingsPreviewCellMarginBottom}">
                                                        <TextBlock Text="当前数据库" Style="{StaticResource SettingsFieldLabelStyle}" />
                                                        <TextBlock Text="{Binding RestorePreviewTargetStateText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <StackPanel Margin="{StaticResource SettingsPreviewCellMarginRight}">
                                                        <TextBlock Text="包含数据" Style="{StaticResource SettingsFieldLabelStyle}" />
                                                        <TextBlock Text="{Binding RestorePreviewCountsText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="恢复结论" Style="{StaticResource SettingsFieldLabelStyle}" />
                                                        <TextBlock Text="{Binding RestorePreviewCanRestoreText}" Style="{StaticResource SettingsItemDescStyle}" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="{Binding RestoreValidateActionText}" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding ValidateBackupCommand}"
                                                    AutomationProperties.AutomationId="Btn_ValidateBackup" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="{StaticResource SettingsStepBadgeRadius}" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" VerticalAlignment="Top" Margin="{StaticResource SettingsStepBadgeMargin}">
                                                <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource UiFontSize12}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="确认并恢复" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding RestoreRiskPromptText}" Style="{StaticResource SettingsItemDescStyle}" Foreground="{DynamicResource WarmTextBrush}" TextWrapping="Wrap" />
                                                <CheckBox x:Name="Chk_RestoreRiskConfirm"
                                                          Margin="{StaticResource SettingsSectionSpacingSm}"
                                                          Content="{Binding RestoreRiskConfirmationText}"
                                                          IsChecked="{Binding IsRestoreRiskConfirmed}"
                                                          IsEnabled="{Binding CanConfirmRestoreRisk}"
                                                          Visibility="{Binding CanConfirmRestoreRisk, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                          AutomationProperties.AutomationId="Chk_RestoreRiskConfirm" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="{Binding RestorePrimaryActionText}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="34" Padding="{StaticResource SettingsPrimaryButtonPadding}"
                                                    Command="{Binding RestoreBackupCommand}"
                                                    AutomationProperties.AutomationId="Btn_RestoreBackup" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                                <StackPanel>
                                    <Grid Margin="{StaticResource SettingsHeaderGridMargin}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="本地旧数据导入云端" Style="{StaticResource SettingsGroupTitleStyle}" Margin="{StaticResource SettingsHeaderTitleMargin}" />
                                            <TextBlock Text="{Binding CloudImportDetailText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="{StaticResource SettingsStatusBadgeRadius}" Padding="{StaticResource SettingsStatusBadgePadding}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CloudImportWorkflowStatusText}" Style="{StaticResource SettingsItemTitleStyle}" FontSize="{DynamicResource UiFontSize12_5}" />
                                        </Border>
                                    </Grid>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="{StaticResource SettingsStepBadgeRadius}" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" VerticalAlignment="Top" Margin="{StaticResource SettingsStepBadgeMargin}">
                                                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource UiFontSize12}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="预检查" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding CloudImportSummaryText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                                <UniformGrid Columns="2" Margin="{StaticResource SettingsSectionSpacingSm}">
                                                    <StackPanel Margin="{StaticResource SettingsPreviewCellMarginWithRightGap}">
                                                        <TextBlock Text="数据量" Style="{StaticResource SettingsFieldLabelStyle}" />
                                                        <TextBlock Text="{Binding CloudImportCountsText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <StackPanel Margin="{StaticResource SettingsPreviewCellMarginBottom}">
                                                        <TextBlock Text="问题" Style="{StaticResource SettingsFieldLabelStyle}" />
                                                        <TextBlock Text="{Binding CloudImportIssuesText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="预检查" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding PreviewCloudImportCommand}"
                                                    AutomationProperties.AutomationId="Btn_PreviewCloudImport" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="{StaticResource SettingsStepBadgeRadius}" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" VerticalAlignment="Top" Margin="{StaticResource SettingsStepBadgeMargin}">
                                                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{DynamicResource UiFontSize12}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="确认导入" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding CloudImportStatusText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                                <CheckBox Margin="{StaticResource SettingsSectionSpacingSm}"
                                                          Content="{Binding CloudImportConfirmationText}"
                                                          IsChecked="{Binding IsCloudImportCommitConfirmed}"
                                                          IsEnabled="{Binding CloudImportDryRun.CanCommit}"
                                                          AutomationProperties.AutomationId="Chk_CloudImportConfirm" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="{Binding CloudImportPrimaryActionText}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="34" Padding="{StaticResource SettingsPrimaryButtonPadding}"
                                                    Command="{Binding CommitCloudImportCommand}"
                                                    AutomationProperties.AutomationId="Btn_CommitCloudImport" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

    </StackPanel>
</UserControl>
