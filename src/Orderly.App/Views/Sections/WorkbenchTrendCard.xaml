<UserControl x:Class="Orderly.App.Views.Sections.WorkbenchTrendCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="20,18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="近 7 日经营趋势" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource BlueTextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="成交额 (元)" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="6,0,16,0" VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource PurpleTextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="订单数 (单)" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Background="#F1F2F5" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="近 7 日" FontSize="12" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 柱状图和折线混合趋势图 -->
            <Grid Grid.Row="1" Margin="0,20,0,0" MinHeight="220">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="20" />
                </Grid.RowDefinitions>
                
                <!-- Y轴底线 -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                    <Border Grid.Row="1" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                    <Border Grid.Row="2" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                    <Border Grid.Row="3" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                    <Border Grid.Row="4" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                </Grid>

                <!-- 柱状图 (成交额) 展现 -->
                <ItemsControl Grid.Row="0" ItemsSource="{Binding StringNarrationWorkbenchTrendItems}" VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Stretch" Margin="10,0">
                                <ProgressBar Value="{Binding RevenueAmount}" Minimum="0" Maximum="18000" Orientation="Vertical" VerticalAlignment="Stretch" Margin="0,25,0,15" Width="24" Background="Transparent" BorderThickness="0">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid SnapsToDevicePixels="true">
                                                <Border CornerRadius="4" Background="Transparent"/>
                                                <Border x:Name="PART_Indicator" CornerRadius="4,4,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#A2C9F8" Offset="0"/>
                                                            <GradientStop Color="#E3EFFE" Offset="0.7"/>
                                                            <GradientStop Color="#FFFFFF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 自适应手绘折线效果 (订单数) -->
                <Canvas x:Name="TrendCanvas" Grid.Row="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="30,0" SizeChanged="TrendCanvas_SizeChanged">
                    <Path x:Name="TrendPath" Stroke="#7A3EDB" StrokeThickness="3.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" />
                    <Ellipse x:Name="TrendPoint0" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                    <Ellipse x:Name="TrendPoint1" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                    <Ellipse x:Name="TrendPoint2" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                    <Ellipse x:Name="TrendPoint3" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                    <Ellipse x:Name="TrendPoint4" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                    <Ellipse x:Name="TrendPoint5" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                    <Ellipse x:Name="TrendPoint6" Width="8" Height="8" Fill="#7A3EDB" Stroke="#FFFFFF" StrokeThickness="2" Visibility="Collapsed" />

                    <!-- 悬浮 Tooltip 卡片 -->
                    <Border x:Name="TrendTooltip" Background="#FFFFFF" CornerRadius="8" Padding="10,8" BorderBrush="#DFE3EA" BorderThickness="1" Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock x:Name="Text_TooltipDate" Text="05-16" FontSize="10" Foreground="{DynamicResource CaptionTextBrush}" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource BlueTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="成交额" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock x:Name="Text_TooltipRevenue" Text=" ¥12,680.00" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource PurpleTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="订单数" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock x:Name="Text_TooltipOrders" Text=" 110" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Canvas>

                <!-- X轴标签 -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding StringNarrationWorkbenchTrendItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{DynamicResource CaptionTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>
