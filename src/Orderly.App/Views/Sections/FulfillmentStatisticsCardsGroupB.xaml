<UserControl x:Class="Orderly.App.Views.Sections.FulfillmentStatisticsCardsGroupB"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="FulfillmentStatsCardButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14,12" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="0" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.0" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CardChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardChrome" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                                    <Setter TargetName="CardChrome" Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(TranslateTransform.Y)"
                                                                 To="-4" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(Button.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.08" Duration="0:0:0.15" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(TranslateTransform.Y)"
                                                                 To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(Button.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.0" Duration="0:0:0.15" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CardChrome" Property="Opacity" Value="0.9" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Card 4: 待发货 -->
        <Button Grid.Column="0"
                Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                CommandParameter="ready_to_ship">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource BlueSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource BlueTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="待发货" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <DockPanel Margin="0,2,0,0">
                        <TextBlock Text="{Binding Stats.ReadyToShipCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Bottom" />
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Button>

        <!-- Card 5: 已发货 -->
        <Button Grid.Column="2"
                Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                CommandParameter="shipped">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryLightBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="&#xE170;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="已发货" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <DockPanel Margin="0,2,0,0">
                        <TextBlock Text="{Binding Stats.ShippedCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Bottom" />
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Button>

        <!-- Card 6: 异常 -->
        <Button Grid.Column="4"
                Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                CommandParameter="exception">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource DangerSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="&#xE7A3;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource DangerTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="异常" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <DockPanel Margin="0,2,0,0">
                        <TextBlock Text="{Binding Stats.ExceptionCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Bottom" />
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Button>

        <!-- Card 7: 已完成 -->
        <Button Grid.Column="6"
                Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                CommandParameter="completed">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="已完成" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <DockPanel Margin="0,2,0,0">
                        <TextBlock Text="{Binding Stats.CompletedCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Bottom" />
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Button>
    </Grid>
</UserControl>
