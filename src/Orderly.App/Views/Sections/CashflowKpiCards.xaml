<UserControl x:Class="Orderly.App.Views.Sections.CashflowKpiCards"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainSharedResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainComponentStyles.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainComponentStyles.C.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,24">
        <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,16,0" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="现金流健康指数" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource CaptionTextBrush}" Margin="4,2,0,0" ToolTip="根据现金余额、应收应付、支出强度等综合算出的健康度" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding CashflowHealthDashboardResult.Summary.CashFlowHealthScore, FallbackValue=85}" FontSize="32" FontWeight="Bold" Foreground="#1F8B4C" VerticalAlignment="Bottom" LineHeight="32" />
                    <Border Background="#E6F9ED" CornerRadius="12" Padding="8,2" Margin="10,0,0,4" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding CashflowHealthLevelText, FallbackValue=健康}" Foreground="#1F8B4C" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="{Binding CashflowHealthSummaryText, FallbackValue=现金状况良好，可正常补货}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,8,0,0" />

                <Grid Grid.Row="3" Margin="0,14,0,0">
                    <ProgressBar Value="{Binding CashflowHealthDashboardResult.Summary.CashFlowHealthScore, FallbackValue=85}" Minimum="0" Maximum="100" Height="6" Background="#F2F4F7" BorderThickness="0">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                                    <Border x:Name="PART_Indicator" CornerRadius="3" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#34C759" Offset="0" />
                                                <GradientStop Color="#4CD964" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </Grid>
            </Grid>
        </Border>

        <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,16,0" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="当前可用现金" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource CaptionTextBrush}" Margin="4,2,0,0" ToolTip="可用余额 = 账上现金 - 待支付 + 待收款" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding CashflowAvailableCashText, FallbackValue='¥ 2,860.00'}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Bottom" LineHeight="32" />
                    <Button Content="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}" Background="Transparent" BorderThickness="0" Margin="8,0,0,4" VerticalAlignment="Bottom" Cursor="Hand" ToolTip="隐藏金额" />
                </StackPanel>

                <TextBlock Grid.Row="2" Text="可用余额 = 现金 - 待支付 + 待收款" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,8,0,0" />
            </Grid>
        </Border>

        <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="预计可支撑天数" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource CaptionTextBrush}" Margin="4,2,0,0" ToolTip="按最近 7 日平均支出估算账上现金可持续的天数" />
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding CashflowSupportDaysText, FallbackValue='32 天'}" FontSize="32" FontWeight="Bold" Foreground="#1F8B4C" Margin="0,12,0,0" LineHeight="32" />

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="按最近 7 日平均支出估算 (" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Text="{Binding CashflowAvgDailyExpense7dText, FallbackValue=¥120/天}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    <TextBlock Text=")" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </UniformGrid>
</UserControl>
