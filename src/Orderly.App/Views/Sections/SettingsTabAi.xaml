<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabAi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <!--
        AI 子 Tab（commerce-settings-ui-rebuild / 任务 14.3）
        ============================================================================
        统一「标签-控件-说明」三段式行：左侧标签 + 说明，右侧控件。
        禁用态由令牌化控件样式（UiCheckBoxStyle / UiTextBoxStyle / UiComboBoxStyle /
        UiSecondaryButtonStyle）的既有禁用视觉承载；超时/模型等输入框校验失败时，以错误
        状态色（DangerTextBrush）经 Validation.ErrorTemplate 在行级呈现既有校验结果，
        不新增校验逻辑。全部引用全局令牌，零硬编码视觉字面量；仅消费 MainViewModel 既有
        绑定（*Input 属性、选项集合）与既有 LostFocus 自动保存钩子，不新增、不重命名路径。
        Ui* 令牌由 App.xaml 提供；设置卡片样式显式合并 MainWindowResources，与数据备份页保持一致。
    -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <!-- ===== 派生 Thickness 布局令牌（对齐 Shape.xaml 的 UiSpace 4pt 栅格 4/8/12/16/24/32） ===== -->
        <Thickness x:Key="SettingsScrollPadding">0,24,0,24</Thickness>
        <Thickness x:Key="SettingsContentMargin">0,0,24,0</Thickness>
        <Thickness x:Key="SettingsCardSpacing">0,16,0,0</Thickness>
        <Thickness x:Key="SettingsRowPadding">0,12,0,12</Thickness>
        <Thickness x:Key="SettingsRowDescMargin">0,4,0,0</Thickness>
        <Thickness x:Key="SettingsControlLeftMargin">16,0,0,0</Thickness>
        <Thickness x:Key="SettingsSubRowLeftMargin">24,0,0,0</Thickness>
        <Thickness x:Key="SettingsModelIconMargin">0,0,8,0</Thickness>
        <Thickness x:Key="SettingsSeparatorThickness">0,0,0,1</Thickness>
        <Thickness x:Key="SettingsZeroThickness">0</Thickness>

        <!-- ===== 控件尺寸令牌 ===== -->
        <sys:Double x:Key="SettingsControlMinWidthNarrow">80</sys:Double>
        <sys:Double x:Key="SettingsControlMinWidthWide">160</sys:Double>

        <!-- ===== 行容器 ===== -->
        <Style x:Key="SettingsRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="{StaticResource SettingsSeparatorThickness}" />
            <Setter Property="Padding" Value="{StaticResource SettingsRowPadding}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="SettingsRowLastStyle" TargetType="Border" BasedOn="{StaticResource SettingsRowStyle}">
            <Setter Property="BorderThickness" Value="{StaticResource SettingsZeroThickness}" />
        </Style>

        <!-- ===== 标签 / 说明 ===== -->
        <Style x:Key="SettingsRowLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource UiFontBody}" />
            <Setter Property="FontWeight" Value="{StaticResource UiFontWeightMedium}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SettingsRowDescStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource UiFontCaption}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="{StaticResource SettingsRowDescMargin}" />
        </Style>

        <!-- ===== 行级校验错误模板（消费 WPF 既有校验结果，以错误状态色呈现，不新增校验逻辑） ===== -->
        <ControlTemplate x:Key="SettingsFieldErrorTemplate">
            <StackPanel>
                <Border BorderBrush="{DynamicResource DangerTextBrush}"
                        BorderThickness="{StaticResource UiFocusThickness}"
                        CornerRadius="{StaticResource UiRadiusMd}"
                        SnapsToDevicePixels="True">
                    <AdornedElementPlaceholder x:Name="ErrorAdorner" />
                </Border>
                <ContentControl Style="{StaticResource UiFieldErrorStyle}"
                                HorizontalAlignment="Right"
                                Content="{Binding ElementName=ErrorAdorner, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}" />
            </StackPanel>
        </ControlTemplate>

        <!-- ===== 行内输入框（套用统一 TextBox 令牌样式 + 行级错误模板） ===== -->
        <Style x:Key="SettingsRowTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource UiTextBoxStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingsControlLeftMargin}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource SettingsFieldErrorTemplate}" />
        </Style>

        <!-- ===== 行内选项下拉（套用统一 ComboBox 令牌样式） ===== -->
        <Style x:Key="SettingsRowComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource UiComboBoxStyle}">
            <Setter Property="Margin" Value="{StaticResource SettingsControlLeftMargin}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="{StaticResource SettingsControlMinWidthWide}" />
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer Style="{DynamicResource SettingsScrollViewerStyle}" Padding="{StaticResource SettingsScrollPadding}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Margin="{StaticResource SettingsContentMargin}" HorizontalAlignment="Stretch">

                <!-- AI 助手核心配置卡片 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}">
                    <StackPanel>
                        <TextBlock Text="AI 智能话术助手" Style="{StaticResource SettingsGroupTitleStyle}" />

                        <!-- 启用 AI 助手 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="开启 AI 话术推荐" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="根据当前客户与订单上下文提供智能快捷回复话术建议" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding EnableAiAssistantInput}"
                                          AutomationProperties.AutomationId="Chk_EnableAiAssistant" />
                            </Grid>
                        </Border>

                        <!-- 允许读取当前订单上下文 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="允许读取订单上下文" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="允许 AI 助手获取当前编辑中或高亮选中的订单数据" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding AllowAiOrderContextInput}"
                                          AutomationProperties.AutomationId="Chk_AllowAiOrderContext" />
                            </Grid>
                        </Border>

                        <!-- 允许分析客户历史行为画像 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="分析客户历史行为画像" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="授权 AI 助手分析该客户的历史备忘以补充个性化话术，不影响最近对话上下文" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding AllowAiCustomerProfileContextInput}"
                                          AutomationProperties.AutomationId="Chk_AllowAiCustomerProfileContext" />
                            </Grid>
                        </Border>

                        <!-- AI 默认模型 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="AI 默认大语言模型" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="优先请求并用于话术推荐的大模型名称" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" Style="{StaticResource SettingsRowComboBoxStyle}"
                                          SelectedValue="{Binding SelectedAiModelOption, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          LostFocus="SettingsTextInput_LostFocus"
                                          AutomationProperties.AutomationId="Cbo_DefaultAiModel">
                                    <ComboBoxItem Tag="deepseek-chat">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource PurpleTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SettingsModelIconMargin}" />
                                            <TextBlock Text="deepseek-chat" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ComboBoxItem>
                                    <ComboBoxItem Tag="deepseek-reasoner">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource PurpleTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SettingsModelIconMargin}" />
                                            <TextBlock Text="deepseek-reasoner" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ComboBoxItem>
                                    <ComboBoxItem Tag="gpt-4o">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SettingsModelIconMargin}" />
                                            <TextBlock Text="gpt-4o" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ComboBoxItem>
                                    <ComboBoxItem Tag="gpt-4o-mini">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SettingsModelIconMargin}" />
                                            <TextBlock Text="gpt-4o-mini" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ComboBoxItem>
                                    <ComboBoxItem Tag="claude-3-5-sonnet">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource WarmTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SettingsModelIconMargin}" />
                                            <TextBlock Text="claude-3-5-sonnet" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ComboBoxItem>
                                    <ComboBoxItem Tag="gemini-1.5-pro">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource BlueTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SettingsModelIconMargin}" />
                                            <TextBlock Text="gemini-1.5-pro" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ComboBoxItem>
                                    <ComboBoxItem Tag="gemini-1.5-flash">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource BlueTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SettingsModelIconMargin}" />
                                            <TextBlock Text="gemini-1.5-flash" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ComboBoxItem>
                                    <ComboBoxItem Tag="自定义...">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource GreyTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SettingsModelIconMargin}" />
                                            <TextBlock Text="自定义..." VerticalAlignment="Center" FontWeight="Bold" />
                                        </StackPanel>
                                    </ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- 自定义大模型名称（缩进联动配置行） -->
                        <Border Style="{StaticResource SettingsRowStyle}"
                                Visibility="{Binding IsCustomAiModelActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="{StaticResource SettingsSubRowLeftMargin}">
                                    <TextBlock Text="自定义模型标识符" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="输入您的私有模型或第三方未列出的模型名称" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}"
                                         MinWidth="{StaticResource SettingsControlMinWidthWide}"
                                         Text="{Binding DefaultAiModelInput, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="SettingsTextInput_LostFocus"
                                         AutomationProperties.AutomationId="Txt_DefaultAiModel" />
                            </Grid>
                        </Border>

                        <!-- AI 请求超时时间 -->
                        <Border Style="{StaticResource SettingsRowLastStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="AI 请求超时时间 (秒)" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="大模型推理超时机制，超时或远程不可用时将回退到本地建议兜底" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}"
                                         MinWidth="{StaticResource SettingsControlMinWidthNarrow}"
                                         Text="{Binding AiTimeoutSecondsInput, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="SettingsTextInput_LostFocus"
                                         AutomationProperties.AutomationId="Txt_AiTimeoutSeconds" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- AI 隐私与安全配置卡片 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                    <StackPanel>
                        <TextBlock Text="AI 隐私安全与脱敏" Style="{StaticResource SettingsGroupTitleStyle}" />

                        <!-- 上下文发送前自动脱敏 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="自动上下文数据脱敏" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="在大数据传输至外部大模型 API 前进行本地脱敏规避风险" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding AiAutoRedactBeforeSendInput}"
                                          AutomationProperties.AutomationId="Chk_AiAutoRedactBeforeSend" />
                            </Grid>
                        </Border>

                        <!-- 屏蔽电话号码 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="自动遮蔽联系电话" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="向 AI 上下文推送数据时自动隐去电话号码" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding AiBlockPhoneInput}"
                                          AutomationProperties.AutomationId="Chk_AiBlockPhone" />
                            </Grid>
                        </Border>

                        <!-- 屏蔽完整收货地址 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="自动遮蔽收货地址" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="向 AI 上下文推送数据时自动隐藏具体物理门牌号" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding AiBlockFullAddressInput}"
                                          AutomationProperties.AutomationId="Chk_AiBlockFullAddress" />
                            </Grid>
                        </Border>

                        <!-- 自动屏蔽交易单号 -->
                        <Border Style="{StaticResource SettingsRowLastStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="自动遮蔽支付交易单号" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="在 AI 通信报文中自动遮蔽第三方平台的流水与交易ID" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding AiBlockPaymentTransactionIdInput}"
                                          AutomationProperties.AutomationId="Chk_AiBlockPaymentTransactionId" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- AI 回复偏好卡片 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                    <StackPanel>
                        <TextBlock Text="AI 回复偏好配置" Style="{StaticResource SettingsGroupTitleStyle}" />

                        <!-- 语气设定 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="AI 回复语气控制" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="设定 AI 推荐话术的感情色彩倾向" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" Style="{StaticResource SettingsRowComboBoxStyle}"
                                          ItemsSource="{Binding AiReplyToneOptions}"
                                          SelectedItem="{Binding AiReplyToneInput}"
                                          AutomationProperties.AutomationId="List_AiReplyTone" />
                            </Grid>
                        </Border>

                        <!-- 长度控制 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="AI 回复字数长度" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="精简回复或提供详实的客服分析模板" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" Style="{StaticResource SettingsRowComboBoxStyle}"
                                          ItemsSource="{Binding AiReplyLengthOptions}"
                                          SelectedItem="{Binding AiReplyLengthInput}"
                                          AutomationProperties.AutomationId="List_AiReplyLength" />
                            </Grid>
                        </Border>

                        <!-- 自动生成订单摘要 -->
                        <Border Style="{StaticResource SettingsRowLastStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="自动填充生成订单摘要" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="允许 AI 助手对长对话生成一键订单概要填充" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding AiAutoGenerateOrderSummaryInput}"
                                          AutomationProperties.AutomationId="Chk_AiAutoGenerateOrderSummary" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- AI 环境诊断（嵌入子控件，承载 AI Provider 自检卡片） -->
                <Sections:SettingsTabAiDiagnostics />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
