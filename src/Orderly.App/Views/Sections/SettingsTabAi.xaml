<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabAi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Stretch">
                            <!-- AI 助手核心配置卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="AI 智能话术助手" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 启用 AI 助手 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开启 AI 话术推荐" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="根据当前客户与订单上下文提供智能快捷回复话术建议" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding EnableAiAssistantInput}"
                                                      AutomationProperties.AutomationId="Chk_EnableAiAssistant" />
                                        </Grid>
                                    </Border>

                                    <!-- 允许读取当前订单上下文 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="允许读取订单上下文" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="允许 AI 助手获取当前编辑中或高亮选中的订单数据" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AllowAiOrderContextInput}"
                                                      AutomationProperties.AutomationId="Chk_AllowAiOrderContext" />
                                        </Grid>
                                    </Border>

                                    <!-- 允许分析客户历史行为画像 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="分析客户历史行为画像" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="授权 AI 助手分析该客户的历史备忘以提供个性化话术" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AllowAiCustomerProfileContextInput}"
                                                      AutomationProperties.AutomationId="Chk_AllowAiCustomerProfileContext" />
                                        </Grid>
                                    </Border>

                                    <!-- AI 默认模型 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 默认大语言模型" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="优先请求并用于话术推荐的大模型名称" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="150"
                                                     Text="{Binding DefaultAiModelInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_DefaultAiModel" />
                                        </Grid>
                                    </Border>

                                    <!-- AI 请求超时时间 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 请求超时时间 (秒)" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="大模型推理超时机制，超时后将自动切换为本地话术" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="80"
                                                     Text="{Binding AiTimeoutSecondsInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_AiTimeoutSeconds" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI 隐私与安全配置卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="AI 隐私安全与脱敏" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 上下文发送前自动脱敏 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动上下文数据脱敏" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在大数据传输至外部大模型 API 前进行本地脱敏规避风险" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiAutoRedactBeforeSendInput}"
                                                      AutomationProperties.AutomationId="Chk_AiAutoRedactBeforeSend" />
                                        </Grid>
                                    </Border>

                                    <!-- 屏蔽电话号码 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动遮蔽联系电话" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="向 AI 上下文推送数据时自动隐去电话号码" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockPhoneInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockPhone" />
                                        </Grid>
                                    </Border>

                                    <!-- 屏蔽完整收货地址 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动遮蔽收货地址" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="向 AI 上下文推送数据时自动隐藏具体物理门牌号" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockFullAddressInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockFullAddress" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动屏蔽交易单号 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动遮蔽支付交易单号" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在 AI 通信报文中自动遮蔽第三方平台的流水与交易ID" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockPaymentTransactionIdInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockPaymentTransactionId" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI 回复偏好卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="AI 回复偏好配置" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 语气设定 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 回复语气控制" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="设定 AI 推荐话术的感情色彩倾向" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding AiReplyToneOptions}"
                                                     SelectedItem="{Binding AiReplyToneInput}"
                                                     AutomationProperties.AutomationId="List_AiReplyTone" />
                                        </Grid>
                                    </Border>

                                    <!-- 长度控制 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 回复字数长度" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="精简回复或提供详实的客服分析模板" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding AiReplyLengthOptions}"
                                                     SelectedItem="{Binding AiReplyLengthInput}"
                                                     AutomationProperties.AutomationId="List_AiReplyLength" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动生成订单摘要 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动填充生成订单摘要" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="允许 AI 助手对长对话生成一键订单概要填充" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiAutoGenerateOrderSummaryInput}"
                                                      AutomationProperties.AutomationId="Chk_AiAutoGenerateOrderSummary" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                    <Sections:SettingsTabAiDiagnostics />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
</UserControl>
