<UserControl x:Class="Orderly.App.Views.Sections.WorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="Page_Workbench">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="WorkbenchMetricCard" TargetType="Border">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#E5E7EC" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="Width" Value="170" />
                <Setter Property="Margin" Value="0,0,12,12" />
            </Style>
            <Style x:Key="WorkbenchMetricCaption" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="#868E96" />
            </Style>
            <Style x:Key="WorkbenchMetricValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="#1D1D1F" />
                <Setter Property="Margin" Value="0,6,0,0" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="Transparent" DataContext="{Binding WorkbenchPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="工作台" FontSize="29" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" />
                <TextBlock Text="经营概览与近 7 天趋势" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshCommand}" VerticalAlignment="Center"
                    Foreground="{DynamicResource BlueTextBrush}" Padding="14,6" />
        </Grid>

        <!-- 加载中 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding ShowLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="正在加载经营概览…" Foreground="{DynamicResource MutedBrush}" FontSize="15" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 加载失败 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="#D12E9F" HorizontalAlignment="Center" />
            <TextBlock Text="经营概览加载失败" Foreground="{DynamicResource HeadingBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,0" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,6,0,0" MaxWidth="420" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" />
            <Button Content="重试" Command="{Binding RefreshCommand}" Margin="0,14,0,0" Padding="18,7" HorizontalAlignment="Center"
                    Foreground="{DynamicResource BlueTextBrush}" />
        </StackPanel>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="暂无经营数据" Foreground="{DynamicResource MutedBrush}" FontSize="15" Margin="0,14,0,0" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 数据 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowContent, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <WrapPanel>
                    <Border Style="{StaticResource WorkbenchMetricCard}">
                        <StackPanel>
                            <TextBlock Text="订单总数" Style="{StaticResource WorkbenchMetricCaption}" />
                            <TextBlock Text="{Binding TotalOrders}" Style="{StaticResource WorkbenchMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkbenchMetricCard}">
                        <StackPanel>
                            <TextBlock Text="已完成订单" Style="{StaticResource WorkbenchMetricCaption}" />
                            <TextBlock Text="{Binding CompletedOrders}" Style="{StaticResource WorkbenchMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkbenchMetricCard}">
                        <StackPanel>
                            <TextBlock Text="营业额" Style="{StaticResource WorkbenchMetricCaption}" />
                            <TextBlock Text="{Binding TotalRevenue, StringFormat=¥{0}}" Style="{StaticResource WorkbenchMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkbenchMetricCard}">
                        <StackPanel>
                            <TextBlock Text="毛利" Style="{StaticResource WorkbenchMetricCaption}" />
                            <TextBlock Text="{Binding GrossProfit, StringFormat=¥{0}}" Style="{StaticResource WorkbenchMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkbenchMetricCard}">
                        <StackPanel>
                            <TextBlock Text="应收账款" Style="{StaticResource WorkbenchMetricCaption}" />
                            <TextBlock Text="{Binding OutstandingReceivable, StringFormat=¥{0}}" Style="{StaticResource WorkbenchMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkbenchMetricCard}">
                        <StackPanel>
                            <TextBlock Text="净现金流" Style="{StaticResource WorkbenchMetricCaption}" />
                            <TextBlock Text="{Binding NetCashFlow, StringFormat=¥{0}}" Style="{StaticResource WorkbenchMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkbenchMetricCard}">
                        <StackPanel>
                            <TextBlock Text="客户数" Style="{StaticResource WorkbenchMetricCaption}" />
                            <TextBlock Text="{Binding CustomerCount}" Style="{StaticResource WorkbenchMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkbenchMetricCard}">
                        <StackPanel>
                            <TextBlock Text="低库存项" Style="{StaticResource WorkbenchMetricCaption}" />
                            <TextBlock Text="{Binding LowStockItemCount}" Style="{StaticResource WorkbenchMetricValue}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <TextBlock Text="近 7 天趋势" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" Margin="6,18,0,10" />
                <DataGrid ItemsSource="{Binding Trend}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="*" />
                        <DataGridTextColumn Header="完成订单" Binding="{Binding CompletedOrderCount}" Width="Auto" />
                        <DataGridTextColumn Header="营业额" Binding="{Binding Revenue, StringFormat=¥{0}}" Width="Auto" />
                        <DataGridTextColumn Header="现金流入" Binding="{Binding CashInflow, StringFormat=¥{0}}" Width="Auto" />
                        <DataGridTextColumn Header="现金流出" Binding="{Binding CashOutflow, StringFormat=¥{0}}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
