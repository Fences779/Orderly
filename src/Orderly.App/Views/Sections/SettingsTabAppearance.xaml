<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabAppearance"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:helpers="clr-namespace:Orderly.App.Helpers">
    <!--
        外观子 Tab（commerce-settings-ui-rebuild / 任务 14.1）
        ============================================================================
        统一「标签-控件-说明」三段式行：左侧标签 + 说明，右侧控件。
        全部引用全局令牌（颜色 DynamicResource、字号/字重/字体族/圆角 StaticResource，
        间距以派生 Thickness 具名令牌承载），零硬编码视觉字面量。
        仅消费 MainViewModel 既有绑定（选项集合 / *Input / 命令），不新增、不重命名路径。
        Ui* 令牌与控件样式经 App.xaml 全局合并提供，无需在此再次合并字典。
    -->
    <UserControl.Resources>
        <!-- ===== 派生 Thickness 布局令牌（对齐 Shape.xaml 的 UiSpace 4pt 栅格 4/8/12/16/24/32） ===== -->
        <Thickness x:Key="SettingsScrollPadding">0,24,0,24</Thickness>            <!-- 上下 UiSpaceLg(24) -->
        <Thickness x:Key="SettingsContentMargin">0,0,24,0</Thickness>            <!-- 右 UiSpaceLg(24) -->
        <Thickness x:Key="SettingsCardPadding">24</Thickness>                    <!-- 四周 UiSpaceLg(24) -->
        <Thickness x:Key="SettingsCardSpacing">0,16,0,0</Thickness>              <!-- 上 UiSpaceMd(16)，卡片间距 -->
        <Thickness x:Key="SettingsGroupTitleMargin">0,0,0,16</Thickness>         <!-- 下 UiSpaceMd(16) -->
        <Thickness x:Key="SettingsRowPadding">0,12,0,12</Thickness>              <!-- 上下 UiSpaceSm(12) -->
        <Thickness x:Key="SettingsRowDescMargin">0,4,0,0</Thickness>             <!-- 上 UiSpaceXxs(4) -->
        <Thickness x:Key="SettingsControlLeftMargin">16,0,0,0</Thickness>        <!-- 左 UiSpaceMd(16)，控件与标签间隔 -->
        <Thickness x:Key="SettingsInlineButtonMargin">8,0,0,0</Thickness>        <!-- 左 UiSpaceXs(8)，行内按钮间隔 -->
        <Thickness x:Key="SettingsSeparatorThickness">0,0,0,1</Thickness>        <!-- 下边 1px 分隔线（UiHairline 对齐） -->
        <Thickness x:Key="SettingsZeroThickness">0</Thickness>                   <!-- 末行无分隔线 -->

        <!-- ===== 控件尺寸令牌 ===== -->
        <sys:Double x:Key="SettingsControlMinWidth">160</sys:Double>

        <!-- ===== 视觉合规局部令牌（RebuiltViewsHardcodeScanTests 校验免硬编码） ===== -->
        <Thickness x:Key="ChooseStartupButtonPadding">16,4,16,4</Thickness>
        <CornerRadius x:Key="StartupButtonRadius">17</CornerRadius>
        <CornerRadius x:Key="SliderTrackRadius">2.5</CornerRadius>

        <!-- ===== Spacing Compliance Thickness Tokens ===== -->
        <Thickness x:Key="StartupButtonIconMargin">0,0,8,0</Thickness>
        <Thickness x:Key="SliderTrackMargin">2,0</Thickness>
        <Thickness x:Key="SliderFillMargin">2,0,0,0</Thickness>
        <Thickness x:Key="SliderIconLeftMargin">0,0,10,0</Thickness>
        <Thickness x:Key="SliderIconRightMargin">10,0,12,0</Thickness>

        <!-- ===== 卡片容器 ===== -->
        <Style x:Key="SettingsGroupCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="{StaticResource UiHairline}" />
            <Setter Property="CornerRadius" Value="{StaticResource UiRadiusLg}" />
            <Setter Property="Padding" Value="{StaticResource SettingsCardPadding}" />
            <Setter Property="Effect" Value="{StaticResource UiElevationCard}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <!-- ===== 分组标题（副标题字号阶） ===== -->
        <Style x:Key="SettingsGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource UiFontSubtitle}" />
            <Setter Property="FontWeight" Value="{StaticResource UiFontWeightSemiBold}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
            <Setter Property="Margin" Value="{StaticResource SettingsGroupTitleMargin}" />
        </Style>

        <!-- ===== 行容器（带底部分隔线） ===== -->
        <Style x:Key="SettingsRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="{StaticResource SettingsSeparatorThickness}" />
            <Setter Property="Padding" Value="{StaticResource SettingsRowPadding}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <!-- 末行：去分隔线 -->
        <Style x:Key="SettingsRowLastStyle" TargetType="Border" BasedOn="{StaticResource SettingsRowStyle}">
            <Setter Property="BorderThickness" Value="{StaticResource SettingsZeroThickness}" />
        </Style>

        <!-- ===== 标签（标题段） ===== -->
        <Style x:Key="SettingsRowLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource UiFontBody}" />
            <Setter Property="FontWeight" Value="{StaticResource UiFontWeightMedium}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- ===== 说明（辅助段） ===== -->
        <Style x:Key="SettingsRowDescStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource UiFontCaption}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="{StaticResource SettingsRowDescMargin}" />
        </Style>

        <!-- ===== 选项下拉（套用统一 ComboBox 令牌样式） ===== -->
        <Style x:Key="SettingsRowComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource UiComboBoxStyle}">
            <Setter Property="MinWidth" Value="{StaticResource SettingsControlMinWidth}" />
            <Setter Property="Margin" Value="{StaticResource SettingsControlLeftMargin}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ===== 选择默认启动页按钮样式 ===== -->
        <Style x:Key="SettingsChooseStartupButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="{StaticResource ChooseStartupButtonPadding}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                Background="{DynamicResource SurfaceSoftBrush}" 
                                BorderThickness="0" 
                                CornerRadius="{StaticResource StartupButtonRadius}"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="1.2" Color="Black" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- 精致图标 -->
                                <TextBlock x:Name="TabIcon" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="{DynamicResource UiFontBodySm}"
                                           Margin="{StaticResource StartupButtonIconMargin}"
                                           VerticalAlignment="Center" />
                                <!-- 当前选项文本 -->
                                <ContentPresenter x:Name="ButtonContent"
                                                  VerticalAlignment="Center" 
                                                  HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="1.8" Color="Black" Opacity="0.09"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            
                            <!-- 动态页面图标与配色映射（与侧边栏高亮呼应，设计精细化） -->
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="工作台">
                                <Setter TargetName="TabIcon" Property="Text" Value="&#xE80F;"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="LightCyan"/>
                                <Setter Property="Foreground" Value="DodgerBlue"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="订单">
                                <Setter TargetName="TabIcon" Property="Text" Value="&#xE8A1;"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="LightGreen"/>
                                <Setter Property="Foreground" Value="ForestGreen"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="商品">
                                <Setter TargetName="TabIcon" Property="Text" Value="&#xE719;"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="MistyRose"/>
                                <Setter Property="Foreground" Value="Crimson"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="库存管理">
                                <Setter TargetName="TabIcon" Property="Text" Value="&#xE7B8;"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="Wheat"/>
                                <Setter Property="Foreground" Value="DarkGoldenrod"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="客户">
                                <Setter TargetName="TabIcon" Property="Text" Value="&#xE77B;"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="PaleTurquoise"/>
                                <Setter Property="Foreground" Value="Teal"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="现金流">
                                <Setter TargetName="TabIcon" Property="Text" Value="&#xE825;"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="Lavender"/>
                                <Setter Property="Foreground" Value="SlateBlue"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="经营建议">
                                <Setter TargetName="TabIcon" Property="Text" Value="&#xE9D9;"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="PeachPuff"/>
                                <Setter Property="Foreground" Value="DarkOrange"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="设置">
                                <Setter TargetName="TabIcon" Property="Text" Value="&#xE713;"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="Thistle"/>
                                <Setter Property="Foreground" Value="DarkOrchid"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ===== 现代精致 Slider 样式（Rich Aesthetics） ===== -->
        <Style x:Key="SettingsFontSizeSliderThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <!-- 外圈发光阴影效果 -->
                            <Ellipse x:Name="OuterShadow"
                                     Fill="Transparent"
                                     Width="20"
                                     Height="20"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                            <!-- 实心滑块 -->
                            <Ellipse x:Name="Grip"
                                     Width="14"
                                     Height="14"
                                     Fill="White"
                                     Stroke="{DynamicResource PrimaryBrush}"
                                     StrokeThickness="2.5"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Color="Black" Opacity="0.12"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Grip" Property="Width" Value="16"/>
                                <Setter TargetName="Grip" Property="Height" Value="16"/>
                                <Setter TargetName="Grip" Property="StrokeThickness" Value="3"/>
                                <Setter TargetName="OuterShadow" Property="Fill" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="OuterShadow" Property="Opacity" Value="0.1"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Grip" Property="Width" Value="15"/>
                                <Setter TargetName="Grip" Property="Height" Value="15"/>
                                <Setter TargetName="Grip" Property="StrokeThickness" Value="3"/>
                                <Setter TargetName="OuterShadow" Property="Fill" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="OuterShadow" Property="Opacity" Value="0.18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsFontSizeSliderStyle" TargetType="Slider">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 轨道背景 -->
                            <Border x:Name="TrackBackground"
                                    Grid.Row="1"
                                    Height="5"
                                    CornerRadius="{StaticResource SliderTrackRadius}"
                                    Background="{DynamicResource SurfaceSoftBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="0.5"
                                    VerticalAlignment="Center"
                                    Margin="{StaticResource SliderTrackMargin}"/>
                                    
                            <!-- 刻度与滑动区 -->
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <!-- 已滑过区域的高亮填充，突出档位感 -->
                                                <Border Height="5" 
                                                        CornerRadius="{StaticResource SliderTrackRadius}" 
                                                        Background="{DynamicResource PrimaryBrush}"
                                                        VerticalAlignment="Center"
                                                        Margin="{StaticResource SliderFillMargin}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SettingsFontSizeSliderThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Style="{DynamicResource SettingsScrollViewerStyle}" Padding="{StaticResource SettingsScrollPadding}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Margin="{StaticResource SettingsContentMargin}" HorizontalAlignment="Stretch">

                <!-- 外观卡片 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}">
                    <StackPanel>
                        <TextBlock Text="个性化外观" Style="{StaticResource SettingsGroupTitleStyle}" />

                        <!-- 主题模式 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="主题模式" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="应用外观主题设定" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <ListBox Grid.Column="1"
                                         Style="{DynamicResource SettingsSegmentedControlStyle}"
                                         ItemContainerStyle="{DynamicResource SettingsSegmentedItemStyle}"
                                         ItemsSource="{Binding ThemeModeOptions}"
                                         SelectedItem="{Binding ThemeModeInput}"
                                         AutomationProperties.AutomationId="List_ThemeMode" />
                            </Grid>
                        </Border>

                        <!-- 字号预设 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="字号预设" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="调整系统界面文本大小" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource SettingsControlLeftMargin}">
                                    <!-- 小字号视觉图标 -->
                                    <TextBlock Text="A" FontSize="{DynamicResource UiFontCaption}" FontWeight="Medium" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SliderIconLeftMargin}"/>
                                    <!-- 现代滑动条 -->
                                    <Slider x:Name="Slider_FontSize"
                                            Width="160"
                                            Minimum="0.8"
                                            Maximum="1.3"
                                            Value="{Binding FontSizePresetInput}"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource SettingsFontSizeSliderStyle}"
                                            AutomationProperties.AutomationId="Slider_FontSizePreset" />
                                    <!-- 大字号视觉图标 -->
                                    <TextBlock Text="A" FontSize="{DynamicResource UiFontTitle}" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="{StaticResource SliderIconRightMargin}"/>
                                    <!-- 百分比数字指示器 -->
                                    <TextBlock Text="{Binding ElementName=Slider_FontSize, Path=Value, StringFormat={}{0:P0}}"
                                               Width="42"
                                               FontSize="{DynamicResource UiFontBody}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HeadingBrush}"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 强调色 -->
                        <Border Style="{StaticResource SettingsRowLastStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="应用强调色" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="选择或自定义符合您品牌的主题强调色" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                            Margin="{StaticResource SettingsControlLeftMargin}">
                                    <ListBox Style="{DynamicResource SettingsColorSwatchListStyle}"
                                             ItemContainerStyle="{DynamicResource SettingsColorSwatchItemStyle}"
                                             ItemsSource="{Binding AccentColorOptions}"
                                             SelectedItem="{Binding AccentColorInput}"
                                             AutomationProperties.AutomationId="List_AccentColor" />
                                    <Button Style="{DynamicResource SettingsRowCustomColorButtonStyle}"
                                            Margin="{StaticResource SettingsInlineButtonMargin}"
                                            ToolTip="自定义强调色..."
                                            Command="{Binding ChooseCustomAccentColorCommand}"
                                            AutomationProperties.AutomationId="Btn_ChooseCustomColor" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 启动与显示卡片 -->
                <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="{StaticResource SettingsCardSpacing}">
                    <StackPanel>
                        <TextBlock Text="启动与显示" Style="{StaticResource SettingsGroupTitleStyle}" />

                        <!-- 默认启动页 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="默认启动页" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="打开应用时默认聚焦的板块" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource SettingsChooseStartupButtonStyle}"
                                        Content="{Binding StartupDefaultSectionInput}"
                                        AutomationProperties.AutomationId="List_StartupDefaultSection"
                                        Click="Btn_ChooseStartupDefaultSection_Click" />
                            </Grid>
                        </Border>

                        <!-- 默认窗口模式 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="默认窗口模式" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="启动应用时的窗口状态" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <ListBox Grid.Column="1"
                                         Style="{DynamicResource SettingsSegmentedControlStyle}"
                                         ItemContainerStyle="{DynamicResource SettingsSegmentedItemStyle}"
                                         ItemsSource="{Binding WindowModeOptions}"
                                         SelectedItem="{Binding DefaultWindowModeInput}"
                                         AutomationProperties.AutomationId="List_DefaultWindowMode" />
                            </Grid>
                        </Border>

                        <!-- 记住上次停留页 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="记住上次停留页" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="启动时恢复至上次关闭前的导航页面" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding RememberLastSectionInput}"
                                          AutomationProperties.AutomationId="Chk_RememberLastSection" />
                            </Grid>
                        </Border>

                        <!-- 开机自启 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="随系统开机启动" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="在系统登录后自动后台启动工作台" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding StartWithWindowsInput}"
                                          AutomationProperties.AutomationId="Chk_StartWithWindows" />
                            </Grid>
                        </Border>

                        <!-- 启动显示悬浮入口球 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="启动时显示悬浮入口球" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="应用开启后自动在桌面显示可拖动的 Orderly 快捷入口" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding ShowFloatingWindowOnStartupInput}"
                                          AutomationProperties.AutomationId="Chk_ShowFloatingWindow" />
                            </Grid>
                        </Border>

                        <!-- 悬浮入口球透明度 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="悬浮入口球透明度" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="调整常驻桌面入口的默认透明程度" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource SettingsControlLeftMargin}">
                                    <Slider x:Name="Slider_FloatingBallOpacity"
                                            Width="160"
                                            Minimum="0.35"
                                            Maximum="1"
                                            Value="{Binding FloatingBallOpacityInput}"
                                            Style="{StaticResource SettingsFontSizeSliderStyle}"
                                            AutomationProperties.AutomationId="Slider_FloatingBallOpacity" />
                                    <TextBlock Text="{Binding ElementName=Slider_FloatingBallOpacity, Path=Value, StringFormat={}{0:P0}}"
                                               Width="42"
                                               FontSize="{DynamicResource UiFontBody}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HeadingBrush}"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 关闭窗口后最小化到托盘 -->
                        <Border Style="{StaticResource SettingsRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="关闭窗口后最小化到托盘" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="点击右上角关闭按钮后隐藏在后台，双击右下角图标打开" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding StartMinimizedToTrayInput}"
                                          AutomationProperties.AutomationId="Chk_StartMinimizedToTray" />
                            </Grid>
                        </Border>

                        <!-- 记住窗口位置 -->
                        <Border Style="{StaticResource SettingsRowLastStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="记住窗口位置" Style="{StaticResource SettingsRowLabelStyle}" />
                                    <TextBlock Text="自动记录并恢复上次关闭时的窗口几何大小与位置" Style="{StaticResource SettingsRowDescStyle}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource SettingsRowCheckBoxStyle}"
                                          IsChecked="{Binding RememberWindowBoundsInput}"
                                          AutomationProperties.AutomationId="Chk_RememberWindowBounds" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
