<UserControl x:Class="Orderly.App.Views.Sections.ArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Orderly.App.Helpers"
             AutomationProperties.AutomationId="Page_Archive">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="Transparent" DataContext="{Binding ArchivePage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="归档数据"
                           FontSize="{DynamicResource UiFontTitle}"
                           FontFamily="{StaticResource UiFontFamilyCjk}"
                           FontWeight="{StaticResource UiFontWeightBold}"
                           Foreground="{DynamicResource HeadingBrush}" />
                <TextBlock Text="查看已归档的数据并恢复"
                           FontSize="{DynamicResource UiFontCaption}"
                           FontFamily="{StaticResource UiFontFamilyCjk}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="刷新"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource UiSecondaryButtonStyle}"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Entity type selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="数据类型："
                       FontSize="{DynamicResource UiFontBody}"
                       FontFamily="{StaticResource UiFontFamilyCjk}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
            <ComboBox ItemsSource="{Binding EntityTypes}"
                      SelectedItem="{Binding SelectedEntityType}"
                      Width="160"
                      VerticalAlignment="Center" />
        </StackPanel>

        <!-- Loading -->
        <ContentControl Grid.Row="2"
                        Style="{StaticResource UiLoadingStateStyle}"
                        VerticalAlignment="Center"
                        Visibility="{Binding ShowLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- Error -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ContentControl Style="{StaticResource UiErrorNoticeStyle}"
                            Content="{Binding ErrorMessage}" />
            <Button Content="重试"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource UiSecondaryButtonStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0" />
        </StackPanel>

        <!-- Empty -->
        <ContentControl Grid.Row="2"
                        Style="{StaticResource UiEmptyStateStyle}"
                        Content="该类型暂无归档数据"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- Content -->
        <DataGrid Grid.Row="2"
                  Style="{StaticResource UiDataGridStyle}"
                  ItemsSource="{Binding Archives}"
                  SelectedItem="{Binding SelectedArchive}"
                  Visibility="{Binding ShowContent, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DataGrid.Resources>
                <helpers:BindingProxy x:Key="ArchivePageProxy" Data="{Binding}" />
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="归档时间" Binding="{Binding ArchivedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="Auto" />
                <DataGridTextColumn Header="归档人" Binding="{Binding ArchivedByDisplayName}" Width="Auto" />
                <DataGridTextColumn Header="归档原因" Binding="{Binding ArchiveReason}" Width="Auto" />
                <DataGridTemplateColumn Header="操作" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="恢复"
                                    Style="{StaticResource UiTextButtonStyle}"
                                    Command="{Binding Data.RecoverCommand, Source={StaticResource ArchivePageProxy}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
