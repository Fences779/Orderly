<UserControl x:Class="Orderly.App.Views.Sections.FulfillmentProductionSheetPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/FulfillmentOrderListResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

                                 <Border Style="{StaticResource CardBorderStyle}" Padding="12"
                                         Visibility="{Binding IsStringNarrationProductionSheetVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                     <Grid>
                                         <Grid.RowDefinitions>
                                             <RowDefinition Height="Auto" />
                                             <RowDefinition Height="*" />
                                         </Grid.RowDefinitions>

                                         <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                             <DockPanel Margin="0,0,0,10">
                                                 <!-- 返回按钮 -->
                                                 <Button Style="{StaticResource SmallTextCopyButtonStyle}" Padding="10,0" Height="28" DockPanel.Dock="Left"
                                                         Command="{Binding ShowStringNarrationOrderListCommand}">
                                                     <StackPanel Orientation="Horizontal">
                                                         <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                         <TextBlock Text="返回列表" FontSize="11" VerticalAlignment="Center" />
                                                     </StackPanel>
                                                 </Button>
                                                 <!-- 状态胶囊 Badge -->
                                                 <Border CornerRadius="6" Padding="6,2.5" DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                     <Border.Style>
                                                         <Style TargetType="Border">
                                                             <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="paid_pending_confirm">
                                                                     <Setter Property="Background" Value="{DynamicResource WarmSoftBrush}" />
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="pending_make">
                                                                     <Setter Property="Background" Value="{DynamicResource PurpleSoftBrush}" />
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="making">
                                                                     <Setter Property="Background" Value="{DynamicResource BlueSoftBrush}" />
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="ready_to_ship">
                                                                     <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="shipped">
                                                                     <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="completed">
                                                                     <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="exception">
                                                                     <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Border.Style>
                                                     <TextBlock Text="{Binding StringNarrationProductionSheetStatusText}" FontSize="10" FontWeight="Bold">
                                                         <TextBlock.Style>
                                                             <Style TargetType="TextBlock">
                                                                 <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="paid_pending_confirm">
                                                                         <Setter Property="Foreground" Value="{DynamicResource WarmTextBrush}" />
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="pending_make">
                                                                         <Setter Property="Foreground" Value="{DynamicResource PurpleTextBrush}" />
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="making">
                                                                         <Setter Property="Foreground" Value="{DynamicResource BlueTextBrush}" />
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="ready_to_ship">
                                                                         <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="shipped">
                                                                         <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="completed">
                                                                         <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding SelectedStringNarrationProductionSheet.WorkOrderStatusColorKey}" Value="exception">
                                                                         <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </TextBlock.Style>
                                                     </TextBlock>
                                                 </Border>
                                             </DockPanel>

                                             <StackPanel Margin="2,0,0,0">
                                                 <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                     <TextBlock Text="&#xEC7A;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                     <TextBlock Text="制作单" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                                                 </StackPanel>
                                                 
                                                 <UniformGrid Columns="2" Margin="0,4,0,0">
                                                     <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                         <TextBlock Text="订单号：" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                         <TextBlock Text="{Binding StringNarrationProductionSheetOrderNoText}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" />
                                                     </StackPanel>
                                                     <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                         <TextBlock Text="制作单号：" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                         <TextBlock Text="{Binding StringNarrationProductionSheetProductionOrderNoText}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" />
                                                     </StackPanel>
                                                     <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                         <TextBlock Text="工单号：" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                         <TextBlock Text="{Binding StringNarrationProductionSheetWorkOrderNoText}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" />
                                                     </StackPanel>
                                                 </UniformGrid>
                                             </StackPanel>
                                         </StackPanel>

                                          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                              <StackPanel>
                                                  <Sections:FulfillmentProductionSheetMaterialsCard />
                                                  <Sections:FulfillmentProductionSheetArrangementCard />
                                                  <Sections:FulfillmentProductionSheetExampleImageCard />
                                                  <Sections:FulfillmentProductionSheetRemarkCard />
                                              </StackPanel>
                                          </ScrollViewer>
                                      </Grid>
                                  </Border>
</UserControl>
