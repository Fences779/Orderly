<UserControl x:Class="Orderly.App.Views.Sections.SettingsTabData"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Stretch">
                            <!-- 数据备份卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="本地备份策略" Style="{StaticResource SettingsGroupTitleStyle}" />
                                    
                                    <!-- 自动数据备份 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动数据备份" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="开启后系统将按照设定频率自动保存本地备份文件" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AutoBackupEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_AutoBackupEnabled" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动备份频率 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动备份频率" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动备份的执行周期" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding AutoBackupFrequencyOptions}"
                                                     SelectedItem="{Binding AutoBackupFrequencyInput}"
                                                     AutomationProperties.AutomationId="List_AutoBackupFrequency" />
                                        </Grid>
                                    </Border>

                                    <!-- 备份保留最大份数 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="备份保留最大份数" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="超出设定份数后将自动清理最旧的备份" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="80"
                                                     Text="{Binding BackupRetentionCountInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_BackupRetentionCount" />
                                        </Grid>
                                    </Border>

                                    <!-- 备份存储目录 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="备份存储目录" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding BackupDirectoryInput}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="更改目录" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding BrowseBackupDirectoryCommand}"
                                                    AutomationProperties.AutomationId="Btn_BrowseBackupDirectory" />
                                        </Grid>
                                    </Border>

                                    <!-- 手动导出备份 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="手动导出备份" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="立即将全部订单与客户数据导出为本地备份文件" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="导出备份" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="34" Padding="14,0"
                                                    Command="{Binding ExportBackupCommand}"
                                                    AutomationProperties.AutomationId="Btn_ExportBackup" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- SN 同步策略卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="SN 接入与数据同步" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 启用订单同步 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="启用订单同步策略" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="与 SN 开放网关自动同步最新的销售与客户订单" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding SnOrderSyncEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_SnOrderSyncEnabled" />
                                        </Grid>
                                    </Border>

                                    <!-- 同步模式 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="同步模式选择" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="通过定时还是手动进行网络同步拉取" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding SnSyncModeOptions}"
                                                     SelectedItem="{Binding SnSyncModeInput}"
                                                     AutomationProperties.AutomationId="List_SnSyncMode" />
                                        </Grid>
                                    </Border>

                                    <!-- 同步频率 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动定时同步频率" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动网关拉取周期的具体间隔时间" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding SnSyncFrequencyOptions}"
                                                     SelectedItem="{Binding SnSyncFrequencyInput}"
                                                     AutomationProperties.AutomationId="List_SnSyncFrequency" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- SN 网关状态卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="SN 网关连接状态" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 云端环境 ID -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="云端环境ID" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SnCloudEnvironmentIdText}" Style="{StaticResource SettingsStatusTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <!-- 网关连接状态 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="网关连接测试状态" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SnConnectionStatusText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="测试连接" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding TestSnConnectionCommand}"
                                                    AutomationProperties.AutomationId="Btn_TestSnConnection" />
                                        </Grid>
                                    </Border>

                                    <!-- 测试结果详情 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="测试详情与结果" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SnLastConnectionResultText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- 同步状态 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="数据拉取与同步状态" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SnLastSyncResultText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="立即同步" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding TriggerSnSyncCommand}"
                                                    AutomationProperties.AutomationId="Btn_TriggerSnSync" />
                                        </Grid>
                                    </Border>

                                    <!-- 同步日志摘要 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="最新拉取结果摘要" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SnSyncLogSummaryText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                    <Sections:SettingsTabDataSecurity />
                    <Sections:SettingsTabDataAudit />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
</UserControl>
