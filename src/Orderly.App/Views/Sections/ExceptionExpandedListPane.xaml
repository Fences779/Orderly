<UserControl x:Class="Orderly.App.Views.Sections.ExceptionExpandedListPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/ExceptionListResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SettingsGroupCardStyle}" Padding="16" Margin="0"
            Visibility="{Binding IsExceptionListExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid>
            <DockPanel>
            <!-- 分页 -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="共 " Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding ExceptionTotalCount, FallbackValue=0}" Foreground="{DynamicResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Text=" 条数据" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="15" Height="30" Padding="1,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateExceptionPrevPageCommand}" ToolTip="上一页">
                                <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                            </Button>
                            <Border Padding="10,0" Background="Transparent" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ExceptionPageLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" />
                            </Border>
                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateExceptionNextPageCommand}" ToolTip="下一页">
                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                            </Button>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <ToggleButton x:Name="Btn_ExceptionPageSizeSelector2"
                                      Style="{StaticResource PageSizeSelectorToggleButtonStyle}"
                                      IsChecked="{Binding IsExceptionPageSizePopupOpen2, Mode=TwoWay}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ExceptionPageSize, StringFormat={}{0} 条/页}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" ▾"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0"/>
                            </StackPanel>
                        </ToggleButton>
                        <Popup x:Name="Popup_ExceptionPageSizeSelector2"
                               PlacementTarget="{Binding ElementName=Btn_ExceptionPageSizeSelector2}"
                               Placement="Top"
                               IsOpen="{Binding IsExceptionPageSizePopupOpen2, Mode=TwoWay}"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="4"
                                    Margin="0,0,0,4">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Direction="90" Color="#111216" Opacity="0.08" />
                                </Border.Effect>
                                <StackPanel Width="90">
                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                            Content="10 条/页"
                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                            CommandParameter="10"/>
                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                            Content="16 条/页"
                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                            CommandParameter="16"/>
                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                            Content="20 条/页"
                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                            CommandParameter="20"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <!-- 空状态 -->
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasExceptionOrders}" Value="False" />
                                        <Condition Binding="{Binding IsExceptionOrdersListBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="64" Height="64" CornerRadius="32" Background="{DynamicResource SurfaceSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{DynamicResource CaptionTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding ExceptionOrdersEmptyStateText}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource HeadingBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>

                <!-- 列表 (双列 UniformGrid) -->
                <ListBox ItemsSource="{Binding ExceptionOrders}"
                         SelectedItem="{Binding SelectedExceptionOrder}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource ExceptionOrderCardListItemStyle}"
                         ItemTemplate="{StaticResource ExceptionOrderCardTemplate}"
                         Padding="2,4,2,2"
                         ClipToBounds="False">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasExceptionOrders}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Grid>
        </DockPanel>

        <!-- Loading Overlay -->
        <Grid x:Name="ExceptionListExpandedLoadingOverlay" Visibility="Collapsed">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExceptionOrdersListBusy}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2" Duration="0">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="#80FFFFFF" CornerRadius="12" />

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE72C;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{DynamicResource HeadingBrush}"
                           HorizontalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5"
                           Margin="0,0,0,12">
                    <TextBlock.RenderTransform>
                        <RotateTransform Angle="0" />
                    </TextBlock.RenderTransform>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ExceptionListExpandedLoadingOverlay, Path=Visibility}" Value="Visible">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="RotateStoryboardListExpanded">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                 From="0" To="360" Duration="0:0:1"
                                                                 RepeatBehavior="Forever" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="RotateStoryboardListExpanded" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding ExceptionStatusMessage}"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="{DynamicResource HeadingBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
                    </Border>
</UserControl>
