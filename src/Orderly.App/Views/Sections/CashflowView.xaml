<UserControl x:Class="Orderly.App.Views.Sections.CashflowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="Page_Cashflow">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="CashflowMetricCard" TargetType="Border">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#E5E7EC" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="Width" Value="180" />
                <Setter Property="Margin" Value="0,0,12,12" />
            </Style>
            <Style x:Key="CashflowMetricCaption" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="#868E96" />
            </Style>
            <Style x:Key="CashflowMetricValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="#1D1D1F" />
                <Setter Property="Margin" Value="0,6,0,0" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="Transparent" DataContext="{Binding CashflowPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="现金流" FontSize="29" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" />
                <TextBlock Text="近 30 天收支、应收应付与现金流健康度" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshCommand}" VerticalAlignment="Center"
                    Foreground="{DynamicResource BlueTextBrush}" Padding="14,6" />
        </Grid>

        <!-- 加载中 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding ShowLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="正在加载现金流数据…" Foreground="{DynamicResource MutedBrush}" FontSize="15" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 加载失败 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="#D12E9F" HorizontalAlignment="Center" />
            <TextBlock Text="现金流数据加载失败" Foreground="{DynamicResource HeadingBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,0" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,6,0,0" MaxWidth="420" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" />
            <Button Content="重试" Command="{Binding RefreshCommand}" Margin="0,14,0,0" Padding="18,7" HorizontalAlignment="Center"
                    Foreground="{DynamicResource BlueTextBrush}" />
        </StackPanel>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="暂无现金流数据" Foreground="{DynamicResource MutedBrush}" FontSize="15" Margin="0,14,0,0" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 数据 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowContent, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <WrapPanel>
                    <Border Style="{StaticResource CashflowMetricCard}">
                        <StackPanel>
                            <TextBlock Text="已实现收入" Style="{StaticResource CashflowMetricCaption}" />
                            <TextBlock Text="{Binding RealizedIncome, StringFormat=¥{0}}" Style="{StaticResource CashflowMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CashflowMetricCard}">
                        <StackPanel>
                            <TextBlock Text="已实现支出" Style="{StaticResource CashflowMetricCaption}" />
                            <TextBlock Text="{Binding RealizedExpense, StringFormat=¥{0}}" Style="{StaticResource CashflowMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CashflowMetricCard}">
                        <StackPanel>
                            <TextBlock Text="净现金流" Style="{StaticResource CashflowMetricCaption}" />
                            <TextBlock Text="{Binding NetCashFlow, StringFormat=¥{0}}" Style="{StaticResource CashflowMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CashflowMetricCard}">
                        <StackPanel>
                            <TextBlock Text="应收账款" Style="{StaticResource CashflowMetricCaption}" />
                            <TextBlock Text="{Binding OutstandingReceivable, StringFormat=¥{0}}" Style="{StaticResource CashflowMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CashflowMetricCard}">
                        <StackPanel>
                            <TextBlock Text="应付账款" Style="{StaticResource CashflowMetricCaption}" />
                            <TextBlock Text="{Binding OutstandingPayable, StringFormat=¥{0}}" Style="{StaticResource CashflowMetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CashflowMetricCard}">
                        <StackPanel>
                            <TextBlock Text="现金流健康度" Style="{StaticResource CashflowMetricCaption}" />
                            <TextBlock Text="{Binding HealthScore}" Style="{StaticResource CashflowMetricValue}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <TextBlock Text="近 30 天收支明细" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" Margin="6,18,0,10" />
                <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="发生时间" Binding="{Binding OccurredAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="*" />
                        <DataGridTextColumn Header="方向" Binding="{Binding Direction, Converter={StaticResource CommerceEnumLabelConverter}}" Width="Auto" />
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat=¥{0}}" Width="Auto" />
                        <DataGridTextColumn Header="结算状态" Binding="{Binding SettlementStatus, Converter={StaticResource CommerceEnumLabelConverter}}" Width="Auto" />
                        <DataGridTextColumn Header="分类" Binding="{Binding CategoryName}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
