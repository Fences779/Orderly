<UserControl x:Class="Orderly.App.Views.Sections.FulfillmentProductionSheetRemarkCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Sections="clr-namespace:Orderly.App.Views.Sections">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/FulfillmentOrderListResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

                                                 <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="12" Padding="14">
                                                     <StackPanel>
                                                         <!-- 标题栏，包含只读态下的编辑按钮 -->
                                                         <DockPanel Margin="0,0,0,10">
                                                             <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                                 <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                 <TextBlock Text="制作备注" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource HeadingBrush}" VerticalAlignment="Center" />
                                                             </StackPanel>
                                                             
                                                             <!-- 编辑图标按钮，只在非编辑态下显示 -->
                                                             <Button Width="24" Height="24" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                     Command="{Binding StartEditStringNarrationProductionRemarkCommand}" ToolTip="修改备注">
                                                                 <Button.Style>
                                                                     <Style TargetType="Button" BasedOn="{StaticResource IconCopyButtonStyle}">
                                                                         <Setter Property="Visibility" Value="Visible" />
                                                                         <Style.Triggers>
                                                                             <DataTrigger Binding="{Binding IsStringNarrationProductionRemarkEditing}" Value="True">
                                                                                 <Setter Property="Visibility" Value="Collapsed" />
                                                                             </DataTrigger>
                                                                         </Style.Triggers>
                                                                     </Style>
                                                                 </Button.Style>
                                                                 <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                             </Button>
                                                         </DockPanel>

                                                         <!-- 内容区域：根据是否处于编辑态切换显示 -->
                                                         <Grid>
                                                             <!-- 1. 只读状态 -->
                                                             <TextBlock Text="{Binding StringNarrationProductionSheetRemarkText}" FontSize="12" Foreground="{DynamicResource HeadingBrush}" TextWrapping="Wrap" LineHeight="18">
                                                                 <TextBlock.Style>
                                                                     <Style TargetType="TextBlock">
                                                                         <Setter Property="Visibility" Value="Visible" />
                                                                         <Style.Triggers>
                                                                             <DataTrigger Binding="{Binding IsStringNarrationProductionRemarkEditing}" Value="True">
                                                                                 <Setter Property="Visibility" Value="Collapsed" />
                                                                             </DataTrigger>
                                                                         </Style.Triggers>
                                                                     </Style>
                                                                 </TextBlock.Style>
                                                             </TextBlock>

                                                             <!-- 2. 编辑状态 -->
                                                             <StackPanel>
                                                                 <StackPanel.Style>
                                                                     <Style TargetType="StackPanel">
                                                                         <Setter Property="Visibility" Value="Collapsed" />
                                                                         <Style.Triggers>
                                                                             <DataTrigger Binding="{Binding IsStringNarrationProductionRemarkEditing}" Value="True">
                                                                                 <Setter Property="Visibility" Value="Visible" />
                                                                             </DataTrigger>
                                                                         </Style.Triggers>
                                                                     </Style>
                                                                 </StackPanel.Style>

                                                                 <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" 
                                                                          Text="{Binding StringNarrationProductionOrderRemarkInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          AcceptsReturn="True" TextWrapping="Wrap" Height="68" Padding="8" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" />
                                                                 
                                                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                                                     <Button Style="{StaticResource SmallTextCopyButtonStyle}" Content="取消" Height="26" Padding="12,0" Margin="0,0,6,0"
                                                                             Command="{Binding CancelEditStringNarrationProductionRemarkCommand}" />
                                                                     <Button Style="{StaticResource DialogPrimaryButtonStyle}" Content="保存" Height="26" Padding="12,0" Background="{DynamicResource PrimaryBrush}" BorderThickness="0"
                                                                             Command="{Binding SaveStringNarrationProductionRemarkCommand}" />
                                                                 </StackPanel>
                                                             </StackPanel>
                                                         </Grid>
                                                     </StackPanel>
                                                 </Border>
</UserControl>
