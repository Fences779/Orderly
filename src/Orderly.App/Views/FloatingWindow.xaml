<Window x:Class="Orderly.App.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orderly 悬浮助手"
        Width="360"
        Height="520"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="#FFFDF8">
    <Border Padding="16" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="悬浮助手" FontSize="22" FontWeight="Bold" />
                <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Margin="0,12,0,12" Padding="10,8" />
                <TextBlock Text="最近订单" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                <TextBlock Text="常用话术" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding FavoriteTemplates}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Command="{Binding DataContext.CopyTemplateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Margin="0,0,0,6"
                                    Background="#1F7A5A"
                                    Foreground="White" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <ListBox ItemsSource="{Binding Orders}" BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" Margin="0,0,0,8" Background="#F7F5EF" CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CustomerName}" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding StatusLabel}" Foreground="#1F7A5A" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
