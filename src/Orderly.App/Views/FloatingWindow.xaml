<Window x:Class="Orderly.App.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orderly 悬浮入口球"
        Width="72"
        Height="72"
        MinWidth="72"
        MinHeight="72"
        MaxWidth="72"
        MaxHeight="72"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="FloatingBallShadow"
                           BlurRadius="18"
                           ShadowDepth="3"
                           Color="#334155"
                           Opacity="0.16" />
    </Window.Resources>

    <Grid x:Name="Root"
          Cursor="Hand"
          ToolTip="Orderly 快捷入口"
          MouseLeftButtonDown="Root_MouseLeftButtonDown"
          MouseLeftButtonUp="Root_MouseLeftButtonUp"
          MouseRightButtonUp="Root_MouseRightButtonUp"
          MouseMove="Root_MouseMove"
          MouseEnter="Root_MouseEnter"
          MouseLeave="Root_MouseLeave">
        <Grid.ContextMenu>
            <ContextMenu x:Name="Menu_FloatingBall"
                         Placement="Right"
                         StaysOpen="False">
                <MenuItem Header="工作台" Tag="工作台" Click="MenuNavigate_Click" />
                <MenuItem Header="订单" Tag="订单" Click="MenuNavigate_Click" />
                <MenuItem Header="客户" Tag="客户" Click="MenuNavigate_Click" />
                <MenuItem Header="商品" Tag="商品" Click="MenuNavigate_Click" />
                <MenuItem Header="库存管理" Tag="库存管理" Click="MenuNavigate_Click" />
                <MenuItem Header="设置" Tag="设置" Click="MenuNavigate_Click" />
                <Separator />
                <MenuItem Header="透明度" StaysOpenOnClick="True">
                    <Slider x:Name="Slider_Opacity"
                            Width="144"
                            Minimum="0.35"
                            Maximum="1"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="False"
                            ValueChanged="Slider_Opacity_ValueChanged" />
                </MenuItem>
                <Separator />
                <MenuItem Header="隐藏悬浮球" Click="MenuHide_Click" />
                <MenuItem Header="退出" Click="MenuExit_Click" />
            </ContextMenu>
        </Grid.ContextMenu>
        
        <Ellipse Width="60"
                 Height="60"
                 Effect="{StaticResource FloatingBallShadow}"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
            </Ellipse.RenderTransform>
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Setter Property="Fill">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E6FFFFFF" Offset="0" />
                                <GradientStop Color="#C0F1F5F9" Offset="0.5" />
                                <GradientStop Color="#99E2E8F0" Offset="1" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Stroke" Value="#25FFFFFF" />
                    <Setter Property="StrokeThickness" Value="1.2" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                            <Setter Property="Fill">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F8FFFFFF" Offset="0" />
                                        <GradientStop Color="#DDF0FDF4" Offset="0.5" />
                                        <GradientStop Color="#BBE0F2E9" Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Stroke" Value="#6610B981" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.04" ScaleY="1.04" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <Image Source="{StaticResource OrderlyBrandLogoImage}"
               Width="28"
               Height="28"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
            </Image.RenderTransform>
            <Image.Style>
                <Style TargetType="Image">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.06" ScaleY="1.06" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
    </Grid>
</Window>
