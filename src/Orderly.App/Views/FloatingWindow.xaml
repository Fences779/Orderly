<Window x:Class="Orderly.App.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orderly 悬浮入口球"
        Width="72"
        Height="72"
        MinWidth="72"
        MinHeight="72"
        MaxWidth="72"
        MaxHeight="72"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Background="Transparent">
    <Window.Resources>
        <!-- 悬浮球的本体投影：更散、更淡，增强漂浮感 -->
        <DropShadowEffect x:Key="FloatingBallShadow"
                           BlurRadius="18"
                           ShadowDepth="3"
                           Color="#1E293B"
                           Opacity="0.12" />
    </Window.Resources>

    <Grid x:Name="Root"
          Background="Transparent"
          Cursor="Hand"
          ToolTip="Orderly 快捷入口"
          PreviewMouseLeftButtonDown="Root_MouseLeftButtonDown"
          PreviewMouseLeftButtonUp="Root_MouseLeftButtonUp"
          PreviewMouseRightButtonUp="Root_MouseRightButtonUp"
          PreviewMouseMove="Root_MouseMove"
          MouseEnter="Root_MouseEnter"
          MouseLeave="Root_MouseLeave">
        <Grid.ContextMenu>
            <ContextMenu x:Name="Menu_FloatingBall"
                         Placement="Right"
                         StaysOpen="False">
                <MenuItem Header="工作台" Tag="工作台" Click="MenuNavigate_Click" />
                <MenuItem Header="订单" Tag="订单" Click="MenuNavigate_Click" />
                <MenuItem Header="客户" Tag="客户" Click="MenuNavigate_Click" />
                <MenuItem Header="商品" Tag="商品" Click="MenuNavigate_Click" />
                <MenuItem Header="库存管理" Tag="库存管理" Click="MenuNavigate_Click" />
                <MenuItem Header="设置" Tag="设置" Click="MenuNavigate_Click" />
                <Separator />
                <MenuItem Header="透明度" StaysOpenOnClick="True">
                    <Slider x:Name="Slider_Opacity"
                            Width="144"
                            Minimum="0.35"
                            Maximum="1"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="False"
                            ValueChanged="Slider_Opacity_ValueChanged" />
                </MenuItem>
                <Separator />
                <MenuItem Header="隐藏悬浮球" Click="MenuHide_Click" />
                <MenuItem Header="退出" Click="MenuExit_Click" />
            </ContextMenu>
        </Grid.ContextMenu>
        
        <!-- 1. 霓虹极光背光层（在悬浮球底层，Hover时亮起并向外微幅扩散） -->
        <Ellipse x:Name="Backlight"
                 Width="46"
                 Height="46"
                 IsHitTestVisible="False"
                 Opacity="0.0"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#A010B981" Offset="0"/> <!-- 品牌绿 -->
                    <GradientStop Color="#403B82F6" Offset="0.6"/> <!-- 极光蓝 -->
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="16" />
            </Ellipse.Effect>
            <Ellipse.RenderTransform>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
            </Ellipse.RenderTransform>
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0.85" Duration="0:0:0.25" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.3" Duration="0:0:0.25" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.3" Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0.0" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <!-- 2. 精致毛玻璃球体 -->
        <Ellipse x:Name="GlassBody"
                 Width="54"
                 Height="54"
                 IsHitTestVisible="False"
                 Effect="{StaticResource FloatingBallShadow}"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
            </Ellipse.RenderTransform>
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Setter Property="Fill">
                        <Setter.Value>
                            <!-- 带有磨砂高透玻璃感的极细微渐变 -->
                            <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                                <GradientStop Color="#FDFDFD" Offset="0" />
                                <GradientStop Color="#EBF1F6" Offset="0.5" />
                                <GradientStop Color="#D0DCE5" Offset="1" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Stroke">
                        <Setter.Value>
                            <!-- 极致精致高光边框：上亮下暗，表现物理折射感 -->
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#E6FFFFFF" Offset="0" />
                                <GradientStop Color="#40FFFFFF" Offset="0.3" />
                                <GradientStop Color="#12000000" Offset="0.75" />
                                <GradientStop Color="#22000000" Offset="1" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="StrokeThickness" Value="1.0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                            <Setter Property="Stroke" Value="#5010B981" /> <!-- 悬停时，物理边框微微带一点透绿 -->
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.05" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.05" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <!-- 3. 立体悬浮 Logo 层 -->
        <Image Source="{StaticResource OrderlyBrandLogoImage}"
               Width="25"
               Height="25"
               IsHitTestVisible="False"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderTransformOrigin="0.5,0.5">
            <Image.Effect>
                <DropShadowEffect BlurRadius="6"
                                  ShadowDepth="1.5"
                                  Color="#0F172A"
                                  Opacity="0.12" />
            </Image.Effect>
            <Image.RenderTransform>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
            </Image.RenderTransform>
            <Image.Style>
                <Style TargetType="Image">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.08" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.08" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
    </Grid>
</Window>
