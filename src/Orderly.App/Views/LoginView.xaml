<Window x:Class="Orderly.App.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orderly"
        Height="560"
        Width="860"
        MinHeight="500"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/AppContentScrollResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 进场动画 -->
            <Storyboard x:Key="LoadAnimation">
                <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- 主按钮：保留强主操作，但降低纯黑压迫感-->
            <Style x:Key="PremiumButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#17181C" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <SolidColorBrush x:Name="ButtonBackgroundBrush" Color="#17181C" />
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect x:Name="ButtonShadowEffect"
                                                  BlurRadius="18"
                                                  ShadowDepth="3"
                                                  Direction="270"
                                                  Color="#101114"
                                                  Opacity="0.07" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="ButtonHoverStoryboard">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ButtonBackgroundBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#1E2025"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ButtonShadowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.18"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ButtonShadowEffect"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="22"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ButtonBackgroundBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#17181C"
                                                            Duration="0:0:0.2">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ButtonShadowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.12"
                                                             Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ButtonShadowEffect"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="18"
                                                             Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#121317" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#C9CCD3" />
                                <Setter Property="Foreground" Value="#F8F8FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            </Style>

        <!-- 输入框：默认态和焦点态拉近，只做轻微点亮 -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Background" Value="#F7F7F9" />
            <Setter Property="BorderBrush" Value="#DFE3EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                CornerRadius="14"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <SolidColorBrush x:Name="TextBoxBackgroundBrush" Color="#F7F7F9" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="TextBoxBorderBrush" Color="#DFE3EA" />
                            </Border.BorderBrush>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TextBoxBackgroundBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FFFFFF"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="TextBoxBorderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#8A9AB5"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TextBoxBackgroundBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#F7F7F9"
                                                            Duration="0:0:0.22">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="TextBoxBorderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#DFE3EA"
                                                            Duration="0:0:0.22">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsKeyboardFocusWithin" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#FAFAFB" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#D4D9E2" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F1F2F5" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#E5E7EC" />
                                <Setter Property="Foreground" Value="#A0A5AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Background" Value="#F7F7F9" />
            <Setter Property="BorderBrush" Value="#DFE3EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                CornerRadius="14"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <SolidColorBrush x:Name="PasswordBoxBackgroundBrush" Color="#F7F7F9" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="PasswordBoxBorderBrush" Color="#DFE3EA" />
                            </Border.BorderBrush>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="PasswordBoxBackgroundBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FFFFFF"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="PasswordBoxBorderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#8A9AB5"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="PasswordBoxBackgroundBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#F7F7F9"
                                                            Duration="0:0:0.22">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="PasswordBoxBorderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#DFE3EA"
                                                            Duration="0:0:0.22">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsKeyboardFocusWithin" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#FAFAFB" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#D4D9E2" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F1F2F5" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#E5E7EC" />
                                <Setter Property="Foreground" Value="#A0A5AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 字段标签 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#606773" />
            <Setter Property="Margin" Value="2,0,0,8" />
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#5F6674" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalAlignment}" VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#1D1D1F" />
                    <Setter Property="Opacity" Value="0.86" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.58" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F5F7" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#ECECF1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.78" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="#F5F5F7" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackButtonBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <Viewbox Width="14" Height="14" Stretch="Uniform" Margin="-2,0,0,0">
                                <Canvas Width="14" Height="14">
                                    <Path Data="M8.8,2.2 L4.2,7 L8.8,11.8"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                    <Line X1="4.6"
                                          Y1="7"
                                          X2="11.2"
                                          Y2="7"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackButtonBorder" Property="Background" Value="#EBEBEF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" CenterX="18" CenterY="18" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadAnimation}" />
        </EventTrigger>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="SilkWavePrimaryTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="-14"
                                     To="18"
                                     Duration="0:0:12" />
                    <DoubleAnimation Storyboard.TargetName="SilkWavePrimaryTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="-8"
                                     To="10"
                                     Duration="0:0:14" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="SilkWaveSecondaryTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="12"
                                     To="-18"
                                     Duration="0:0:10" />
                    <DoubleAnimation Storyboard.TargetName="SilkWaveSecondaryTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="6"
                                     To="-12"
                                     Duration="0:0:13" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- 窗口外部留出阴影空间 -->
    <Border x:Name="RootGrid" Background="Transparent" Padding="32">
        <Border x:Name="MainCard" Background="#FCFCFD" CornerRadius="24" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="20" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect x:Name="MainCardShadow" BlurRadius="46" ShadowDepth="14" Direction="270" Color="#111216" Opacity="0.08" />
            </Border.Effect>

            <!-- 主内容区域，绑定拖拽事件 -->
            <Grid x:Name="MainCardContent"
                  Background="Transparent"
                  MouseLeftButtonDown="RootGrid_MouseLeftButtonDown"
                  SizeChanged="MainCardContent_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="286" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左侧品牌展示�?(深邃的高级感) -->
                <Border x:Name="BrandSurface"
                        Grid.Column="0"
                        Background="#F7F7F9"
                        BorderBrush="#ECEEF3"
                        BorderThickness="0,0,1,0"
                        CornerRadius="24,0,0,24"
                        ClipToBounds="True">
                    <Grid>
                        <Canvas IsHitTestVisible="False" ClipToBounds="True">
                            <Ellipse Width="320"
                                     Height="520"
                                     Canvas.Left="-112"
                                     Canvas.Top="-126"
                                     Opacity="0.42">
                                <Ellipse.Fill>
                                    <RadialGradientBrush GradientOrigin="0.42,0.35" Center="0.5,0.5" RadiusX="0.72" RadiusY="0.72">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#F7F8FB" Offset="0.46" />
                                        <GradientStop Color="#00F7F8FB" Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform x:Name="SilkWavePrimaryTranslate" X="0" Y="0" />
                                        <RotateTransform Angle="-16" CenterX="160" CenterY="260" />
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="286"
                                     Height="432"
                                     Canvas.Left="74"
                                     Canvas.Top="134"
                                     Opacity="0.26">
                                <Ellipse.Fill>
                                    <RadialGradientBrush GradientOrigin="0.58,0.48" Center="0.5,0.5" RadiusX="0.76" RadiusY="0.76">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#F0F2F7" Offset="0.52" />
                                        <GradientStop Color="#00F0F2F7" Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform x:Name="SilkWaveSecondaryTranslate" X="0" Y="0" />
                                        <RotateTransform Angle="18" CenterX="143" CenterY="216" />
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Canvas>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="88" Height="88" Background="#FFFFFF" CornerRadius="26" HorizontalAlignment="Center" Margin="0,0,0,24">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="22" ShadowDepth="8" Direction="270" Color="#121317" Opacity="0.12" />
                                </Border.Effect>
                                <Image Source="{StaticResource OrderlyBrandLogoImage}"
                                       Width="58"
                                       Height="58"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Orderly" FontSize="29" FontWeight="Bold" Foreground="#1D1D1F" HorizontalAlignment="Center" />
                            <TextBlock Text="String Narration" FontSize="11" Foreground="#7D8390" HorizontalAlignment="Center" Margin="0,10,0,0" Opacity="0.82" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 右侧登录表单区 -->
                <Grid Grid.Column="1" x:Name="RightSurface" ClipToBounds="True">
                    <Grid Margin="42,0,28,0" ClipToBounds="True">
                    <!-- ============================ -->
                    <!-- 登录态面�?(Sign In)          -->
                    <!-- ============================ -->
                    <Grid x:Name="SignInPanel"
                          Visibility="Visible"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Opacity="1"
                          FocusManager.FocusedElement="{Binding ElementName=TxtSignInUsername}">
                        <Grid.RenderTransform>
                            <TranslateTransform X="0" />
                        </Grid.RenderTransform>
                        <Grid Margin="0,26,0,30">
                            <StackPanel Width="320" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0">
                                <StackPanel x:Name="SignInAccountBlock" Margin="0,0,0,22">
                                    <StackPanel.RenderTransform>
                                        <TranslateTransform x:Name="SignInAccountBlockTranslateTransform" Y="0" />
                                    </StackPanel.RenderTransform>
                                    <TextBlock Text="账号"
                                               Style="{StaticResource FieldLabel}"
                                               FontWeight="Bold"
                                               Foreground="#1D1D1F"
                                               Margin="0,0,0,8" />
                                    <Grid x:Name="SignInAccountSection"
                                          Width="320"
                                          HorizontalAlignment="Left">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBox x:Name="TxtSignInUsername"
                                                 Grid.Row="0"
                                                 HorizontalAlignment="Stretch"
                                                 PreviewMouseLeftButtonDown="TxtSignInUsername_PreviewMouseLeftButtonDown"
                                                 GotKeyboardFocus="TxtSignInUsername_GotKeyboardFocus"
                                                 KeyDown="TxtSignInUsername_KeyDown"
                                                 TextChanged="TxtSignInUsername_TextChanged"
                                                 LostKeyboardFocus="TxtSignInUsername_LostKeyboardFocus" />
                                        <Border x:Name="RecentAccountsDropdown"
                                                Grid.Row="1"
                                                Margin="0,10,0,0"
                                                Padding="6"
                                                Background="#FFFFFF"
                                                BorderBrush="#DCE1E9"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                SnapsToDevicePixels="True"
                                                Visibility="Collapsed"
                                                Opacity="0"
                                                MaxHeight="0"
                                                RenderTransformOrigin="0.5,0">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform x:Name="RecentAccountsDropdownScaleTransform" ScaleY="0.96" />
