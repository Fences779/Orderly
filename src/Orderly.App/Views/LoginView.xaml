                                    <TextBlock Text="账户管理"
                                               FontWeight="Bold"
                                               FontSize="24"
                                               Foreground="#1D1D1F"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="BtnBackFromAccountManagement"
