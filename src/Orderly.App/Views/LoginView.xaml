<Window x:Class="Orderly.App.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Orderly.App.Views"
        Title="Orderly"
        Height="560"
        Width="860"
        MinHeight="500"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/AppContentScrollResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.B.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.C.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 进场动画 -->
            <Storyboard x:Key="LoadAnimation">
                <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

        </ResourceDictionary>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadAnimation}" />
        </EventTrigger>
    </Window.Triggers>

    <!-- 窗口外部留出阴影空间 -->
    <Border x:Name="RootGrid" Background="Transparent" Padding="32">
        <Border x:Name="MainCard" Background="#FCFCFD" CornerRadius="24" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="20" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect x:Name="MainCardShadow" BlurRadius="46" ShadowDepth="14" Direction="270" Color="#111216" Opacity="0.08" />
            </Border.Effect>

            <!-- 主内容区域，绑定拖拽事件 -->
            <Grid x:Name="MainCardContent"
                  Background="Transparent"
                  MouseLeftButtonDown="RootGrid_MouseLeftButtonDown"
                  SizeChanged="MainCardContent_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="286" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左侧品牌展示区 (深邃的高级感) -->
                <views:LoginBrandPanel Grid.Column="0" />

                <!-- 右侧登录表单区 -->
                <Grid Grid.Column="1" x:Name="RightSurface" ClipToBounds="True">
                    <Grid Margin="42,0,28,0" ClipToBounds="True">
                    <!-- ============================ -->
                    <!-- 登录态面板 (Sign In)          -->
                    <!-- ============================ -->
                    <views:LoginSignInPanel x:Name="SignInPanel" />

                    <views:LoginPasswordRecoveryPanel x:Name="PasswordRecoveryPanel" />

                    <views:LoginAccountManagementPanel x:Name="AccountManagementPanel" />

                    <views:LoginCreateAccountPanel x:Name="CreateManagedAccountPanel" />

                </Grid>

                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Panel.ZIndex="20">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAccountManagementNoticeOpen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="#D9F7F7FA"
                                CornerRadius="0,24,24,0" />

                        <Border Width="430"
                                Padding="24"
                                Background="#FFFFFF"
                                CornerRadius="18"
                                BorderBrush="#E5E5EA"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="10" Direction="270" Color="#000000" Opacity="0.12" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="使用说明"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1D1D1F" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#6E6E73"
                                           FontSize="13"
                                           TextWrapping="Wrap">
                                    此处仅展示已有账号概览。
                                    <LineBreak />
                                    主账号无法查看其他账号密码；
                                    <LineBreak />
                                    如需删除已有账户，必须通过主账号验证并输入 PIN 二次确认。
                                </TextBlock>
                                <Button Content="我已知晓"
                                        Width="120"
                                        Height="42"
                                        HorizontalAlignment="Right"
                                        Margin="0,20,0,0"
                                        Style="{StaticResource PremiumButtonStyle}"
                                        Click="BtnAcknowledgeAccountManagementNotice_Click" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                    <!-- ============================ -->
                    <!-- 首次初始化面板 (Create Owner) -->
                    <!-- ============================ -->
                    <views:LoginOwnerCreatePanel x:Name="OwnerCreatePanel" Grid.Column="0" Grid.ColumnSpan="2" Visibility="Collapsed" />

                    <Grid Grid.ColumnSpan="2"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Panel.ZIndex="30">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPendingDeleteAccount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="#CCF7F7FA"
                                CornerRadius="24" />

                        <Border Width="452"
                                MaxWidth="452"
                                Padding="24"
                                Background="#FFF7F2"
                                BorderBrush="#F2D3BE"
                                BorderThickness="1"
                                CornerRadius="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="24"
                                MouseLeftButtonDown="DeleteAccountDialog_MouseLeftButtonDown">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24"
                                                  ShadowDepth="10"
                                                  Direction="270"
                                                  Color="#000000"
                                                  Opacity="0.12" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding PendingDeleteAccountConfirmationTitle}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="#1D1D1F"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="152" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="主账号" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="TxtDeleteOwnerUsername" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                                        <PasswordBox x:Name="TxtDeleteOwnerPin" MaxLength="6" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" />
                                    <PasswordBox x:Name="TxtDeleteOwnerPassword" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,18,0,0">
                                    <Button Content="取消"
                                            Width="90"
                                            Margin="0,0,10,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="BtnCancelDeleteAccount_Click" />
                                    <Button Content="确认删除"
                                            Width="110"
                                            Style="{StaticResource PremiumButtonStyle}"
                                            Click="BtnConfirmDeleteAccount_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="TxtError" Grid.Column="1" Foreground="#FF3B30" FontSize="13" FontWeight="SemiBold" Visibility="Collapsed" TextWrapping="Wrap" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" />

                    <!-- 右侧遮罩：Toast 出现时叠加在右侧内容上方 -->
                    <Grid x:Name="RightPaneOverlay"
                          Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Panel.ZIndex="48"
                          Visibility="Collapsed"
                          IsHitTestVisible="False">
                        <Border Background="#B2F7F7FA"
                                CornerRadius="0,24,24,0" />
                    </Grid>

                    <!-- Toast 通知层：必须在 MainCardContent 最顶层，ColumnSpan=2 确保覆盖全宽 -->
                    <views:LoginToastOverlay x:Name="ToastOverlay"
                                            Grid.ColumnSpan="2"
                                            Panel.ZIndex="50" />
                </Grid>
        </Border>
        </Border>
</Window>
