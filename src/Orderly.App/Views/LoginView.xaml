                                            CornerRadius="18"
                                            Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="管理员验证"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="#1D1D1F" />
