                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="最近登录"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#175CD3" />
                                                                    </Border>
                                                                    <Border Padding="8,2"
                                                                            Background="#F1F2F6"
                                                                            CornerRadius="10"
                                                                            Margin="0,0,8,0">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Role, Mode=OneWay}" Value="Owner">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#4A4A52">
                                                                            <Run Text="主账号" />
                                                                        </TextBlock>
                                                                    </Border>
                                                                    <Border Padding="8,2"
                                                                            Background="#FCE8E8"
                                                                            CornerRadius="10">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsEnabled, Mode=OneWay}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="已禁用"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#B42318" />
                                                                    </Border>
                                                                </StackPanel>
                                                                <Button Grid.Column="1"
