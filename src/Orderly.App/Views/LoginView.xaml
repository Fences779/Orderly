<Window x:Class="Orderly.App.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Orderly.App.Views"
        Title="Orderly"
        Height="560"
        Width="860"
        MinHeight="500"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/AppContentScrollResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.B.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.C.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 进场动画 -->
            <Storyboard x:Key="LoadAnimation">
                <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

        </ResourceDictionary>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadAnimation}" />
        </EventTrigger>
    </Window.Triggers>

    <!-- 窗口外部留出阴影空间 -->
    <Border x:Name="RootGrid" Background="Transparent" Padding="32">
        <Border x:Name="MainCard" Background="#FCFCFD" CornerRadius="24" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="20" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect x:Name="MainCardShadow" BlurRadius="46" ShadowDepth="14" Direction="270" Color="#111216" Opacity="0.08" />
            </Border.Effect>

            <!-- 主内容区域，绑定拖拽事件 -->
            <Grid x:Name="MainCardContent"
                  Background="Transparent"
                  MouseLeftButtonDown="RootGrid_MouseLeftButtonDown"
                  SizeChanged="MainCardContent_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="286" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左侧品牌展示区 (深邃的高级感) -->
                <views:LoginBrandPanel Grid.Column="0" />

                <!-- 右侧登录表单区 -->
                <Grid Grid.Column="1" x:Name="RightSurface" ClipToBounds="True">
                    <Grid Margin="42,0,28,0" ClipToBounds="True">
                    <!-- ============================ -->
                    <!-- 登录态面�?(Sign In)          -->
                    <!-- ============================ -->
                    <Grid x:Name="SignInPanel"
                          Visibility="Visible"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Opacity="1"
                          FocusManager.FocusedElement="{Binding ElementName=TxtSignInUsername}">
                        <Grid.RenderTransform>
                            <TranslateTransform X="0" />
                        </Grid.RenderTransform>
                        <Grid Margin="0,26,0,30">
                            <StackPanel Width="320" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0">
                                <StackPanel x:Name="SignInAccountBlock" Margin="0,0,0,22">
                                    <StackPanel.RenderTransform>
                                        <TranslateTransform x:Name="SignInAccountBlockTranslateTransform" Y="0" />
                                    </StackPanel.RenderTransform>
                                    <TextBlock Text="账号"
                                               Style="{StaticResource FieldLabel}"
                                               FontWeight="Bold"
                                               Foreground="#1D1D1F"
                                               Margin="0,0,0,8" />
                                    <Grid x:Name="SignInAccountSection"
                                          Width="320"
                                          HorizontalAlignment="Left">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBox x:Name="TxtSignInUsername"
                                                 Grid.Row="0"
                                                 HorizontalAlignment="Stretch"
                                                 PreviewMouseLeftButtonDown="TxtSignInUsername_PreviewMouseLeftButtonDown"
                                                 GotKeyboardFocus="TxtSignInUsername_GotKeyboardFocus"
                                                 KeyDown="TxtSignInUsername_KeyDown"
                                                 TextChanged="TxtSignInUsername_TextChanged"
                                                 LostKeyboardFocus="TxtSignInUsername_LostKeyboardFocus" />
                                        <Border x:Name="RecentAccountsDropdown"
                                                Grid.Row="1"
                                                Margin="0,10,0,0"
                                                Padding="6"
                                                Background="#FFFFFF"
                                                BorderBrush="#DCE1E9"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                SnapsToDevicePixels="True"
                                                Visibility="Collapsed"
                                                Opacity="0"
                                                MaxHeight="0"
                                                RenderTransformOrigin="0.5,0">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform x:Name="RecentAccountsDropdownScaleTransform" ScaleY="0.96" />
                                                    <TranslateTransform x:Name="RecentAccountsDropdownTranslateTransform" Y="-8" />
                                                </TransformGroup>
                                            </Border.RenderTransform>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="18"
                                                                  ShadowDepth="4"
                                                                  Direction="270"
                                                                  Color="#111216"
                                                                  Opacity="0.04" />
                                            </Border.Effect>
                                            <ListBox x:Name="LstRecentSignInAccounts"
                                                     ItemsSource="{Binding FilteredSignInAccounts}"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     MaxHeight="168"
                                                     SelectionChanged="LstRecentSignInAccounts_SelectionChanged"
                                                     ItemContainerStyle="{StaticResource RecentSignInAccountItemContainerStyle}"
                                                     ItemTemplate="{StaticResource RecentSignInAccountItemTemplate}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock x:Name="TxtSignInAccountHint"
                                               Margin="2,8,0,0"
                                               Foreground="#D14B4B"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                </StackPanel>

                                <Grid x:Name="SignInCredentialSection"
                                      Width="320"
                                      HorizontalAlignment="Left"
                                      MaxHeight="0"
                                      Opacity="0"
                                      ClipToBounds="True"
                                      IsHitTestVisible="False">
                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" FontWeight="Bold" Foreground="#1D1D1F" />
                                            <PasswordBox x:Name="TxtSignInPassword" Width="320" HorizontalAlignment="Left" KeyDown="TxtSignInPassword_KeyDown" />
                                        </StackPanel>

                                        <Button x:Name="BtnSignIn"
                                                Content="进入系统"
                                                Width="320"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource PremiumButtonStyle}"
                                                Margin="0,14,0,0"
                                                Click="BtnSignIn_Click" />
                                    </StackPanel>
                                </Grid>

                                <Grid Width="320" Margin="0,22,0,0" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnOpenPasswordRecovery"
                                            Grid.Column="0"
                                            Content="忘记密码"
                                            Style="{StaticResource LinkButtonStyle}"
                                            Click="BtnOpenPasswordRecovery_Click" />
                                    <Button x:Name="BtnOpenAccountManagement"
                                            Grid.Column="2"
                                            Content="账户管理"
                                            Style="{StaticResource LinkButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Click="BtnOpenAccountManagement_Click" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid x:Name="PasswordRecoveryPanel" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Opacity="0">
                        <Grid.RenderTransform>
                            <TranslateTransform X="0" />
                        </Grid.RenderTransform>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalAlignment="Center">
                        <Grid Margin="0,26,0,30">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="重置主密码" FontWeight="Bold" FontSize="26" Foreground="#1D1D1F" />
                                        <TextBlock Text="{Binding RecoveryResetHintMessage}" Foreground="#86868B" FontSize="14" Margin="0,6,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button x:Name="BtnBackToSignIn"
                                            Grid.Column="1"
                                            Style="{StaticResource BackIconButtonStyle}"
                                            VerticalAlignment="Top"
                                            Click="BtnBackToSignIn_Click" />
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="账号" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="TxtRecoveryOwnerUsername"
                                                 TextChanged="TxtRecoveryOwnerUsername_TextChanged" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                                        <PasswordBox x:Name="TxtRecoveryOwnerPin" MaxLength="6" />
                                    </StackPanel>
                                </Grid>

                                <Border Background="#F5F5F7"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,20">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRecoveryOwnerSection}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="恢复验证"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1D1D1F" />
                                        <TextBlock Text="主账号恢复时，需要该账号的 Recovery Key 和新主密码。"
                                                   Margin="0,8,0,0"
                                                   Foreground="#86868B"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />

                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock Text="恢复密钥" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="TxtRecoveryKeyInput" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="#F5F5F7"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,20">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRecoveryMemberSection}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="管理员验证"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1D1D1F" />
                                        <TextBlock Text="成员账号恢复时，需要管理员账号、主密码和 PIN 完成验证。"
                                                   Margin="0,8,0,0"
                                                   Foreground="#86868B"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="管理员账号" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="TxtRecoveryAdminUsername" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="管理员 PIN" Style="{StaticResource FieldLabel}" />
                                                <PasswordBox x:Name="TxtRecoveryAdminPin" MaxLength="6" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Text="管理员主密码" Style="{StaticResource FieldLabel}" />
                                            <PasswordBox x:Name="TxtRecoveryAdminPassword" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="#F5F5F7"
                                        CornerRadius="18"
                                        Padding="18"
                                        Margin="0,0,0,20">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="0.62" />
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanEditRecoveryNewPassword}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="IsEnabled" Value="True" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="设置新密码"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1D1D1F" />
                                        <TextBlock Text="验证通过后，才能设置该账号的新主密码。"
                                                   Margin="0,8,0,0"
                                                   Foreground="#86868B"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock Text="新密码" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="TxtRecoveryNewPassword" />
                                            <TextBlock Text="至少 8 位，含大小写字母和数字，且不能包含空白或前后空格。"
                                                       Margin="0,6,0,0"
                                                       Foreground="#86868B"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="BtnResetOwnerPassword"
                                        Content="{Binding RecoveryPrimaryActionLabel}"
                                        Style="{StaticResource PremiumButtonStyle}"
                                        Margin="0,12,0,0"
                                        Click="BtnResetOwnerPassword_Click" />
                                <TextBlock x:Name="TxtNotice"
                                           Margin="0,14,0,0"
                                           Foreground="#000000"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </Grid>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="AccountManagementPanel"
                          Visibility="Collapsed"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Opacity="0">
                        <Grid.RenderTransform>
                            <TranslateTransform X="0" />
                        </Grid.RenderTransform>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,0">
                            <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  MaxWidth="612">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="账户管理"
                                               FontWeight="Bold"
                                               FontSize="24"
                                               Foreground="#1D1D1F"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="BtnBackFromAccountManagement"
                                            Grid.Column="1"
                                            Style="{StaticResource BackIconButtonStyle}"
                                            Click="BtnBackFromAccountManagement_Click" />
                                </Grid>

                                <Border Grid.Row="1"
                                        Background="#F5F5F7"
                                        CornerRadius="18"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1D1D1F">
                                            <Run Text="已有账户" />
                                            <Run Text=" " />
                                            <Run Text="{Binding AccountDirectory.Count, Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock Text="{Binding AccountManagementStatus}"
                                                   Margin="0,8,0,0"
                                                   Foreground="#86868B"
                                                   FontSize="12"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAccountManagementStatus}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <ListBox x:Name="LstAccountDirectory"
                                                 ItemsSource="{Binding AccountDirectory}"
                                                 Margin="0,12,0,0"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 MaxHeight="220"
                                                 ItemContainerStyle="{StaticResource AccountDirectoryItemContainerStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="AccountCard"
                                                            Background="#FFFFFF"
                                                            BorderBrush="#E5E5EA"
                                                            BorderThickness="1"
                                                            CornerRadius="14"
                                                            Padding="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#1D1D1F" />
                                                                <TextBlock Text="{Binding Username, Mode=OneWay, StringFormat=@{0}}"
                                                                           Margin="0,6,0,0"
                                                                           Foreground="#6E6E73"
                                                                           FontSize="12" />
                                                            </StackPanel>
                                                            <Grid Grid.Column="1"
                                                                  Margin="12,0,0,0">
                                                                <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Top">
                                                                    <Border Padding="8,2"
                                                                            Background="#E7F1FF"
                                                                            CornerRadius="10"
                                                                            Margin="0,0,8,0">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsMostRecentlyLoggedIn, Mode=OneWay}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="最近登录"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#175CD3" />
                                                                    </Border>
                                                                    <Border Padding="8,2"
                                                                            Background="#F1F2F6"
                                                                            CornerRadius="10"
                                                                            Margin="0,0,8,0">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Role, Mode=OneWay}" Value="Owner">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#4A4A52">
                                                                            <Run Text="主账号" />
                                                                        </TextBlock>
                                                                    </Border>
                                                                    <Border Padding="8,2"
                                                                            Background="#FCE8E8"
                                                                            CornerRadius="10">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsEnabled, Mode=OneWay}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="已禁用"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#B42318" />
                                                                    </Border>
                                                                </StackPanel>
                                                                <Button Grid.Column="1"
                                                                        Content="删除账户"
                                                                        Tag="{Binding AccountId}"
                                                                        Width="84"
                                                                        Height="30"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center"
                                                                        Background="#FCE8E8"
                                                                        Foreground="#B42318"
                                                                        BorderBrush="#F6C7C7"
                                                                        Click="BtnRequestDeleteAccount_Click">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Role, Mode=OneWay}" Value="Owner">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter TargetName="AccountCard" Property="BorderBrush" Value="#E5E5EA" />
                                                            <Setter TargetName="AccountCard" Property="Background" Value="#FFFFFF" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                    </StackPanel>
                                </Border>

                                <Button x:Name="BtnCreateManagedAccount"
                                        Grid.Row="2"
                                        Content="创建新账号"
                                        Style="{StaticResource PremiumButtonStyle}"
                                        Height="52"
                                        Width="208"
                                        HorizontalAlignment="Center"
                                        Margin="0,28,0,0"
                                        Click="BtnCreateManagedAccount_Click" />

                            </Grid>
                        </ScrollViewer>

                    </Grid>

                    <views:LoginCreateAccountPanel x:Name="CreateManagedAccountPanel" />

                    <views:LoginToastOverlay x:Name="ToastOverlay" Panel.ZIndex="40" />

                </Grid>

                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Panel.ZIndex="20">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAccountManagementNoticeOpen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="#D9F7F7FA"
                                CornerRadius="0,24,24,0" />

                        <Border Width="430"
                                Padding="24"
                                Background="#FFFFFF"
                                CornerRadius="18"
                                BorderBrush="#E5E5EA"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="10" Direction="270" Color="#000000" Opacity="0.12" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="使用说明"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1D1D1F" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#6E6E73"
                                           FontSize="13"
                                           TextWrapping="Wrap">
                                    此处仅展示已有账号概览。
                                    <LineBreak />
                                    主账号无法查看其他账号密码；
                                    <LineBreak />
                                    如需删除已有账户，必须通过主账号验证并输入 PIN 二次确认。
                                </TextBlock>
                                <Button Content="我已知晓"
                                        Width="120"
                                        Height="42"
                                        HorizontalAlignment="Right"
                                        Margin="0,20,0,0"
                                        Style="{StaticResource PremiumButtonStyle}"
                                        Click="BtnAcknowledgeAccountManagementNotice_Click" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                    <!-- ============================ -->
                    <!-- 首次初始化面板 (Create Owner) -->
                    <!-- ============================ -->
                    <views:LoginOwnerCreatePanel x:Name="OwnerCreatePanel" Grid.Column="1" Visibility="Collapsed" />

                    <Grid Grid.ColumnSpan="2"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Panel.ZIndex="30">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPendingDeleteAccount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="#CCF7F7FA"
                                CornerRadius="24" />

                        <Border Width="452"
                                MaxWidth="452"
                                Padding="24"
                                Background="#FFF7F2"
                                BorderBrush="#F2D3BE"
                                BorderThickness="1"
                                CornerRadius="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="24"
                                MouseLeftButtonDown="DeleteAccountDialog_MouseLeftButtonDown">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24"
                                                  ShadowDepth="10"
                                                  Direction="270"
                                                  Color="#000000"
                                                  Opacity="0.12" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding PendingDeleteAccountConfirmationTitle}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="#1D1D1F"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="152" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="主账号" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="TxtDeleteOwnerUsername" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                                        <PasswordBox x:Name="TxtDeleteOwnerPin" MaxLength="6" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" />
                                    <PasswordBox x:Name="TxtDeleteOwnerPassword" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,18,0,0">
                                    <Button Content="取消"
                                            Width="90"
                                            Margin="0,0,10,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="BtnCancelDeleteAccount_Click" />
                                    <Button Content="确认删除"
                                            Width="110"
                                            Style="{StaticResource PremiumButtonStyle}"
                                            Click="BtnConfirmDeleteAccount_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="TxtError" Grid.Column="1" Foreground="#FF3B30" FontSize="13" FontWeight="SemiBold" Visibility="Collapsed" TextWrapping="Wrap" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" />
                </Grid>
        </Border>
        </Border>
</Window>
