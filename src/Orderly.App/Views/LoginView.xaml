                                                               FontSize="12"
                                                               TextWrapping="Wrap" />

                                                    <Grid Margin="0,14,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="16" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="用户名" Style="{StaticResource FieldLabel}" />
                                                            <TextBox x:Name="TxtCreateMemberUsername" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="昵称" Style="{StaticResource FieldLabel}" />
                                                            <TextBox x:Name="TxtCreateMemberDisplayName" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,12,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="16" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" />
                                                            <PasswordBox x:Name="TxtCreateMemberPassword" />
                                                            <TextBlock Text="至少8位，包含大小写字母和数字，不能含空白或首尾空格。"
                                                                       Margin="0,6,0,0"
                                                                       Foreground="#86868B"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                                                            <PasswordBox x:Name="TxtCreateMemberPin" MaxLength="6" />
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Button x:Name="BtnSubmitCreateManagedAccount"
                                                    Content="{Binding CreateManagedAccountPrimaryActionLabel}"
                                                    Style="{StaticResource PremiumButtonStyle}"
                                                    Width="220"
                                                    Height="52"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,22,0,0"
                                                    Click="BtnSubmitCreateManagedAccount_Click" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <Grid IsHitTestVisible="False"
                          Panel.ZIndex="40">
                        <Border x:Name="ErrorToastOverlay"
                                Visibility="Collapsed"
                                Opacity="0"
                                Padding="22,16"
                                Background="#FFF6F5"
                                BorderBrush="#F4C7C3"
                                BorderThickness="1"
                                CornerRadius="18"
                                MaxWidth="620"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,126,0,0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ErrorToastTranslateTransform" Y="10" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24"
                                                  ShadowDepth="8"
                                                  Direction="270"
                                                  Color="#101114"
                                                  Opacity="0.12" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="28"
                                        Height="28"
                                        Background="#FDE8E6"
                                        CornerRadius="14"
                                        Grid.Column="0"
                                        VerticalAlignment="Top">
                                    <Grid>
                                        <Path Data="M8,8 L20,20 M20,8 L8,20"
                                              Width="12"
                                              Height="12"
                                              Stretch="Fill"
                                              Stroke="#D92D20"
                                              StrokeThickness="2.2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,0,0,0" />
                                    </Grid>
                                </Border>
                                <TextBlock x:Name="TxtErrorToast"
                                           Grid.Column="2"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#B42318"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="520" />
                            </Grid>
                        </Border>

                        <Border x:Name="SuccessToastOverlay"
                                Visibility="Collapsed"
                                Opacity="0"
                                Padding="22,16"
                                Background="#FDFDFE"
                                BorderBrush="#E2E6ED"
                                BorderThickness="1"
                                CornerRadius="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,126,0,0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="SuccessToastTranslateTransform" Y="10" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24"
                                                  ShadowDepth="8"
                                                  Direction="270"
                                                  Color="#101114"
                                                  Opacity="0.12" />
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28"
                                        Height="28"
                                        Background="#E8F7EE"
                                        CornerRadius="14"
                                        Margin="0,0,12,0">
                                    <Grid>
                                        <Path Data="M7,14 L12,19 L21,9"
                                              Width="14"
                                              Height="10"
                                              Stretch="Fill"
                                              Stroke="#18864B"
                                              StrokeThickness="2.2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,0" />
                                    </Grid>
                                </Border>
                                <TextBlock x:Name="TxtSuccessToast"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#1D1D1F"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                </Grid>

                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Panel.ZIndex="20">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAccountManagementNoticeOpen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="#D9F7F7FA"
                                CornerRadius="0,24,24,0" />

                        <Border Width="430"
                                Padding="24"
                                Background="#FFFFFF"
                                CornerRadius="18"
                                BorderBrush="#E5E5EA"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="10" Direction="270" Color="#000000" Opacity="0.12" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="使用说明"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1D1D1F" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#6E6E73"
                                           FontSize="13"
                                           TextWrapping="Wrap">
                                    此处仅展示已有账号概览。
                                    <LineBreak />
                                    主账号无法查看其他账号密码；
                                    <LineBreak />
                                    如需删除已有账户，必须通过主账号验证并输入 PIN 二次确认。
                                </TextBlock>
                                <Button Content="我已知晓"
                                        Width="120"
                                        Height="42"
                                        HorizontalAlignment="Right"
                                        Margin="0,20,0,0"
                                        Style="{StaticResource PremiumButtonStyle}"
                                        Click="BtnAcknowledgeAccountManagementNotice_Click" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                    <!-- ============================ -->
                    <!-- 首次初始化面�?(Create Owner) -->
                    <!-- ============================ -->
                    <Grid x:Name="OwnerCreatePanel" Grid.Column="1" Visibility="Collapsed" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="初始化系统" FontWeight="Bold" FontSize="26" Foreground="#1D1D1F" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="1" Text="创建首个管理员全局账户" Foreground="#86868B" FontSize="14" Margin="0,0,0,32" />
                        <StackPanel Grid.Row="2" Margin="0,0,0,8">
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="账号" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="TxtOwnerUsername" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="昵称" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="TxtOwnerDisplayName" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" />
                                    <PasswordBox x:Name="TxtOwnerPassword" />
                                    <TextBlock Text="至少 8 位，含大小写字母和数字，且不能包含空白或前后空格。"
                                               Margin="0,6,0,0"
                                               Foreground="#86868B"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                                    <PasswordBox x:Name="TxtOwnerPin" MaxLength="6" />
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="ChkImportLegacyDb" IsChecked="{Binding ImportLegacyDatabase}" Visibility="Collapsed" />
                            <CheckBox x:Name="ChkOverwriteLegacyTarget" IsChecked="{Binding OverwriteLegacyTarget}" Visibility="Collapsed" />

                            <Button x:Name="BtnCreateOwner" Content="创建并登录" Style="{StaticResource PremiumButtonStyle}" Margin="0,8,0,0" Click="BtnCreateOwner_Click" />
                        </StackPanel>

                        <Border x:Name="RecoveryPanel"
                                Grid.RowSpan="3"
                                Background="#66FFFFFF"
                                CornerRadius="24"
                                Visibility="Collapsed">
                            <Grid>
                                <Border Width="420"
                                        Padding="28"
                                        Background="#FFFFFF"
                                        CornerRadius="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="30" ShadowDepth="10" Direction="270" Color="#000000" Opacity="0.12" />
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="保存 Recovery Key"
                                                   FontWeight="Bold"
                                                   FontSize="24"
                                                   Foreground="#1D1D1F" />
                                        <TextBlock Text="这是重置管理员主密码的唯一离线密钥。请先保存，再继续进入系统。"
                                                   Margin="0,10,0,0"
                                                   Foreground="#86868B"
                                                   FontSize="14"
                                                   TextWrapping="Wrap" />

                                        <Border Margin="0,24,0,0"
                                                Padding="18"
                                                Background="#F5F5F7"
                                                CornerRadius="14">
                                            <TextBlock x:Name="TxtRecoveryKeyValue"
                                                       FontFamily="Consolas"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="#000000"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <CheckBox x:Name="ChkRecoverySaved"
                                                  Content="我已妥善保存此密钥"
                                                  Margin="0,18,0,0"
                                                  Checked="ChkRecoverySaved_OnChanged"
                                                  Unchecked="ChkRecoverySaved_OnChanged"
                                                  Foreground="#1D1D1F"
                                                  FontWeight="SemiBold" />

                                        <Button x:Name="BtnContinueAfterRecovery"
                                                Content="确认并进入系统"
                                                Height="48"
                                                Margin="0,24,0,0"
                                                IsEnabled="False"
                                                Click="BtnContinueAfterRecovery_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#000000"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Background" Value="#E5E5EA"/>
                                                            <Setter Property="Foreground" Value="#A1A1A6"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.ColumnSpan="2"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Panel.ZIndex="30">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPendingDeleteAccount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="#CCF7F7FA"
                                CornerRadius="24" />

                        <Border Width="452"
                                MaxWidth="452"
                                Padding="24"
                                Background="#FFF7F2"
                                BorderBrush="#F2D3BE"
                                BorderThickness="1"
                                CornerRadius="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="24"
                                MouseLeftButtonDown="DeleteAccountDialog_MouseLeftButtonDown">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24"
                                                  ShadowDepth="10"
                                                  Direction="270"
                                                  Color="#000000"
                                                  Opacity="0.12" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding PendingDeleteAccountConfirmationTitle}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="#1D1D1F"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="152" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="主账号" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="TxtDeleteOwnerUsername" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                                        <PasswordBox x:Name="TxtDeleteOwnerPin" MaxLength="6" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" />
                                    <PasswordBox x:Name="TxtDeleteOwnerPassword" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,18,0,0">
                                    <Button Content="取消"
                                            Width="90"
                                            Margin="0,0,10,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="BtnCancelDeleteAccount_Click" />
                                    <Button Content="确认删除"
                                            Width="110"
                                            Style="{StaticResource PremiumButtonStyle}"
                                            Click="BtnConfirmDeleteAccount_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="TxtError" Grid.Column="1" Foreground="#FF3B30" FontSize="13" FontWeight="SemiBold" Visibility="Collapsed" TextWrapping="Wrap" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" />
                </Grid>
        </Border>
        </Border>
</Window>
