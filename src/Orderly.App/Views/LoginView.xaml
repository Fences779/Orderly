                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAccountManagementStatus}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

