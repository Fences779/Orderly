<UserControl x:Class="Orderly.App.Views.LoginPasswordRecoveryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Opacity="0">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.B.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform X="0" />
        </Grid.RenderTransform>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Center">
        <Grid Margin="0,26,0,30">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="重置主密码" FontWeight="Bold" FontSize="26" Foreground="#1D1D1F" />
                        <TextBlock Text="{Binding RecoveryResetHintMessage}" Foreground="#86868B" FontSize="14" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button x:Name="BtnBackToSignIn"
                            Grid.Column="1"
                            Style="{StaticResource BackIconButtonStyle}"
                            VerticalAlignment="Top"
                            Click="BtnBackToSignIn_Click" />
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="账号" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtRecoveryOwnerUsername"
                                 TextChanged="TxtRecoveryOwnerUsername_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                        <PasswordBox x:Name="TxtRecoveryOwnerPin" MaxLength="6" />
                    </StackPanel>
                </Grid>

                <Border Background="#F5F5F7"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,0,20">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRecoveryOwnerSection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="恢复验证"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1D1D1F" />
                        <TextBlock Text="主账号恢复时，需要该账号的 Recovery Key 和新主密码。"
                                   Margin="0,8,0,0"
                                   Foreground="#86868B"
                                   FontSize="12"
                                   TextWrapping="Wrap" />

                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Text="恢复密钥" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="TxtRecoveryKeyInput" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#F5F5F7"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,0,20">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRecoveryMemberSection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="管理员验证"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1D1D1F" />
                        <TextBlock Text="成员账号恢复时，需要管理员账号、主密码和 PIN 完成验证。"
                                   Margin="0,8,0,0"
                                   Foreground="#86868B"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="管理员账号" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="TxtRecoveryAdminUsername" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="管理员 PIN" Style="{StaticResource FieldLabel}" />
                                <PasswordBox x:Name="TxtRecoveryAdminPin" MaxLength="6" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="管理员主密码" Style="{StaticResource FieldLabel}" />
                            <PasswordBox x:Name="TxtRecoveryAdminPassword" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#F5F5F7"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,0,20">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0.62" />
                            <Setter Property="IsEnabled" Value="False" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanEditRecoveryNewPassword}" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="IsEnabled" Value="True" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="设置新密码"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1D1D1F" />
                        <TextBlock Text="验证通过后，才能设置该账号的新主密码。"
                                   Margin="0,8,0,0"
                                   Foreground="#86868B"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Text="新密码" Style="{StaticResource FieldLabel}" />
                            <PasswordBox x:Name="TxtRecoveryNewPassword" />
                            <TextBlock Text="至少 8 位，含大小写字母和数字，且不能包含空白或前后空格。"
                                       Margin="0,6,0,0"
                                       Foreground="#86868B"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button x:Name="BtnResetOwnerPassword"
                        Content="{Binding RecoveryPrimaryActionLabel}"
                        Style="{StaticResource PremiumButtonStyle}"
                        Margin="0,12,0,0"
                        Click="BtnResetOwnerPassword_Click" />
                <TextBlock x:Name="TxtNotice"
                           Margin="0,14,0,0"
                           Foreground="#000000"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
