<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        StatePresenters.xaml — 可复用状态呈现模板（commerce-settings-ui-rebuild 任务 3.2）
        ========================================================================================
        作用范围：八个被重建业务页与设置页（经 App.xaml 集中合并，合并入口由任务 3.3 负责，
                  本文件不修改 App.xaml）。

        提供以下可复用呈现资源（均与具体 ViewModel 类型解耦，用通用占位/Content 承载文案）：
          1. 状态徽标（胶囊形，状态四态「底+前景」，圆点图标 + 文字双载体，不以颜色为唯一信息载体）
          2. 加载占位（骨架块 + 指示条 + 组合加载态）
          3. 空状态占位（图标 + 标题 + 说明，含便捷模板与可组合构件样式）
          4. 错误提示（危险色提示条，图标 + 文案）
          5. 行级校验错误（内联字段错误：图标 + 文案）

        令牌引用约定（design.md §令牌词表组织策略）：
          - 颜色语义画刷一律以 DynamicResource 引用（支持亮/暗主题整体替换即时切换）。
          - 非颜色令牌（字号 UiFont* / 圆角 UiRadius* / 间距 UiSpace* / 字重 UiFontWeight*
            / 字体族 UiFontFamily*）以 StaticResource 引用 Tokens/Typography.xaml、Tokens/Shape.xaml。
          - 本文件零硬编码颜色/字号/圆角字面量；其中 WPF 的 Thickness（Margin/Padding/
            BorderThickness）无法直接引用 Double 类型的 UiSpace 令牌，故在本文件顶部以同一
            4pt 栅格（4/8/12/16/24/32）派生一组 Thickness 布局令牌，供下方样式统一引用，
            消费侧引用具名令牌而非散落的魔法数值。
    -->

    <!-- ==================== Thickness 布局令牌（UiSpace 4pt 栅格的 Thickness 投影） ==================== -->
    <!-- WPF Margin/Padding/BorderThickness 需 Thickness 类型，无法直接引用 Double 型 UiSpace 令牌，
         故在此以与 Shape.xaml 相同的 4pt 栅格派生，集中定义、统一引用。 -->
    <Thickness x:Key="UiBorderThin">1</Thickness>
    <Thickness x:Key="UiBadgePadding">12,4,12,4</Thickness>
    <Thickness x:Key="UiNoticePadding">16,12,16,12</Thickness>
    <Thickness x:Key="UiEmptyStatePadding">24,32,24,32</Thickness>
    <Thickness x:Key="UiPresenterGapRight">0,0,8,0</Thickness>
    <Thickness x:Key="UiPresenterGapBottom">0,0,0,8</Thickness>
    <Thickness x:Key="UiPresenterGapBottomLg">0,0,0,12</Thickness>
    <Thickness x:Key="UiFieldErrorMargin">0,4,0,0</Thickness>

    <!-- ============================================================================ -->
    <!-- 1. 状态徽标（胶囊形 · 状态四态 · 圆点+文字双载体）                              -->
    <!-- ============================================================================ -->
    <!--
        用法：<ContentControl Style="{StaticResource UiBadgeSuccessStyle}" Content="已完成" />
        徽标同时承载「圆点图标 + 文字」，颜色仅作强化，不作唯一信息载体（满足需求 12.4）。
        胶囊外形采用 UiRadiusLg 圆角令牌；底色用 *SoftBrush、前景（含圆点与文字）用 *TextBrush。
    -->
    <ControlTemplate x:Key="UiStatusBadgeTemplate" TargetType="ContentControl">
        <Border Background="{TemplateBinding Background}"
                CornerRadius="{StaticResource UiRadiusLg}"
                Padding="{StaticResource UiBadgePadding}"
                SnapsToDevicePixels="True">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="{StaticResource UiSpaceXs}"
                         Height="{StaticResource UiSpaceXs}"
                         Fill="{TemplateBinding Foreground}"
                         VerticalAlignment="Center"
                         Margin="{StaticResource UiPresenterGapRight}" />
                <ContentPresenter VerticalAlignment="Center"
                                  TextElement.Foreground="{TemplateBinding Foreground}" />
            </StackPanel>
        </Border>
    </ControlTemplate>

    <Style x:Key="UiStatusBadgeBaseStyle" TargetType="ContentControl">
        <Setter Property="Template" Value="{StaticResource UiStatusBadgeTemplate}" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontCaption}" />
        <Setter Property="FontWeight" Value="{StaticResource UiFontWeightMedium}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- 成功（绿）：已完成 / 正常 / 净流入 -->
    <Style x:Key="UiBadgeSuccessStyle" TargetType="ContentControl" BasedOn="{StaticResource UiStatusBadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
    </Style>

    <!-- 警告（黄）：需要关注 / 低库存预警 -->
    <Style x:Key="UiBadgeWarningStyle" TargetType="ContentControl" BasedOn="{StaticResource UiStatusBadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource WarmSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource WarmTextBrush}" />
    </Style>

    <!-- 错误（红）：异常 / 逾期 / 净流出 / 校验失败 -->
    <Style x:Key="UiBadgeErrorStyle" TargetType="ContentControl" BasedOn="{StaticResource UiStatusBadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
    </Style>

    <!-- 信息（蓝）：待处理 / 提示 -->
    <Style x:Key="UiBadgeInfoStyle" TargetType="ContentControl" BasedOn="{StaticResource UiStatusBadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BlueSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BlueTextBrush}" />
    </Style>

    <!-- 中性（灰）：默认 / 未分类 / 无状态 -->
    <Style x:Key="UiBadgeNeutralStyle" TargetType="ContentControl" BasedOn="{StaticResource UiStatusBadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource GreySoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource GreyTextBrush}" />
    </Style>

    <!-- ============================================================================ -->
    <!-- 2. 加载占位（骨架块 / 指示条 / 组合加载态）                                     -->
    <!-- ============================================================================ -->
    <!--
        骨架块：用于占位将要加载的文本行 / 卡片块；带轻微呼吸（透明度）动画暗示"加载中"。
        用法：<Border Style="{StaticResource UiSkeletonBlockStyle}" Width="..." /> 可重复堆叠。
    -->
    <Style x:Key="UiSkeletonBlockStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource UiRadiusSm}" />
        <Setter Property="MinHeight" Value="{StaticResource UiSpaceMd}" />
        <Setter Property="Margin" Value="{StaticResource UiPresenterGapBottomLg}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0.45" To="0.9"
                                         Duration="0:0:0.9"
                                         AutoReverse="True"
                                         RepeatBehavior="Forever" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- 加载指示条：纤细的不确定进度条，主色前景。 -->
    <Style x:Key="UiLoadingBarStyle" TargetType="ProgressBar">
        <Setter Property="IsIndeterminate" Value="True" />
        <Setter Property="Height" Value="{StaticResource UiSpaceXxs}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!--
        组合加载态：居中的指示条 + "加载中…" 说明，铺满可用宽度。
        用法：<ContentControl Style="{StaticResource UiLoadingStateStyle}" />
    -->
    <ControlTemplate x:Key="UiLoadingStateTemplate" TargetType="ContentControl">
        <StackPanel VerticalAlignment="Center" Margin="{StaticResource UiEmptyStatePadding}">
            <ProgressBar Style="{StaticResource UiLoadingBarStyle}"
                         HorizontalAlignment="Stretch"
                         Margin="{StaticResource UiPresenterGapBottomLg}" />
            <TextBlock Text="加载中…"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="{DynamicResource UiFontCaption}"
                       FontFamily="{StaticResource UiFontFamilyCjk}" />
        </StackPanel>
    </ControlTemplate>

    <Style x:Key="UiLoadingStateStyle" TargetType="ContentControl">
        <Setter Property="Template" Value="{StaticResource UiLoadingStateTemplate}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ============================================================================ -->
    <!-- 3. 空状态占位（图标 + 标题 + 说明）                                             -->
    <!-- ============================================================================ -->
    <!--
        可组合构件样式：页面可用面板 + 图标 + 标题 + 说明自由组合多行文案。
        亦提供便捷模板 UiEmptyStateStyle：内置图标 + 默认标题，Content 承载说明文案。
    -->
    <Style x:Key="UiEmptyStatePanelStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="{StaticResource UiEmptyStatePadding}" />
    </Style>

    <Style x:Key="UiEmptyStateGlyphStyle" TargetType="TextBlock">
        <Setter Property="Text" Value="□" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontDisplay}" />
        <Setter Property="Foreground" Value="{DynamicResource CaptionTextBrush}" />
        <Setter Property="Margin" Value="{StaticResource UiPresenterGapBottomLg}" />
    </Style>

    <Style x:Key="UiEmptyStateTitleStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontSubtitle}" />
        <Setter Property="FontWeight" Value="{StaticResource UiFontWeightMedium}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
        <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
        <Setter Property="Margin" Value="{StaticResource UiPresenterGapBottom}" />
    </Style>

    <Style x:Key="UiEmptyStateCaptionStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontCaption}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
    </Style>

    <ControlTemplate x:Key="UiEmptyStateTemplate" TargetType="ContentControl">
        <StackPanel Style="{StaticResource UiEmptyStatePanelStyle}">
            <TextBlock Style="{StaticResource UiEmptyStateGlyphStyle}" />
            <TextBlock Text="暂无数据" Style="{StaticResource UiEmptyStateTitleStyle}" />
            <ContentPresenter HorizontalAlignment="Center"
                              TextElement.Foreground="{DynamicResource SecondaryTextBrush}" />
        </StackPanel>
    </ControlTemplate>

    <Style x:Key="UiEmptyStateStyle" TargetType="ContentControl">
        <Setter Property="Template" Value="{StaticResource UiEmptyStateTemplate}" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontCaption}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ============================================================================ -->
    <!-- 4. 错误提示（危险色提示条 · 图标 + 文案）                                       -->
    <!-- ============================================================================ -->
    <!--
        用法：<ContentControl Style="{StaticResource UiErrorNoticeStyle}" Content="{Binding ErrorMessage}" />
        仅呈现错误文案与图标；重试入口由页面以既有 RefreshCommand 绑定独立按钮承载（不在此模板内新增命令通道）。
        图标 + 文字与颜色共同表达错误，不以颜色为唯一信息载体。
    -->
    <ControlTemplate x:Key="UiErrorNoticeTemplate" TargetType="ContentControl">
        <Border Background="{DynamicResource DangerSoftBrush}"
                BorderBrush="{DynamicResource DangerBorderBrush}"
                BorderThickness="{StaticResource UiBorderThin}"
                CornerRadius="{StaticResource UiRadiusMd}"
                Padding="{StaticResource UiNoticePadding}"
                SnapsToDevicePixels="True">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚠"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DangerTextBrush}"
                           FontSize="{DynamicResource UiFontSubtitle}"
                           Margin="{StaticResource UiPresenterGapRight}" />
                <ContentPresenter VerticalAlignment="Center"
                                  TextElement.Foreground="{DynamicResource DangerTextBrush}" />
            </StackPanel>
        </Border>
    </ControlTemplate>

    <Style x:Key="UiErrorNoticeStyle" TargetType="ContentControl">
        <Setter Property="Template" Value="{StaticResource UiErrorNoticeTemplate}" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontBodySm}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- ============================================================================ -->
    <!-- 5. 行级校验错误（内联字段错误 · 图标 + 文案）                                   -->
    <!-- ============================================================================ -->
    <!--
        用法：<ContentControl Style="{StaticResource UiFieldErrorStyle}" Content="{Binding XxxError}" />
        置于表单字段下方，呈现行级校验提示；仅展示既有错误字段，不新增校验逻辑。
    -->
    <ControlTemplate x:Key="UiFieldErrorTemplate" TargetType="ContentControl">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="{StaticResource UiFieldErrorMargin}">
            <TextBlock Text="⚠"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DangerTextBrush}"
                       FontSize="{DynamicResource UiFontCaption}"
                       Margin="{StaticResource UiPresenterGapRight}" />
            <ContentPresenter VerticalAlignment="Center"
                              TextElement.Foreground="{DynamicResource DangerTextBrush}" />
        </StackPanel>
    </ControlTemplate>

    <Style x:Key="UiFieldErrorStyle" TargetType="ContentControl">
        <Setter Property="Template" Value="{StaticResource UiFieldErrorTemplate}" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontCaption}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!-- 行级错误纯文本样式（无图标场景，直接套用于 TextBlock） -->
    <Style x:Key="UiFieldErrorTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource UiFontCaption}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamilyCjk}" />
        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="{StaticResource UiFieldErrorMargin}" />
    </Style>

</ResourceDictionary>
