<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 浅色模式画笔资源 -->
    <!-- 主色：墨蓝，四级（默认/悬停/按下/禁用）+ 浅底 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#1F4E79" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1A4369" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#143352" />
    <SolidColorBrush x:Key="PrimaryDisabledBrush" Color="#AEBECF" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#E8EEF5" />
    <SolidColorBrush x:Key="HeadingBrush" Color="#1D1D1F" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#86868B" />
    <SolidColorBrush x:Key="CaptionTextBrush" Color="#A0A5AF" />
    <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#F7F7F9" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#ECECEF" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#FFFFFF" />
    <!-- 状态：成功（绿）底色 + 可读前景，对比度 ≈ 5.7:1 -->
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#E7F4EC" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#176B47" />
    <!-- 状态：警告（黄）底色 + 可读前景，对比度 ≈ 4.8:1 -->
    <SolidColorBrush x:Key="WarmSoftBrush" Color="#FBF0E0" />
    <SolidColorBrush x:Key="WarmTextBrush" Color="#9A5B00" />
    <!-- 状态：信息（蓝）底色 + 可读前景，对比度 ≈ 5.5:1 -->
    <SolidColorBrush x:Key="BlueSoftBrush" Color="#E8F1FB" />
    <SolidColorBrush x:Key="BlueTextBrush" Color="#1A5FB4" />
    <SolidColorBrush x:Key="PurpleSoftBrush" Color="#F2EBFC" />
    <SolidColorBrush x:Key="PurpleTextBrush" Color="#7A3EDB" />
    <!-- 状态：错误（红）底色 + 可读前景，对比度 ≈ 5.1:1 -->
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FCEAEA" />
    <SolidColorBrush x:Key="DangerBorderBrush" Color="#F5C9C9" />
    <SolidColorBrush x:Key="DangerTextBrush" Color="#C02626" />
    <SolidColorBrush x:Key="GreySoftBrush" Color="#F2F4F7" />
    <SolidColorBrush x:Key="GreyTextBrush" Color="#667085" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#DFE3EA" />
    <SolidColorBrush x:Key="TimelineBrush" Color="#DFE3EA" />
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F5F7" />

    <!-- 焦点边框画刷（键盘可达性） -->
    <SolidColorBrush x:Key="UiFocusBrush" Color="#2F6FB5" />
    
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MutedBrush" Color="#86868B" />
    <SolidColorBrush x:Key="PremiumDarkBrush" Color="#17181C" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FBFAF6" />
    <SolidColorBrush x:Key="SidebarBrandBrush" Color="#17211D" />
</ResourceDictionary>
