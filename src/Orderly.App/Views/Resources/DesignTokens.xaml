<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!--
        DesignTokens.xaml — 设置页与我的页精装升级专用设计令牌字典
        - 仅供「设置页 (SettingsView)」与「我的页 (MeProfileView)」两页消费，
          通过各自的 UserControl.Resources 按需 Merge，避免污染其它页面。
        - 沿用既有画刷键（HeadingBrush / SecondaryTextBrush / BorderBrushSoft /
          PrimaryBrush / AccentSoftBrush / DangerTextBrush / MutedBrush /
          PageBackgroundBrush / SurfaceRaisedBrush / SurfaceSoftBrush / CaptionTextBrush），
          全部以 DynamicResource 引用以保持深浅色主题切换正确。
        - 新增键采用 Refine* / Radius* / Elevation* / Space* / Type* 前缀，避免命名冲突。
        参见 design.md §3「设计令牌与视觉系统」。
    -->

    <!-- ==================== 3.1 圆角刻度 (Corner Radius Scale) ==================== -->
    <CornerRadius x:Key="RadiusSm">8</CornerRadius>
    <CornerRadius x:Key="RadiusMd">12</CornerRadius>
    <CornerRadius x:Key="RadiusLg">16</CornerRadius>
    <CornerRadius x:Key="RadiusXl">20</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <!-- ==================== 3.2 阴影 / 高度刻度 (Shadow / Elevation Scale) ==================== -->
    <!-- 统一方向 270°、低不透明度，营造柔和悬浮感。 -->
    <DropShadowEffect x:Key="ElevationCard" BlurRadius="18" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.06" />
    <DropShadowEffect x:Key="ElevationRaised" BlurRadius="28" ShadowDepth="4" Direction="270" Color="#111216" Opacity="0.10" />
    <DropShadowEffect x:Key="ElevationToast" BlurRadius="12" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.18" />

    <!-- ==================== 3.3 间距刻度 (Spacing Scale, 8pt grid) ==================== -->
    <system:Double x:Key="SpaceXxs">4</system:Double>
    <system:Double x:Key="SpaceXs">8</system:Double>
    <system:Double x:Key="SpaceSm">12</system:Double>
    <system:Double x:Key="SpaceMd">16</system:Double>
    <system:Double x:Key="SpaceLg">24</system:Double>
    <system:Double x:Key="SpaceXl">32</system:Double>
    <system:Double x:Key="SpaceXxl">48</system:Double>
    <!-- Thickness 便捷令牌：卡片内边距统一 SpaceLg(24)、卡片间距 SpaceMd(16) -->
    <Thickness x:Key="SpaceCardPadding">24</Thickness>
    <Thickness x:Key="SpaceCardMargin">0,0,0,16</Thickness>

    <!-- ==================== 3.4 字阶 (Typography Hierarchy) ==================== -->
    <!-- 页面级标题（我的页头图主名） -->
    <system:Double x:Key="TypeDisplayFontSize">28</system:Double>
    <FontWeight x:Key="TypeDisplayFontWeight">Bold</FontWeight>
    <!-- 卡片标题 / 身份名 -->
    <system:Double x:Key="TypeTitleFontSize">18</system:Double>
    <FontWeight x:Key="TypeTitleFontWeight">Bold</FontWeight>
    <!-- 卡片分组标题 -->
    <system:Double x:Key="TypeGroupTitleFontSize">15</system:Double>
    <FontWeight x:Key="TypeGroupTitleFontWeight">SemiBold</FontWeight>
    <!-- 行项标题 -->
    <system:Double x:Key="TypeItemTitleFontSize">13.5</system:Double>
    <FontWeight x:Key="TypeItemTitleFontWeight">Medium</FontWeight>
    <!-- 正文 -->
    <system:Double x:Key="TypeBodyFontSize">13</system:Double>
    <FontWeight x:Key="TypeBodyFontWeight">Normal</FontWeight>
    <!-- 描述 / 辅助说明 -->
    <system:Double x:Key="TypeCaptionFontSize">11.5</system:Double>
    <FontWeight x:Key="TypeCaptionFontWeight">Normal</FontWeight>

    <!-- ============================================================ -->
    <!-- 3.5 设置/我的页专用样式键 (Refine* styles)                    -->
    <!-- 仅两页消费，沿用既有画刷键，不污染其它页面。                  -->
    <!-- ============================================================ -->

    <!-- 左侧竖向导航列表 -->
    <Style x:Key="RefineNavListStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ItemContainerStyle" Value="{DynamicResource RefineNavItemStyle}" />
    </Style>

    <!-- 导航项 -->
    <Style x:Key="RefineNavItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontSize13_5}" />
        <Setter Property="FontWeight" Value="{StaticResource TypeItemTitleFontWeight}" />
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="Margin" Value="2,3" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="NavBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter TargetName="NavBorder" Property="Effect" Value="{StaticResource ElevationCard}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 搜索框 -->
    <Style x:Key="RefineSearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="{DynamicResource UiFontSize13}" />
        <Setter Property="Height" Value="38" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="SearchBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 身份头图容器 -->
    <Style x:Key="RefineIdentityHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}" />
        <Setter Property="Padding" Value="{StaticResource SpaceCardPadding}" />
        <Setter Property="Margin" Value="{StaticResource SpaceCardMargin}" />
        <Setter Property="Effect" Value="{StaticResource ElevationCard}" />
    </Style>

    <!-- 通用 Toast 浮层 -->
    <Style x:Key="RefineToastStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Effect" Value="{StaticResource ElevationToast}" />
    </Style>

    <!-- 启用/禁用状态徽章（胶囊） -->
    <Style x:Key="RefineStatusBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- 密码显隐切换按钮 -->
    <Style x:Key="RefinePasswordRevealButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="RevealBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusSm}">
                        <!-- 默认隐藏(显示「显示」眼睛图标 E7B3)，选中时显示明文(图标 E890) -->
                        <TextBlock x:Name="RevealGlyph"
                                   Text="&#xE7B3;"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="RevealGlyph" Property="Text" Value="&#xE890;" />
                            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RevealBorder" Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 密码强度计 -->
    <Style x:Key="RefineStrengthMeterStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="100" />
        <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border x:Name="MeterTrack"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusPill}"
                            ClipToBounds="True">
                        <Grid>
                            <Border x:Name="PART_Track" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource RadiusPill}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
