<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Recent sign-in account dropdown item container (no event handlers / page-scope names) -->
    <Style x:Key="RecentSignInAccountItemContainerStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="AccountOption"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,10">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="AccountOption" Property="Background" Value="#F7F7F9" />
                            <Setter TargetName="AccountOption" Property="BorderBrush" Value="#ECEEF3" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="AccountOption" Property="Background" Value="#F3F4F7" />
                            <Setter TargetName="AccountOption" Property="BorderBrush" Value="#DFE3EA" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Recent sign-in account dropdown item template (data bindings only) -->
    <DataTemplate x:Key="RecentSignInAccountItemTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding Username}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#1D1D1F" />
                <TextBlock Text="{Binding DisplayName}"
                           Margin="0,2,0,0"
                           FontSize="12"
                           Foreground="#7D8390" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#A0A5AF"
                       Text="{Binding LastLoginAt, StringFormat=最近登录 {0:MM-dd HH:mm}}" />
        </Grid>
    </DataTemplate>

    <!-- Account directory item container (no event handlers / page-scope names) -->
    <Style x:Key="AccountDirectoryItemContainerStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="Transparent"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
