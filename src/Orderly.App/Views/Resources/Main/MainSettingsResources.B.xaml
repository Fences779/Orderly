<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Orderly.App.Converters"
                    xmlns:helpers="clr-namespace:Orderly.App.Helpers">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainComponentStyles.A.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <Style x:Key="SettingsMetricBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#E6EAF0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,10,10"/>
    </Style>

    <!-- Settings: placeholder for future tabs -->
    <Style x:Key="SettingsPlaceholderStyle" TargetType="StackPanel">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,60,0,0"/>
    </Style>

    <!-- ===== Reference-design row-based settings styles ===== -->

    <!-- Group card: white rounded card wrapping a group of setting rows -->
    <Style x:Key="SettingsGroupCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.04"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Page title inside settings content area -->
    <Style x:Key="SettingsPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
    </Style>

    <!-- Page description -->
    <Style x:Key="SettingsPageDescStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#9CA3AF"/>
        <Setter Property="Margin" Value="0,4,0,24"/>
    </Style>

    <!-- Group title inside a card -->
    <Style x:Key="SettingsGroupTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
        <Setter Property="Margin" Value="0,12,0,4"/>
    </Style>

    <!-- Single setting row: bottom border separator -->
    <Style x:Key="SettingsRowItemBorder" TargetType="Border">
        <Setter Property="BorderBrush" Value="#F0F0F3"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="12,18"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F8F9FA"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Setting item title -->
    <Style x:Key="SettingsItemTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
    </Style>

    <!-- Setting item description -->
    <Style x:Key="SettingsItemDescStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#9CA3AF"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,3,0,0"/>
    </Style>

    <!-- Row icon background circle -->
    <Style x:Key="SettingsRowIconBgStyle" TargetType="Border">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#F5F5F7"/>
        <Setter Property="Margin" Value="0,0,14,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Inline ComboBox for settings rows -->
    <Style x:Key="SettingsRowComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="140"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Inline TextBox for settings rows -->
    <Style x:Key="SettingsRowTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="60"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <!-- Inline CheckBox for settings rows (right-aligned) -->
    <Style x:Key="SettingsRowCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Margin" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid x:Name="SwitchContainer" Background="Transparent">
                        <Border x:Name="SwitchTrack" Width="42" Height="22" CornerRadius="11" Background="#E5E7EB" SnapsToDevicePixels="True"/>
                        <Border x:Name="SwitchTrackBlue" Width="42" Height="22" CornerRadius="11" Background="#2563EB" Opacity="0" SnapsToDevicePixels="True"/>
                        <Border x:Name="SwitchThumb" Width="16" Height="16" CornerRadius="8" Background="#FFFFFF" HorizontalAlignment="Left" Margin="3,0,3,0" SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <TranslateTransform X="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SwitchTrackBlue"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="SwitchThumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="20" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SwitchTrackBlue"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="SwitchThumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SwitchContainer" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#F3F4F6"/>
                            <Setter TargetName="SwitchThumb" Property="Background" Value="#D1D5DB"/>
                            <Setter TargetName="SwitchTrackBlue" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="SwitchContainer" Property="Opacity" Value="0.75"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Status / read-only text in settings -->
    <Style x:Key="SettingsStatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#6B7280"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="18"/>
    </Style>

    <!-- Compact action button for settings rows -->
    <Style x:Key="SettingsRowActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarSecondaryButtonStyle}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="MinWidth" Value="72"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
