<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Orderly.App.Converters"
                    xmlns:helpers="clr-namespace:Orderly.App.Helpers">
    <!-- Main Navigation Button Style (Left sidebar) -->
    <Style x:Key="MainMenuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="2,5"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                            CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="IconBg" Width="30" Height="30" CornerRadius="8" Background="#F0F1F3" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <TextBlock x:Name="TabIcon" FontFamily="Segoe MDL2 Assets"
                                           Text="{TemplateBinding Tag}" FontSize="13.5"
                                           Foreground="#8B8D94"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter ContentSource="Content" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Individual colors for each tab item icon based on Content AND SelectedState / HoverState -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="工作台"/>
                                <Condition Binding="{Binding SelectedSection}" Value="工作台"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#E0F2FE"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#0284C7"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="工作台"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#E0F2FE"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#0284C7"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="订单"/>
                                <Condition Binding="{Binding SelectedSection}" Value="订单"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#DCFCE7"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#16A34A"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="订单"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#DCFCE7"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#16A34A"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="商品"/>
                                <Condition Binding="{Binding SelectedSection}" Value="商品"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#FCE7F3"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#DB2777"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="商品"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#FCE7F3"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#DB2777"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="库存"/>
                                <Condition Binding="{Binding SelectedSection}" Value="库存管理"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#FEF3C7"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#B45309"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="库存"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#FEF3C7"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#B45309"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="客户"/>
                                <Condition Binding="{Binding SelectedSection}" Value="客户"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#CCFBF1"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#0D9488"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="客户"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#CCFBF1"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#0D9488"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="现金流"/>
                                <Condition Binding="{Binding SelectedSection}" Value="现金流"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#E0E7FF"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#4F46E5"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="现金流"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#E0E7FF"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#4F46E5"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="经营建议"/>
                                <Condition Binding="{Binding SelectedSection}" Value="经营建议"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#FFEDD5"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#EA580C"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="经营建议"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#FFEDD5"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#EA580C"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="设置"/>
                                <Condition Binding="{Binding SelectedSection}" Value="设置"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#F3E8FF"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#9333EA"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="设置"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconBg" Property="Background" Value="#F3E8FF"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#9333EA"/>
                        </MultiDataTrigger>

                        <!-- Hover State when not selected: subtle background highlight -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceSoftBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}"/>
                        </MultiTrigger>

                        <!-- Hover Animation: Icon scales up slightly -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Profile Menu Button Style (Left sidebar bottom) -->
    <Style x:Key="ProfileMenuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="2,12,2,4"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                            BorderBrush="Transparent" BorderThickness="1"
                            CornerRadius="14" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 渐变圆形头像区 -->
                            <Border x:Name="AvatarBg" Grid.Column="0" Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F472B6" Offset="0"/>
                                        <GradientStop Color="#A78BFA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="AvatarScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <TextBlock x:Name="AvatarIcon" FontFamily="Segoe MDL2 Assets"
                                           Text="{TemplateBinding Tag}" FontSize="13.5"
                                           Foreground="#FFFFFF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- 用户名称与状态文本 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="NameText" Text="{Binding CurrentAccountDisplayName, FallbackValue=商家用户}" FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F"/>
                                <TextBlock x:Name="RoleText" Text="系统店员" FontSize="11" Foreground="#86868B" Margin="0,2,0,0"/>
                            </StackPanel>
                            
                            <!-- 右侧跳转小箭头 -->
                            <TextBlock Grid.Column="2" FontFamily="Segoe MDL2 Assets" Text="&#xE76C;" 
                                       FontSize="10" Foreground="#86868B" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 动态角色身份触发器 -->
                        <DataTrigger Binding="{Binding IsCurrentUserOwner}" Value="True">
                            <Setter TargetName="RoleText" Property="Text" Value="系统管理员"/>
                        </DataTrigger>
                        
                        <!-- Hover 状态 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#F1F2F5"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        
                        <!-- Selected 状态 -->
                        <DataTrigger Binding="{Binding SelectedSection}" Value="我的">
                            <Setter TargetName="TabBorder" Property="Background" Value="#FFFFFF"/>
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E5E7EC"/>
                            <Setter TargetName="TabBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
