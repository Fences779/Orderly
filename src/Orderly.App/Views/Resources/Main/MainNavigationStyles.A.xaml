<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Orderly.App.Converters"
                    xmlns:helpers="clr-namespace:Orderly.App.Helpers">
    <!-- Main Navigation Button Style (Left sidebar) -->
    <Style x:Key="MainMenuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="2,5"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="{TemplateBinding Margin}">
                        <!-- Hover 专用的淡入淡出背景层。当 TabBorder 是透明时（即未选中状态），我们可以完全看到这一层 -->
                        <Border x:Name="HoverBorder" Background="{DynamicResource SidebarHoverBrush}"
                                CornerRadius="12" Opacity="0" IsHitTestVisible="False"/>

                        <!-- 正常状态/选中状态的 Border。当选中时，背景变为不透明，覆盖在 HoverBorder 之上 -->
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="IconBg" Width="30" Height="30" CornerRadius="8" Background="#F0F1F3" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Grid>
                                        <!-- 默认图标前景色 -->
                                        <TextBlock x:Name="TabIcon" FontFamily="Segoe MDL2 Assets"
                                                   Text="{TemplateBinding Tag}" FontSize="13.5"
                                                   Foreground="#8B8D94"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                        <!-- Hover / 选中高亮图标及背景叠加层 -->
                                        <Border x:Name="IconHighlightBg" CornerRadius="8" Opacity="0" IsHitTestVisible="False">
                                            <TextBlock x:Name="TabIconHighlight" FontFamily="Segoe MDL2 Assets"
                                                       Text="{TemplateBinding Tag}" FontSize="13.5"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <ContentPresenter ContentSource="Content" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Common Hover Trigger (Opacity fade in/out animation) -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 整体的 hover 背景淡入 -->
                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- 图标高亮层淡入 -->
                                        <DoubleAnimation Storyboard.TargetName="IconHighlightBg" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- 图标略微放大 -->
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 整体 hover 背景淡出 -->
                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- 图标高亮层淡出 -->
                                        <DoubleAnimation Storyboard.TargetName="IconHighlightBg" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- 图标略微缩小恢复 -->
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- Individual colors for each tab item icon based on Content AND SelectedState / HoverState -->
                        <!-- 1. 工作台 (Workbench) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="工作台"/>
                                <Condition Binding="{Binding SelectedSection}" Value="工作台"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#E0F2FE"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#0284C7"/>
                            <Setter TargetName="IconHighlightBg" Property="Opacity" Value="1"/>
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="工作台"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#E0F2FE"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#0284C7"/>
                        </MultiDataTrigger>

                        <!-- 2. 订单 (Orders) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="订单"/>
                                <Condition Binding="{Binding SelectedSection}" Value="订单"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#DCFCE7"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#16A34A"/>
                            <Setter TargetName="IconHighlightBg" Property="Opacity" Value="1"/>
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="订单"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#DCFCE7"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#16A34A"/>
                        </MultiDataTrigger>

                        <!-- 3. 商品 (Products) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="商品"/>
                                <Condition Binding="{Binding SelectedSection}" Value="商品"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#FCE7F3"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#DB2777"/>
                            <Setter TargetName="IconHighlightBg" Property="Opacity" Value="1"/>
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="商品"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#FCE7F3"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#DB2777"/>
                        </MultiDataTrigger>

                        <!-- 4. 库存 (Inventory) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="库存"/>
                                <Condition Binding="{Binding SelectedSection}" Value="库存管理"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#FEF3C7"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#B45309"/>
                            <Setter TargetName="IconHighlightBg" Property="Opacity" Value="1"/>
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="库存"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#FEF3C7"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#B45309"/>
                        </MultiDataTrigger>

                        <!-- 5. 客户 (Customers) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="客户"/>
                                <Condition Binding="{Binding SelectedSection}" Value="客户"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#CCFBF1"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#0D9488"/>
                            <Setter TargetName="IconHighlightBg" Property="Opacity" Value="1"/>
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="客户"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#CCFBF1"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#0D9488"/>
                        </MultiDataTrigger>

                        <!-- 6. 现金流 (Cash Flow) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="现金流"/>
                                <Condition Binding="{Binding SelectedSection}" Value="现金流"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#E0E7FF"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#4F46E5"/>
                            <Setter TargetName="IconHighlightBg" Property="Opacity" Value="1"/>
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="现金流"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#E0E7FF"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#4F46E5"/>
                        </MultiDataTrigger>

                        <!-- 7. 经营建议 (Business Advice) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="经营建议"/>
                                <Condition Binding="{Binding SelectedSection}" Value="经营建议"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#FFEDD5"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#EA580C"/>
                            <Setter TargetName="IconHighlightBg" Property="Opacity" Value="1"/>
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="经营建议"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#FFEDD5"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#EA580C"/>
                        </MultiDataTrigger>

                        <!-- 8. 设置 (Settings) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="设置"/>
                                <Condition Binding="{Binding SelectedSection}" Value="设置"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#F3E8FF"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#9333EA"/>
                            <Setter TargetName="IconHighlightBg" Property="Opacity" Value="1"/>
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="设置"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="IconHighlightBg" Property="Background" Value="#F3E8FF"/>
                            <Setter TargetName="TabIconHighlight" Property="Foreground" Value="#9333EA"/>
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Profile Menu Button Style (Left sidebar bottom) -->
    <Style x:Key="ProfileMenuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="2,12,2,4"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                            BorderBrush="Transparent" BorderThickness="1"
                            CornerRadius="14" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 渐变圆形头像区 -->
                            <Border x:Name="AvatarBg" Grid.Column="0" Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F472B6" Offset="0"/>
                                        <GradientStop Color="#A78BFA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="AvatarScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <TextBlock x:Name="AvatarIcon" FontFamily="Segoe MDL2 Assets"
                                           Text="{TemplateBinding Tag}" FontSize="13.5"
                                           Foreground="#FFFFFF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- 用户名称与状态文本 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="NameText" Text="{Binding CurrentAccountDisplayName, FallbackValue=商家用户}" FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F"/>
                                <TextBlock x:Name="RoleText" Text="系统店员" FontSize="11" Foreground="#86868B" Margin="0,2,0,0"/>
                            </StackPanel>
                            
                            <!-- 右侧跳转小箭头 -->
                            <TextBlock Grid.Column="2" FontFamily="Segoe MDL2 Assets" Text="&#xE76C;" 
                                       FontSize="10" Foreground="#86868B" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 动态角色身份触发器 -->
                        <DataTrigger Binding="{Binding IsCurrentUserOwner}" Value="True">
                            <Setter TargetName="RoleText" Property="Text" Value="系统管理员"/>
                        </DataTrigger>
                        
                        <!-- Hover 状态 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#F1F2F5"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AvatarScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        
                        <!-- Selected 状态 -->
                        <DataTrigger Binding="{Binding SelectedSection}" Value="我的">
                            <Setter TargetName="TabBorder" Property="Background" Value="#FFFFFF"/>
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E5E7EC"/>
                            <Setter TargetName="TabBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
