<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BitmapImage x:Key="OrderlyBrandLogoImage"
                 UriSource="pack://application:,,,/Assets/Brand/Orderly%20Logo.png" />

    <!-- 全局 Window 字体 -->
    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="TextElement.FontSize" Value="13" />
        <Setter Property="Icon" Value="pack://application:,,,/Assets/Brand/Orderly%20Logo.ico" />
    </Style>

    <!-- 全局隐藏所有 ScrollBar 滚动条 (防止被控件局部设置的 Visibility="Auto" 覆盖) -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="0"/>
        <Setter Property="Height" Value="0"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="MinHeight" Value="0"/>
    </Style>

    <!-- 全局默认 Button -->
    <Style TargetType="Button">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
</ResourceDictionary>
