<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 导航按钮 -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#36433D" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Padding" Value="14,10" />
    </Style>

    <!-- 卡片边框 -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="32" ShadowDepth="6" Direction="270" Color="#111216" Opacity="0.05" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 弹窗主按钮（确认） -->
    <Style x:Key="DialogPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="42" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="{StaticResource PremiumDarkBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#2D2F35" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#0F1014" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Background" Value="#E4E7ED" />
                            <Setter Property="Foreground" Value="#8F959E" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 弹窗次按钮（取消） -->
    <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="42" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="#F5F5F7" />
        <Setter Property="Foreground" Value="#1D1D1F" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#ECECF1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.78" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 弹窗字段标签 -->
    <Style x:Key="DialogFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#1F2329" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- 弹窗标题 -->
    <Style x:Key="DialogSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#17211D" />
        <Setter Property="Margin" Value="0,0,0,18" />
    </Style>

    <!-- 快捷筛选 Chip 按钮 -->
    <Style x:Key="ChipButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="#F0EDE5" />
        <Setter Property="Foreground" Value="#4A5250" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#D6D1C4" />
        <Setter Property="Margin" Value="0,0,6,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#E3DDD0" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#D5CFC0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 快捷筛选 Chip 激活态 -->
    <Style x:Key="ChipButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource ChipButtonStyle}">
        <Setter Property="Background" Value="#D8EDE4" />
        <Setter Property="Foreground" Value="#1F7A5A" />
        <Setter Property="BorderBrush" Value="#9DCABC" />
    </Style>
</ResourceDictionary>
