    <Style x:Key="SectionBlockBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <Style x:Key="ModernCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="ModernTabRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
        <Setter Property="Padding" Value="16,6" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="#22644A" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ListItemBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#FCFCFD" />
        <Setter Property="BorderBrush" Value="#DFE3EA" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="AccentPillBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style x:Key="OutlinePillBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#F7F7F9" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <DataTemplate x:Key="CustomerListItemTemplate">
        <Border x:Name="CustomerItemCard" Style="{StaticResource ListItemBorderStyle}" AutomationProperties.AutomationId="{Binding RemoteId}">
            <StackPanel>
                <DockPanel>
                    <TextBlock x:Name="CustomerNameText"
                               Text="{Binding Name}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource HeadingBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="CustomerLastContactText"
                               DockPanel.Dock="Right"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="12,2,0,0"
                               Text="{Binding LastContactAt, StringFormat=最近联系：{0:MM-dd HH:mm}}" />
                </DockPanel>

                <WrapPanel Margin="0,10,0,0">
                    <Border Style="{StaticResource AccentPillBorderStyle}" Margin="0,0,8,8">
                        <TextBlock Text="{Binding Status, Converter={StaticResource EnumLabelConverter}}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                    </Border>
                    <Border Style="{StaticResource OutlinePillBorderStyle}" Margin="0,0,8,8">
                        <TextBlock Text="{Binding Priority, Converter={StaticResource EnumLabelConverter}}" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" FontSize="11" />
                    </Border>
                </WrapPanel>

                <TextBlock x:Name="CustomerSourceText"
                           Text="{Binding SourcePlatform, StringFormat=来源：{0}}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,0,0,4"
                           TextWrapping="Wrap" />

                <TextBlock Text="{Binding ContactHandle, StringFormat=联系：{0}}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ContactHandle}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="{Binding Phone, StringFormat=电话：{0}}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ContactHandle}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Phone}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="联系方式：待补充"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ContactHandle}" Value="" />
                                        <Condition Binding="{Binding Phone}" Value="" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Name}" Value="">
                <Setter TargetName="CustomerNameText" Property="Text" Value="未知客户" />
            </DataTrigger>
            <DataTrigger Binding="{Binding SourcePlatform}" Value="">
                <Setter TargetName="CustomerSourceText" Property="Text" Value="来源：未记录" />
            </DataTrigger>
            <DataTrigger Binding="{Binding LastContactAt}" Value="{x:Null}">
                <Setter TargetName="CustomerLastContactText" Property="Text" Value="最近联系：暂无记录" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                <Setter TargetName="CustomerItemCard" Property="Background" Value="#F5F5F7" />
                <Setter TargetName="CustomerItemCard" Property="BorderBrush" Value="#D4D9E2" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="OrderListItemTemplate">
        <Border x:Name="OrderItemCard" Style="{StaticResource ListItemBorderStyle}" AutomationProperties.AutomationId="{Binding RemoteId}">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="{Binding CustomerNameDisplay}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding AmountText}"
                               Foreground="{StaticResource WarmTextBrush}"
                               FontWeight="Bold"
                               Margin="12,0,0,0" />
                </DockPanel>

                <TextBlock Text="{Binding TitleDisplay}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource HeadingBrush}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />

                <TextBlock Text="{Binding RequirementSummary}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Margin="0,8,0,0"
                           MaxHeight="42" />

                <WrapPanel Margin="0,10,0,0">
                    <Border Style="{StaticResource AccentPillBorderStyle}" Margin="0,0,8,8">
                        <TextBlock Text="{Binding StatusLabel}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                    </Border>
                    <Border Style="{StaticResource OutlinePillBorderStyle}" Margin="0,0,8,8">
                        <TextBlock Text="{Binding NextFollowUpDisplay, StringFormat=跟进：{0}}" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" FontSize="11" />
                    </Border>
                </WrapPanel>

                <TextBlock Text="{Binding LastActivityDisplay}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                <Setter TargetName="OrderItemCard" Property="Background" Value="#F5F5F7" />
                <Setter TargetName="OrderItemCard" Property="BorderBrush" Value="#D4D9E2" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ==================== Settings Page Styles ==================== -->

    <!-- Settings: left-nav + right-content TabControl -->
    <Style x:Key="SettingsTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="TabStripPlacement" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="236"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0" Margin="16,16,16,24">
                            <StackPanel DockPanel.Dock="Top" Margin="6,0,0,16">
                                <TextBlock Text="设置" FontSize="26" FontWeight="Bold" Foreground="#1D1D1F"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel IsItemsHost="True"/>
                            </ScrollViewer>
                        </DockPanel>
                        <Border Grid.Column="1" Width="1" Margin="0,28">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00E8E8E8" Offset="0"/>
                                    <GradientStop Color="#E8E8E8" Offset="0.15"/>
                                    <GradientStop Color="#E8E8E8" Offset="0.85"/>
                                    <GradientStop Color="#00E8E8E8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border Grid.Column="2" Padding="32,28,28,28" Background="Transparent">
                            <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Settings: tab item (nav entry) -->
    <Style x:Key="SettingsTabItemStyle" TargetType="TabItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#55555C"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="2,5"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                            CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="IconBg" Width="30" Height="30" CornerRadius="8" Background="#F0F1F3" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <TextBlock x:Name="TabIcon" FontFamily="Segoe MDL2 Assets"
                                           Text="{TemplateBinding Tag}" FontSize="13.5"
                                           Foreground="#8B8D94"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Individual colors for each tab item icon based on Header -->
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource Self}}" Value="应用与外观">
                            <Setter TargetName="IconBg" Property="Background" Value="#E0F2FE"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#0284C7"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource Self}}" Value="数据与安全">
                            <Setter TargetName="IconBg" Property="Background" Value="#DCFCE7"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#16A34A"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource Self}}" Value="AI 助手">
                            <Setter TargetName="IconBg" Property="Background" Value="#F3E8FF"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#9333EA"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource Self}}" Value="系统提醒">
                            <Setter TargetName="IconBg" Property="Background" Value="#FEF3C7"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#D97706"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource Self}}" Value="快捷键">
                            <Setter TargetName="IconBg" Property="Background" Value="#FFE4E6"/>
                            <Setter TargetName="TabIcon" Property="Foreground" Value="#E11D48"/>
                        </DataTrigger>

                        <!-- Selected State: Floating Card with drop shadow -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Panel.ZIndex" Value="1"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="#FFFFFF"/>
                            <Setter Property="Foreground" Value="#1D1D1F"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="TabBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!-- Hover State when not selected: subtle background highlight -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabBorder" Property="Background" Value="#EAEAEA"/>
                            <Setter Property="Foreground" Value="#1D1D1F"/>
                        </MultiTrigger>

                        <!-- Hover Animation: Icon scales up slightly -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Settings: row with bottom separator, generous padding -->
    <Style x:Key="SettingsRowStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="#F0F0F2"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="4,18"/>
    </Style>

    <!-- Settings: hint/note text -->
    <Style x:Key="SettingsHintStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#9CA3AF"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <!-- Settings: section sub-header inside a tab -->
    <Style x:Key="SettingsSectionSubHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
        <Setter Property="Margin" Value="0,24,0,12"/>
    </Style>

    <!-- Settings: compact secondary button -->
    <Style x:Key="SettingsCompactButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarSecondaryButtonStyle}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="80"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="FontSize" Value="12.5"/>
    </Style>

    <Style x:Key="SettingsPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="#F8F9FB"/>
        <Setter Property="BorderBrush" Value="#E6EAF0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="SettingsFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="SettingsFieldCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#86868B"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="18"/>
    </Style>

    <Style x:Key="SettingsInlineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Height" Value="38"/>
        <Setter Property="MinWidth" Value="150"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <Style x:Key="SettingsInlineComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Height" Value="38"/>
        <Setter Property="MinWidth" Value="150"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <Style x:Key="SettingsCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="#1D1D1F"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <BulletDecorator Background="Transparent">
                        <BulletDecorator.Bullet>
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="5"
                                    Background="#FFFFFF"
                                    BorderBrush="#D0D7E2"
                                    BorderThickness="1"
                                    Margin="0,1,10,0">
                                <Path x:Name="Check"
                                      Data="M 4 9 L 7.5 12.5 L 14 5.5"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                        </BulletDecorator.Bullet>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </BulletDecorator>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="#2563EB"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="#2563EB"/>
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="#9FB3D4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#9CA3AF"/>
                            <Setter TargetName="Box" Property="Background" Value="#F3F4F6"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="#E5E7EB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsMetricBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#E6EAF0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,10,10"/>
    </Style>

    <!-- Settings: placeholder for future tabs -->
    <Style x:Key="SettingsPlaceholderStyle" TargetType="StackPanel">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,60,0,0"/>
    </Style>

    <!-- ===== Reference-design row-based settings styles ===== -->

    <!-- Group card: white rounded card wrapping a group of setting rows -->
    <Style x:Key="SettingsGroupCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.04"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Page title inside settings content area -->
    <Style x:Key="SettingsPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
    </Style>

    <!-- Page description -->
    <Style x:Key="SettingsPageDescStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#9CA3AF"/>
        <Setter Property="Margin" Value="0,4,0,24"/>
    </Style>

    <!-- Group title inside a card -->
    <Style x:Key="SettingsGroupTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#1D1D1F"/>
        <Setter Property="Margin" Value="0,12,0,4"/>
    </Style>

    <!-- Single setting row: bottom border separator -->
    <Style x:Key="SettingsRowItemBorder" TargetType="Border">
        <Setter Property="BorderBrush" Value="#F0F0F3"/>
