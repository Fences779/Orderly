<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 主按钮：保留强主操作，但降低纯黑压迫感-->
    <Style x:Key="PremiumButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="#17181C" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Height" Value="50" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Button">
                <Border x:Name="bg"
                        CornerRadius="14"
                        SnapsToDevicePixels="True">
                    <Border.Background>
                        <SolidColorBrush x:Name="ButtonBackgroundBrush" Color="#17181C" />
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect x:Name="ButtonShadowEffect"
                                          BlurRadius="18"
                                          ShadowDepth="3"
                                          Direction="270"
                                          Color="#101114"
                                          Opacity="0.07" />
                    </Border.Effect>
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard x:Name="ButtonHoverStoryboard">
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="ButtonBackgroundBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#1E2025"
                                                    Duration="0:0:0.16">
                                        <ColorAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ButtonShadowEffect"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.18"
                                                     Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ButtonShadowEffect"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="22"
                                                     Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="ButtonBackgroundBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#17181C"
                                                    Duration="0:0:0.2">
                                        <ColorAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ButtonShadowEffect"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.12"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ButtonShadowEffect"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="18"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="bg" Property="Background" Value="#121317" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="bg" Property="Background" Value="#C9CCD3" />
                        <Setter Property="Foreground" Value="#F8F8FA" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
    </Style>

            <!-- 输入框：默认态和焦点态拉近，只做轻微点亮 -->
            <Style TargetType="TextBox">
    <Setter Property="Height" Value="48" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="Background" Value="#F7F7F9" />
    <Setter Property="BorderBrush" Value="#DFE3EA" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="#1D1D1F" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="TextBox">
                <Border x:Name="border"
                        CornerRadius="14"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                    <Border.Background>
                        <SolidColorBrush x:Name="TextBoxBackgroundBrush" Color="#F7F7F9" />
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush x:Name="TextBoxBorderBrush" Color="#DFE3EA" />
                    </Border.BorderBrush>
                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="TextBoxBackgroundBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#FFFFFF"
                                                    Duration="0:0:0.16">
                                        <ColorAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation Storyboard.TargetName="TextBoxBorderBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#8A9AB5"
                                                    Duration="0:0:0.16">
                                        <ColorAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="TextBoxBackgroundBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#F7F7F9"
                                                    Duration="0:0:0.22">
                                        <ColorAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation Storyboard.TargetName="TextBoxBorderBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#DFE3EA"
                                                    Duration="0:0:0.22">
                                        <ColorAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsMouseOver" Value="True" />
                            <Condition Property="IsKeyboardFocusWithin" Value="False" />
                        </MultiTrigger.Conditions>
                        <Setter TargetName="border" Property="Background" Value="#FAFAFB" />
                        <Setter TargetName="border" Property="BorderBrush" Value="#D4D9E2" />
                    </MultiTrigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="border" Property="Background" Value="#F1F2F5" />
                        <Setter TargetName="border" Property="BorderBrush" Value="#E5E7EC" />
                        <Setter Property="Foreground" Value="#A0A5AF" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
            </Style>

</ResourceDictionary>
