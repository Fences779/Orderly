<Window x:Class="Orderly.App.Views.AddCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增客户"
        Width="480"
        Height="460"
        MinWidth="440"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource PageBackgroundBrush}"
        AutomationProperties.AutomationId="AddCustomerDialog">
    <Grid>
        <!-- 顶部标题栏 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题区 -->
        <Border Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="新增客户" Style="{StaticResource DialogSectionTitleStyle}" Margin="0" />
                <TextBlock Text="填写客户基本信息，保存后可在客户列表中查看" Foreground="{StaticResource MutedBrush}" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="22,18,22,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 客户姓名 -->
                <TextBlock Grid.Row="0" Text="客户姓名 *" Style="{StaticResource DialogFieldLabelStyle}" />
                <TextBox x:Name="NameTextBox"
                         Grid.Row="1"
                         Margin="0,0,0,14"
                         AutomationProperties.AutomationId="AddCustomerDialog_Name" />

                <!-- 联系方式 + 来源 -->
                <Grid Grid.Row="2" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="联系方式（账号 / 微信 / 手机）" Style="{StaticResource DialogFieldLabelStyle}" />
                        <TextBox x:Name="ContactTextBox"
                                 Margin="0,0,0,14"
                                 AutomationProperties.AutomationId="AddCustomerDialog_Contact" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="来源平台" Style="{StaticResource DialogFieldLabelStyle}" />
                        <TextBox x:Name="SourceTextBox"
                                 Margin="0,0,0,14"
                                 AutomationProperties.AutomationId="AddCustomerDialog_Source" />
                    </StackPanel>
                </Grid>

                <!-- 状态 + 优先级 -->
                <Grid Grid.Row="3" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="客户状态" Style="{StaticResource DialogFieldLabelStyle}" />
                        <ComboBox x:Name="StatusComboBox"
                                  Margin="0,0,0,14"
                                  AutomationProperties.AutomationId="AddCustomerDialog_Status" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="优先级" Style="{StaticResource DialogFieldLabelStyle}" />
                        <ComboBox x:Name="PriorityComboBox"
                                  Margin="0,0,0,14"
                                  AutomationProperties.AutomationId="AddCustomerDialog_Priority" />
                    </StackPanel>
                </Grid>

                <!-- 备注 -->
                <TextBlock Grid.Row="4" Text="客户备注" Style="{StaticResource DialogFieldLabelStyle}" />
                <TextBox x:Name="RemarkTextBox"
                         Grid.Row="5"
                         Margin="0,0,0,0"
                         MinHeight="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         AutomationProperties.AutomationId="AddCustomerDialog_Remark" />
            </Grid>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2"
                Background="#FFFDF8"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Style="{StaticResource DialogSecondaryButtonStyle}"
                        IsCancel="True"
                        Margin="0,0,10,0"
                        AutomationProperties.AutomationId="AddCustomerDialog_Cancel" />
                <Button Content="确认保存"
                        Style="{StaticResource DialogPrimaryButtonStyle}"
                        IsDefault="True"
                        Click="ConfirmButton_Click"
                        AutomationProperties.AutomationId="AddCustomerDialog_Confirm" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
