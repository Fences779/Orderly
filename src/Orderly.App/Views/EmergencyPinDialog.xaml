<Window x:Class="Orderly.App.Views.EmergencyPinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="紧急启用入口"
        Width="460"
        Height="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <!--
        独立的「紧急入口弹窗」（任务 18.6，design §9.7，BC-13，Req 17.1）：
        - 仅采集 6 位 PIN 并回传给 MeProfileViewModel.PickEmergencyPin 委托，再由 VM 调 TryEmergencyEnable。
        - 此弹窗与登录页完全独立，登录页保持不变（Req 17.x）。
        - 明文 PIN 即用即清：关闭后 PasswordBox 内容随窗口释放，VM 校验后清空局部引用（P4）。
    -->
    <Border Background="#FAFAFC" CornerRadius="16" BorderBrush="#E5E5EA" BorderThickness="1">
        <StackPanel VerticalAlignment="Center" Margin="36,0">

            <Border Width="64" Height="64" CornerRadius="32" Background="#B91C1C" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="6" Direction="270" Color="#000000" Opacity="0.15" />
                </Border.Effect>
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                           VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#FFFFFF" />
            </Border>

            <TextBlock Text="紧急启用入口" FontSize="22" FontWeight="Bold" Foreground="#1D1D1F" HorizontalAlignment="Center" />
            <TextBlock Text="请输入系统管理员（Owner）的 6 位安全 PIN 以进入受限权限模式，仅可执行数据抢救类操作。"
                       Margin="0,8,0,24" Foreground="#86868B" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <Border Width="280" Background="#F5F5F7" CornerRadius="12" BorderThickness="1" BorderBrush="Transparent" Margin="0,0,0,14">
                <PasswordBox x:Name="TxtPin" Height="52" FontSize="24" Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                             KeyDown="TxtPin_KeyDown" MaxLength="6" />
            </Border>

            <TextBlock x:Name="TxtError" Foreground="#FF3B30" Margin="0,0,0,14" Visibility="Collapsed"
                       TextWrapping="Wrap" HorizontalAlignment="Center" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Content="取消" Width="120" Height="44" Margin="0,0,12,0" Click="BtnCancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E5E5EA" />
                            <Setter Property="Foreground" Value="#1D1D1F" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D1D1D6" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="确认启用" Width="120" Height="44" Click="BtnConfirm_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#B91C1C" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Opacity" Value="0.85" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="bg" Property="Opacity" Value="0.7" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
