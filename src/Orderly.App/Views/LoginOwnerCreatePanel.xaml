<UserControl x:Class="Orderly.App.Views.LoginOwnerCreatePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Center">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.B.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 新增复制图标按钮样式 -->
            <Style x:Key="CopyIconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#86868B" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="8" SnapsToDevicePixels="True">
                                <Viewbox Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="iconBack" Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1Z" Fill="{TemplateBinding Foreground}" />
                                        <Path x:Name="iconFront" Data="M19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5ZM19 21H8V7H19V21Z" Fill="{TemplateBinding Foreground}" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#EBEBEF" />
                                    <Setter Property="Foreground" Value="#1D1D1F" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#DFDFE3" />
                                    <Setter Property="Foreground" Value="#000000" />
                                    <Setter TargetName="bg" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="16" CenterY="16" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="42,28,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="初始化系统" FontWeight="Bold" FontSize="26" Foreground="#1D1D1F" Margin="0,0,0,6" />
        <TextBlock Grid.Row="1" Text="创建首个管理员全局账户" Foreground="#86868B" FontSize="14" Margin="0,0,0,24" />
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <!-- 第一行：账号 / 昵称（短字段双列） -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="账号" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="TxtOwnerUsername" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="昵称" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="TxtOwnerDisplayName" />
                </StackPanel>
            </Grid>

            <!-- 第二行：主密码（独占整行，下方保留说明文字） -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" />
                <PasswordBox x:Name="TxtOwnerPassword" />
                <TextBlock Text="至少 8 位，含大小写字母和数字，且不能包含空白或前后空格。"
                           Margin="0,6,0,0"
                           Foreground="#86868B"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- 第三行：PIN（独占整行，限制宽度靠左，避免输入框过长） -->
            <StackPanel Margin="0,0,0,22" HorizontalAlignment="Left" Width="220">
                <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                <PasswordBox x:Name="TxtOwnerPin" MaxLength="6" />
            </StackPanel>

            <CheckBox x:Name="ChkImportLegacyDb" IsChecked="{Binding ImportLegacyDatabase}" Visibility="Collapsed" />
            <CheckBox x:Name="ChkOverwriteLegacyTarget" IsChecked="{Binding OverwriteLegacyTarget}" Visibility="Collapsed" />

            <Button x:Name="BtnCreateOwner" Content="创建并登录" Style="{StaticResource PremiumButtonStyle}" Margin="0,8,0,0" Click="BtnCreateOwner_Click" />
        </StackPanel>

        <Border x:Name="RecoveryPanel"
                Grid.RowSpan="3"
                Background="#B3000000"
                CornerRadius="24"
                Visibility="Collapsed">
            <Grid>
                <Border Width="420"
                        Padding="28"
                        Background="#FFFFFF"
                        CornerRadius="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="10" Direction="270" Color="#000000" Opacity="0.12" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="保存 Recovery Key"
                                   FontWeight="Bold"
                                   FontSize="24"
                                   Foreground="#1D1D1F" />
                        <TextBlock Text="这是重置管理员主密码的唯一离线密钥。请先保存，再继续进入系统。"
                                   Margin="0,10,0,0"
                                   Foreground="#86868B"
                                   FontSize="14"
                                   TextWrapping="Wrap" />

                        <Grid Margin="0,24,0,0">
                            <Border Padding="18,18,52,18"
                                    Background="#F5F5F7"
                                    CornerRadius="14">
                                <TextBlock x:Name="TxtRecoveryKeyValue"
                                           FontFamily="Consolas"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#000000"
                                           TextWrapping="Wrap" />
                            </Border>
                            <Button x:Name="BtnCopyRecoveryKey"
                                    Style="{StaticResource CopyIconButtonStyle}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0"
                                    Width="32"
                                    Height="32"
                                    ToolTip="复制密钥"
                                    Click="BtnCopyRecoveryKey_Click" />
                        </Grid>

                        <TextBlock x:Name="TxtCopyRecoveryKeyStatus"
                                   Margin="2,8,0,0"
                                   Foreground="#5F6674"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Visibility="Collapsed" />

                        <CheckBox x:Name="ChkRecoverySaved"
                                  Content="我已妥善保存此密钥"
                                  Margin="0,18,0,0"
                                  Checked="ChkRecoverySaved_OnChanged"
                                  Unchecked="ChkRecoverySaved_OnChanged"
                                  Foreground="#1D1D1F"
                                  FontWeight="SemiBold" />

                        <Button x:Name="BtnContinueAfterRecovery"
                                Content="确认并进入系统"
                                Style="{StaticResource PremiumButtonStyle}"
                                Margin="0,24,0,0"
                                IsEnabled="False"
                                Click="BtnContinueAfterRecovery_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
