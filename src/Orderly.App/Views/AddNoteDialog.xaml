<Window x:Class="Orderly.App.Views.AddNoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增备注"
        Width="460"
        Height="420"
        MinWidth="420"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PageBackgroundBrush}"
        AutomationProperties.AutomationId="AddNoteDialog">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/AppContentScrollResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题区 -->
        <Border Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="新增备注" Style="{StaticResource DialogSectionTitleStyle}" Margin="0" />
                <TextBlock Text="选择备注类型，可插入话术模板后二次编辑" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <Grid Grid.Row="1" Margin="22,18,22,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 备注类型 -->
            <TextBlock Grid.Row="0" Text="备注类型" Style="{StaticResource DialogFieldLabelStyle}" />
            <ComboBox x:Name="TypeComboBox"
                      Grid.Row="1"
                      Margin="0,0,0,14"
                      AutomationProperties.AutomationId="AddNoteDialog_Type" />

            <!-- 话术模板插入 -->
            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="TemplateComboBox"
                          DisplayMemberPath="Title"
                          AutomationProperties.AutomationId="AddNoteDialog_Template" />
                <Button Grid.Column="2"
                        Content="插入话术"
                        Style="{StaticResource DialogSecondaryButtonStyle}"
                        MinWidth="0"
                        Padding="12,6"
                        Click="InsertTemplateButton_Click"
                        AutomationProperties.AutomationId="AddNoteDialog_InsertTemplate" />
            </Grid>

            <!-- 备注内容 -->
            <StackPanel Grid.Row="3">
                <TextBlock Text="备注内容 *" Style="{StaticResource DialogFieldLabelStyle}" />
                <TextBox x:Name="ContentTextBox"
                         Margin="0,0,0,0"
                         MinHeight="120"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         AutomationProperties.AutomationId="AddNoteDialog_Content" />
            </StackPanel>
        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2"
                Background="#FFFDF8"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Style="{StaticResource DialogSecondaryButtonStyle}"
                        IsCancel="True"
                        Margin="0,0,10,0"
                        AutomationProperties.AutomationId="AddNoteDialog_Cancel" />
                <Button Content="确认保存"
                        Style="{StaticResource DialogPrimaryButtonStyle}"
                        IsDefault="True"
                        Click="ConfirmButton_Click"
                        AutomationProperties.AutomationId="AddNoteDialog_Confirm" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
