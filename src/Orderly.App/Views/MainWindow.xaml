<Window x:Class="Orderly.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Sections="clr-namespace:Orderly.App.Views.Sections"
        Title="Orderly 商家工作台"
        Width="1280"
        Height="820"
        MinWidth="1140"
        MinHeight="800"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FBFAF6" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0" Padding="18">
            <DockPanel>
                <!-- 底部“我的”按钮 -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Button x:Name="Tab_Me" AutomationProperties.AutomationId="Tab_Me" Content="我的" Tag="&#xE77B;" Style="{StaticResource ProfileMenuGlassButtonStyle}" Command="{Binding SelectSectionCommand}" CommandParameter="我的"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Orderly" FontSize="26" FontWeight="Bold" Foreground="#17211D" />
                    <TextBlock Text="本地商家工作台" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,20" />

                    <Button x:Name="Tab_Dashboard" AutomationProperties.AutomationId="Tab_Dashboard" Content="工作台" Tag="&#xE80F;" Command="{Binding SelectSectionCommand}" CommandParameter="工作台">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Fulfillment" AutomationProperties.AutomationId="Tab_Fulfillment" Content="订单履约" Tag="&#xE8A1;" Command="{Binding SelectSectionCommand}" CommandParameter="订单履约">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Inventory" AutomationProperties.AutomationId="Tab_Inventory" Content="库存管理" Tag="&#xE7B8;" Command="{Binding SelectSectionCommand}" CommandParameter="库存管理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="库存管理">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Cashflow" AutomationProperties.AutomationId="Tab_Cashflow" Content="现金流" Tag="&#xE825;" Command="{Binding SelectSectionCommand}" CommandParameter="现金流">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="现金流">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_ExceptionOrders" AutomationProperties.AutomationId="Tab_ExceptionOrders" Content="异常处理" Tag="&#xE7BA;" Command="{Binding SelectSectionCommand}" CommandParameter="异常处理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Settings" AutomationProperties.AutomationId="Tab_Settings" Content="设置" Tag="&#xE713;" Command="{Binding SelectSectionCommand}" CommandParameter="设置">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Margin" Value="0,0,0,18" />
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="库存管理">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="现金流">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="我的">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding SelectedSection}" FontSize="29" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                    <TextBlock Text="客户、订单、跟进和快捷回复集中处理" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
                </StackPanel>
            </DockPanel>
            <Sections:WorkbenchView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=工作台}" />

            <!-- 库存管理 -->
            <Sections:InventoryView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=库存管理}" />

            <!-- 现金流 -->
            <Sections:CashflowView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=现金流}" />

            <!-- 订单履约 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=订单履约}">
                <Grid.RowDefinitions>
                    <!-- 0. Custom Header -->
                    <RowDefinition Height="Auto" />
                    <!-- 1. Statistics Cards -->
                    <RowDefinition Height="Auto" />
                    <!-- 2. Search & Filters -->
                    <RowDefinition Height="Auto" />
                    <!-- 3. List & Detail Content Area -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 1. Statistics Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Sections:FulfillmentStatisticsCardsGroupA Grid.Column="0" Grid.ColumnSpan="5" />
                    <Sections:FulfillmentStatisticsCardsGroupB Grid.Column="6" Grid.ColumnSpan="7" />
                </Grid>

                <!-- 2. Search & Filters -->
                <Sections:FulfillmentToolbar Grid.Row="2" />

                <!-- 3. List & Detail Content Area -->
                <Grid Grid.Row="3">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Sections:FulfillmentOrderListPane Grid.Column="0" Grid.ColumnSpan="2" />

                    <!-- Right: Selected Order Detail Panel -->
                    <Sections:FulfillmentDetailView Grid.Column="1" />
                    <!-- 统一工作区加载遮罩（覆盖左侧列表+右侧详情） -->
                    <Grid x:Name="StringNarrationWorkAreaBusyOverlay" Grid.Column="0" Grid.ColumnSpan="2" Background="#D8FFFFFF" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStringNarrationWorkAreaBusy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2" Duration="0">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72C;" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       FontSize="30" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}" 
                                       HorizontalAlignment="Center" 
                                       RenderTransformOrigin="0.5,0.5" 
                                       Margin="0,0,0,12">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=StringNarrationWorkAreaBusyOverlay, Path=Visibility}" Value="Visible">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="RotateStoryboardWorkArea">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="360" Duration="0:0:1"
                                                                             RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="RotateStoryboardWorkArea" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding StringNarrationStatusMessage}" 
                                       FontSize="13" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}" 
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 首次加载数据同步初始化遮罩层 -->
                <Grid x:Name="InitializationLoadingOverlay" Grid.Row="0" Grid.RowSpan="4" Panel.ZIndex="999" Background="{StaticResource PageBackgroundBrush}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStringNarrationInitializing}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.25" Duration="0">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE72C;" 
                                   FontFamily="Segoe MDL2 Assets" 
                                   FontSize="36" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource HeadingBrush}" 
                                   HorizontalAlignment="Center" 
                                   RenderTransformOrigin="0.5,0.5" 
                                   Margin="0,0,0,16">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0" />
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=InitializationLoadingOverlay, Path=Visibility}" Value="Visible">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RotateStoryboardInit">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360" Duration="0:0:1"
                                                                         RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RotateStoryboardInit" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <TextBlock Text="正在初始化..." 
                                   FontSize="15" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource HeadingBrush}" 
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ==================== 异常处理面板 ==================== -->
            <Sections:ExceptionView Grid.Row="1" />





            <Sections:SettingsView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=设置}" />

            <!-- ==================== “我的”板块 (Me/Profile Page) ==================== -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=我的}">
                <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="10*" MaxWidth="1050" MinWidth="600" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        
                        <Grid Grid.Column="1" Margin="0,0,24,0">
                            <!-- 两栏布局：左侧个人卡片，右侧安全设置与店员管理 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左侧：个人资料与快捷控制卡片 -->
                                <StackPanel Grid.Column="0" Margin="0,88,0,0">
                                    <Border Style="{StaticResource SettingsGroupCardStyle}">
                                        <StackPanel Margin="8">
                                            <!-- 头像区域 -->
                                            <Grid HorizontalAlignment="Center" Margin="0,16,0,16">
                                                <Border Width="80" Height="80" CornerRadius="40">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#2B7A5C" Offset="0" />
                                                            <GradientStop Color="#4E9B7B" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>

                                            <!-- 显示昵称 -->
                                            <TextBlock Text="{Binding CurrentAccountDisplayName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" />
                                            
                                            <!-- 身份徽章 -->
                                            <Border CornerRadius="12" Padding="10,3" Margin="0,8,0,20" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F2F4F7" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrentUserOwner}" Value="True">
                                                                <Setter Property="Background" Value="#DCFCE7" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontWeight="SemiBold" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="系统店员 Member" />
                                                            <Setter Property="Foreground" Value="#667085" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrentUserOwner}" Value="True">
                                                                    <Setter Property="Text" Value="系统管理员 Owner" />
                                                                    <Setter Property="Foreground" Value="#16A34A" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <Separator Background="{StaticResource BorderBrushSoft}" Margin="0,0,0,16" />

                                            <!-- 锁定与退出按钮 -->
                                            <!-- 锁定工作台 -->
                                            <Button Content="锁定工作台" Command="{Binding LockSessionCommand}" Style="{StaticResource ToolbarSecondaryButtonStyle}" Margin="0,0,0,12" Height="38" HorizontalAlignment="Stretch" />
                                            
                                            <!-- 安全登出 -->
                                            <Button Content="安全退出登录" Command="{Binding LogoutCommand}" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="38" HorizontalAlignment="Stretch" Foreground="{StaticResource DangerTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- 右侧：安全设置与成员管理列表 -->
                                <ScrollViewer Grid.Column="2" Style="{StaticResource SettingsScrollViewerStyle}" Margin="0,32,0,0">
                                    <StackPanel Margin="0,0,16,0">
                                    <!-- 成员管理卡片（仅系统所有者 Owner 可见） -->
                                    <Border Style="{StaticResource SettingsGroupCardStyle}" Visibility="{Binding CanManageAccounts, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="店员成员管理" Style="{StaticResource SettingsGroupTitleStyle}" />
                                            <TextBlock Text="系统管理员可在此创建、管理其他成员账号" Style="{StaticResource SettingsItemDescStyle}" Margin="0,2,0,16" />

                                            <!-- 创建新成员表单 -->
                                            <Border Background="#F9FAFB" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,18">
                                                <StackPanel>
                                                    <TextBlock Text="新建店员账号" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,10" />
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 第一行：用户名与显示名称 -->
                                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                                            <TextBlock Text="用户名" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberUsername, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                        
                                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                                            <TextBlock Text="显示姓名" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="0" Grid.Column="4">
                                                            <TextBlock Text="主密码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberPassword, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="0" Grid.Column="6">
                                                            <TextBlock Text="PIN 码 (4位)" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberPin, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Button Content="创建账号" Command="{Binding CreateMemberCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" Margin="0,12,0,0" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Border>

                                            <!-- 店员列表 -->
                                            <TextBlock Text="已创建成员" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,10" />
                                            <ListBox BorderThickness="1"
                                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                                     Background="#FFFFFF"
                                                     Padding="4"
                                                     MaxHeight="200"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     ItemsSource="{Binding ManagedAccounts}"
                                                     SelectedItem="{Binding SelectedManagedAccount}">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                        <Setter Property="BorderBrush" Value="#F2F4F7" />
                                                        <Setter Property="Padding" Value="8" />
                                                        <Setter Property="Margin" Value="0" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border x:Name="ContainerBorder" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="ContainerBorder" Property="Background" Value="#F8F9FA" />
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="ContainerBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Background="#EAF2EF" Margin="0,0,10,0">
                                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource HeadingBrush}" />
                                                                    <TextBlock Text="{Binding Username, StringFormat=({0})}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="6,1,0,0" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <!-- 选中店员的操作区 -->
                                            <Border Margin="0,12,0,0" Padding="14" Background="#F8F9FA" CornerRadius="8" Visibility="{Binding CanOperateMember, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="选中成员控制：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding SelectedManagedAccount.DisplayName}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding SelectedManagedAccount.Username, StringFormat=({0})}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="4,1,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- 重置主密码 -->
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="重置该店员主密码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="8" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0" Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding ResetMemberPasswordInput, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button Grid.Column="2" Content="重置密码" Command="{Binding ResetMemberPasswordCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="30" Padding="12,0" Margin="0" />
                                                            </Grid>
                                                        </StackPanel>

                                                        <!-- 重置 PIN -->
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="重置店员 PIN 码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="8" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0" Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding ResetMemberPinInput, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button Grid.Column="2" Content="重置 PIN" Command="{Binding ResetMemberPinCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="30" Padding="12,0" Margin="0" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                    
                                                    <Button Content="停用/禁用此店员账号" Command="{Binding DisableMemberCommand}" Style="{StaticResource ToolbarSecondaryButtonStyle}" Foreground="{StaticResource DangerTextBrush}" Height="32" Margin="0,12,0,0" HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <TextBlock Text="{Binding AccountManagementStatus}" Style="{StaticResource SettingsItemDescStyle}" Margin="0,10,0,0" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 密码与 PIN 修改安全设置卡片 -->
                                    <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="登录凭证修改" Style="{StaticResource SettingsGroupTitleStyle}" />
                                            <TextBlock Text="保护您的账户安全，建议定期更换安全凭证" Style="{StaticResource SettingsItemDescStyle}" Margin="0,2,0,16" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- 修改主密码 -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="修改账户主密码" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,12" />
                                                    
                                                    <TextBlock Text="当前密码验证" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Margin="0,0,0,10" Text="{Binding CurrentMasterPasswordInput, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Text="输入新主密码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Margin="0,0,0,12" Text="{Binding NewCurrentMasterPasswordInput, UpdateSourceTrigger=PropertyChanged}" />

                                                    <Button Content="确认修改主密码" Command="{Binding ChangeCurrentMasterPasswordCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" HorizontalAlignment="Left" />
                                                </StackPanel>

                                                <!-- 修改 PIN 码 -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="修改安全 PIN 码" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,12" />
                                                    
                                                    <TextBlock Text="当前 PIN 验证" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Margin="0,0,0,10" Text="{Binding CurrentPinInput, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Text="输入新 PIN 码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Margin="0,0,0,12" Text="{Binding NewCurrentPinInput, UpdateSourceTrigger=PropertyChanged}" />

                                                    <Button Content="确认修改 PIN 码" Command="{Binding ChangeCurrentPinCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>

            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <!-- 复制成功气泡提示 -->
            <Popup x:Name="Popup_CopyToast" Placement="Mouse" AllowsTransparency="True" HorizontalOffset="10" VerticalOffset="10">
                <Border Background="#222224" CornerRadius="8" Padding="12,6" BorderThickness="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock x:Name="Text_CopyToast" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>

