                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="80"
                                                     Text="{Binding AiTimeoutSecondsInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_AiTimeoutSeconds" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI 隐私与安全配置卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="AI 隐私安全与脱敏" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 上下文发送前自动脱敏 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
