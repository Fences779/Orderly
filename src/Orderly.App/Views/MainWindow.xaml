                                                        Command="{Binding SelectOcrImageCommand}"
                                                        Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                                        Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding CurrentOcrFileNameText}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />
