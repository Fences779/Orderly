                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasCustomerNotes}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{StaticResource HeadingBrush}" LineHeight="20" />
                                                            <WrapPanel Margin="0,8,0,0">
                                                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="9" Padding="8,2" Margin="0,0,8,6">
                                                                    <TextBlock Text="{Binding Type, Converter={StaticResource EnumLabelConverter}}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                                                </Border>
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}">
