                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="详细地址" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Top" Margin="0,3,0,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.FullAddressText}" Foreground="{StaticResource HeadingBrush}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,3,0,0" />
                                            <Button Grid.Column="2" Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="0,1,0,0" VerticalAlignment="Top"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="address" ToolTip="复制地址">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Button>
                                        </Grid>
                                        
                                        <Border Background="{StaticResource SurfaceSoftBrush}" Height="1" Margin="0,0,0,12" HorizontalAlignment="Stretch" />
                                        
                                        <!-- Logistics details inputs -->
                                        <StackPanel>
                                            <TextBlock Text="发货快递公司与单号" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,8" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0">
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationCarrierInput, Mode=TwoWay}"
                                                             AutomationProperties.AutomationId="Input_FulfillmentCarrier" KeyDown="FulfillmentInput_KeyDown" />
                                                    <TextBlock Text="快递公司 (如 顺丰)" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
