                            <!-- Card 5: 异常订单 (红色) -->
                            <Border Grid.Column="8" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16,14">
                                <Border.Effect>
