                                            </Border>
                                            <Border Background="{StaticResource WarmSoftBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,8,8">
                                                <TextBlock Text="{Binding CustomerPriorityLabel, StringFormat=优先级 {0}}" Foreground="{StaticResource WarmTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                            </Border>
                                        </WrapPanel>
