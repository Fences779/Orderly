                                                     AutomationProperties.AutomationId="Txt_NotifyPaidUnconfirmedHours" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
