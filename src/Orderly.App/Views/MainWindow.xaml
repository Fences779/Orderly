<Window x:Class="Orderly.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Sections="clr-namespace:Orderly.App.Views.Sections"
        Title="Orderly 商家工作台"
        Width="1280"
        Height="820"
        MinWidth="1140"
        MinHeight="800"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FBFAF6" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0" Padding="18">
            <DockPanel>
                <!-- 底部“我的”按钮 -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Button x:Name="Tab_Me" AutomationProperties.AutomationId="Tab_Me" Content="我的" Tag="&#xE77B;" Style="{StaticResource ProfileMenuGlassButtonStyle}" Command="{Binding SelectSectionCommand}" CommandParameter="我的"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Orderly" FontSize="26" FontWeight="Bold" Foreground="#17211D" />
                    <TextBlock Text="本地商家工作台" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,20" />

                    <Button x:Name="Tab_Dashboard" AutomationProperties.AutomationId="Tab_Dashboard" Content="工作台" Tag="&#xE80F;" Command="{Binding SelectSectionCommand}" CommandParameter="工作台">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Fulfillment" AutomationProperties.AutomationId="Tab_Fulfillment" Content="订单履约" Tag="&#xE8A1;" Command="{Binding SelectSectionCommand}" CommandParameter="订单履约">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Inventory" AutomationProperties.AutomationId="Tab_Inventory" Content="库存管理" Tag="&#xE7B8;" Command="{Binding SelectSectionCommand}" CommandParameter="库存管理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="库存管理">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Cashflow" AutomationProperties.AutomationId="Tab_Cashflow" Content="现金流" Tag="&#xE825;" Command="{Binding SelectSectionCommand}" CommandParameter="现金流">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="现金流">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_ExceptionOrders" AutomationProperties.AutomationId="Tab_ExceptionOrders" Content="异常处理" Tag="&#xE7BA;" Command="{Binding SelectSectionCommand}" CommandParameter="异常处理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Settings" AutomationProperties.AutomationId="Tab_Settings" Content="设置" Tag="&#xE713;" Command="{Binding SelectSectionCommand}" CommandParameter="设置">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Margin" Value="0,0,0,18" />
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="库存管理">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="现金流">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="我的">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding SelectedSection}" FontSize="29" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                    <TextBlock Text="客户、订单、跟进和快捷回复集中处理" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
                </StackPanel>
            </DockPanel>
            <Sections:WorkbenchView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=工作台}" />

            <!-- 库存管理 -->
            <Sections:InventoryView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=库存管理}" />

            <!-- 现金流 -->
            <Sections:CashflowView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=现金流}" />

            <!-- 订单履约 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=订单履约}">
                <Grid.RowDefinitions>
                    <!-- 0. Custom Header -->
                    <RowDefinition Height="Auto" />
                    <!-- 1. Statistics Cards -->
                    <RowDefinition Height="Auto" />
                    <!-- 2. Search & Filters -->
                    <RowDefinition Height="Auto" />
                    <!-- 3. List & Detail Content Area -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 1. Statistics Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Sections:FulfillmentStatisticsCardsGroupA Grid.Column="0" Grid.ColumnSpan="5" />
                    <Sections:FulfillmentStatisticsCardsGroupB Grid.Column="6" Grid.ColumnSpan="7" />
                </Grid>

                <!-- 2. Search & Filters -->
                <Sections:FulfillmentToolbar Grid.Row="2" />

                <!-- 3. List & Detail Content Area -->
                <Grid Grid.Row="3">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Sections:FulfillmentOrderListPane Grid.Column="0" Grid.ColumnSpan="2" />

                    <!-- Right: Selected Order Detail Panel -->
                    <Sections:FulfillmentDetailView Grid.Column="1" />
                    <!-- 统一工作区加载遮罩（覆盖左侧列表+右侧详情） -->
                    <Grid x:Name="StringNarrationWorkAreaBusyOverlay" Grid.Column="0" Grid.ColumnSpan="2" Background="#D8FFFFFF" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStringNarrationWorkAreaBusy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2" Duration="0">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72C;" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       FontSize="30" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}" 
                                       HorizontalAlignment="Center" 
                                       RenderTransformOrigin="0.5,0.5" 
                                       Margin="0,0,0,12">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=StringNarrationWorkAreaBusyOverlay, Path=Visibility}" Value="Visible">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="RotateStoryboardWorkArea">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="360" Duration="0:0:1"
                                                                             RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="RotateStoryboardWorkArea" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding StringNarrationStatusMessage}" 
                                       FontSize="13" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}" 
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 首次加载数据同步初始化遮罩层 -->
                <Grid x:Name="InitializationLoadingOverlay" Grid.Row="0" Grid.RowSpan="4" Panel.ZIndex="999" Background="{StaticResource PageBackgroundBrush}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStringNarrationInitializing}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.25" Duration="0">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE72C;" 
                                   FontFamily="Segoe MDL2 Assets" 
                                   FontSize="36" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource HeadingBrush}" 
                                   HorizontalAlignment="Center" 
                                   RenderTransformOrigin="0.5,0.5" 
                                   Margin="0,0,0,16">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0" />
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=InitializationLoadingOverlay, Path=Visibility}" Value="Visible">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RotateStoryboardInit">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360" Duration="0:0:1"
                                                                         RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RotateStoryboardInit" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <TextBlock Text="正在初始化..." 
                                   FontSize="15" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource HeadingBrush}" 
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ==================== 异常处理面板 ==================== -->
            <Sections:ExceptionView Grid.Row="1" />





            <Sections:SettingsView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=设置}" />

            <!-- ==================== “我的”板块 (Me/Profile Page) ==================== -->
            <Sections:MeProfileView Grid.Row="1" />

            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <!-- 复制成功气泡提示 -->
            <Popup x:Name="Popup_CopyToast" Placement="Mouse" AllowsTransparency="True" HorizontalOffset="10" VerticalOffset="10">
                <Border Background="#222224" CornerRadius="8" Padding="12,6" BorderThickness="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock x:Name="Text_CopyToast" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>

