                                                     AutomationProperties.AutomationId="Txt_DefaultAiModel" />
                                        </Grid>
                                    </Border>

                                    <!-- AI 请求超时时间 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 请求超时时间 (秒)" Style="{StaticResource SettingsItemTitleStyle}" />
