<Window x:Class="Orderly.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Sections="clr-namespace:Orderly.App.Views.Sections"
        Title="Orderly 商家工作台"
        Width="1280"
        Height="820"
        MinWidth="1140"
        MinHeight="800"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FBFAF6" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0" Padding="18">
            <DockPanel>
                <!-- 底部“我的”按钮 -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Button x:Name="Tab_Me" AutomationProperties.AutomationId="Tab_Me" Content="我的" Tag="&#xE77B;" Style="{StaticResource ProfileMenuGlassButtonStyle}" Command="{Binding SelectSectionCommand}" CommandParameter="我的"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Orderly" FontSize="26" FontWeight="Bold" Foreground="#17211D" />
                    <TextBlock Text="本地商家工作台" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,20" />

                    <Button x:Name="Tab_Dashboard" AutomationProperties.AutomationId="Tab_Dashboard" Content="工作台" Tag="&#xE80F;" Command="{Binding SelectSectionCommand}" CommandParameter="工作台">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Fulfillment" AutomationProperties.AutomationId="Tab_Fulfillment" Content="订单履约" Tag="&#xE8A1;" Command="{Binding SelectSectionCommand}" CommandParameter="订单履约">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Inventory" AutomationProperties.AutomationId="Tab_Inventory" Content="库存管理" Tag="&#xE7B8;" Command="{Binding SelectSectionCommand}" CommandParameter="库存管理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="库存管理">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Cashflow" AutomationProperties.AutomationId="Tab_Cashflow" Content="现金流" Tag="&#xE825;" Command="{Binding SelectSectionCommand}" CommandParameter="现金流">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="现金流">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_ExceptionOrders" AutomationProperties.AutomationId="Tab_ExceptionOrders" Content="异常处理" Tag="&#xE7BA;" Command="{Binding SelectSectionCommand}" CommandParameter="异常处理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Settings" AutomationProperties.AutomationId="Tab_Settings" Content="设置" Tag="&#xE713;" Command="{Binding SelectSectionCommand}" CommandParameter="设置">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Margin" Value="0,0,0,18" />
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="库存管理">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="现金流">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="我的">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding SelectedSection}" FontSize="29" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                    <TextBlock Text="客户、订单、跟进和快捷回复集中处理" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
                </StackPanel>
            </DockPanel>
            <Sections:WorkbenchView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=工作台}" />

            <!-- 库存管理 -->
            <Sections:InventoryView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=库存管理}" />

            <!-- 现金流 -->
            <Sections:CashflowView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=现金流}" />

            <!-- 订单履约 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=订单履约}">
                <Grid.RowDefinitions>
                    <!-- 0. Custom Header -->
                    <RowDefinition Height="Auto" />
                    <!-- 1. Statistics Cards -->
                    <RowDefinition Height="Auto" />
                    <!-- 2. Search & Filters -->
                    <RowDefinition Height="Auto" />
                    <!-- 3. List & Detail Content Area -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 1. Statistics Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Sections:FulfillmentStatisticsCardsGroupA Grid.Column="0" Grid.ColumnSpan="5" />
                    <Sections:FulfillmentStatisticsCardsGroupB Grid.Column="6" Grid.ColumnSpan="7" />
                </Grid>

                <!-- 2. Search & Filters -->
                <Sections:FulfillmentToolbar Grid.Row="2" />

                <!-- 3. List & Detail Content Area -->
                <Grid Grid.Row="3">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Sections:FulfillmentOrderListPane Grid.Column="0" Grid.ColumnSpan="2" />

                    <!-- Right: Selected Order Detail Panel -->
                    <Border x:Name="DetailPanel" Grid.Column="1" Padding="18" Margin="0" RenderTransformOrigin="0.5,0.5"
                            Visibility="{Binding IsStringNarrationDetailPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.RenderTransform>
                            <TranslateTransform X="40" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource SettingsGroupCardStyle}">
                                <Style.Triggers>
                                    <Trigger Property="Visibility" Value="Visible">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="40" To="0" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Header -->
                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="订单详情" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="订单号：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.OrderNoText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                                <Button Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="6,0,0,2" VerticalAlignment="Center"
                                                        Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="orderNo" ToolTip="复制订单号">
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="32" Height="32" Padding="0" VerticalAlignment="Top"
                                                Click="CloseDetails_Click" ToolTip="关闭详情">
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Stepper -->
                                <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="12" Padding="14,12" Margin="0,0,0,14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Node 1: 待确认 -->
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Cursor="Hand" Tag="paid_pending_confirm" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为待确认状态">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="paid_pending_confirm">
                                                                <Setter Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource BlueTextBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource BlueTextBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="1" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="待确认" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="paid_pending_confirm">
                                                                <Setter Property="Foreground" Value="{StaticResource BlueTextBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Line 1-2 -->
                                        <Rectangle Grid.Column="1" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 2: 待制作 -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Cursor="Hand" Tag="pending_make" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为待制作状态">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="#D0D4D9" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make">
                                                                <Setter Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource WarmTextBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource WarmTextBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="2" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="待制作" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make">
                                                                <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Line 2-3 -->
                                        <Rectangle Grid.Column="3" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 3: 制作中 -->
                                        <StackPanel Grid.Column="4" HorizontalAlignment="Center" Cursor="Hand" Tag="making" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为制作中状态">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="#D0D4D9" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making">
                                                                <Setter Property="Background" Value="{StaticResource PurpleSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource PurpleTextBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource PurpleTextBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="3" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="制作中" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making">
                                                                <Setter Property="Foreground" Value="{StaticResource PurpleTextBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Line 3-4 -->
                                        <Rectangle Grid.Column="5" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 4: 待发货 -->
                                        <StackPanel Grid.Column="6" HorizontalAlignment="Center" Cursor="Hand" Tag="ready_to_ship" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为待发货状态">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="#D0D4D9" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship">
                                                                <Setter Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource BlueTextBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource BlueTextBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="4" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="待发货" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship">
                                                                <Setter Property="Foreground" Value="{StaticResource BlueTextBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Line 4-5 -->
                                        <Rectangle Grid.Column="7" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 5: 已发货 -->
                                        <StackPanel Grid.Column="8" HorizontalAlignment="Center" Cursor="Hand" Tag="shipped" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为已发货状态">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="#D0D4D9" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
                                                                <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="5" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="已发货" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
                                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Line 5-6 -->
                                        <Rectangle Grid.Column="9" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 6: 已完成 -->
                                        <StackPanel Grid.Column="10" HorizontalAlignment="Center" Cursor="Hand" Tag="completed" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为已完成状态">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="#D0D4D9" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed">
                                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentTextBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource AccentTextBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="6" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="已完成" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Overview Grid -->
                                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="订单概览" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,10" />
                                        <UniformGrid Columns="3">
                                            <!-- Box 1: Receiver Name -->
                                            <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,8">
                                                <StackPanel>
                                                    <TextBlock Text="客户昵称" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverName, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Box 2: Amount -->
                                            <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,8">
                                                <StackPanel>
                                                    <TextBlock Text="订单金额" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.AmountText, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Box 3: Count -->
                                            <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="商品数量" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ItemCountText, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Box 4: CreatedAt -->
                                            <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Text="下单时间" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.CreatedAtText, FallbackValue='-'}" FontSize="11" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Box 5: PaidAt -->
                                            <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Text="支付时间" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.PaidAtText, FallbackValue='-'}" FontSize="11" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Box 6: Channel -->
                                            <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="支付通道" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="微信支付" FontSize="11" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <!-- Product snap list -->
                                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="商品快照" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,10" />
                                        <ItemsControl ItemsSource="{Binding SelectedStringNarrationOrderDetail.ItemsSnapshot}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource SurfaceSoftBrush}" 
                                                            BorderBrush="{StaticResource BorderBrushSoft}" 
                                                            BorderThickness="1" 
                                                            CornerRadius="8" 
                                                            Margin="4" 
                                                            Padding="8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="40" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" ClipToBounds="True" VerticalAlignment="Center">
                                                                <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                                                            </Border>
                                                            
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding TitleText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" MaxHeight="32" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding DesignIdText}" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" />
                                                            </StackPanel>
                                                            
                                                            <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Production Order section -->
                                <Grid Margin="0,0,0,14">
                                    <!-- Case A: Production Order Exists -->
                                    <Border Padding="14">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.HasData}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock Text="生产工单信息" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="8" Padding="6,2" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.StatusText}" FontSize="11" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                                                </Border>
                                            </DockPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="工单单号：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.ProductionOrderNoText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="制作来源：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.SourceText}" Foreground="{StaticResource HeadingBrush}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="制作备注：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.RemarkText}" Foreground="{StaticResource HeadingBrush}" FontSize="12" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Case B: Generate Production Order Button -->
                                    <Border BorderThickness="0" Background="Transparent" Padding="0" Cursor="Hand" Height="64">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.HasData}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Button Command="{Binding GenerateStringNarrationProductionOrderCommand}" Background="Transparent" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Rectangle x:Name="BgRect" Stroke="{StaticResource HeadingBrush}" StrokeThickness="1.5" StrokeDashArray="4 2" RadiusX="12" RadiusY="12" Fill="#FAFBFD" SnapsToDevicePixels="True" />
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                            <TextBlock Text="生成制作单" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BgRect" Property="Fill" Value="{StaticResource SurfaceSoftBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Border>
                                </Grid>

                                <!-- Shipping Info -->
                                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="收货人与物流信息" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                            <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="24" Padding="8,0" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="receiverInfo" ToolTip="复制完整收货信息">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="复制整单" FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </DockPanel>
                                        
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="收件人" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverName}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="联系电话" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverPhone}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="0,0,0,2" VerticalAlignment="Center"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="phone" ToolTip="复制电话">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Button>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="详细地址" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Top" Margin="0,3,0,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.FullAddressText}" Foreground="{StaticResource HeadingBrush}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,3,0,0" />
                                            <Button Grid.Column="2" Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="0,1,0,0" VerticalAlignment="Top"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="address" ToolTip="复制地址">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Button>
                                        </Grid>
                                        
                                        <Border Background="{StaticResource SurfaceSoftBrush}" Height="1" Margin="0,0,0,12" HorizontalAlignment="Stretch" />
                                        
                                        <!-- Logistics details inputs -->
                                        <StackPanel>
                                            <TextBlock Text="发货快递公司与单号" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,8" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0">
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationCarrierInput, Mode=TwoWay}"
                                                             AutomationProperties.AutomationId="Input_FulfillmentCarrier" KeyDown="FulfillmentInput_KeyDown" />
                                                    <TextBlock Text="快递公司 (如 顺丰)" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StringNarrationCarrierInput}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StringNarrationCarrierInput}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                                <Grid Grid.Column="2">
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationTrackingNoInput, Mode=TwoWay}"
                                                             AutomationProperties.AutomationId="Input_FulfillmentTrackingNo" KeyDown="FulfillmentInput_KeyDown" />
                                                    <TextBlock Text="快递单号" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StringNarrationTrackingNoInput}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StringNarrationTrackingNoInput}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                            
                                            <Grid Margin="0,0,0,10">
                                                <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationAdminRemarkInput, Mode=TwoWay}"
                                                         AutomationProperties.AutomationId="Input_FulfillmentAdminRemark" KeyDown="FulfillmentInput_KeyDown" />
                                                <TextBlock Text="后台备注 (如 加急制作)" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationAdminRemarkInput}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationAdminRemarkInput}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <ComboBox Grid.Column="0" Height="36" Style="{StaticResource FulfillmentInputComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource FulfillmentComboBoxItemStyle}"
                                                          ItemsSource="{Binding StringNarrationFulfillmentStatusOptions}"
                                                          SelectedItem="{Binding StringNarrationFulfillmentStatusInput}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource FulfillmentStatusLabelConverter}}" VerticalAlignment="Center" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                
                                                <Button Grid.Column="2" Content="保存履约信息" Style="{StaticResource DialogPrimaryButtonStyle}" Height="36" Padding="14,0" Command="{Binding UpdateStringNarrationFulfillmentCommand}" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Bottom Action buttons -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Button Content="联系客户" Style="{StaticResource DialogSecondaryButtonStyle}" Height="36" Padding="14,0" Margin="0,0,8,0" />
                                        <Button Content="异常处理" Style="{StaticResource DialogSecondaryButtonStyle}" Height="36" Padding="14,0" Foreground="{StaticResource DangerTextBrush}" Tag="exception" Click="QuickFulfillmentUpdate_Click" />
                                    </StackPanel>
                                    
                                    <Grid Grid.Column="1">
                                        <!-- paid_pending_confirm -> Confirm demand -->
                                        <Button Content="确认需求" Height="36" Padding="16,0" Tag="pending_make" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="paid_pending_confirm">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- pending_make -> Generate Production Order / Mark Making -->
                                        <Button Content="生成工单并制作" Background="#FF8800" Height="36" Padding="16,0" Tag="making" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- making -> Finish Making (Ready to ship) -->
                                        <Button Content="制作完成" Height="36" Padding="16,0" Tag="ready_to_ship" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- ready_to_ship -> Confirm Ship (Shipped) -->
                                        <Button Content="确认发货" Background="#1F7A5A" Height="36" Padding="16,0" Tag="shipped" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- shipped -> Completed -->
                                        <Button Content="完成订单" Height="36" Padding="16,0" Tag="completed" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                            </ScrollViewer>

                            <!-- Detail loading overlay -->
                            <Grid x:Name="DetailLoadingOverlay" Visibility="Collapsed">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStringNarrationDetailBusyVisible_Disabled}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15" Duration="0">
                                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE72C;" 
                                               FontFamily="Segoe MDL2 Assets" 
                                               FontSize="30" 
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HeadingBrush}" 
                                               HorizontalAlignment="Center" 
                                               RenderTransformOrigin="0.5,0.5" 
                                               Margin="0,0,0,12">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </TextBlock.RenderTransform>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=DetailLoadingOverlay, Path=Visibility}" Value="Visible">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="RotateStoryboardDetail">
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                     From="0" To="360" Duration="0:0:1"
                                                                                     RepeatBehavior="Forever" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="RotateStoryboardDetail" />
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding StringNarrationStatusMessage}" 
                                               FontSize="13" 
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HeadingBrush}" 
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                    <!-- 统一工作区加载遮罩（覆盖左侧列表+右侧详情） -->
                    <Grid x:Name="StringNarrationWorkAreaBusyOverlay" Grid.Column="0" Grid.ColumnSpan="2" Background="#D8FFFFFF" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStringNarrationWorkAreaBusy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2" Duration="0">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72C;" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       FontSize="30" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}" 
                                       HorizontalAlignment="Center" 
                                       RenderTransformOrigin="0.5,0.5" 
                                       Margin="0,0,0,12">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=StringNarrationWorkAreaBusyOverlay, Path=Visibility}" Value="Visible">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="RotateStoryboardWorkArea">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="360" Duration="0:0:1"
                                                                             RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="RotateStoryboardWorkArea" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding StringNarrationStatusMessage}" 
                                       FontSize="13" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}" 
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 首次加载数据同步初始化遮罩层 -->
                <Grid x:Name="InitializationLoadingOverlay" Grid.Row="0" Grid.RowSpan="4" Panel.ZIndex="999" Background="{StaticResource PageBackgroundBrush}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStringNarrationInitializing}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.25" Duration="0">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE72C;" 
                                   FontFamily="Segoe MDL2 Assets" 
                                   FontSize="36" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource HeadingBrush}" 
                                   HorizontalAlignment="Center" 
                                   RenderTransformOrigin="0.5,0.5" 
                                   Margin="0,0,0,16">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0" />
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=InitializationLoadingOverlay, Path=Visibility}" Value="Visible">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RotateStoryboardInit">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360" Duration="0:0:1"
                                                                         RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RotateStoryboardInit" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <TextBlock Text="正在初始化..." 
                                   FontSize="15" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource HeadingBrush}" 
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ==================== 异常处理面板 ==================== -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=异常处理}">
                <Grid.RowDefinitions>
                    <!-- 0. Search & Filters -->
                    <RowDefinition Height="Auto" />
                    <!-- 1. List & Detail Content Area -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 0. Search & Filters 独立筛选栏 -->
                <Border Grid.Row="0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="0" Margin="0,0,0,14">
                    <Grid>
                        <!-- 搜索框 -->
                        <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="36" Padding="32,0,10,0"
                                 Text="{Binding ExceptionKeyword, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="🔍 搜索订单号/客户昵称/异常原因..." Foreground="{StaticResource CaptionTextBrush}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,0,0,0" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ExceptionKeyword}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ExceptionKeyword}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- 1. List & Detail Content Area -->
                <Grid Grid.Row="1">
                    <Grid.Resources>
                        <!-- 异常卡片样式 -->
                        <Style x:Key="ExceptionOrderCardListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource CardListBoxItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <EventSetter Event="MouseDoubleClick" Handler="ExceptionOrderCard_MouseDoubleClick" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid Margin="6">
                                            <Border x:Name="CardBorder" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14" RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="CardTransform" Y="0" />
                                                </Border.RenderTransform>
                                                <Border.Effect>
                                                    <DropShadowEffect x:Name="CardShadow" BlurRadius="12" ShadowDepth="1" Direction="270" Color="#111216" Opacity="0.02" />
                                                </Border.Effect>
                                                <ContentPresenter />
                                            </Border>
                                            <Border x:Name="ActiveIndicator" Width="4" Height="36" Background="#17181C" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" Margin="1,0,0,0" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <!-- 悬停动画 -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True" />
                                                    <Condition Property="IsSelected" Value="False" />
                                                </MultiTrigger.Conditions>
                                                <MultiTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardTransform" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.1">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.10" Duration="0" />
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="16" Duration="0" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiTrigger.EnterActions>
                                                <MultiTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.12">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.02" Duration="0" />
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="12" Duration="0" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiTrigger.ExitActions>
                                                <Setter TargetName="CardBorder" Property="Background" Value="#F8F9FA" />
                                            </MultiTrigger>

                                            <!-- 选中状态 -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardTransform" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.1">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.06" Duration="0" />
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="16" Duration="0" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.12">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.02" Duration="0" />
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="12" Duration="0" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                                <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <!-- 单个异常卡片数据模板 -->
                        <DataTemplate x:Key="ExceptionOrderCardTemplate">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /> <!-- 警告图标 -->
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />    <!-- 主要信息 -->
                                </Grid.ColumnDefinitions>

                                <!-- 警告图标 -->
                                <Border x:Name="IconBorder" Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource GreySoftBrush}" VerticalAlignment="Center">
                                    <TextBlock x:Name="IconText" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource GreyTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- 主要信息 -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Exception.ExceptionCategoryLabel}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                        <Border x:Name="PriorityTag" Margin="8,0,0,0" Padding="6,1.5" CornerRadius="4" Background="{StaticResource GreySoftBrush}" VerticalAlignment="Center">
                                            <TextBlock x:Name="PriorityTagText" Text="{Binding Exception.LevelText}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource GreyTextBrush}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding OrderNoText}" FontSize="11.5" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="Medium" />
                                        <TextBlock Text="|" Foreground="{StaticResource BorderBrushSoft}" Margin="6,0" />
                                        <TextBlock Text="{Binding ReceiverSummaryText}" FontSize="11.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </StackPanel>

                            </Grid>
                            <DataTemplate.Triggers>
                                <!-- 根据严重程度改变颜色 -->
                                <DataTrigger Binding="{Binding Exception.SeverityCategory}" Value="Money">
                                    <Setter TargetName="IconBorder" Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                    <Setter TargetName="IconText" Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                    <Setter TargetName="PriorityTag" Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                    <Setter TargetName="PriorityTagText" Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="IconBorder" Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.25" />
                                                <DoubleAnimation Storyboard.TargetName="PriorityTag" Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.25" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Exception.SeverityCategory}" Value="Warning">
                                    <Setter TargetName="IconBorder" Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                    <Setter TargetName="IconText" Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                    <Setter TargetName="PriorityTag" Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                    <Setter TargetName="PriorityTagText" Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="IconBorder" Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.25" />
                                                <DoubleAnimation Storyboard.TargetName="PriorityTag" Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.25" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                                <!-- 已解决，淡化 -->
                                <DataTrigger Binding="{Binding Exception.IsResolved}" Value="True">
                                    <Setter TargetName="IconBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                    <Setter TargetName="IconText" Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                    <Setter TargetName="IconText" Property="Text" Value="&#xE73E;" />
                                    <Setter TargetName="PriorityTag" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                    <Setter TargetName="PriorityTagText" Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                    <Setter TargetName="PriorityTagText" Property="Text" Value="已解决" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="IconBorder" Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.25" />
                                                <DoubleAnimation Storyboard.TargetName="PriorityTag" Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.25" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </Grid.Resources>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <!-- A. 列表收起模式 (选中详情时，左边占 2/5 宽度，单列) -->
                    <Border Grid.Column="0" Style="{StaticResource SettingsGroupCardStyle}" Padding="16" Margin="0,0,14,0"
                            Visibility="{Binding IsExceptionDetailPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <DockPanel>
                            <!-- 分页 -->
                            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="共 " Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding ExceptionTotalCount, FallbackValue=0}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text=" 条数据" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="15" Height="30" Padding="1,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateExceptionPrevPageCommand}" ToolTip="上一页">
                                                <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Button>
                                            <Border Padding="10,0" Background="Transparent" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ExceptionPageLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                            </Border>
                                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateExceptionNextPageCommand}" ToolTip="下一页">
                                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ToggleButton x:Name="Btn_ExceptionPageSizeSelector1"
                                                      Style="{StaticResource PageSizeSelectorToggleButtonStyle}"
                                                      IsChecked="{Binding IsExceptionPageSizePopupOpen1, Mode=TwoWay}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ExceptionPageSize, StringFormat={}{0} 条/页}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text=" ▾"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,0,0"/>
                                            </StackPanel>
                                        </ToggleButton>
                                        <Popup x:Name="Popup_ExceptionPageSizeSelector1"
                                               PlacementTarget="{Binding ElementName=Btn_ExceptionPageSizeSelector1}"
                                               Placement="Top"
                                               IsOpen="{Binding IsExceptionPageSizePopupOpen1, Mode=TwoWay}"
                                               StaysOpen="False"
                                               AllowsTransparency="True">
                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="4"
                                                    Margin="0,0,0,4">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Direction="90" Color="#111216" Opacity="0.08" />
                                                </Border.Effect>
                                                <StackPanel Width="90">
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="10 条/页"
                                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                                            CommandParameter="10"/>
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="16 条/页"
                                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                                            CommandParameter="16"/>
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="20 条/页"
                                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                                            CommandParameter="20"/>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid>
                                <!-- 空状态 -->
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasExceptionOrders}" Value="False" />
                                                        <Condition Binding="{Binding IsExceptionOrdersListBusy}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource SurfaceSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{StaticResource CaptionTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding ExceptionOrdersEmptyStateText}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    </StackPanel>
                                </Grid>

                                <!-- 列表 -->
                                <ListBox ItemsSource="{Binding ExceptionOrders}"
                                         SelectedItem="{Binding SelectedExceptionOrder}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource ExceptionOrderCardListItemStyle}"
                                         ItemTemplate="{StaticResource ExceptionOrderCardTemplate}"
                                         Padding="2,4,2,2"
                                         ClipToBounds="False">
                                    <ListBox.Style>
                                        <Style TargetType="ListBox">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasExceptionOrders}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Style>
                                </ListBox>
                            </Grid>
                        </DockPanel>

                        <!-- Loading Overlay -->
                        <Grid x:Name="ExceptionListCollapsedLoadingOverlay" Visibility="Collapsed">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="Opacity" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExceptionOrdersListBusy}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2" Duration="0">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Border Background="#80FFFFFF" CornerRadius="12" />

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE72C;" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="30" 
                                           FontWeight="Bold"
                                           Foreground="{StaticResource HeadingBrush}" 
                                           HorizontalAlignment="Center" 
                                           RenderTransformOrigin="0.5,0.5" 
                                           Margin="0,0,0,12">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=ExceptionListCollapsedLoadingOverlay, Path=Visibility}" Value="Visible">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="RotateStoryboardListCollapsed">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                 From="0" To="360" Duration="0:0:1"
                                                                                 RepeatBehavior="Forever" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="RotateStoryboardListCollapsed" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ExceptionStatusMessage}" 
                                           FontSize="13" 
                                           FontWeight="Bold"
                                           Foreground="{StaticResource HeadingBrush}" 
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                    <!-- B. 列表展开模式 (无详情时，占满两列，双列) -->
                    <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SettingsGroupCardStyle}" Padding="16" Margin="0"
                            Visibility="{Binding IsExceptionListExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <DockPanel>
                            <!-- 分页 -->
                            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="共 " Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding ExceptionTotalCount, FallbackValue=0}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text=" 条数据" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="15" Height="30" Padding="1,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateExceptionPrevPageCommand}" ToolTip="上一页">
                                                <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Button>
                                            <Border Padding="10,0" Background="Transparent" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ExceptionPageLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                            </Border>
                                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateExceptionNextPageCommand}" ToolTip="下一页">
                                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ToggleButton x:Name="Btn_ExceptionPageSizeSelector2"
                                                      Style="{StaticResource PageSizeSelectorToggleButtonStyle}"
                                                      IsChecked="{Binding IsExceptionPageSizePopupOpen2, Mode=TwoWay}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ExceptionPageSize, StringFormat={}{0} 条/页}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text=" ▾"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,0,0"/>
                                            </StackPanel>
                                        </ToggleButton>
                                        <Popup x:Name="Popup_ExceptionPageSizeSelector2"
                                               PlacementTarget="{Binding ElementName=Btn_ExceptionPageSizeSelector2}"
                                               Placement="Top"
                                               IsOpen="{Binding IsExceptionPageSizePopupOpen2, Mode=TwoWay}"
                                               StaysOpen="False"
                                               AllowsTransparency="True">
                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="4"
                                                    Margin="0,0,0,4">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Direction="90" Color="#111216" Opacity="0.08" />
                                                </Border.Effect>
                                                <StackPanel Width="90">
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="10 条/页"
                                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                                            CommandParameter="10"/>
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="16 条/页"
                                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                                            CommandParameter="16"/>
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="20 条/页"
                                                            Command="{Binding ChangeExceptionPageSizeCommand}"
                                                            CommandParameter="20"/>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid>
                                <!-- 空状态 -->
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasExceptionOrders}" Value="False" />
                                                        <Condition Binding="{Binding IsExceptionOrdersListBusy}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource SurfaceSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{StaticResource CaptionTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding ExceptionOrdersEmptyStateText}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    </StackPanel>
                                </Grid>

                                <!-- 列表 (双列 UniformGrid) -->
                                <ListBox ItemsSource="{Binding ExceptionOrders}"
                                         SelectedItem="{Binding SelectedExceptionOrder}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource ExceptionOrderCardListItemStyle}"
                                         ItemTemplate="{StaticResource ExceptionOrderCardTemplate}"
                                         Padding="2,4,2,2"
                                         ClipToBounds="False">
                                    <ListBox.Style>
                                        <Style TargetType="ListBox">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasExceptionOrders}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Style>
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                            </Grid>
                        </DockPanel>

                        <!-- Loading Overlay -->
                        <Grid x:Name="ExceptionListExpandedLoadingOverlay" Visibility="Collapsed">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="Opacity" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExceptionOrdersListBusy}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2" Duration="0">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Border Background="#80FFFFFF" CornerRadius="12" />

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE72C;" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="30" 
                                           FontWeight="Bold"
                                           Foreground="{StaticResource HeadingBrush}" 
                                           HorizontalAlignment="Center" 
                                           RenderTransformOrigin="0.5,0.5" 
                                           Margin="0,0,0,12">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=ExceptionListExpandedLoadingOverlay, Path=Visibility}" Value="Visible">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="RotateStoryboardListExpanded">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                 From="0" To="360" Duration="0:0:1"
                                                                                 RepeatBehavior="Forever" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="RotateStoryboardListExpanded" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ExceptionStatusMessage}" 
                                           FontSize="13" 
                                           FontWeight="Bold"
                                           Foreground="{StaticResource HeadingBrush}" 
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                    <!-- C. 右侧异常详情工作区 -->
                    <Grid x:Name="ExceptionRightPaneContainer"
                          Grid.Column="1"
                          Visibility="{Binding IsExceptionDetailPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border x:Name="ExceptionDetailPanel"
                                Padding="20"
                                Margin="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform X="40" />
                            </Border.RenderTransform>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SettingsGroupCardStyle}">
                                    <Style.Triggers>
                                        <Trigger Property="Visibility" Value="Visible">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="40" To="0" Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                            <!-- 1. 头部标题 & 关闭 (双行紧凑布局以和履约一致) -->
                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="异常详情" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="订单号：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding SelectedExceptionOrderDetail.OrderNoText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                            <Button Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="6,0,0,2" VerticalAlignment="Center"
                                                    Tag="{Binding SelectedExceptionOrderDetail.OrderNo}" Click="CopyText_Click" ToolTip="复制订单号">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="1" Style="{StaticResource ExceptionCloseButtonStyle}" Width="32" Height="32" Padding="0" VerticalAlignment="Top"
                                            Click="CloseExceptionDetails_Click" ToolTip="关闭详情">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- 2. 滚动详情内容 -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-8,0" Padding="0,0,8,0">
                                <StackPanel>
                                    <!-- 核心警告 Banner -->
                                    <Border CornerRadius="12" Padding="14" Margin="0,0,0,16">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <!-- 默认一般问题（灰色） -->
                                                <Setter Property="Background" Value="{StaticResource GreySoftBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.SeverityCategory}" Value="Money">
                                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.SeverityCategory}" Value="Warning">
                                                        <Setter Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.IsResolved}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="28" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <!-- 默认一般问题（灰色） -->
                                                        <Setter Property="Text" Value="&#xE7BA;" />
                                                        <Setter Property="Foreground" Value="{StaticResource GreyTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.SeverityCategory}" Value="Money">
                                                                <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.SeverityCategory}" Value="Warning">
                                                                <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.IsResolved}" Value="True">
                                                                <Setter Property="Text" Value="&#xE73E;" />
                                                                <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding SelectedExceptionOrderDetail.Exception.ExceptionCategoryLabel}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                    <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <!-- 默认一般问题（灰色） -->
                                                                <Setter Property="Background" Value="{StaticResource GreyTextBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.SeverityCategory}" Value="Money">
                                                                        <Setter Property="Background" Value="{StaticResource DangerTextBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.SeverityCategory}" Value="Warning">
                                                                        <Setter Property="Background" Value="{StaticResource WarmTextBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.IsResolved}" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource AccentTextBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding SelectedExceptionOrderDetail.Exception.LevelText}" FontSize="10.5" FontWeight="Bold" Foreground="#FFFFFF" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding SelectedExceptionOrderDetail.Exception.DetectedAtText, StringFormat=发现时间：{0}}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- 异常原因 -->
                                    <TextBlock Text="异常原因" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,6" />
                                    <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,14" BorderThickness="1" BorderBrush="{StaticResource BorderBrushSoft}">
                                        <TextBlock Text="{Binding SelectedExceptionOrderDetail.Exception.EffectiveReason}" FontSize="13" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" LineHeight="18" />
                                    </Border>

                                    <!-- 影响范围 -->
                                    <TextBlock Text="影响范围" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,6" />
                                    <Border Background="{StaticResource WarmSoftBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,16" BorderThickness="1" BorderBrush="{StaticResource DangerBorderBrush}">
                                        <TextBlock Text="将阻断订单履约流程，如果不处理可能导致发货延迟，影响微信发货同步或用户投诉。" FontSize="13" Foreground="{StaticResource WarmTextBrush}" TextWrapping="Wrap" LineHeight="18" />
                                    </Border>

                                    <!-- 关联订单表格 -->
                                    <TextBlock Text="关联订单" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,8" />
                                    <Border BorderThickness="1" BorderBrush="{StaticResource BorderBrushSoft}" CornerRadius="10" Margin="0,0,0,16" Background="#FFFFFF">
                                        <Grid Margin="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Row 0: 订单号 -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="订单号" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                            <DockPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                                                <Button DockPanel.Dock="Right" Style="{StaticResource ExceptionTableCopyButtonStyle}" Width="16" Height="16" Padding="0" Margin="6,0,0,0" Tag="{Binding SelectedExceptionOrderDetail.OrderNo}" Click="CopyText_Click" ToolTip="复制订单号">
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                </Button>
                                                <TextBlock Text="{Binding SelectedExceptionOrderDetail.OrderNoText}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" TextTrimming="CharacterEllipsis" />
                                            </DockPanel>

                                            <!-- Row 2: 下单时间 -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="下单时间" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedExceptionOrderDetail.CreatedAtText}" FontSize="12.5" Foreground="{StaticResource HeadingBrush}" />

                                            <!-- Row 4: 支付订单号 -->
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="支付订单号" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                            <DockPanel Grid.Row="4" Grid.Column="1" VerticalAlignment="Center">
                                                <Button DockPanel.Dock="Right" Style="{StaticResource ExceptionTableCopyButtonStyle}" Width="16" Height="16" Padding="0" Margin="6,0,0,0" Tag="{Binding SelectedExceptionOrderDetail.WxOutTradeNo}" Click="CopyText_Click" ToolTip="复制支付单号">
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                </Button>
                                                <TextBlock Text="{Binding SelectedExceptionOrderDetail.WxOutTradeNoText}" FontSize="12.5" Foreground="{StaticResource HeadingBrush}" TextTrimming="CharacterEllipsis" />
                                            </DockPanel>

                                            <!-- Row 6: 支付时间 -->
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="支付时间" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedExceptionOrderDetail.PaidAtText}" FontSize="12.5" Foreground="{StaticResource HeadingBrush}" />

                                            <!-- Row 8: 客户昵称 -->
                                            <TextBlock Grid.Row="8" Grid.Column="0" Text="客户昵称" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedExceptionOrderDetail.ReceiverSummaryText}" FontSize="12.5" Foreground="{StaticResource HeadingBrush}" />

                                            <!-- Row 10: 订单金额 -->
                                            <TextBlock Grid.Row="10" Grid.Column="0" Text="订单金额" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding SelectedExceptionOrderDetail.AmountText}" FontSize="12.5" FontWeight="Bold" Foreground="{StaticResource WarmTextBrush}" />
                                        </Grid>
                                    </Border>

                                    <!-- 异常详情 -->
                                    <TextBlock Text="异常参数" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,8" />
                                    <Border BorderThickness="1" BorderBrush="{StaticResource BorderBrushSoft}" CornerRadius="10" Margin="0,0,0,16" Background="#FFFFFF">
                                        <Grid Margin="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="异常类型" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedExceptionOrderDetail.Exception.ExceptionCategoryLabel}" FontSize="12.5" Foreground="{StaticResource HeadingBrush}" />

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="严重程度" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedExceptionOrderDetail.Exception.LevelText}" FontSize="12.5" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource GreyTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.SeverityCategory}" Value="Money">
                                                                <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.SeverityCategory}" Value="Warning">
                                                                <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedExceptionOrderDetail.Exception.IsResolved}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="当前状态" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedExceptionOrderDetail.Exception.ResolutionStatusLabel}" FontSize="12.5" Foreground="{StaticResource HeadingBrush}" />

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="异常描述" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedExceptionOrderDetail.Exception.EffectiveReason}" FontSize="12.5" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <!-- 推荐处理动作 -->
                                    <TextBlock Text="推荐处理动作" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 补充地址 -->
                                        <Button Grid.Column="0" Height="68" Style="{StaticResource ExceptionActionCardButtonStyle}" Padding="4" Margin="0" Cursor="Hand" Click="JumpToOrderFulfillment_Click">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                                <TextBlock Text="去补充地址" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <!-- 联系客户 -->
                                        <Button Grid.Column="2" Height="68" Style="{StaticResource ExceptionActionCardButtonStyle}" Padding="4" Margin="0" Cursor="Hand" Click="ContactCustomer_Click">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#2B7A5C" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                                <TextBlock Text="联系客户" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <!-- 跳转订单 -->
                                        <Button Grid.Column="4" Height="68" Style="{StaticResource ExceptionActionCardButtonStyle}" Padding="4" Margin="0" Cursor="Hand" Click="JumpToOrderFulfillment_Click">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource WarmTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                                <TextBlock Text="跳转订单" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <!-- 标记已处理 -->
                                        <Button Grid.Column="6" Height="68" Style="{StaticResource ExceptionActionCardButtonStyle}" Padding="4" Margin="0" Cursor="Hand" Command="{Binding ResolveSelectedExceptionCommand}">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                                <TextBlock Text="标记已处理" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <!-- 操作日志 -->
                                    <TextBlock Text="操作日志" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding ExceptionAuditLogs}" Margin="4,0,0,16">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="14" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0" VerticalAlignment="Stretch">
                                                        <Rectangle Width="1.5" Fill="{StaticResource BorderBrushSoft}" HorizontalAlignment="Center" Margin="0,14,0,-14" />
                                                        <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Top" Margin="0,5,0,0" />
                                                    </Grid>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock x:Name="ActionText" Text="{Binding Action}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Action}" Value="assign">
                                                                            <Setter Property="Text" Value="分配处理人" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Action}" Value="start_processing">
                                                                            <Setter Property="Text" Value="开始处理异常" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Action}" Value="resolve">
                                                                            <Setter Property="Text" Value="标记异常已解决" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Action}" Value="ignore">
                                                                            <Setter Property="Text" Value="忽略异常" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Action}" Value="reopen">
                                                                            <Setter Property="Text" Value="重新打开异常" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Action}" Value="comment">
                                                                            <Setter Property="Text" Value="添加备注" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Remark}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <Trigger Property="Text" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </Trigger>
                                                                        <Trigger Property="Text" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock Text="{Binding OperatorText}" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                                            <TextBlock Text="•" Foreground="{StaticResource CaptionTextBrush}" Margin="6,0" />
                                                            <TextBlock Text="{Binding AtText}" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- 3. 底部确定处理按钮 -->
                            <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrushSoft}" Padding="0,16,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="2" Content="取消" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="90" Height="36" Padding="0" Margin="0" Click="CloseExceptionDetails_Click" />
                                    <Button Grid.Column="4" Content="标记已处理" Style="{StaticResource ToolbarPrimaryButtonStyle}" Width="110" Height="36" Padding="0" Margin="0" Command="{Binding ResolveSelectedExceptionCommand}" Background="#0066cc" />
                                </Grid>
                            </Border>
                            </Grid>
                        </Border>

                    </Grid>

                    <Grid x:Name="ExceptionWorkAreaLoadingOverlay" Grid.Column="0" Grid.ColumnSpan="2" Background="#D8FFFFFF" Visibility="Collapsed" Panel.ZIndex="10">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExceptionOrderDetailBusy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15" Duration="0">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Border Background="Transparent" CornerRadius="12" />

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}"
                                       HorizontalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5"
                                       Margin="0,0,0,12">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=ExceptionWorkAreaLoadingOverlay, Path=Visibility}" Value="Visible">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="RotateStoryboardExceptionWorkArea">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="360" Duration="0:0:1"
                                                                             RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="RotateStoryboardExceptionWorkArea" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ExceptionStatusMessage}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>





            <Sections:SettingsView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=设置}" />

            <!-- ==================== “我的”板块 (Me/Profile Page) ==================== -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=我的}">
                <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="10*" MaxWidth="1050" MinWidth="600" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        
                        <Grid Grid.Column="1" Margin="0,0,24,0">
                            <!-- 两栏布局：左侧个人卡片，右侧安全设置与店员管理 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左侧：个人资料与快捷控制卡片 -->
                                <StackPanel Grid.Column="0" Margin="0,88,0,0">
                                    <Border Style="{StaticResource SettingsGroupCardStyle}">
                                        <StackPanel Margin="8">
                                            <!-- 头像区域 -->
                                            <Grid HorizontalAlignment="Center" Margin="0,16,0,16">
                                                <Border Width="80" Height="80" CornerRadius="40">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#2B7A5C" Offset="0" />
                                                            <GradientStop Color="#4E9B7B" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>

                                            <!-- 显示昵称 -->
                                            <TextBlock Text="{Binding CurrentAccountDisplayName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" />
                                            
                                            <!-- 身份徽章 -->
                                            <Border CornerRadius="12" Padding="10,3" Margin="0,8,0,20" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F2F4F7" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrentUserOwner}" Value="True">
                                                                <Setter Property="Background" Value="#DCFCE7" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontWeight="SemiBold" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="系统店员 Member" />
                                                            <Setter Property="Foreground" Value="#667085" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrentUserOwner}" Value="True">
                                                                    <Setter Property="Text" Value="系统管理员 Owner" />
                                                                    <Setter Property="Foreground" Value="#16A34A" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <Separator Background="{StaticResource BorderBrushSoft}" Margin="0,0,0,16" />

                                            <!-- 锁定与退出按钮 -->
                                            <!-- 锁定工作台 -->
                                            <Button Content="锁定工作台" Command="{Binding LockSessionCommand}" Style="{StaticResource ToolbarSecondaryButtonStyle}" Margin="0,0,0,12" Height="38" HorizontalAlignment="Stretch" />
                                            
                                            <!-- 安全登出 -->
                                            <Button Content="安全退出登录" Command="{Binding LogoutCommand}" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="38" HorizontalAlignment="Stretch" Foreground="{StaticResource DangerTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- 右侧：安全设置与成员管理列表 -->
                                <ScrollViewer Grid.Column="2" Style="{StaticResource SettingsScrollViewerStyle}" Margin="0,32,0,0">
                                    <StackPanel Margin="0,0,16,0">
                                    <!-- 成员管理卡片（仅系统所有者 Owner 可见） -->
                                    <Border Style="{StaticResource SettingsGroupCardStyle}" Visibility="{Binding CanManageAccounts, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="店员成员管理" Style="{StaticResource SettingsGroupTitleStyle}" />
                                            <TextBlock Text="系统管理员可在此创建、管理其他成员账号" Style="{StaticResource SettingsItemDescStyle}" Margin="0,2,0,16" />

                                            <!-- 创建新成员表单 -->
                                            <Border Background="#F9FAFB" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,18">
                                                <StackPanel>
                                                    <TextBlock Text="新建店员账号" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,10" />
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 第一行：用户名与显示名称 -->
                                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                                            <TextBlock Text="用户名" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberUsername, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                        
                                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                                            <TextBlock Text="显示姓名" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="0" Grid.Column="4">
                                                            <TextBlock Text="主密码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberPassword, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="0" Grid.Column="6">
                                                            <TextBlock Text="PIN 码 (4位)" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding NewMemberPin, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Button Content="创建账号" Command="{Binding CreateMemberCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" Margin="0,12,0,0" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Border>

                                            <!-- 店员列表 -->
                                            <TextBlock Text="已创建成员" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,10" />
                                            <ListBox BorderThickness="1"
                                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                                     Background="#FFFFFF"
                                                     Padding="4"
                                                     MaxHeight="200"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     ItemsSource="{Binding ManagedAccounts}"
                                                     SelectedItem="{Binding SelectedManagedAccount}">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                        <Setter Property="BorderBrush" Value="#F2F4F7" />
                                                        <Setter Property="Padding" Value="8" />
                                                        <Setter Property="Margin" Value="0" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border x:Name="ContainerBorder" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="ContainerBorder" Property="Background" Value="#F8F9FA" />
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="ContainerBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Background="#EAF2EF" Margin="0,0,10,0">
                                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource HeadingBrush}" />
                                                                    <TextBlock Text="{Binding Username, StringFormat=({0})}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="6,1,0,0" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <!-- 选中店员的操作区 -->
                                            <Border Margin="0,12,0,0" Padding="14" Background="#F8F9FA" CornerRadius="8" Visibility="{Binding CanOperateMember, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="选中成员控制：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding SelectedManagedAccount.DisplayName}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding SelectedManagedAccount.Username, StringFormat=({0})}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="4,1,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- 重置主密码 -->
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="重置该店员主密码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="8" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0" Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding ResetMemberPasswordInput, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button Grid.Column="2" Content="重置密码" Command="{Binding ResetMemberPasswordCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="30" Padding="12,0" Margin="0" />
                                                            </Grid>
                                                        </StackPanel>

                                                        <!-- 重置 PIN -->
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="重置店员 PIN 码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="8" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0" Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Text="{Binding ResetMemberPinInput, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button Grid.Column="2" Content="重置 PIN" Command="{Binding ResetMemberPinCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="30" Padding="12,0" Margin="0" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                    
                                                    <Button Content="停用/禁用此店员账号" Command="{Binding DisableMemberCommand}" Style="{StaticResource ToolbarSecondaryButtonStyle}" Foreground="{StaticResource DangerTextBrush}" Height="32" Margin="0,12,0,0" HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <TextBlock Text="{Binding AccountManagementStatus}" Style="{StaticResource SettingsItemDescStyle}" Margin="0,10,0,0" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 密码与 PIN 修改安全设置卡片 -->
                                    <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="登录凭证修改" Style="{StaticResource SettingsGroupTitleStyle}" />
                                            <TextBlock Text="保护您的账户安全，建议定期更换安全凭证" Style="{StaticResource SettingsItemDescStyle}" Margin="0,2,0,16" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- 修改主密码 -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="修改账户主密码" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,12" />
                                                    
                                                    <TextBlock Text="当前密码验证" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Margin="0,0,0,10" Text="{Binding CurrentMasterPasswordInput, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Text="输入新主密码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Margin="0,0,0,12" Text="{Binding NewCurrentMasterPasswordInput, UpdateSourceTrigger=PropertyChanged}" />

                                                    <Button Content="确认修改主密码" Command="{Binding ChangeCurrentMasterPasswordCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" HorizontalAlignment="Left" />
                                                </StackPanel>

                                                <!-- 修改 PIN 码 -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="修改安全 PIN 码" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,12" />
                                                    
                                                    <TextBlock Text="当前 PIN 验证" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Margin="0,0,0,10" Text="{Binding CurrentPinInput, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Text="输入新 PIN 码" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Height="30" Margin="0,0,0,12" Text="{Binding NewCurrentPinInput, UpdateSourceTrigger=PropertyChanged}" />

                                                    <Button Content="确认修改 PIN 码" Command="{Binding ChangeCurrentPinCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="32" Padding="14,0" HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>

            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <!-- 复制成功气泡提示 -->
            <Popup x:Name="Popup_CopyToast" Placement="Mouse" AllowsTransparency="True" HorizontalOffset="10" VerticalOffset="10">
                <Border Background="#222224" CornerRadius="8" Padding="12,6" BorderThickness="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock x:Name="Text_CopyToast" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>

