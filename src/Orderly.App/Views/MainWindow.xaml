                                                    <TextBlock Text="商品数量" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ItemCountText, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Box 4: CreatedAt -->
                                            <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Text="下单时间" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.CreatedAtText, FallbackValue='-'}" FontSize="11" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
