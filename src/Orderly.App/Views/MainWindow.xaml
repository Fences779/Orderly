                                                <TextBlock Text="{Binding CurrentOcrHintText}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="18" />
                                                <TextBox x:Name="Output_OcrTextPreview"
