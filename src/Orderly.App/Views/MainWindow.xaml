                                                                        <TextBlock Text="{Binding TypeLabel}" Foreground="#55665D" FontWeight="SemiBold" FontSize="11" />
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,1,0,0" />
                                                                </WrapPanel>
                                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,0" LineHeight="20">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Description}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="快捷回复" Style="{StaticResource SectionHeaderTextStyle}" />
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding ReplyTemplates}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                            <TextBlock Text="{Binding Content}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" MaxHeight="58" Margin="0,6,0,10" LineHeight="20" />
                                                            <Button Content="复制话术" Command="{Binding DataContext.CopyTemplateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource ToolbarPrimaryButtonStyle}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=客户/订单}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <!-- 搜索 + 状态筛选 -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="客户 / 订单" Style="{StaticResource SectionHeaderTextStyle}" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Style="{StaticResource CountBadgeBorderStyle}" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding CustomersCountText}" Style="{StaticResource CaptionTextStyle}" />
                                    </Border>
                                    <Border Style="{StaticResource CountBadgeBorderStyle}">
                                        <TextBlock Text="{Binding OrdersCountText}" Style="{StaticResource CaptionTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBox DockPanel.Dock="Left"
                                         Width="200"
                                         Margin="0,0,8,0"
                                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.AutomationId="Input_SearchKeyword" />
                                <ComboBox Width="200"
                                          Margin="0,0,8,0"
                                          ItemsSource="{Binding SearchFilterOptions}"
                                          SelectedItem="{Binding SelectedStatusFilter}"
                                          AutomationProperties.AutomationId="Combo_SearchFilter">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="AutomationProperties.AutomationId" Value="{Binding Kind, StringFormat=Filter_\{0\}}" />
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                                <Button x:Name="Btn_ClearFilters"
                                        AutomationProperties.AutomationId="Btn_ClearFilters"
                                        Content="清空" Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                        Padding="10,4" Margin="0,0,0,0"
                                        Command="{Binding ClearSearchAndFiltersCommand}" />
                            </DockPanel>
                        </StackPanel>

                        <!-- 快捷筛选 Chip 行 -->
                        <WrapPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,0">
                            <TextBlock Text="快捷：" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,6" />
                            <Button Content="全部" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="All"
                                    AutomationProperties.AutomationId="Chip_All" />
                            <Button Content="今日跟进" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="TodayFollowUp"
                                    AutomationProperties.AutomationId="Chip_TodayFollowUp" />
                            <Button Content="逾期跟进" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="OverdueFollowUp"
                                    AutomationProperties.AutomationId="Chip_OverdueFollowUp" />
                            <Button Content="明日跟进" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="TomorrowFollowUp"
                                    AutomationProperties.AutomationId="Chip_TomorrowFollowUp" />
                            <Button Content="待处理订单" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="PendingOrders"
                                    AutomationProperties.AutomationId="Chip_PendingOrders" />
                            <Button Content="已成交订单" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="WonOrders"
                                    AutomationProperties.AutomationId="Chip_WonOrders" />
                        </WrapPanel>

                        <!-- 状态消息面板 -->
                        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Style="{StaticResource StatusPanelStyle}" Margin="18,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding StatusMessageTitle}" Style="{StaticResource StatusMessageTitleTextStyle}" />
                                <TextBlock Text="{Binding StatusMessage}" Margin="0,5,0,0" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="客户列表" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <TextBlock Text="查看客户状态、优先级和最近联系情况" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                    <TextBlock Text="{Binding CustomersCountText}" Style="{StaticResource CaptionTextStyle}" />
                                </Border>
                            </DockPanel>

                            <TextBlock Text="{Binding CustomersEmptyStateText}"
                                       Style="{StaticResource HasItemsEmptyStateTextStyle}"
                                       Tag="{Binding HasCustomers}" />

                            <ListBox ItemsSource="{Binding Customers}"
                                     SelectedItem="{Binding SelectedCustomer}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Style="{StaticResource HasItemsListBoxStyle}"
                                     Tag="{Binding HasCustomers}"
                                     ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="CustomerListItemTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="订单列表" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <TextBlock Text="聚焦客户、需求摘要、状态、金额和跟进时间" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                    <TextBlock Text="{Binding OrdersCountText}" Style="{StaticResource CaptionTextStyle}" />
                                </Border>
                            </DockPanel>

                            <TextBlock Text="{Binding OrdersEmptyStateText}"
                                       Style="{StaticResource HasItemsEmptyStateTextStyle}"
                                       Tag="{Binding HasOrders}" />

                            <ListBox ItemsSource="{Binding Orders}"
                                     SelectedItem="{Binding SelectedOrderItem}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Style="{StaticResource HasItemsListBoxStyle}"
                                     Tag="{Binding HasOrders}"
                                     ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="OrderListItemTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=话术库}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="快捷回复话术库" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                    <ListView ItemsSource="{Binding ReplyTemplates}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="标题" DisplayMemberBinding="{Binding Title}" Width="180" />
                                <GridViewColumn Header="场景" DisplayMemberBinding="{Binding Scene}" Width="120" />
                                <GridViewColumn Header="平台" DisplayMemberBinding="{Binding SourcePlatform}" Width="100" />
                                <GridViewColumn Header="内容" DisplayMemberBinding="{Binding Content}" Width="560" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=设置}">
                <StackPanel>
                    <TextBlock Text="基础设置" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="{Binding DatabasePath, StringFormat=数据库：{0}}" Margin="0,16,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Preferences.MainHotkey, StringFormat=主窗口快捷键：{0}}" Margin="0,10,0,0" />
                    <TextBlock Text="{Binding Preferences.FloatingHotkey, StringFormat=悬浮窗快捷键：{0}}" Margin="0,6,0,0" />
                    <TextBlock Text="扩展位：AI 助手、微信/闲鱼同步、OCR、自动回复已保留接口，第一版不接真实后端。" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,18,0,0" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
