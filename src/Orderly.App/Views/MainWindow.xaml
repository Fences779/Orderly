<Window x:Class="Orderly.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Sections="clr-namespace:Orderly.App.Views.Sections"
        Title="Orderly 商家工作台"
        Width="1280"
        Height="820"
        MinWidth="1140"
        MinHeight="800"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/Main/MainWindowInlineStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FBFAF6" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0" Padding="18">
            <DockPanel>
                <!-- 底部“我的”按钮 -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Button x:Name="Tab_Me" AutomationProperties.AutomationId="Tab_Me" Content="我的" Tag="&#xE77B;" Style="{StaticResource ProfileMenuGlassButtonStyle}" Command="{Binding SelectSectionCommand}" CommandParameter="我的"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Orderly" FontSize="26" FontWeight="Bold" Foreground="#17211D" />
                    <TextBlock Text="本地商家工作台" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,20" />

                    <Button x:Name="Tab_Dashboard" AutomationProperties.AutomationId="Tab_Dashboard" Content="工作台" Tag="&#xE80F;" Command="{Binding SelectSectionCommand}" CommandParameter="工作台">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Fulfillment" AutomationProperties.AutomationId="Tab_Fulfillment" Content="订单履约" Tag="&#xE8A1;" Command="{Binding SelectSectionCommand}" CommandParameter="订单履约">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Inventory" AutomationProperties.AutomationId="Tab_Inventory" Content="库存管理" Tag="&#xE7B8;" Command="{Binding SelectSectionCommand}" CommandParameter="库存管理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="库存管理">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Cashflow" AutomationProperties.AutomationId="Tab_Cashflow" Content="现金流" Tag="&#xE825;" Command="{Binding SelectSectionCommand}" CommandParameter="现金流">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="现金流">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_ExceptionOrders" AutomationProperties.AutomationId="Tab_ExceptionOrders" Content="异常处理" Tag="&#xE7BA;" Command="{Binding SelectSectionCommand}" CommandParameter="异常处理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Settings" AutomationProperties.AutomationId="Tab_Settings" Content="设置" Tag="&#xE713;" Command="{Binding SelectSectionCommand}" CommandParameter="设置">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MainMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                        <Setter Property="Background" Value="#FFFFFF" />
                                        <Setter Property="Foreground" Value="#1D1D1F" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Margin" Value="0,0,0,18" />
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="库存管理">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="现金流">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="我的">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding SelectedSection}" FontSize="29" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                    <TextBlock Text="客户、订单、跟进和快捷回复集中处理" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
                </StackPanel>
            </DockPanel>
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=工作台}">
                <Grid>
                    <Grid Margin="0,0,0,12" Background="Transparent">
                        <Grid.RowDefinitions>
                            <!-- 0. 独立头部区域 -->
                            <RowDefinition Height="Auto" />
                            <!-- 1. 五个概览卡片 -->
                            <RowDefinition Height="Auto" />
                            <!-- 2. 中间趋势与履约压力 -->
                            <RowDefinition Height="*" MinHeight="340" />
                            <!-- 3. 底部库存与现金流 -->
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 0. 独立头部区域 -->
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                <TextBlock Text="工作台" FontSize="30" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                <TextBlock Text="概览经营数据，掌握履约进度，助力高效成交与履约" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- 刷新按钮 -->
                                <Button Command="{Binding LoadStringNarrationStatsCommand}" Style="{StaticResource SubtleActionButtonStyle}" Padding="12,6" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource PrimaryBrush}" />
                                        <TextBlock Text="刷新" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource HeadingBrush}" />
                                    </StackPanel>
                                </Button>
                                <!-- 同步时间 -->
                                <TextBlock Text="最后同步：" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding StringNarrationWorkbenchLastSyncedAtFriendlyText}" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,16,0" />
                                <!-- 钟铛通知 -->
                                <Grid Width="36" Height="36" Cursor="Hand">
                                    <Border Width="36" Height="36" CornerRadius="18" Background="#F1F2F5">
                                        <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Width="16" Height="16" CornerRadius="8" Background="#DE4C4A" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" BorderBrush="#FFFFFF" BorderThickness="1.5">
                                        <TextBlock Text="12" FontSize="9" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- 1. 五个概览卡片 -->
                        <Grid Grid.Row="1" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Card 1: 今日订单数 (蓝色) -->
                            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{StaticResource BlueSoftBrush}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE193;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BlueTextBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="今日订单数" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding StringNarrationWorkbenchTodayOrderCountText, FallbackValue=0}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,6,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="较昨日" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                            <TextBlock Text="{Binding StringNarrationWorkbenchTodayOrderCountDeltaText}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource CaptionTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchTodayOrderCountDeltaPositive}" Value="True">
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchTodayOrderCountDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchTodayOrderCountDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="2,0,0,0" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchTodayOrderCountDeltaPositive}" Value="True">
                                                                <Setter Property="Text" Value="↑" />
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchTodayOrderCountDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchTodayOrderCountDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Text" Value="↓" />
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Card 2: 今日成交额 (绿色) -->
                            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{StaticResource AccentSoftBrush}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="￥" Foreground="{StaticResource AccentTextBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="今日成交额" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding StringNarrationWorkbenchTodayRevenueAmountText, FallbackValue=0}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,6,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="较昨日" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                            <TextBlock Text="{Binding StringNarrationWorkbenchTodayRevenueAmountDeltaText}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource CaptionTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchTodayRevenueAmountDeltaPositive}" Value="True">
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchTodayRevenueAmountDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchTodayRevenueAmountDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="2,0,0,0" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchTodayRevenueAmountDeltaPositive}" Value="True">
                                                                <Setter Property="Text" Value="↑" />
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchTodayRevenueAmountDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchTodayRevenueAmountDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Text" Value="↓" />
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Card 3: 待制作 (橙色) -->
                            <Border Grid.Column="4" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{StaticResource WarmSoftBrush}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource WarmTextBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="待制作" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding StringNarrationWorkbenchPendingMakeCountText, FallbackValue=0}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,6,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="较昨日" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                            <TextBlock Text="{Binding StringNarrationWorkbenchPendingMakeDeltaText}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource CaptionTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchPendingMakeDeltaPositive}" Value="True">
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchPendingMakeDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchPendingMakeDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="2,0,0,0" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchPendingMakeDeltaPositive}" Value="True">
                                                                <Setter Property="Text" Value="↑" />
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchPendingMakeDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchPendingMakeDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Text" Value="↓" />
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Card 4: 待发货 (紫色) -->
                            <Border Grid.Column="6" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{StaticResource PurpleSoftBrush}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PurpleTextBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="待发货" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding StringNarrationWorkbenchReadyToShipCountText, FallbackValue=0}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,6,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="较昨日" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                            <TextBlock Text="{Binding StringNarrationWorkbenchReadyToShipDeltaText}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource CaptionTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchReadyToShipDeltaPositive}" Value="True">
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchReadyToShipDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchReadyToShipDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="2,0,0,0" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchReadyToShipDeltaPositive}" Value="True">
                                                                <Setter Property="Text" Value="↑" />
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchReadyToShipDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchReadyToShipDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Text" Value="↓" />
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Card 5: 异常订单 (红色) -->
                            <Border Grid.Column="8" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{StaticResource DangerSoftBrush}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource DangerTextBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="异常订单" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding StringNarrationWorkbenchExceptionOrderCountText, FallbackValue=0}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,6,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="较昨日" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                            <TextBlock Text="{Binding StringNarrationWorkbenchExceptionOrderDeltaText}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource CaptionTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchExceptionOrderDeltaPositive}" Value="True">
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchExceptionOrderDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchExceptionOrderDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="2,0,0,0" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStringNarrationWorkbenchExceptionOrderDeltaPositive}" Value="True">
                                                                <Setter Property="Text" Value="↑" />
                                                                <Setter Property="Foreground" Value="#DE4C4A" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchExceptionOrderDeltaPositive}" Value="False" />
                                                                    <Condition Binding="{Binding IsStringNarrationWorkbenchExceptionOrderDeltaZero}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Text" Value="↓" />
                                                                <Setter Property="Foreground" Value="#2B7A5C" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 2. 中间趋势与履约压力 -->
                        <Grid Grid.Row="2" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.7*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 左侧：近 7 日经营趋势 -->
                            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="20,18">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="近 7 日经营趋势" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Ellipse Width="8" Height="8" Fill="{StaticResource BlueTextBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="成交额 (元)" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="6,0,16,0" VerticalAlignment="Center"/>
                                                <Ellipse Width="8" Height="8" Fill="{StaticResource PurpleTextBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="订单数 (单)" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#F1F2F5" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="近 7 日" FontSize="12" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- 柱状图和折线混合趋势图 -->
                                    <Grid Grid.Row="1" Margin="0,20,0,0" MinHeight="220">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="20" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Y轴底线 -->
                                        <Grid Grid.Row="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                            <Border Grid.Row="1" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                            <Border Grid.Row="2" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                            <Border Grid.Row="3" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                            <Border Grid.Row="4" BorderBrush="#F1F2F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                        </Grid>

                                        <!-- 柱状图 (成交额) 展现 -->
                                        <ItemsControl Grid.Row="0" ItemsSource="{Binding StringNarrationWorkbenchTrendItems}" VerticalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="7" Rows="1" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid VerticalAlignment="Stretch" Margin="10,0">
                                                        <ProgressBar Value="{Binding RevenueAmount}" Minimum="0" Maximum="18000" Orientation="Vertical" VerticalAlignment="Stretch" Margin="0,25,0,15" Width="24" Background="Transparent" BorderThickness="0">
                                                            <ProgressBar.Template>
                                                                <ControlTemplate TargetType="ProgressBar">
                                                                    <Grid SnapsToDevicePixels="true">
                                                                        <Border CornerRadius="4" Background="Transparent"/>
                                                                        <Border x:Name="PART_Indicator" CornerRadius="4,4,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
                                                                            <Border.Background>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                                    <GradientStop Color="#A2C9F8" Offset="0"/>
                                                                                    <GradientStop Color="#E3EFFE" Offset="0.7"/>
                                                                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Border.Background>
                                                                        </Border>
                                                                    </Grid>
                                                                </ControlTemplate>
                                                            </ProgressBar.Template>
                                                        </ProgressBar>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 自适应手绘折线效果 (订单数) -->
                                        <Canvas x:Name="TrendCanvas" Grid.Row="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="30,0" SizeChanged="TrendCanvas_SizeChanged">
                                            <Path x:Name="TrendPath" Stroke="#7A3EDB" StrokeThickness="3.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" />
                                            <Ellipse x:Name="TrendPoint0" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                                            <Ellipse x:Name="TrendPoint1" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                                            <Ellipse x:Name="TrendPoint2" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                                            <Ellipse x:Name="TrendPoint3" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                                            <Ellipse x:Name="TrendPoint4" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                                            <Ellipse x:Name="TrendPoint5" Width="8" Height="8" Fill="#FFFFFF" Stroke="#7A3EDB" StrokeThickness="2" Visibility="Collapsed" />
                                            <Ellipse x:Name="TrendPoint6" Width="8" Height="8" Fill="#7A3EDB" Stroke="#FFFFFF" StrokeThickness="2" Visibility="Collapsed" />

                                            <!-- 悬浮 Tooltip 卡片 -->
                                            <Border x:Name="TrendTooltip" Background="#FFFFFF" CornerRadius="8" Padding="10,8" BorderBrush="#DFE3EA" BorderThickness="1" Visibility="Collapsed">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.08"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <TextBlock x:Name="Text_TooltipDate" Text="05-16" FontSize="10" Foreground="{StaticResource CaptionTextBrush}" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <Ellipse Width="6" Height="6" Fill="{StaticResource BlueTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                        <TextBlock Text="成交额" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                        <TextBlock x:Name="Text_TooltipRevenue" Text=" ¥12,680.00" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <Ellipse Width="6" Height="6" Fill="{StaticResource PurpleTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                        <TextBlock Text="订单数" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                        <TextBlock x:Name="Text_TooltipOrders" Text=" 110" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Canvas>

                                        <!-- X轴标签 -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding StringNarrationWorkbenchTrendItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="7" Rows="1" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- 右侧：今日履约压力 -->
                            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="20,18">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="今日履约压力" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                    </StackPanel>

                                    <!-- 履约压力卡片 -->
                                    <StackPanel Grid.Row="1" Margin="0,18,0,0" VerticalAlignment="Top">
                                        <!-- 待制作 -->
                                        <Border Background="#FBFAF6" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource WarmSoftBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource WarmTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <Grid>
                                                        <TextBlock Text="待制作" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Left" />
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <TextBlock Text="占未完成订单 " FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                            <TextBlock Text="60%" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Text="18 单" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,4" />
                                                    <ProgressBar Value="{Binding StringNarrationWorkbenchPendingMakeCount, Mode=OneWay}" Maximum="{Binding StringNarrationWorkbenchUnfinishedOrderCount, Mode=OneWay}" Height="6" Background="#E5E7EC" Foreground="{StaticResource WarmTextBrush}" BorderThickness="0" Margin="0,4,0,0">
                                                        <ProgressBar.Template>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Grid>
                                                                    <Border CornerRadius="3" Background="{TemplateBinding Background}"/>
                                                                    <Border x:Name="PART_Indicator" CornerRadius="3" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left"/>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- 待发货 -->
                                        <Border Background="#FBFAF6" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PurpleSoftBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PurpleTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <Grid>
                                                        <TextBlock Text="待发货" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Left" />
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <TextBlock Text="占未完成订单 " FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                            <TextBlock Text="30%" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Text="9 单" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,4" />
                                                    <ProgressBar Value="{Binding StringNarrationWorkbenchReadyToShipCount, Mode=OneWay}" Maximum="{Binding StringNarrationWorkbenchUnfinishedOrderCount, Mode=OneWay}" Height="6" Background="#E5E7EC" Foreground="{StaticResource PurpleTextBrush}" BorderThickness="0" Margin="0,4,0,0">
                                                        <ProgressBar.Template>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Grid>
                                                                    <Border CornerRadius="3" Background="{TemplateBinding Background}"/>
                                                                    <Border x:Name="PART_Indicator" CornerRadius="3" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left"/>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- 中间弹性占位 -->
                                    <Border Grid.Row="2" />

                                    <!-- 底部：当日实际总单数 -->
                                    <Border Grid.Row="3" BorderBrush="#F1F2F5" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="当日实际总单数：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{Binding StringNarrationWorkbenchTodayOrderCount}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                            <TextBlock Text=" 单" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="3" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 3. 底部库存与现金流 -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 左边：库存状态 (点击循环切换测试) -->
                            <Button Grid.Column="0" Command="{Binding ToggleInventoryTestStatusCommand}" Style="{StaticResource InvisibleContainerButtonStyle}" HorizontalContentAlignment="Stretch">
                                <Border x:Name="InventoryCard" BorderThickness="1" CornerRadius="12" Padding="20,18" Height="140">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                            <Setter Property="Background" Value="#FFFFFF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#EAF2EF" Offset="0"/>
                                                                <GradientStop Color="#FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FFF8F0" Offset="0"/>
                                                                <GradientStop Color="#FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FFF2F2" Offset="0"/>
                                                                <GradientStop Color="#FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="库存状态" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                        
                                        <Grid Grid.Row="1" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- 图标色 -->
                                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" VerticalAlignment="Center" Margin="0,0,16,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F2F5" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                                <Setter Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                                <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource GreyTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            
                                            <!-- 详情描述 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontWeight="Bold" FontSize="18">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="正常" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                                    <Setter Property="Text" Value="正常" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                                    <Setter Property="Text" Value="需关注" />
                                                                    <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                                    <Setter Property="Text" Value="警告" />
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="所有材料库存充足，运营状况良好。" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                                    <Setter Property="Text" Value="所有材料库存充足，运营状况良好。" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                                    <Setter Property="Text" Value="部分材料库存偏低，建议及时关注补货。" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                                    <Setter Property="Text" Value="核心材料库存严重不足，请立即采购补充！" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <!-- 跳转按钮 -->
                                            <Button Grid.Column="2" Content="查看库存详情 →" Style="{StaticResource SubtleActionButtonStyle}" Foreground="{StaticResource BlueTextBrush}" FontSize="12" VerticalAlignment="Center"
                                                    Command="{Binding SelectSectionCommand}" CommandParameter="库存管理" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- 右边：现金流 (含天数圆弧环) -->
                            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="20,18" Height="140">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="现金流" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                    
                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- 环形图 (WPF Path 圆弧，72分时大约是260度弧度) -->
                                        <Grid Grid.Column="0" Width="64" Height="64" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <Ellipse Width="56" Height="56" Stroke="#F1F2F5" StrokeThickness="6" />
                                            <Path StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Stroke" Value="{Binding StringNarrationWorkbenchCashFlowColorText}" />
                                                        <Setter Property="Data" Value="M 32,7 A 25,25 0 1,1 8,28" />
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding StringNarrationWorkbenchCashFlowScoreText, FallbackValue=72}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding StringNarrationWorkbenchCashFlowEvaluation, FallbackValue=健康}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,1,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{Binding StringNarrationWorkbenchCashFlowColorText}" />
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="现金流状况良好，可支撑当前运营" FontSize="12" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="较昨日" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                                <TextBlock Text="{Binding StringNarrationWorkbenchCashFlowDeltaText}" FontSize="11" Foreground="#2B7A5C" FontWeight="Bold" Margin="4,0,0,0" />
                                                <TextBlock Text="天" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" Margin="2,0,0,0" />
                                                <TextBlock Text=" ↑" FontSize="11" Foreground="#2B7A5C" FontWeight="Bold" />
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- 跳转按钮 -->
                                        <Button Grid.Column="2" Content="查看现金流详情 →" Style="{StaticResource SubtleActionButtonStyle}" Foreground="{StaticResource BlueTextBrush}" FontSize="12" VerticalAlignment="Center"
                                                Command="{Binding SelectSectionCommand}" CommandParameter="现金流" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <!-- 库存管理 -->
            <Sections:InventoryView Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=库存管理}" />

            <!-- 现金流 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=现金流}">
                <Grid Margin="24,12,24,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- 标题栏 -->
                        <RowDefinition Height="*" />    <!-- 内容区 -->
                        <RowDefinition Height="Auto" /> <!-- 最底脚注 -->
                    </Grid.RowDefinitions>
                        
                        <!-- Row 0: 标题栏 -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="现金流健康" Style="{StaticResource SectionHeaderTextStyle}" FontSize="20" FontWeight="Bold" />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="掌握资金流动，做出更好的经营决策" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource CaptionTextBrush}" Margin="6,1,0,0" VerticalAlignment="Center" ToolTip="基于近30天的收支动向评估现金流状况" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CashflowUpdatedAtText, Mode=OneWay, StringFormat=数据更新：{0}}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,16,0" />
                                <!-- 日期范围展示圆角框 -->
                                <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12,6" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="2024-05-14 ~ 2024-06-12" FontSize="12" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Button Content="刷新数据" Command="{Binding RefreshCashflowCommand}" Style="{StaticResource ToolbarPrimaryButtonStyle}" Margin="0" Height="32" Padding="16,0" MinWidth="80" />
                            </StackPanel>
                        </Grid>
                        
                        <!-- Row 1: 左右分栏内容区 -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3.1*" />
                                <ColumnDefinition Width="1.1*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- 左侧 3.1* 区域 -->
                            <Grid Grid.Column="0" Margin="0,0,16,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition x:Name="CashflowFirstRow" Height="Auto" /> <!-- 第一排: 三张卡片 -->
                                    <RowDefinition x:Name="CashflowTrendRow" Height="*" />    <!-- 第二排: 趋势图卡片 -->
                                    <RowDefinition x:Name="CashflowBreakdownRow" Height="Auto" /> <!-- 第三排: 构成卡片 -->
                                </Grid.RowDefinitions>
                                
                                <!-- 第一排: 三张卡片 -->
                                <UniformGrid Grid.Row="0" Columns="3" Rows="1" Margin="0,0,0,24">
                                    <!-- 现金流健康指数 -->
                                    <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,16,0" Padding="16,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="现金流健康指数" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource CaptionTextBrush}" Margin="4,2,0,0" ToolTip="根据现金余额、应收应付、支出强度等综合算出的健康度" />
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Bottom">
                                                <TextBlock Text="{Binding CashflowHealthDashboardResult.Summary.CashFlowHealthScore, FallbackValue=85}" FontSize="32" FontWeight="Bold" Foreground="#1F8B4C" VerticalAlignment="Bottom" LineHeight="32" />
                                                <!-- 健康度 Badge -->
                                                <Border Background="#E6F9ED" CornerRadius="12" Padding="8,2" Margin="10,0,0,4" VerticalAlignment="Bottom">
                                                    <TextBlock Text="{Binding CashflowHealthLevelText, FallbackValue=健康}" Foreground="#1F8B4C" FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Row="2" Text="{Binding CashflowHealthSummaryText, FallbackValue=现金状况良好，可正常补货}" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,8,0,0" />
                                            
                                            <!-- 进度条 -->
                                            <Grid Grid.Row="3" Margin="0,14,0,0">
                                                <ProgressBar Value="{Binding CashflowHealthDashboardResult.Summary.CashFlowHealthScore, FallbackValue=85}" Minimum="0" Maximum="100" Height="6" Background="#F2F4F7" BorderThickness="0">
                                                    <ProgressBar.Template>
                                                        <ControlTemplate TargetType="ProgressBar">
                                                            <Grid>
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                                                                <Border x:Name="PART_Indicator" CornerRadius="3" HorizontalAlignment="Left">
                                                                    <Border.Background>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                            <GradientStop Color="#34C759" Offset="0" />
                                                                            <GradientStop Color="#4CD964" Offset="1" />
                                                                        </LinearGradientBrush>
                                                                    </Border.Background>
                                                                </Border>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </ProgressBar.Template>
                                                </ProgressBar>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- 当前可用现金 -->
                                    <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,16,0" Padding="16,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="当前可用现金" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource CaptionTextBrush}" Margin="4,2,0,0" ToolTip="可用余额 = 账上现金 - 待支付 + 待收款" />
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Bottom">
                                                <TextBlock Text="{Binding CashflowAvailableCashText, FallbackValue='¥ 2,860.00'}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" LineHeight="32" />
                                                <Button Content="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Background="Transparent" BorderThickness="0" Margin="8,0,0,4" VerticalAlignment="Bottom" Cursor="Hand" ToolTip="隐藏金额" />
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Row="2" Text="可用余额 = 现金 - 待支付 + 待收款" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,8,0,0" />
                                        </Grid>
                                    </Border>

                                    <!-- 预计可支撑天数 -->
                                    <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0" Padding="16,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="预计可支撑天数" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource CaptionTextBrush}" Margin="4,2,0,0" ToolTip="按最近 7 日平均支出估算账上现金可持续的天数" />
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Row="1" Text="{Binding CashflowSupportDaysText, FallbackValue='32 天'}" FontSize="32" FontWeight="Bold" Foreground="#1F8B4C" Margin="0,12,0,0" LineHeight="32" />
                                            
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Text="按最近 7 日平均支出估算 (" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource SecondaryTextBrush}" />
                                                <TextBlock Text="{Binding CashflowAvgDailyExpense7dText, FallbackValue=¥120/天}" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" />
                                                <TextBlock Text=")" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </UniformGrid>
                                
                                <!-- 第二排: 趋势图卡片 -->
                                <Border x:Name="CashflowTrendCard" Grid.Row="1" Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,0,24" Padding="20,16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" /> <!-- 标题/选择器 -->
                                            <RowDefinition Height="*" />    <!-- 图表区 -->
                                            <RowDefinition Height="Auto" /> <!-- X 轴标签 -->
                                            <RowDefinition Height="Auto" /> <!-- 底部图例 -->
                                        </Grid.RowDefinitions>
                                        
                                        <!-- 标题/选择器 -->
                                        <Grid Grid.Row="0" Margin="0,0,0,16">
                                            <TextBlock Text="近30天现金流趋势" Style="{StaticResource SectionHeaderTextStyle}" FontSize="15" />
                                            
                                            <Border HorizontalAlignment="Right" Background="#F2F4F7" CornerRadius="8" Padding="2">
                                                <StackPanel Orientation="Horizontal">
                                                    <RadioButton Content="7天" GroupName="TrendRange" Style="{StaticResource ModernTabRadioButtonStyle}" Padding="10,4" Margin="0" FontSize="11" IsChecked="False" />
                                                    <RadioButton Content="30天" GroupName="TrendRange" Style="{StaticResource ModernTabRadioButtonStyle}" Padding="10,4" Margin="0" FontSize="11" IsChecked="True" />
                                                    <RadioButton Content="90天" GroupName="TrendRange" Style="{StaticResource ModernTabRadioButtonStyle}" Padding="10,4" Margin="0" FontSize="11" IsChecked="False" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        
                                        <!-- 图表区 -->
                                        <Canvas x:Name="CashflowTrendCanvas" Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="30,10" SizeChanged="CashflowTrendCanvas_SizeChanged" />
                                        
                                        <!-- X 轴标签 -->
                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding CashflowHealthTrendItems}" Margin="30,4,30,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="{Binding CashflowHealthTrendItems.Count, FallbackValue=30}" Rows="1" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <!-- 底部图例 -->
                                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                <Border Background="#34C759" Width="10" Height="10" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="收入" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                <Border Background="#FF9F0A" Width="10" Height="10" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="支出" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#5856D6" Width="16" Height="3" CornerRadius="1.5" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <Ellipse Fill="#5856D6" Width="6" Height="6" Stroke="White" StrokeThickness="1" VerticalAlignment="Center" Margin="-17,0,11,0" />
                                                <TextBlock Text="净现金流" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <!-- 第三排: 构成卡片 -->
                                <UniformGrid Grid.Row="2" Columns="2" Rows="1">
                                    <!-- 收入构成 -->
                                    <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,8,0" Padding="16,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" MinHeight="120" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            
                                            <!-- 头部 -->
                                            <DockPanel Margin="0,0,0,12" LastChildFill="False">
                                                <TextBlock Text="收入构成 (近30天)" Style="{StaticResource SectionHeaderTextStyle}" FontSize="14" VerticalAlignment="Center" />
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="总收入 " FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding CashflowIncomeTotalText, FallbackValue='¥ 12,680.00'}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                </StackPanel>
                                            </DockPanel>
                                            
                                            <!-- 中部: 环形图 + 列表 -->
                                            <Grid Grid.Row="1" Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- 环形 Canvas -->
                                                <Canvas x:Name="CanvasIncomeDonut" Width="110" Height="110" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,0" SizeChanged="CanvasIncomeDonut_SizeChanged" />
                                                
                                                <!-- 分类列表 -->
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding CashflowIncomeBreakdown.Items}" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="50" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border x:Name="Bullet" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,8,0">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#4D96FF" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Category}" Value="订单收入">
                                                                                    <Setter Property="Background" Value="#4D96FF" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="定制收入">
                                                                                    <Setter Property="Background" Value="#FFD93D" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="尾款补款">
                                                                                    <Setter Property="Background" Value="#9B5DE5" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="其他收入">
                                                                                    <Setter Property="Background" Value="#FF6B6B" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="12" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat={}{0:C0}}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" Margin="10,0" />
                                                                <TextBlock Grid.Column="3" Text="{Binding Percent, StringFormat={}{0:0.0}%}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                            
                                            <!-- 底部明细链接 -->
                                            <Button Grid.Row="2" Content="查看明细 >" Foreground="{StaticResource BlueTextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" />
                                        </Grid>
                                    </Border>
                                    
                                    <!-- 支出构成 -->
                                    <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="8,0,0,0" Padding="16,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" MinHeight="120" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            
                                            <!-- 头部 -->
                                            <DockPanel Margin="0,0,0,12" LastChildFill="False">
                                                <TextBlock Text="支出构成 (近30天)" Style="{StaticResource SectionHeaderTextStyle}" FontSize="14" VerticalAlignment="Center" />
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="总支出 " FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding CashflowExpenseTotalText, FallbackValue='¥ 9,820.00'}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                </StackPanel>
                                            </DockPanel>
                                            
                                            <!-- 中部: 环形图 + 列表 -->
                                            <Grid Grid.Row="1" Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- 环形 Canvas -->
                                                <Canvas x:Name="CanvasExpenseDonut" Width="110" Height="110" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,0" SizeChanged="CanvasExpenseDonut_SizeChanged" />
                                                
                                                <!-- 分类列表 -->
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding CashflowExpenseBreakdown.Items}" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="50" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border x:Name="Bullet" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,8,0">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#4D96FF" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Category}" Value="材料采购">
                                                                                    <Setter Property="Background" Value="#6BCB77" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="快递物流">
                                                                                    <Setter Property="Background" Value="#4D96FF" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="包装耗材">
                                                                                    <Setter Property="Background" Value="#9B5DE5" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="平台/手续费">
                                                                                    <Setter Property="Background" Value="#FFD93D" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="其他支出">
                                                                                    <Setter Property="Background" Value="#FF6B6B" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="12" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat={}{0:C0}}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" Margin="10,0" />
                                                                <TextBlock Grid.Column="3" Text="{Binding Percent, StringFormat={}{0:0.0}%}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                            
                                            <!-- 底部明细链接 -->
                                            <Button Grid.Row="2" Content="查看明细 >" Foreground="{StaticResource BlueTextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" />
                                        </Grid>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                            
                            <!-- 右侧 1.1* 区域 -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- 经营建议卡片 -->
                                    <RowDefinition Height="12" />   <!-- 间距 -->
                                    <RowDefinition Height="*" />    <!-- 待发生现金事项卡片 -->
                                </Grid.RowDefinitions>
                                
                                <!-- 经营建议卡片 -->
                                <Border Grid.Row="0" Style="{StaticResource SectionBlockBorderStyle}" Margin="0" Padding="20,16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- 头部 -->
                                        <DockPanel LastChildFill="False" Margin="0,0,0,16">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="💡" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                <TextBlock Text="现金流建议" Style="{StaticResource SectionHeaderTextStyle}" FontSize="14" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Button DockPanel.Dock="Right" Content="查看详情 >" Foreground="{StaticResource BlueTextBrush}" FontSize="11" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" />
                                        </DockPanel>
                                        
                                        <!-- 建议条 -->
                                        <Border Grid.Row="1" Background="#EBF8F2" BorderBrush="#34C759" BorderThickness="4,0,0,0" CornerRadius="0,8,8,0" Padding="12" Margin="0,0,0,16">
                                            <StackPanel>
                                                <TextBlock Text="{Binding CashflowAdviceTitleText, FallbackValue='🟢 当前现金流健康，经营状况良好'}" FontSize="13" FontWeight="Bold" Foreground="#1F8B4C" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding CashflowAdviceDescriptionText, FallbackValue='近7日净现金流为正，可进行小额补货。建议单次补货金额不超过¥800，优先补充高动销材料。'}" FontSize="12" Foreground="#2B7A5C" Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="18" />
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- 下方提示参数 -->
                                        <StackPanel Grid.Row="2">
                                            <!-- 补货建议 -->
                                            <Grid Margin="0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🛍️" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="补货建议：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding CashflowAdvice.RestockSuggestionAmount, StringFormat=≤ ¥{0:N0}, TargetNullValue=≤ ¥800}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                            </Grid>
                                            
                                            <!-- 风险提示 -->
                                            <Grid Margin="0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⚠️" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="风险提示：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding CashflowAdvice.RiskHint, TargetNullValue=无}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                            </Grid>
                                            
                                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Margin="0,12" />
                                            
                                            <!-- 下周关注 -->
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="🎯" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="下周关注：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <ItemsControl ItemsSource="{Binding CashflowAdvice.NextFocus}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                                                <Ellipse Width="4" Height="4" Fill="#34C759" VerticalAlignment="Center" Margin="6,0,8,0" />
                                                                <TextBlock Text="{Binding}" FontSize="12" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="暂无关注事项" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="6,3,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasCashflowAdviceFocusItems}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <!-- 待发生现金事项卡片 -->
                                <Border Grid.Row="2" Style="{StaticResource SectionBlockBorderStyle}" Margin="0" Padding="20,16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- 头部 -->
                                        <DockPanel LastChildFill="False" Margin="0,0,0,16">
                                            <TextBlock Text="待发生现金事项" Style="{StaticResource SectionHeaderTextStyle}" FontSize="14" VerticalAlignment="Center" />
                                            <Button DockPanel.Dock="Right" Content="查看全部 >" Foreground="{StaticResource BlueTextBrush}" FontSize="11" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" />
                                        </DockPanel>
                                        
                                        <!-- 列表 -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding CashflowUpcomingCashItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F8F9FA" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <Border x:Name="IconBorder" Width="28" Height="28" CornerRadius="14" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                <TextBlock x:Name="IconText" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                                <TextBlock Text="{Binding Note}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            
                                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Amount, StringFormat={}{0:C0}}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Right" />
                                                                <TextBlock Text="{Binding Count, StringFormat=涉及 {0} 项}" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" HorizontalAlignment="Right" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="payable">
                                                            <Setter TargetName="IconBorder" Property="Background" Value="#FF9500" />
                                                            <Setter TargetName="IconText" Property="Text" Value="&#xE7BF;" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="receivable">
                                                            <Setter TargetName="IconBorder" Property="Background" Value="#34C759" />
                                                            <Setter TargetName="IconText" Property="Text" Value="&#xE8C0;" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="refund">
                                                            <Setter TargetName="IconBorder" Property="Background" Value="#007AFF" />
                                                            <Setter TargetName="IconText" Property="Text" Value="&#xE8A9;" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="restock">
                                                            <Setter TargetName="IconBorder" Property="Background" Value="#AF52DE" />
                                                            <Setter TargetName="IconText" Property="Text" Value="&#xE8F1;" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <!-- 即将发生现金提示底注 -->
                                        <TextBlock Grid.Row="2" Text="建议控制在安全额度内" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                        
                        <!-- 最底脚注 -->
                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,24,0,0" FontSize="11" Foreground="{StaticResource CaptionTextBrush}">
                            <Run Text="ℹ️ 数据统计截止至 " />
                            <Run Text="{Binding CashflowUpdatedAtText, Mode=OneWay, FallbackValue='2024-06-12 23:59:59'}" />
                            <Run Text="，部分数据可能存在延迟，仅供参考。" />
                        </TextBlock>
                    </Grid>
            </Grid>

            <!-- 订单履约 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=订单履约}">
                <Grid.RowDefinitions>
                    <!-- 0. Custom Header -->
                    <RowDefinition Height="Auto" />
                    <!-- 1. Statistics Cards -->
                    <RowDefinition Height="Auto" />
                    <!-- 2. Search & Filters -->
                    <RowDefinition Height="Auto" />
                    <!-- 3. List & Detail Content Area -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 1. Statistics Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.Resources>
                        <Style x:Key="FulfillmentStatsCardButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="14,12" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="0" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.0" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CardChrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="16"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardChrome" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                                <Setter TargetName="CardChrome" Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(TranslateTransform.Y)"
                                                                             To="-4" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.Effect).(DropShadowEffect.Opacity)"
                                                                             To="0.08" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(TranslateTransform.Y)"
                                                                             To="0" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.Effect).(DropShadowEffect.Opacity)"
                                                                             To="0.0" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="CardChrome" Property="Opacity" Value="0.9" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: 已支付待确认 -->
                    <Button Grid.Column="0"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="paid_pending_confirm">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource BlueSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE194;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BlueTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="待确认" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.PaidPendingConfirmCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 2: 待制作 -->
                    <Button Grid.Column="2"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="pending_make">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource WarmSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE18C;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource WarmTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="待制作" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.PendingMakeCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 3: 制作中 -->
                    <Button Grid.Column="4"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="making">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PurpleSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE7A3;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PurpleTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="制作中" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.MakingCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 4: 待发货 -->
                    <Button Grid.Column="6"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="ready_to_ship">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource BlueSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BlueTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="待发货" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ReadyToShipCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 5: 已发货 -->
                    <Button Grid.Column="8"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="shipped">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PrimaryLightBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE170;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="已发货" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ShippedCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 6: 异常 -->
                    <Button Grid.Column="10"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="exception">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource DangerSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE7A3;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource DangerTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="异常" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ExceptionCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 7: 已完成 -->
                    <Button Grid.Column="12"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="completed">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource AccentSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="已完成" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.CompletedCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>
                </Grid>

                <!-- 2. Search & Filters -->
                <Border Grid.Row="2" Style="{StaticResource SettingsGroupCardStyle}" Padding="14,10" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,10,0">
                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Padding="14,0,10,0"
                                     Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.AutomationId="Input_FulfillmentSearchKeyword" />
                            <TextBlock Text="🔍 搜索订单号/客户昵称/收件人姓名/微信号..." Foreground="{StaticResource CaptionTextBrush}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Keyword}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Keyword}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button x:Name="Btn_SelectDateRange" Content="选择时间范围" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="36" Padding="12,0" Click="Btn_SelectDateRange_Click" />
                            <Popup x:Name="Popup_DateRangePicker" PlacementTarget="{Binding ElementName=Btn_SelectDateRange}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Direction="270" Color="#111216" Opacity="0.08" />
                                    </Border.Effect>
                                    <StackPanel Width="280">
                                        <TextBlock Text="选择过滤时间范围" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,12" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <DatePicker SelectedDate="{Binding StartAt, Converter={StaticResource TimestampToDateTimeConverter}, Mode=TwoWay}" Height="32" Width="120" Grid.Column="0" />
                                            <TextBlock Text="至" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="6,0" Grid.Column="1" />
                                            <DatePicker SelectedDate="{Binding EndAt, Converter={StaticResource TimestampToDateTimeConverter}, Mode=TwoWay}" Height="32" Width="120" Grid.Column="2" />
                                        </Grid>
                                        <DockPanel>
                                            <Button Content="清空时间" Style="{StaticResource DialogSecondaryButtonStyle}" Height="30" Padding="12,0" HorizontalAlignment="Left" Click="Btn_ClearDateRange_Click" />
                                            <Button Content="确认应用" Style="{StaticResource DialogPrimaryButtonStyle}" Height="30" Padding="12,0" HorizontalAlignment="Right" Click="Btn_ApplyDateRange_Click" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="重置筛选" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="36" Padding="14,0" Command="{Binding ClearStringNarrationFiltersCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 3. List & Detail Content Area -->
                <Grid Grid.Row="3">
                    <Grid.Resources>
                        <Style x:Key="StringNarrationOrderCardListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource CardListBoxItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid Margin="6">
                                            <Border x:Name="CardBorder" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14" RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="CardTransform" Y="0" />
                                                </Border.RenderTransform>
                                                <Border.Effect>
                                                    <DropShadowEffect x:Name="CardShadow" BlurRadius="12" ShadowDepth="1" Direction="270" Color="#111216" Opacity="0.02" />
                                                </Border.Effect>
                                                <ContentPresenter />
                                            </Border>
                                            <Border x:Name="ActiveIndicator" Width="4" Height="36" Background="#17181C" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" Margin="1,0,0,0" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <!-- 状态 A：未选中但悬停，触发浮起与落回 -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True" />
                                                    <Condition Property="IsSelected" Value="False" />
                                                </MultiTrigger.Conditions>
                                                <MultiTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardTransform" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.1">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.10" Duration="0" />
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="16" Duration="0" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiTrigger.EnterActions>
                                                <MultiTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.12">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.02" Duration="0" />
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="12" Duration="0" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiTrigger.ExitActions>
                                                <Setter TargetName="CardBorder" Property="Background" Value="#F8F9FA" />
                                            </MultiTrigger>

                                            <!-- 状态 B：选中状态，保持浮起，直到取消选中 -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardTransform" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.1">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.06" Duration="0" />
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="16" Duration="0" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.12">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.02" Duration="0" />
                                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="12" Duration="0" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                                <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <DataTemplate x:Key="StringNarrationOrderCardTemplate">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding OrderNoText}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                        <Button Style="{StaticResource IconCopyButtonStyle}" Width="18" Height="18" Padding="0" Margin="6,0,0,0"
                                                Command="{Binding DataContext.CopyStringNarrationOrderSummaryOrderNoCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" ToolTip="复制订单号">
                                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                        </Button>
                                    </StackPanel>

                                     <Border DockPanel.Dock="Right" CornerRadius="6" Padding="6,2.5" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                        <Setter Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                        <Setter Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                                        <Setter Property="Background" Value="{StaticResource PurpleSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                                        <Setter Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding FulfillmentStatusLabel}" FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                            <Setter Property="Foreground" Value="{StaticResource BlueTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                            <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                                            <Setter Property="Foreground" Value="{StaticResource PurpleTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                                            <Setter Property="Foreground" Value="{StaticResource BlueTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DockPanel>

                                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding TitleSnapshotText}" FontSize="13" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                                </StackPanel>

                                <DockPanel Grid.Row="2">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <TextBlock Text="👤" Foreground="{StaticResource CaptionTextBrush}" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ReceiverSummaryText}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" MaxWidth="160" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding CreatedAt, Converter={StaticResource TimestampToDateTimeConverter}, StringFormat={}{0:MM-dd HH:mm}}" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding AmountText}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </DataTemplate>
                    </Grid.Resources>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SettingsGroupCardStyle}" Padding="16" Margin="0,0,14,0"
                            Visibility="{Binding IsStringNarrationDetailPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="共 " Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding StringNarrationTotalCount, FallbackValue=0}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text=" 条数据" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="15" Height="30" Padding="1,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateStringNarrationPrevPageCommand}" ToolTip="上一页">
                                                <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Button>
                                            <Border Padding="10,0" Background="Transparent" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StringNarrationPageLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                            </Border>
                                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateStringNarrationNextPageCommand}" ToolTip="下一页">
                                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ToggleButton x:Name="Btn_PageSizeSelector"
                                                      Style="{StaticResource PageSizeSelectorToggleButtonStyle}"
                                                      IsChecked="{Binding IsStringNarrationPageSizePopupOpen, Mode=TwoWay}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StringNarrationPageSize, StringFormat={}{0} 条/页}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text=" ▾"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,0,0"/>
                                            </StackPanel>
                                        </ToggleButton>
                                        <Popup x:Name="Popup_PageSizeSelector"
                                               PlacementTarget="{Binding ElementName=Btn_PageSizeSelector}"
                                               Placement="Top"
                                               IsOpen="{Binding IsStringNarrationPageSizePopupOpen, Mode=TwoWay}"
                                               StaysOpen="False"
                                               AllowsTransparency="True">
                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="4"
                                                    Margin="0,0,0,4">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Direction="90" Color="#111216" Opacity="0.08" />
                                                </Border.Effect>
                                                <StackPanel Width="90">
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="10 条/页"
                                                            Command="{Binding ChangeStringNarrationPageSizeCommand}"
                                                            CommandParameter="10"/>
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="16 条/页"
                                                            Command="{Binding ChangeStringNarrationPageSizeCommand}"
                                                            CommandParameter="16"/>
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="20 条/页"
                                                            Command="{Binding ChangeStringNarrationPageSizeCommand}"
                                                            CommandParameter="20"/>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid>
                                <Grid Visibility="{Binding IsStringNarrationOrderListVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <!-- Empty state UI -->
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding HasStringNarrationOrders}" Value="False" />
                                                            <Condition Binding="{Binding IsStringNarrationLoading}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <MultiDataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </MultiDataTrigger.EnterActions>
                                                        <MultiDataTrigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15" Duration="0">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </MultiDataTrigger.ExitActions>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource SurfaceSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                                                <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{StaticResource CaptionTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" Margin="0,0,0,6">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="暂无订单数据" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                                <Setter Property="Text" Value="暂无已支付待确认的订单" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                                <Setter Property="Text" Value="暂无待制作订单" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
