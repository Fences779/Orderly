                <TabItem Header="系统提醒" Style="{StaticResource SettingsTabItemStyle}" Tag="&#xE715;">
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Stretch">
                            <!-- 系统提醒与通知策略卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="系统事件提醒与通知" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 新订单事件 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="有新订单拉取成功时提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在桌面右下角推送新拉取到的订单气泡消息" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifyNewOrderInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifyNewOrder" />
                                        </Grid>
                                    </Border>

                                    <!-- 异常订单事件 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="发现异常订单时提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="订单被标记为异常、缺货或支付异常时进行提醒" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifyExceptionOrderInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifyExceptionOrder" />
                                        </Grid>
                                    </Border>

                                    <!-- 超期未处理 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="待办任务超期未处理提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="超过设定时限仍未流转状态时触发预警" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifyOverdueUnhandledInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifyOverdueUnhandled" />
                                        </Grid>
                                    </Border>

                                    <!-- 同步失败提醒 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="网关同步失败提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动后台同步连接超时或网关授权过期时报错提醒" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifySyncFailedInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifySyncFailed" />
                                        </Grid>
                                    </Border>

                                    <!-- 各种时限设置 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="未确认订单催促提醒 (小时)" Style="{StaticResource SettingsItemTitleStyle}" />
