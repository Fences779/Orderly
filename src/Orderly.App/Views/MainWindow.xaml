                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPriceAdjustments}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ListBox ItemsSource="{Binding PriceAdjustments}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPriceAdjustments}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                                        <StackPanel>
                                                            <WrapPanel>
                                                                <TextBlock Text="{Binding OriginalAmount, StringFormat=原价 ¥{0:N0}}" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,0,10,0" />
                                                                <TextBlock Text="{Binding AdjustedAmount, StringFormat=调整后 ¥{0:N0}}" Foreground="{StaticResource WarmTextBrush}" FontWeight="Bold" />
                                                            </WrapPanel>
                                                            <WrapPanel Margin="0,8,0,0">
                                                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="9" Padding="8,2" Margin="0,0,8,6">
                                                                    <TextBlock Text="{Binding Status, Converter={StaticResource EnumLabelConverter}}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                                                </Border>
                                                                <TextBlock Text="{Binding Reason, StringFormat=原因：{0}}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="消息 / 沟通记录" Style="{StaticResource SectionHeaderTextStyle}" />
                                            <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                                <TextBlock Text="{Binding ConversationMessagesCount, StringFormat={}{0} 条}" Style="{StaticResource CaptionTextStyle}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Text="最小入口：支持手工录入消息和手动导入图片做本地 OCR fallback，仅用于沉淀上下文，不连接真实自动发送。"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20" />
                                        <Border Background="#F8F6F0" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="手动 OCR 入口" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SelectedConversationContextText}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                                <Button x:Name="Btn_SelectOcrImage"
                                                        AutomationProperties.AutomationId="Btn_SelectOcrImage"
                                                        Content="选择图片 / 导入截图"
                                                        Command="{Binding SelectOcrImageCommand}"
                                                        Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                                        Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding CurrentOcrFileNameText}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding CurrentOcrStatusText, StringFormat=OCR 状态：{0}}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" Margin="0,6,0,0" />
                                                <TextBlock Text="{Binding CurrentOcrHintText}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="18" />
                                                <TextBox x:Name="Output_OcrTextPreview"
                                                         AutomationProperties.AutomationId="Output_OcrTextPreview"
                                                         Margin="0,8,0,0"
                                                         MinHeight="72"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding CurrentOcrPreviewText, Mode=OneWay}" />
                                                <Button x:Name="Btn_ConvertOcrToConversationMessage"
                                                        AutomationProperties.AutomationId="Btn_ConvertOcrToConversationMessage"
                                                        Content="转为沟通记录"
                                                        Command="{Binding ConvertOcrToConversationMessageCommand}"
                                                        Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                                        Margin="0,10,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F8F6F0" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedConversationContextText}" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                                <TextBox x:Name="Input_ConversationMessage"
                                                         AutomationProperties.AutomationId="Input_ConversationMessage"
                                                         Margin="0,8,0,0"
                                                         MinHeight="80"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding ConversationMessageInput, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button x:Name="Btn_AddConversationMessage"
                                                        AutomationProperties.AutomationId="Btn_AddConversationMessage"
                                                        Content="保存沟通记录"
                                                        Command="{Binding AddConversationMessageCommand}"
                                                        Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                                        Margin="0,10,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="当前上下文还没有沟通记录" Margin="0,12,0,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasConversationMessages}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ListBox ItemsSource="{Binding ConversationMessages}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasConversationMessages}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding SenderName}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                                <TextBlock DockPanel.Dock="Right" Text="{Binding MessageTimeText}" Foreground="{StaticResource SecondaryTextBrush}" />
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding MetaText}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                                                            <TextBlock Text="{Binding Content}" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,14,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="AI 建议" Style="{StaticResource SectionHeaderTextStyle}" />
                                            <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                                <TextBlock Text="{Binding AiSuggestionsCount, StringFormat={}{0} 条}" Style="{StaticResource CaptionTextStyle}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Text="默认使用 Local Stub；已预留 DeepSeek / OpenAI-compatible Provider；复制草稿只写入系统剪贴板，本软件不会自动发送，请手动粘贴到微信/闲鱼等平台。"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20" />
                                        <Border Background="#F8F6F0" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedConversationContextText}" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                                <Button x:Name="Btn_GenerateAiSuggestion"
                                                        AutomationProperties.AutomationId="Btn_GenerateAiSuggestion"
                                                        Content="生成建议"
                                                        Command="{Binding GenerateAiSuggestionCommand}"
                                                        Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                                        Margin="0,10,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="当前上下文还没有 AI 建议" Margin="0,12,0,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAiSuggestions}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ListBox ItemsSource="{Binding AiSuggestions}"
                                                 SelectedItem="{Binding SelectedAiSuggestion}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAiSuggestions}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                                <TextBlock DockPanel.Dock="Right" Text="{Binding CreatedAtText}" Foreground="{StaticResource SecondaryTextBrush}" />
                                                            </DockPanel>
                                                            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="9" Padding="8,2" Margin="0,8,0,0" HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding ProviderBadgeText}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                                            </Border>
                                                            <TextBlock Text="{Binding SuggestionText}" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20" />
                                                            <TextBlock Text="{Binding Reason}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="18" />
                                                            <TextBlock Text="{Binding DraftStateHint}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="18">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DraftStateHint}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <WrapPanel Margin="0,10,0,0">
                                                                <Button Content="接受"
                                                                        Command="{Binding DataContext.AcceptAiSuggestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                                                        IsEnabled="{Binding CanReview}" />
                                                                <Button Content="拒绝"
                                                                        Command="{Binding DataContext.RejectAiSuggestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                        IsEnabled="{Binding CanReview}"
                                                                        Margin="8,0,0,0" />
                                                                <Button Content="准备回复草稿"
                                                                         Command="{Binding DataContext.PrepareAutoReplyDraftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                         CommandParameter="{Binding}"
                                                                         Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                         IsEnabled="{Binding CanPrepareDraft}"
                                                                         Margin="8,0,0,0" />
                                                                <Button Content="复制草稿"
                                                                        AutomationProperties.AutomationId="Btn_CopyAutoReplyDraft"
                                                                        Command="{Binding DataContext.CopyAutoReplyDraftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                        IsEnabled="{Binding CanCopyDraft}"
                                                                        Margin="8,0,0,0" />
                                                                <Button Content="标记已发送"
                                                                        AutomationProperties.AutomationId="Btn_MarkAutoReplySent"
                                                                        Command="{Binding DataContext.MarkAutoReplySentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                        IsEnabled="{Binding CanMarkSent}"
                                                                        Margin="8,0,0,0" />
                                                                <Button Content="拒绝草稿"
                                                                        Command="{Binding DataContext.RejectAutoReplyDraftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                        IsEnabled="{Binding CanRejectDraft}"
                                                                        Margin="8,0,0,0" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="ActivityLog" Style="{StaticResource SectionHeaderTextStyle}" />
                                            <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                                <TextBlock Text="{Binding ActivityLogsCount, StringFormat={}{0} 条}" Style="{StaticResource CaptionTextStyle}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Text="当前客户还没有活动记录" Margin="0,6,0,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasActivityLogs}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ListBox ItemsSource="{Binding ActivityLogs}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasActivityLogs}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72" />
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Margin="0,3,10,0">
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MM-dd}}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:HH:mm}}" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                        <Grid Grid.Column="1">
                                                            <Border Width="1" Background="{StaticResource TimelineBrush}" HorizontalAlignment="Center" Margin="0,14,0,0" />
                                                            <Ellipse Width="10" Height="10" Fill="{StaticResource AccentSoftBrush}" Stroke="#9FB7AA" StrokeThickness="1" VerticalAlignment="Top" Margin="0,4,0,0" />
                                                        </Grid>
                                                        <Border Grid.Column="2" Style="{StaticResource ListItemBorderStyle}">
                                                            <StackPanel>
                                                                <WrapPanel>
                                                                    <Border Background="#EEF2EE" CornerRadius="9" Padding="8,2" Margin="0,0,8,8">
                                                                        <TextBlock Text="{Binding TypeLabel}" Foreground="#55665D" FontWeight="SemiBold" FontSize="11" />
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,1,0,0" />
                                                                </WrapPanel>
                                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,0" LineHeight="20">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Description}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="快捷回复" Style="{StaticResource SectionHeaderTextStyle}" />
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding ReplyTemplates}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                            <TextBlock Text="{Binding Content}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" MaxHeight="58" Margin="0,6,0,10" LineHeight="20" />
                                                            <Button Content="复制话术" Command="{Binding DataContext.CopyTemplateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource ToolbarPrimaryButtonStyle}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- 订单履约 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=订单履约}">
                <Grid.RowDefinitions>
                    <!-- 0. Custom Header -->
                    <RowDefinition Height="Auto" />
                    <!-- 1. Statistics Cards -->
                    <RowDefinition Height="Auto" />
                    <!-- 2. Search & Filters -->
                    <RowDefinition Height="Auto" />
                    <!-- 3. List & Detail Content Area -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 1. Statistics Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.Resources>
                        <Style x:Key="FulfillmentStatsCardButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="14,12" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="0" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.0" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CardChrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="16"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardChrome" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                                <Setter TargetName="CardChrome" Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(TranslateTransform.Y)"
                                                                             To="-4" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.Effect).(DropShadowEffect.Opacity)"
                                                                             To="0.08" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(TranslateTransform.Y)"
                                                                             To="0" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.Effect).(DropShadowEffect.Opacity)"
                                                                             To="0.0" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="CardChrome" Property="Opacity" Value="0.9" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: 已支付待确认 -->
                    <Button Grid.Column="0"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="paid_pending_confirm">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource BlueSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE194;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BlueTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="已支付待确认" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.PaidPendingConfirmCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 2: 待制作 -->
                    <Button Grid.Column="2"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="pending_make">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource WarmSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE18C;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource WarmTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="待制作" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.PendingMakeCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 3: 制作中 -->
                    <Button Grid.Column="4"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="making">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PurpleSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE7A3;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PurpleTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="制作中" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.MakingCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 4: 待发货 -->
                    <Button Grid.Column="6"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="ready_to_ship">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource BlueSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BlueTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="待发货" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ReadyToShipCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 5: 已发货 -->
                    <Button Grid.Column="8"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="shipped">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PrimaryLightBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE170;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="已发货" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ShippedCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 6: 异常 -->
                    <Button Grid.Column="10"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="exception">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource DangerSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE7A3;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource DangerTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="异常" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ExceptionCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Card 7: 已完成 -->
                    <Button Grid.Column="12"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="completed">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource AccentSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="已完成" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.CompletedCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Button>
                </Grid>

                <!-- 2. Search & Filters -->
                <Border Grid.Row="2" Style="{StaticResource SettingsGroupCardStyle}" Padding="14,10" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,10,0">
                            <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Padding="32,0,10,0"
                                     Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.AutomationId="Input_FulfillmentSearchKeyword" />
                            <TextBlock Text="🔍" Foreground="{StaticResource CaptionTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False" />
                            <TextBlock Text="搜索订单号/客户昵称/收件人姓名/微信号..." Foreground="{StaticResource CaptionTextBrush}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Keyword}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Keyword}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button x:Name="Btn_SelectDateRange" Content="选择时间范围" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="36" Padding="12,0" Click="Btn_SelectDateRange_Click" />
                            <Popup x:Name="Popup_DateRangePicker" PlacementTarget="{Binding ElementName=Btn_SelectDateRange}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Direction="270" Color="#111216" Opacity="0.08" />
                                    </Border.Effect>
                                    <StackPanel Width="280">
                                        <TextBlock Text="选择过滤时间范围" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,12" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <DatePicker SelectedDate="{Binding StartAt, Converter={StaticResource TimestampToDateTimeConverter}, Mode=TwoWay}" Height="32" Width="120" Grid.Column="0" />
                                            <TextBlock Text="至" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="6,0" Grid.Column="1" />
                                            <DatePicker SelectedDate="{Binding EndAt, Converter={StaticResource TimestampToDateTimeConverter}, Mode=TwoWay}" Height="32" Width="120" Grid.Column="2" />
                                        </Grid>
                                        <DockPanel>
                                            <Button Content="清空时间" Style="{StaticResource DialogSecondaryButtonStyle}" Height="30" Padding="12,0" HorizontalAlignment="Left" Click="Btn_ClearDateRange_Click" />
                                            <Button Content="确认应用" Style="{StaticResource DialogPrimaryButtonStyle}" Height="30" Padding="12,0" HorizontalAlignment="Right" Click="Btn_ApplyDateRange_Click" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="重置筛选" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="36" Padding="14,0" Command="{Binding ClearStringNarrationFiltersCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 3. List & Detail Content Area -->
                <Grid Grid.Row="3">
                    <Grid.Resources>
                        <Style x:Key="StringNarrationOrderCardListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource CardListBoxItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid Margin="0,0,12,12">
                                            <Border x:Name="CardBorder" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Direction="270" Color="#111216" Opacity="0.02" />
                                                </Border.Effect>
                                                <ContentPresenter />
                                            </Border>
                                            <Border x:Name="ActiveIndicator" Width="4" Height="36" Background="{StaticResource PrimaryBrush}" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" Margin="1,0,0,0" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="#F8F9FA" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="#EBF4EF" />
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <DataTemplate x:Key="StringNarrationOrderCardTemplate">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="20" Height="20" Padding="0" Margin="0,0,6,0"
                                                Command="{Binding DataContext.CopyStringNarrationOrderFieldCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="orderNo" ToolTip="复制订单号">
                                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                        </Button>
                                        <TextBlock Text="{Binding OrderNoText}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Border DockPanel.Dock="Right" CornerRadius="8" Padding="8,4" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                        <Setter Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                        <Setter Property="Background" Value="{StaticResource PurpleSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                                        <Setter Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding FulfillmentStatusLabel}" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                            <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                            <Setter Property="Foreground" Value="{StaticResource PurpleTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                                            <Setter Property="Foreground" Value="{StaticResource BlueTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DockPanel>

                                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding TitleSnapshotText}" FontSize="13" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                                </StackPanel>

                                <DockPanel Grid.Row="2">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <TextBlock Text="👤" Foreground="{StaticResource CaptionTextBrush}" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ReceiverSummaryText}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" MaxWidth="160" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding AmountText}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding CreatedAtText}" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </DataTemplate>
                    </Grid.Resources>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SettingsGroupCardStyle}" Padding="16" Margin="0,0,14,0"
                            Visibility="{Binding IsStringNarrationDetailPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="共 " Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding StringNarrationOrders.Count, FallbackValue=0}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text=" 条数据" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="&lt;" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="28" Height="28" Padding="0" IsEnabled="False" Margin="0,0,4,0" />
                                        <Button Content="1" Style="{StaticResource DialogPrimaryButtonStyle}" Width="28" Height="28" Padding="0" Margin="0,0,4,0" />
                                        <Button Content="&gt;" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="28" Height="28" Padding="0" IsEnabled="False" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="20 条/页" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ListBox ItemsSource="{Binding StringNarrationOrders}"
                                     SelectedItem="{Binding SelectedStringNarrationOrder}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MouseDoubleClick="StringNarrationOrdersList_MouseDoubleClick"
                                     ItemContainerStyle="{StaticResource StringNarrationOrderCardListItemStyle}"
                                     ItemTemplate="{StaticResource StringNarrationOrderCardTemplate}" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SettingsGroupCardStyle}" Padding="16" Margin="0"
                            Visibility="{Binding IsStringNarrationListExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="共 " Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding StringNarrationOrders.Count, FallbackValue=0}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text=" 条数据" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="&lt;" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="28" Height="28" Padding="0" IsEnabled="False" Margin="0,0,4,0" />
                                        <Button Content="1" Style="{StaticResource DialogPrimaryButtonStyle}" Width="28" Height="28" Padding="0" Margin="0,0,4,0" />
                                        <Button Content="&gt;" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="28" Height="28" Padding="0" IsEnabled="False" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="20 条/页" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ListBox ItemsSource="{Binding StringNarrationOrders}"
                                     SelectedItem="{Binding SelectedStringNarrationOrder}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MouseDoubleClick="StringNarrationOrdersList_MouseDoubleClick"
                                     ItemContainerStyle="{StaticResource StringNarrationOrderCardListItemStyle}"
                                     ItemTemplate="{StaticResource StringNarrationOrderCardTemplate}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Right: Selected Order Detail Panel -->
                    <Border Grid.Column="1" Style="{StaticResource SettingsGroupCardStyle}" Padding="18" Margin="0"
                            Visibility="{Binding IsStringNarrationDetailPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Header -->
                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="订单详情" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="订单号：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.OrderNoText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                                <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="20" Height="20" Padding="0" Margin="6,0,0,0"
                                                        Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="orderNo" ToolTip="复制订单号">
                                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                        
