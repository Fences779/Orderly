                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.AmountText, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Box 3: Count -->
                                            <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,0,8">
