                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="敏感电话默认加星" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在客户与订单列表中遮蔽电话号码关键数字" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding MaskPhoneByDefaultInput}"
                                                      AutomationProperties.AutomationId="Chk_MaskPhoneByDefault" />
                                        </Grid>
                                    </Border>

                                    <!-- 敏感地址默认遮蔽 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="敏感地址默认加星" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在客户与订单列表中遮蔽联系地址关键详情" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding MaskAddressByDefaultInput}"
                                                      AutomationProperties.AutomationId="Chk_MaskAddressByDefault" />
                                        </Grid>
                                    </Border>

                                    <!-- 备份时包含明文敏感字段 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="备份导出明文敏感字段" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="导出数据时包含明文敏感信息（不推荐开启）" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding IncludeSensitiveInExportInput}"
                                                      AutomationProperties.AutomationId="Chk_IncludeSensitiveInExport" />
