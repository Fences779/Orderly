                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- SN 同步策略卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="SN 接入与数据同步" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 启用订单同步 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="启用订单同步策略" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="与 SN 开放网关自动同步最新的销售与客户订单" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding SnOrderSyncEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_SnOrderSyncEnabled" />
                                        </Grid>
                                    </Border>

                                    <!-- 同步模式 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="同步模式选择" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="通过定时还是手动进行网络同步拉取" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding SnSyncModeOptions}"
                                                     SelectedItem="{Binding SnSyncModeInput}"
                                                     AutomationProperties.AutomationId="List_SnSyncMode" />
                                        </Grid>
                                    </Border>

                                    <!-- 同步频率 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动定时同步频率" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动网关拉取周期的具体间隔时间" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding SnSyncFrequencyOptions}"
                                                     SelectedItem="{Binding SnSyncFrequencyInput}"
                                                     AutomationProperties.AutomationId="List_SnSyncFrequency" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- SN 网关状态卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="SN 网关连接状态" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 云端环境 ID -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="云端环境ID" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SnCloudEnvironmentIdText}" Style="{StaticResource SettingsStatusTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <!-- 网关连接状态 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="网关连接测试状态" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SnConnectionStatusText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="测试连接" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding TestSnConnectionCommand}"
                                                    AutomationProperties.AutomationId="Btn_TestSnConnection" />
                                        </Grid>
                                    </Border>

                                    <!-- 测试结果详情 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="测试详情与结果" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SnLastConnectionResultText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- 同步状态 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="数据拉取与同步状态" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SnLastSyncResultText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="立即同步" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding TriggerSnSyncCommand}"
                                                    AutomationProperties.AutomationId="Btn_TriggerSnSync" />
                                        </Grid>
                                    </Border>

                                    <!-- 同步日志摘要 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="最新拉取结果摘要" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SnSyncLogSummaryText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 数据安全与隐私卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="数据安全与隐私" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 敏感电话默认遮蔽 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="敏感电话默认加星" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在客户与订单列表中遮蔽电话号码关键数字" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding MaskPhoneByDefaultInput}"
                                                      AutomationProperties.AutomationId="Chk_MaskPhoneByDefault" />
                                        </Grid>
                                    </Border>

                                    <!-- 敏感地址默认遮蔽 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="敏感地址默认加星" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在客户与订单列表中遮蔽联系地址关键详情" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding MaskAddressByDefaultInput}"
                                                      AutomationProperties.AutomationId="Chk_MaskAddressByDefault" />
                                        </Grid>
                                    </Border>

                                    <!-- 备份时包含明文敏感字段 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="备份导出明文敏感字段" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="导出数据时包含明文敏感信息（不推荐开启）" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding IncludeSensitiveInExportInput}"
                                                      AutomationProperties.AutomationId="Chk_IncludeSensitiveInExport" />
                                        </Grid>
                                    </Border>

                                    <!-- 复制订单摘要时脱敏 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="复制订单摘要时脱敏" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="一键复制订单时自动隐藏客户姓名、金额等隐私" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding MaskOrderSummaryOnCopyInput}"
                                                      AutomationProperties.AutomationId="Chk_MaskOrderSummaryOnCopy" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 数据库维护卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="本地数据库维护" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 数据库路径 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="数据库路径" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding DatabasePath}" Style="{StaticResource SettingsStatusTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <!-- 数据库体积 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="数据体积" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding DatabaseSizeText}" Style="{StaticResource SettingsStatusTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <!-- 完整性检查 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="数据完整性校验" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding DatabaseHealthStatusText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="开始检查" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding CheckDatabaseHealthCommand}"
                                                    AutomationProperties.AutomationId="Btn_CheckDatabaseHealth" />
                                        </Grid>
                                    </Border>

                                    <!-- 检查详细结果 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="校验日志详情" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding DatabaseHealthDetailText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 数据验证与恢复卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="数据校验与导入恢复" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="选择备份文件" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding SelectedBackupPath, StringFormat='已选：\{0\}'}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="选择文件" Style="{StaticResource SettingsRowActionButtonStyle}" Margin="0,0,8,0"
                                                        Command="{Binding SelectBackupFileCommand}"
                                                        AutomationProperties.AutomationId="Btn_SelectBackupFile" />
                                                <Button Content="验证备份" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                        Command="{Binding ValidateBackupCommand}"
                                                        AutomationProperties.AutomationId="Btn_ValidateBackup" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- 恢复检查报告 -->
                                    <Border Background="#F8F6F0" CornerRadius="10" Padding="14" Margin="0,14,0,0" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="数据恢复校验报告" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Text="文件名" Style="{StaticResource SettingsFieldLabelStyle}" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RestorePreviewFileName}" TextWrapping="Wrap" />

                                                <TextBlock Grid.Row="1" Text="导出时间" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,6,0,0" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RestorePreviewExportedAtText}" Margin="0,6,0,0" />

                                                <TextBlock Grid.Row="2" Text="校验状态" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,6,0,0" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RestorePreviewChecksumStatusText}" Margin="0,6,0,0" />

                                                <TextBlock Grid.Row="3" Text="允许恢复" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,6,0,0" />
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RestorePreviewCanRestoreText}" Margin="0,6,0,0" FontWeight="SemiBold" />

                                                <TextBlock Grid.Row="4" Text="风险警示" Style="{StaticResource SettingsFieldLabelStyle}" Margin="0,6,0,0" />
                                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RestoreRiskPromptText}" Margin="0,6,0,0" Foreground="{StaticResource WarmTextBrush}" TextWrapping="Wrap" />
                                            </Grid>

                                            <CheckBox x:Name="Chk_RestoreRiskConfirm" Margin="0,10,0,0"
                                                      Content="{Binding RestoreRiskConfirmationText}"
                                                      IsChecked="{Binding IsRestoreRiskConfirmed}"
                                                      IsEnabled="{Binding CanConfirmRestoreRisk}"
                                                      AutomationProperties.AutomationId="Chk_RestoreRiskConfirm" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 执行导入 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0" Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开始执行数据恢复" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding RestoreStatusText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="执行安全恢复" Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="34" Padding="14,0"
                                                    Command="{Binding RestoreBackupCommand}"
                                                    AutomationProperties.AutomationId="Btn_RestoreBackup" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 日志清理配置卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="系统日志记录" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="启用操作日志记录" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="系统会自动在本地审计记录重要的商家操作" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding OperationLogEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_OperationLogEnabled" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="日志自动清理周期" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动清理设定天数前的旧审计日志" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                             <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><TextBox Style="{StaticResource SettingsRowTextBoxStyle}" Width="80" Text="{Binding OperationLogRetentionDaysInput, UpdateSourceTrigger=PropertyChanged}" LostFocus="SettingsTextInput_LostFocus" AutomationProperties.AutomationId="Txt_OperationLogRetentionDays" /><TextBlock Text="&#x5929;" Margin="8,0,0,0" VerticalAlignment="Center" Style="{StaticResource SettingsItemTitleStyle}" Foreground="#6B7280" /></StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开发者调试模式" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="开启后系统将生成更详尽的诊断文件以备排查" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding DebugModeEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_DebugModeEnabled" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 保存应用配置按钮 -->
                            <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0" Margin="0,16,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="保存数据与同步配置" Style="{StaticResource SettingsItemTitleStyle}" />
                                        <TextBlock Text="保存当前数据备份、同步参数及隐私审计选项" Style="{StaticResource SettingsItemDescStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="保存并应用" 
                                            Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="36" Padding="16,0" VerticalAlignment="Center"
                                            Command="{Binding SaveP0SettingsCommand}"
                                            AutomationProperties.AutomationId="Btn_SavePreferences_Data" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                </TabItem>

                <!-- Tab 4: AI 助手 -->
                <TabItem Header="AI 助手" Style="{StaticResource SettingsTabItemStyle}" Tag="&#xE99A;">
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Stretch">
                            <!-- AI 助手核心配置卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="AI 智能话术助手" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 启用 AI 助手 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开启 AI 话术推荐" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="根据当前客户与订单上下文提供智能快捷回复话术建议" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding EnableAiAssistantInput}"
                                                      AutomationProperties.AutomationId="Chk_EnableAiAssistant" />
                                        </Grid>
                                    </Border>

                                    <!-- 允许读取当前订单上下文 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="允许读取订单上下文" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="允许 AI 助手获取当前编辑中或高亮选中的订单数据" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AllowAiOrderContextInput}"
                                                      AutomationProperties.AutomationId="Chk_AllowAiOrderContext" />
                                        </Grid>
                                    </Border>

                                    <!-- 允许分析客户历史行为画像 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
