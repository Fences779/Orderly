                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource WarmSoftBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource WarmTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <Grid>
                                                        <TextBlock Text="待制作" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Left" />
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <TextBlock Text="占未完成订单 " FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                            <TextBlock Text="60%" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Text="18 单" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,4" />
                                                    <ProgressBar Value="{Binding StringNarrationWorkbenchPendingMakeCount, Mode=OneWay}" Maximum="{Binding StringNarrationWorkbenchUnfinishedOrderCount, Mode=OneWay}" Height="6" Background="#E5E7EC" Foreground="{StaticResource WarmTextBrush}" BorderThickness="0" Margin="0,4,0,0">
                                                        <ProgressBar.Template>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Grid>
                                                                    <Border CornerRadius="3" Background="{TemplateBinding Background}"/>
                                                                    <Border x:Name="PART_Indicator" CornerRadius="3" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left"/>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- 待发货 -->
                                        <Border Background="#FBFAF6" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PurpleSoftBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PurpleTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <Grid>
                                                        <TextBlock Text="待发货" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Left" />
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <TextBlock Text="占未完成订单 " FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                            <TextBlock Text="30%" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Text="9 单" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,4" />
                                                    <ProgressBar Value="{Binding StringNarrationWorkbenchReadyToShipCount, Mode=OneWay}" Maximum="{Binding StringNarrationWorkbenchUnfinishedOrderCount, Mode=OneWay}" Height="6" Background="#E5E7EC" Foreground="{StaticResource PurpleTextBrush}" BorderThickness="0" Margin="0,4,0,0">
                                                        <ProgressBar.Template>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Grid>
                                                                    <Border CornerRadius="3" Background="{TemplateBinding Background}"/>
                                                                    <Border x:Name="PART_Indicator" CornerRadius="3" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left"/>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- 中间弹性占位 -->
                                    <Border Grid.Row="2" />

                                    <!-- 底部：当日实际总单数 -->
                                    <Border Grid.Row="3" BorderBrush="#F1F2F5" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="当日实际总单数：" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{Binding StringNarrationWorkbenchTodayOrderCount}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                            <TextBlock Text=" 单" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="3" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 3. 底部库存与现金流 -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 左边：库存状态 (点击循环切换测试) -->
                            <Button Grid.Column="0" Command="{Binding ToggleInventoryTestStatusCommand}" Style="{StaticResource InvisibleContainerButtonStyle}" HorizontalContentAlignment="Stretch">
                                <Border x:Name="InventoryCard" BorderThickness="1" CornerRadius="12" Padding="20,18" Height="140">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                            <Setter Property="Background" Value="#FFFFFF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#EAF2EF" Offset="0"/>
                                                                <GradientStop Color="#FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FFF8F0" Offset="0"/>
                                                                <GradientStop Color="#FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FFF2F2" Offset="0"/>
                                                                <GradientStop Color="#FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="库存状态" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                        
                                        <Grid Grid.Row="1" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- 图标色 -->
                                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" VerticalAlignment="Center" Margin="0,0,16,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F2F5" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                                <Setter Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                                <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource GreyTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            
                                            <!-- 详情描述 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontWeight="Bold" FontSize="18">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="正常" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                                    <Setter Property="Text" Value="正常" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                                    <Setter Property="Text" Value="需关注" />
                                                                    <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                                    <Setter Property="Text" Value="警告" />
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="所有材料库存充足，运营状况良好。" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="健康">
                                                                    <Setter Property="Text" Value="所有材料库存充足，运营状况良好。" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="需注意">
                                                                    <Setter Property="Text" Value="部分材料库存偏低，建议及时关注补货。" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationWorkbenchInventoryTestStatus}" Value="警告">
                                                                    <Setter Property="Text" Value="核心材料库存严重不足，请立即采购补充！" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <!-- 跳转按钮 -->
                                            <Button Grid.Column="2" Content="查看库存详情 →" Style="{StaticResource SubtleActionButtonStyle}" Foreground="{StaticResource BlueTextBrush}" FontSize="12" VerticalAlignment="Center"
                                                    Command="{Binding SelectSectionCommand}" CommandParameter="库存管理" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- 右边：现金流 (含天数圆弧环) -->
                            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="20,18" Height="140">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.03"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="现金流" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                    
                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- 环形图 (WPF Path 圆弧，72分时大约是260度弧度) -->
                                        <Grid Grid.Column="0" Width="64" Height="64" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <Ellipse Width="56" Height="56" Stroke="#F1F2F5" StrokeThickness="6" />
                                            <Path StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Stroke" Value="{Binding StringNarrationWorkbenchCashFlowColorText}" />
                                                        <Setter Property="Data" Value="M 32,7 A 25,25 0 1,1 8,28" />
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding StringNarrationWorkbenchCashFlowScoreText, FallbackValue=72}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding StringNarrationWorkbenchCashFlowEvaluation, FallbackValue=健康}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,1,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{Binding StringNarrationWorkbenchCashFlowColorText}" />
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="现金流状况良好，可支撑当前运营" FontSize="12" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="较昨日" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" />
                                                <TextBlock Text="{Binding StringNarrationWorkbenchCashFlowDeltaText}" FontSize="11" Foreground="#2B7A5C" FontWeight="Bold" Margin="4,0,0,0" />
                                                <TextBlock Text="天" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" Margin="2,0,0,0" />
                                                <TextBlock Text=" ↑" FontSize="11" Foreground="#2B7A5C" FontWeight="Bold" />
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- 跳转按钮 -->
                                        <Button Grid.Column="2" Content="查看现金流详情 →" Style="{StaticResource SubtleActionButtonStyle}" Foreground="{StaticResource BlueTextBrush}" FontSize="12" VerticalAlignment="Center"
                                                Command="{Binding SelectSectionCommand}" CommandParameter="现金流" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <!-- 库存管理 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=库存管理}" Background="{StaticResource PageBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- 0: 顶部标题栏 -->
                    <RowDefinition Height="Auto" /> <!-- 1: 5个大卡片 -->
                    <RowDefinition Height="Auto" /> <!-- 2: 过滤工具栏 -->
                    <RowDefinition Height="*" />    <!-- 3: 表格列表 -->
                    <RowDefinition Height="Auto" /> <!-- 4: 分页栏 -->
                </Grid.RowDefinitions>

                <!-- 0: 顶部标题栏 -->
                <Grid Grid.Row="0" Margin="24,16,24,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="库存管理" FontSize="22" FontWeight="Bold" Foreground="#1D1D1F" />
                        <TextBlock Text="用材料动销效率判断补货、压货和库存风险" FontSize="12" Foreground="#868E96" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="数据更新：" Foreground="#868E96" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding InventoryUpdatedAtText}" Foreground="#868E96" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" />
                        <Button Content="刷新库存" Command="{Binding RefreshInventoryCommand}" Style="{StaticResource SubtleActionButtonStyle}" Foreground="{StaticResource BlueTextBrush}" Padding="12,6" />
                    </StackPanel>
                </Grid>

                <!-- 1: 5个指标卡片 -->
                <Grid Grid.Row="1" Margin="24,0,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 卡片 1: 平均每单消耗珠子 -->
                    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E7EC" BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.02"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- 圆形小图标 -->
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="#F2EEFC" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" Foreground="#7A3EDB" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="平均每单消耗珠子" FontSize="11" Foreground="#868E96" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding InventoryDashboardSummary.AvgOrderMaterialUsage, StringFormat={}{0:0.0}}" FontSize="20" FontWeight="Bold" Foreground="#1D1D1F" />
                                    <TextBlock Text=" 颗" FontSize="11" Foreground="#868E96" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 卡片 2: 平均珠子单价 -->
                    <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E5E7EC" BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.02"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="#FFF5EC" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" Foreground="#FF9500" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="平均珠子单价" FontSize="11" Foreground="#868E96" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding InventoryDashboardSummary.AvgMaterialUnitCost, StringFormat=¥{0:0.00}}" FontSize="20" FontWeight="Bold" Foreground="#1D1D1F" />
                                    <TextBlock Text=" / 颗" FontSize="11" Foreground="#868E96" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 卡片 3: 平均每串售价 -->
                    <Border Grid.Column="4" Background="#FFFFFF" BorderBrush="#E5E7EC" BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.02"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="#EBF8F2" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" Foreground="#2B7A5C" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="平均每串售价" FontSize="11" Foreground="#868E96" />
                                <TextBlock Text="{Binding InventoryDashboardSummary.AvgBraceletSalePrice, StringFormat=¥{0:0.00}}" FontSize="20" FontWeight="Bold" Foreground="#1D1D1F" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 卡片 4: 平均每串成本 -->
                    <Border Grid.Column="6" Background="#FFFFFF" BorderBrush="#E5E7EC" BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.02"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="#EAF4FC" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" Foreground="#1A73E8" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="平均每串成本" FontSize="11" Foreground="#868E96" />
                                <TextBlock Text="{Binding InventoryDashboardSummary.AvgBraceletCostPrice, StringFormat=¥{0:0.00}}" FontSize="20" FontWeight="Bold" Foreground="#1D1D1F" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 卡片 5: 毛利率 -->
                    <Border Grid.Column="8" Background="#FFFFFF" BorderBrush="#E5E7EC" BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.02"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="#FCEEF9" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Foreground="#D12E9F" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="毛利率" FontSize="11" Foreground="#868E96" />
                                <TextBlock Text="{Binding InventoryDashboardSummary.GrossMarginRate, StringFormat={}{0:0.0}%}" FontSize="20" FontWeight="Bold" Foreground="#1D1D1F" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2: 过滤工具栏 -->
                <Grid Grid.Row="2" Margin="24,0,24,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" /> <!-- 搜索框 -->
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="120" /> <!-- 分类 -->
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="120" /> <!-- 状态 -->
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" /> <!-- 视图切换 -->
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" /> <!-- 显示字段 -->
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" /> <!-- 排序 -->
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" /> <!-- 筛选 -->
                    </Grid.ColumnDefinitions>

                    <!-- 搜索框 -->
                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding InventoryKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FulfillmentInputTextBoxStyle}" 
                                 Padding="28,0,10,0" Tag="搜索材料名称" Height="34" />
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#A0A5AF" FontSize="12" 
                                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False" />
                        <TextBlock Text="搜索材料名称" FontSize="12" Foreground="#A0A5AF" IsHitTestVisible="False" VerticalAlignment="Center" Margin="30,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding InventoryKeyword}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding InventoryKeyword}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- 分类 ComboBox -->
                    <ComboBox Grid.Column="2" 
                              ItemsSource="{Binding InventoryCategoryOptions}" 
                              SelectedItem="{Binding SelectedInventoryCategory}"
                              Style="{StaticResource FulfillmentInputComboBoxStyle}" Height="34" />

                    <!-- 状态 ComboBox -->
                    <ComboBox Grid.Column="4" 
                              ItemsSource="{Binding InventoryStatusOptions}" 
                              SelectedItem="{Binding SelectedInventoryStatus}"
                              Style="{StaticResource FulfillmentInputComboBoxStyle}" Height="34" />

                    <!-- 视图切换 (分段控件) -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="视图：" Foreground="#868E96" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Border BorderBrush="#DFE3EA" BorderThickness="1" CornerRadius="6" Background="#FFFFFF" Padding="2" Height="32">
                            <StackPanel Orientation="Horizontal">
                                <!-- 精简 -->
                                <Button Content="精简" Command="{Binding SwitchInventoryViewCommand}" CommandParameter="精简" Padding="12,0" BorderThickness="0" Height="26" FontSize="12">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="#495057" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInventoryView}" Value="精简">
                                                    <Setter Property="Background" Value="#EBF3FC" />
                                                    <Setter Property="Foreground" Value="#1A73E8" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!-- 动销 -->
                                <Button Content="动销" Command="{Binding SwitchInventoryViewCommand}" CommandParameter="动销" Padding="12,0" BorderThickness="0" Height="26" FontSize="12">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="#495057" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInventoryView}" Value="动销">
                                                    <Setter Property="Background" Value="#EBF3FC" />
                                                    <Setter Property="Foreground" Value="#1A73E8" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!-- 库存 -->
                                <Button Content="库存" Command="{Binding SwitchInventoryViewCommand}" CommandParameter="库存" Padding="12,0" BorderThickness="0" Height="26" FontSize="12">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="#495057" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInventoryView}" Value="库存">
                                                    <Setter Property="Background" Value="#EBF3FC" />
                                                    <Setter Property="Foreground" Value="#1A73E8" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 显示字段 ToggleButton + Popup -->
                    <Grid Grid.Column="8" VerticalAlignment="Center">
                        <ToggleButton x:Name="Btn_ShowCols" Style="{StaticResource InvisibleContainerToggleButtonStyle}" Height="32">
                            <Border BorderBrush="#DFE3EA" BorderThickness="1" CornerRadius="6" Background="#FFFFFF" Padding="12,0" Height="32">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE7B4;" FontFamily="Segoe MDL2 Assets" Foreground="#495057" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="显示字段" Foreground="#495057" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text=" ▾" Foreground="#868E96" FontSize="10" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=Btn_ShowCols}" StaysOpen="False" PlacementTarget="{Binding ElementName=Btn_ShowCols}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Slide">
                            <Border Background="#FFFFFF" BorderBrush="#DFE3EA" BorderThickness="1" CornerRadius="8" Width="200" Padding="14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Direction="270" Color="#000000" Opacity="0.08"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="显示字段" FontWeight="Bold" FontSize="13" Foreground="#1D1D1F" VerticalAlignment="Center" />
                                        <Button Content="重置" Command="{Binding SwitchInventoryViewCommand}" CommandParameter="精简" 
                                                Style="{StaticResource SubtleActionButtonStyle}" Foreground="{StaticResource BlueTextBrush}" 
                                                FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                    <Separator Background="#F1F2F5" Margin="0,0,0,10" />

                                    <TextBlock Text="基础信息" FontSize="11" Foreground="#868E96" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <CheckBox Content="材料名称" IsChecked="{Binding ShowColMaterialName}" Margin="0,0,0,6" IsEnabled="False" />
                                    <CheckBox Content="分类" IsChecked="{Binding ShowColCategory}" Margin="0,0,0,6" />
                                    <CheckBox Content="当前库存" IsChecked="{Binding ShowColCurrentStock}" Margin="0,0,0,6" />
                                    <CheckBox Content="状态" IsChecked="{Binding ShowColStatus}" Margin="0,0,0,12" />

                                    <TextBlock Text="动销数据" FontSize="11" Foreground="#868E96" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <CheckBox Content="7日动销 (动销比)" IsChecked="{Binding ShowCol7dSold}" Margin="0,0,0,6" />
                                    <CheckBox Content="30日动销 (动销比)" IsChecked="{Binding ShowCol30dSold}" Margin="0,0,0,12" />

                                    <TextBlock Text="库存建议" FontSize="11" Foreground="#868E96" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <CheckBox Content="安全库存建议" IsChecked="{Binding ShowColSafeStock}" Margin="0,0,0,12" />

                                    <TextBlock Text="其他" FontSize="11" Foreground="#868E96" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <CheckBox Content="单位成本" IsChecked="{Binding ShowColUnitCost}" Margin="0,0,0,6" />
                                    <CheckBox Content="最近补货" IsChecked="{Binding ShowColLastRestock}" Margin="0,0,0,6" />
                                    <CheckBox Content="供应商" IsChecked="{Binding ShowColSupplier}" Margin="0,0,0,6" />
                                    <CheckBox Content="备注" IsChecked="{Binding ShowColRemark}" Margin="0,0,0,12" />

                                    <Separator Background="#F1F2F5" Margin="0,0,0,10" />
                                    <Button Content="恢复默认" Command="{Binding SwitchInventoryViewCommand}" CommandParameter="精简" 
                                            Style="{StaticResource SubtleActionButtonStyle}" Foreground="{StaticResource BlueTextBrush}" 
                                            FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- 排序 ComboBox + 排序方向 ToggleButton -->
                    <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="排序：" Foreground="#868E96" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding InventorySortOptions}" 
                                  SelectedItem="{Binding SelectedInventorySortBy}"
                                  Style="{StaticResource FulfillmentInputComboBoxStyle}" Width="120" Height="32" />
                        <Button Command="{Binding ToggleInventorySortDirectionCommand}" Style="{StaticResource InvisibleContainerButtonStyle}" Margin="4,0,0,0" Height="32" Width="32">
                            <Border BorderBrush="#DFE3EA" BorderThickness="1" CornerRadius="6" Background="#FFFFFF" Height="32" Width="32">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" Foreground="#495057" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInventorySortDirection}" Value="asc">
                                                    <Setter Property="Text" Value="&#xE74A;" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Button>
                    </StackPanel>

                    <!-- 筛选按钮 -->
                    <Button Grid.Column="12" Style="{StaticResource InvisibleContainerButtonStyle}" Height="32">
                        <Border BorderBrush="#DFE3EA" BorderThickness="1" CornerRadius="6" Background="#FFFFFF" Padding="12,0" Height="32">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" Foreground="#495057" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="筛选" Foreground="#495057" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>
                </Grid>

                <!-- 3: 表格列表 -->
                <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#E5E7EC" BorderThickness="1" CornerRadius="12" Margin="24,0,24,12" Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.02"/>
                    </Border.Effect>
                    <Grid>
                        <!-- 正常表格展示 -->
                        <DataGrid ItemsSource="{Binding PagedInventoryItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  RowHeaderWidth="0"
                                  Background="Transparent"
                                  RowHeight="48"
                                  HorizontalGridLinesBrush="#F1F2F5"
                                  ColumnHeaderHeight="40">
                            
                            <!-- 表头样式定义 -->
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FCFCFD" />
                                    <Setter Property="Foreground" Value="#868E96" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Padding" Value="14,0" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="BorderBrush" Value="#E5E7EC" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <!-- 行样式定义 -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <!-- 1. 材料名称 -->
                                <DataGridTemplateColumn Header="材料名称" Width="200" 
                                                        Visibility="{Binding DataContext.ShowColMaterialName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MaterialName, TargetNullValue=暂无数据}" 
                                                       FontWeight="Bold" Foreground="#1D1D1F" 
                                                       VerticalAlignment="Center" Margin="14,0" FontSize="13" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 2. 分类 -->
                                <DataGridTemplateColumn Header="分类" Width="100"
                                                        Visibility="{Binding DataContext.ShowColCategory, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Category, TargetNullValue=未分类}" 
                                                       Foreground="#495057" VerticalAlignment="Center" Margin="14,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 3. 当前库存 -->
                                <DataGridTemplateColumn Header="当前库存" Width="120"
                                                        Visibility="{Binding DataContext.ShowColCurrentStock, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                                <TextBlock Text="{Binding CurrentStockQty, StringFormat={}{0:0.##}}" FontWeight="Bold" Foreground="#1D1D1F" />
                                                <TextBlock Text=" " />
                                                <TextBlock Text="{Binding StockUnit}" Foreground="#868E96" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 4. 7日动销 (动销比) -->
                                <DataGridTemplateColumn Header="7日动销 (动销比)" Width="160"
                                                        Visibility="{Binding DataContext.ShowCol7dSold, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                                <TextBlock Text="{Binding Sold7dQty, StringFormat={}{0:0.##}}" Foreground="#1D1D1F" />
                                                <TextBlock Text=" " />
                                                <TextBlock Text="{Binding StockUnit}" Foreground="#868E96" />
                                                <TextBlock Text=" / " Foreground="#E5E7EC" />
                                                <TextBlock Text="{Binding Sold7dRatio, StringFormat={}{0:0.0}%}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#868E96" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="fast_selling">
                                                                    <Setter Property="Foreground" Value="#E0533C" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="low_selling">
                                                                    <Setter Property="Foreground" Value="#2B7A5C" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 5. 30日动销 (动销比) -->
                                <DataGridTemplateColumn Header="30日动销 (动销比)" Width="160"
                                                        Visibility="{Binding DataContext.ShowCol30dSold, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                                <TextBlock Text="{Binding Sold30dQty, StringFormat={}{0:0.##}}" Foreground="#1D1D1F" />
                                                <TextBlock Text=" " />
                                                <TextBlock Text="{Binding StockUnit}" Foreground="#868E96" />
                                                <TextBlock Text=" / " Foreground="#E5E7EC" />
                                                <TextBlock Text="{Binding Sold30dRatio, StringFormat={}{0:0.0}%}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#868E96" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="fast_selling">
                                                                    <Setter Property="Foreground" Value="#E0533C" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="low_selling">
                                                                    <Setter Property="Foreground" Value="#2B7A5C" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 6. 安全库存建议 -->
                                <DataGridTemplateColumn Header="安全库存建议" Width="130"
                                                        Visibility="{Binding DataContext.ShowColSafeStock, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                                <TextBlock Text="{Binding SafeStockSuggestedQty, StringFormat={}{0:0.##}, TargetNullValue=未评估}" Foreground="#495057" />
                                                <TextBlock Text=" " />
                                                <TextBlock Text="{Binding StockUnit}" Foreground="#868E96">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SafeStockSuggestedQty}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 7. 状态 -->
                                <DataGridTemplateColumn Header="状态" Width="110"
                                                        Visibility="{Binding DataContext.ShowColStatus, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="14,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F3F5" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="fast_selling">
                                                                <Setter Property="Background" Value="#FFF0E6" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="low_selling">
                                                                <Setter Property="Background" Value="#EBF8F2" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="low_stock">
                                                                <Setter Property="Background" Value="#FFF0F0" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="normal">
                                                                <Setter Property="Background" Value="#E6F0FA" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusLabel, TargetNullValue=正常}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#495057" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="fast_selling">
                                                                    <Setter Property="Foreground" Value="#E0533C" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="low_selling">
                                                                    <Setter Property="Foreground" Value="#2B7A5C" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="low_stock">
                                                                    <Setter Property="Foreground" Value="#D93838" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="normal">
                                                                    <Setter Property="Foreground" Value="#1A73E8" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 8. 单位成本 -->
                                <DataGridTemplateColumn Header="单位成本" Width="100"
                                                        Visibility="{Binding DataContext.ShowColUnitCost, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding UnitCost, StringFormat=¥{0:0.00}, TargetNullValue=未评估}" 
                                                       Foreground="#495057" VerticalAlignment="Center" Margin="14,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 9. 最近补货 -->
                                <DataGridTemplateColumn Header="最近补货" Width="140"
                                                        Visibility="{Binding DataContext.ShowColLastRestock, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LastRestockedAt, Converter={StaticResource TimestampToDateTimeConverter}, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=未记录}" 
                                                       Foreground="#495057" VerticalAlignment="Center" Margin="14,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 10. 供应商 -->
                                <DataGridTemplateColumn Header="供应商" Width="130"
                                                        Visibility="{Binding DataContext.ShowColSupplier, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SupplierName, TargetNullValue=未记录}" 
                                                       Foreground="#495057" VerticalAlignment="Center" Margin="14,0" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 11. 备注 -->
                                <DataGridTemplateColumn Header="备注" Width="*"
                                                        Visibility="{Binding DataContext.ShowColRemark, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Remark}" Foreground="#868E96" VerticalAlignment="Center" Margin="14,0" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasInventoryDashboardItems}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Style>
                        </DataGrid>

                        <!-- 空数据展示 -->
                        <TextBlock Text="{Binding InventoryEmptyStateText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#868E96" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasInventoryDashboardItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- 4: 底部分页栏 -->
                <Grid Grid.Row="4" Margin="24,0,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- 共 N 条 -->
                        <ColumnDefinition Width="*" />    <!-- 页码按钮 -->
                        <ColumnDefinition Width="Auto" /> <!-- 每页条数下拉框 -->
                    </Grid.ColumnDefinitions>

                    <!-- 共 N 条 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="共 " Foreground="#868E96" FontSize="12" />
                        <TextBlock Text="{Binding InventoryTotalCount}" Foreground="#1D1D1F" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text=" 条" Foreground="#868E96" FontSize="12" />
                    </StackPanel>

                    <!-- 页码按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- 上一页 -->
                        <Button Content="&#xE0E2;" FontFamily="Segoe MDL2 Assets" 
                                Command="{Binding GoToPreviousInventoryPageCommand}" 
                                IsEnabled="{Binding CanGoToPreviousInventoryPage}"
                                Height="28" Width="28" FontSize="10" 
                                Style="{StaticResource InvisibleContainerButtonStyle}" Margin="0,0,4,0" />

                        <!-- 动态生成的数字页码 -->
                        <ItemsControl ItemsSource="{Binding InventoryPageNumbers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- 页码数字按钮 -->
                                        <Button Content="{Binding DisplayText}" 
                                                Command="{Binding DataContext.ChangeInventoryPageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                CommandParameter="{Binding PageNumber}"
                                                Height="28" MinWidth="28" FontSize="12" Margin="2,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Foreground" Value="#495057" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#DFE3EA" BorderThickness="{TemplateBinding BorderThickness}" Padding="6,0">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <!-- 鼠标悬浮 -->
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F1F2F5" />
                                                        </Trigger>
                                                        <!-- 高亮选中页码 -->
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Background" Value="#1A73E8" />
                                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                        </DataTrigger>
                                                        <!-- 省略号 0 展示 -->
                                                        <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Setter Property="Foreground" Value="#868E96" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 下一页 -->
                        <Button Content="&#xE0E3;" FontFamily="Segoe MDL2 Assets" 
                                Command="{Binding GoToNextInventoryPageCommand}" 
                                IsEnabled="{Binding CanGoToNextInventoryPage}"
                                Height="28" Width="28" FontSize="10" 
                                Style="{StaticResource InvisibleContainerButtonStyle}" Margin="4,0,0,0" />
                    </StackPanel>

                    <!-- 每页条数下拉框 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox ItemsSource="{Binding InventoryPageSizeOptions}" 
                                  SelectedItem="{Binding InventoryPageSize}"
                                  Style="{StaticResource FulfillmentInputComboBoxStyle}" Width="90" Height="28">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0} 条/页}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- 现金流 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=现金流}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,0,6,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="现金流" Style="{StaticResource SectionHeaderTextStyle}" />
                                <TextBlock Text="{Binding CashflowHealthSummaryText}" Style="{StaticResource CaptionTextStyle}" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding CashflowUpdatedAtText}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Grid.Column="2" Content="刷新现金流" Command="{Binding RefreshCashflowCommand}" Style="{StaticResource SubtleActionButtonStyle}" Foreground="{StaticResource BlueTextBrush}" Padding="12,6" VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="健康评分" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding CashflowHealthScoreText}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding CashflowHealthLevelText}" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="账上现金" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding CashflowCashBalanceText}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Text="真实现金账户余额" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="可用现金" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding CashflowAvailableCashText}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Text="现金 - 应付 + 应收" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="可支撑天数" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding CashflowSupportDaysText}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding CashflowAvgDailyExpense7dText}" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource SummaryMetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="应收 / 应付" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding CashflowReceivableAmountHealthText}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding CashflowPayableAmountHealthText}" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.35*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="数据可用性" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Margin="0,12,0,0" TextWrapping="Wrap">
                                        <Run Text="现金余额：" />
                                        <Run Text="{Binding CashflowHealthDashboardResult.DataAvailability.CashBalance.SourceType, TargetNullValue=未接入}" />
                                        <Run Text="  " />
                                        <Run Text="{Binding CashflowHealthDashboardResult.DataAvailability.CashBalance.Reason}" />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Margin="0,6,0,0" TextWrapping="Wrap">
                                        <Run Text="应收：" />
                                        <Run Text="{Binding CashflowHealthDashboardResult.DataAvailability.Receivable.SourceType, TargetNullValue=未接入}" />
                                        <Run Text="  " />
                                        <Run Text="{Binding CashflowHealthDashboardResult.DataAvailability.Receivable.Reason}" />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Margin="0,6,0,0" TextWrapping="Wrap">
                                        <Run Text="应付：" />
                                        <Run Text="{Binding CashflowHealthDashboardResult.DataAvailability.Payable.SourceType, TargetNullValue=未接入}" />
                                        <Run Text="  " />
                                        <Run Text="{Binding CashflowHealthDashboardResult.DataAvailability.Payable.Reason}" />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Margin="0,6,0,0" TextWrapping="Wrap">
                                        <Run Text="补货预算：" />
                                        <Run Text="{Binding CashflowHealthDashboardResult.DataAvailability.InventorySource.SourceType, TargetNullValue=未接入}" />
                                        <Run Text="  " />
                                        <Run Text="{Binding CashflowHealthDashboardResult.DataAvailability.InventorySource.Reason}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="经营建议" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <TextBlock Text="{Binding CashflowAdviceTitleText}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,12,0,0" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding CashflowAdviceDescriptionText}" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap">
                                        <Run Text="风险提示：" />
                                        <Run Text="{Binding CashflowAdvice.RiskHint, TargetNullValue=暂无}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="30 天趋势" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <Grid Grid.Row="1" Margin="0,12,0,0">
                                        <DataGrid ItemsSource="{Binding CashflowHealthTrendItems}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  BorderThickness="0"
                                                  RowHeaderWidth="0"
                                                  AlternatingRowBackground="#FCFCFD"
                                                  Background="Transparent"
                                                  MaxHeight="320">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="日期" Binding="{Binding Date, TargetNullValue=暂无}" Width="100" />
                                                <DataGridTextColumn Header="收入" Binding="{Binding IncomeAmount, StringFormat={}{0:C0}}" Width="90" />
                                                <DataGridTextColumn Header="支出" Binding="{Binding ExpenseAmount, StringFormat={}{0:C0}}" Width="90" />
                                                <DataGridTextColumn Header="净额" Binding="{Binding NetCashflowAmount, StringFormat={}{0:C0}}" Width="100" />
                                            </DataGrid.Columns>
                                            <DataGrid.Style>
                                                <Style TargetType="DataGrid">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasCashflowHealthTrendItems}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Style>
                                        </DataGrid>
                                        <TextBlock Text="暂无现金流趋势数据">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasCashflowHealthTrendItems}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="即将影响现金流" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <ItemsControl ItemsSource="{Binding CashflowUpcomingCashItems}" Margin="0,12,0,0">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCashflowUpcomingCashItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label, TargetNullValue=未命名}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                            <TextBlock Text="{Binding Note, TargetNullValue=暂无说明}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding Amount, StringFormat={}{0:C0}}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding Count, StringFormat=涉及 {0} 项}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="暂无 upcoming cash items">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCashflowUpcomingCashItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="收入结构" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <ItemsControl ItemsSource="{Binding CashflowIncomeBreakdown.Items}" Margin="0,12,0,0">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCashflowIncomeBreakdownItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Category, TargetNullValue=未分类}" Foreground="{StaticResource HeadingBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat={}{0:C0}}" Foreground="{StaticResource HeadingBrush}" Margin="12,0,0,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Percent, StringFormat={}{0:0.#}%}" Style="{StaticResource CaptionTextStyle}" Margin="12,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="暂无收入拆分">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCashflowIncomeBreakdownItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="支出结构" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <ItemsControl ItemsSource="{Binding CashflowExpenseBreakdown.Items}" Margin="0,12,0,0">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCashflowExpenseBreakdownItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Category, TargetNullValue=未分类}" Foreground="{StaticResource HeadingBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat={}{0:C0}}" Foreground="{StaticResource HeadingBrush}" Margin="12,0,0,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Percent, StringFormat={}{0:0.#}%}" Style="{StaticResource CaptionTextStyle}" Margin="12,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="暂无支出拆分">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCashflowExpenseBreakdownItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ItemsControl ItemsSource="{Binding CashflowAdvice.NextFocus}" Margin="0,16,0,0">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCashflowAdviceFocusItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BlueSoftBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource BlueTextBrush}" FontSize="12" FontWeight="SemiBold" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- 订单履约 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=订单履约}">
                <Grid.RowDefinitions>
                    <!-- 0. Custom Header -->
                    <RowDefinition Height="Auto" />
                    <!-- 1. Statistics Cards -->
                    <RowDefinition Height="Auto" />
                    <!-- 2. Search & Filters -->
                    <RowDefinition Height="Auto" />
                    <!-- 3. List & Detail Content Area -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 1. Statistics Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.Resources>
                        <Style x:Key="FulfillmentStatsCardButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="14,12" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="0" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.0" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CardChrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="16"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardChrome" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                                <Setter TargetName="CardChrome" Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(TranslateTransform.Y)"
                                                                             To="-4" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
