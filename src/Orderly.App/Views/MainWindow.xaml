                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding CurrentOcrPreviewText, Mode=OneWay}" />
                                                <Button x:Name="Btn_ConvertOcrToConversationMessage"
