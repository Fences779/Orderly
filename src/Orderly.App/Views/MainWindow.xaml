                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding NotifyDoNotDisturbRangeInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_NotifyDoNotDisturbRange" />
                                        </Grid>
                                    </Border>

                                    <!-- 仅通知高优先级 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="仅推送高优先级待办" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="仅对标红或最高优先级的事务触发气泡弹框" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifyHighPriorityOnlyInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifyHighPriorityOnly" />
                                        </Grid>
                                    </Border>

                                    <!-- 通知状态与测试按钮 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="桌面弹窗通知状态" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding NotificationStrategyStatusText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
