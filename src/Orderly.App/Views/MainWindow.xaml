                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.06" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource BlueSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
