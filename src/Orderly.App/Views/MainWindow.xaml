                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="显示/隐藏主窗口" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="激活并让工作台恢复至屏幕最前" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding MainWindowHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.AutomationId="Txt_MainWindowHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 2. 悬浮窗 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="显示/隐藏桌面悬浮窗" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="呼出右上角的悬浮按钮面板" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding FloatingWindowHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.AutomationId="Txt_FloatingWindowHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 3. 全局搜索 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="全局客户与订单搜索" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="一键聚焦搜索文本框" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding GlobalSearchHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.AutomationId="Txt_GlobalSearchHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 4. 工作台 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="导航至今日工作台" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="快速切换至今日待办面板" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding TodayWorkbenchHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.AutomationId="Txt_TodayWorkbenchHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 5. 一键复制摘要 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="一键复制订单摘要" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="复制当前选中的订单核心规格" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding CopyOrderSummaryHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.AutomationId="Txt_CopyOrderSummaryHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 6. 待制作工单 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="打开待制作工单" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="快速查看已生成未开工的待确认工单" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding OpenProductionSheetHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.AutomationId="Txt_OpenProductionSheetHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 7. 标记异常 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="标记当前订单异常" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="将处理卡壳的订单快速进行挂起预警" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding MarkOrderExceptionHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.AutomationId="Txt_MarkOrderExceptionHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 8. 快速推进履约 -->
