                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AutoBackupEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_AutoBackupEnabled" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动备份频率 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
