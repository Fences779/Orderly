                                                <TextBlock Text="自动上下文数据脱敏" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在大数据传输至外部大模型 API 前进行本地脱敏规避风险" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiAutoRedactBeforeSendInput}"
                                                      AutomationProperties.AutomationId="Chk_AiAutoRedactBeforeSend" />
                                        </Grid>
                                    </Border>

                                    <!-- 屏蔽电话号码 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动遮蔽联系电话" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="向 AI 上下文推送数据时自动隐去电话号码" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockPhoneInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockPhone" />
                                        </Grid>
                                    </Border>

                                    <!-- 屏蔽完整收货地址 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动遮蔽收货地址" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="向 AI 上下文推送数据时自动隐藏具体物理门牌号" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockFullAddressInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockFullAddress" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动屏蔽交易单号 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动遮蔽支付交易单号" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在 AI 通信报文中自动遮蔽第三方平台的流水与交易ID" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockPaymentTransactionIdInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockPaymentTransactionId" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI 回复偏好卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="AI 回复偏好配置" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 语气设定 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 回复语气控制" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="设定 AI 推荐话术的感情色彩倾向" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding AiReplyToneOptions}"
                                                     SelectedItem="{Binding AiReplyToneInput}"
                                                     AutomationProperties.AutomationId="List_AiReplyTone" />
                                        </Grid>
                                    </Border>

                                    <!-- 长度控制 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 回复字数长度" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="精简回复或提供详实的客服分析模板" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding AiReplyLengthOptions}"
                                                     SelectedItem="{Binding AiReplyLengthInput}"
                                                     AutomationProperties.AutomationId="List_AiReplyLength" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动生成订单摘要 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动填充生成订单摘要" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="允许 AI 助手对长对话生成一键订单概要填充" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiAutoGenerateOrderSummaryInput}"
                                                      AutomationProperties.AutomationId="Chk_AiAutoGenerateOrderSummary" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI 环境诊断 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="AI Provider 环境状态" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="核心运行框架" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding AiRuntimeProviderText}" Style="{StaticResource SettingsStatusTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="服务链接状态" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding AiConnectionCheckStatusText}" Style="{StaticResource SettingsStatusTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 接入服务自检" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding AiModelPreferenceStatusText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="运行配置检查" Style="{StaticResource SettingsRowActionButtonStyle}"
                                                    Command="{Binding CheckAiConfigurationCommand}"
                                                    AutomationProperties.AutomationId="Btn_CheckAiConfiguration" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 保存配置按钮 -->
                            <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0" Margin="0,16,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="保存 AI 助手配置" Style="{StaticResource SettingsItemTitleStyle}" />
                                        <TextBlock Text="保存当前 AI 参数及语气字数限制" Style="{StaticResource SettingsItemDescStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="保存并应用" 
                                            Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="36" Padding="16,0" VerticalAlignment="Center"
                                            Command="{Binding SaveP0SettingsCommand}"
                                            AutomationProperties.AutomationId="Btn_SavePreferences_Ai" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                </TabItem>

                <!-- Tab 5: 系统提醒 -->
                <TabItem Header="系统提醒" Style="{StaticResource SettingsTabItemStyle}" Tag="&#xE715;">
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Stretch">
                            <!-- 系统提醒与通知策略卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="系统事件提醒与通知" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 新订单事件 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="有新订单拉取成功时提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在桌面右下角推送新拉取到的订单气泡消息" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifyNewOrderInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifyNewOrder" />
                                        </Grid>
                                    </Border>

                                    <!-- 异常订单事件 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="发现异常订单时提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="订单被标记为异常、缺货或支付异常时进行提醒" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifyExceptionOrderInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifyExceptionOrder" />
                                        </Grid>
                                    </Border>

                                    <!-- 超期未处理 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="待办任务超期未处理提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="超过设定时限仍未流转状态时触发预警" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifyOverdueUnhandledInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifyOverdueUnhandled" />
                                        </Grid>
                                    </Border>

                                    <!-- 同步失败提醒 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="网关同步失败提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动后台同步连接超时或网关授权过期时报错提醒" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifySyncFailedInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifySyncFailed" />
                                        </Grid>
                                    </Border>

                                    <!-- 各种时限设置 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="未确认订单催促提醒 (小时)" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="已支付订单超此时间未由商家确认则发出提醒" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="80"
                                                     Text="{Binding NotifyPaidUnconfirmedHoursInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_NotifyPaidUnconfirmedHours" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="待制作工单催促提醒 (小时)" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="已确认订单超此时间未制作出单则发出预警" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="80"
                                                     Text="{Binding NotifyPendingProductionHoursInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_NotifyPendingProductionHours" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="待发货超时催促提醒 (小时)" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="工单完成后超此时间未录单发货则发出预警" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="80"
                                                     Text="{Binding NotifyPendingShipmentHoursInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_NotifyPendingShipmentHours" />
                                        </Grid>
                                    </Border>

                                    <!-- 地址缺失提醒 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="收货联系地址缺失提醒" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="导入订单如无详细地址则立刻弹出提示" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding NotifyMissingAddressInput}"
                                                      AutomationProperties.AutomationId="Chk_NotifyMissingAddress" />
                                        </Grid>
                                    </Border>

                                    <!-- 免打扰时间段 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="系统免打扰时间段" Style="{StaticResource SettingsItemTitleStyle}" />
