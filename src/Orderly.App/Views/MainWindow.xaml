                </ScrollViewer>
                </TabItem>

                <!-- Tab 2: 数据与安全 -->
                <TabItem Header="数据与安全" Style="{StaticResource SettingsTabItemStyle}" Tag="&#xE8B5;">
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
