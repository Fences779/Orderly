                                                    <TextBlock Text="客户昵称" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverName, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
