                                                <TextBlock Text="{Binding PriceAdjustmentsCount, StringFormat={}{0} 条}" Style="{StaticResource CaptionTextStyle}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Text="当前客户还没有改价记录" Margin="0,6,0,6">
