                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAiSuggestions}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                                <TextBlock DockPanel.Dock="Right" Text="{Binding CreatedAtText}" Foreground="{StaticResource SecondaryTextBrush}" />
                                                            </DockPanel>
                                                            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="9" Padding="8,2" Margin="0,8,0,0" HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding ProviderBadgeText}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                                            </Border>
                                                            <TextBlock Text="{Binding SuggestionText}" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20" />
                                                            <TextBlock Text="{Binding Reason}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="18" />
                                                            <TextBlock Text="{Binding DraftStateHint}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="18">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DraftStateHint}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <WrapPanel Margin="0,10,0,0">
                                                                <Button Content="接受"
                                                                        Command="{Binding DataContext.AcceptAiSuggestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                                                        IsEnabled="{Binding CanReview}" />
                                                                <Button Content="拒绝"
                                                                        Command="{Binding DataContext.RejectAiSuggestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                        IsEnabled="{Binding CanReview}"
                                                                        Margin="8,0,0,0" />
                                                                <Button Content="准备回复草稿"
                                                                         Command="{Binding DataContext.PrepareAutoReplyDraftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                         CommandParameter="{Binding}"
                                                                         Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                         IsEnabled="{Binding CanPrepareDraft}"
                                                                         Margin="8,0,0,0" />
                                                                <Button Content="复制草稿"
                                                                        AutomationProperties.AutomationId="Btn_CopyAutoReplyDraft"
                                                                        Command="{Binding DataContext.CopyAutoReplyDraftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                        IsEnabled="{Binding CanCopyDraft}"
                                                                        Margin="8,0,0,0" />
                                                                <Button Content="标记已发送"
                                                                        AutomationProperties.AutomationId="Btn_MarkAutoReplySent"
                                                                        Command="{Binding DataContext.MarkAutoReplySentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                        IsEnabled="{Binding CanMarkSent}"
                                                                        Margin="8,0,0,0" />
                                                                <Button Content="拒绝草稿"
                                                                        Command="{Binding DataContext.RejectAutoReplyDraftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                                                        IsEnabled="{Binding CanRejectDraft}"
                                                                        Margin="8,0,0,0" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="ActivityLog" Style="{StaticResource SectionHeaderTextStyle}" />
                                            <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                                <TextBlock Text="{Binding ActivityLogsCount, StringFormat={}{0} 条}" Style="{StaticResource CaptionTextStyle}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Text="当前客户还没有活动记录" Margin="0,6,0,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasActivityLogs}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ListBox ItemsSource="{Binding ActivityLogs}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasActivityLogs}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72" />
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Margin="0,3,10,0">
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MM-dd}}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:HH:mm}}" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                        <Grid Grid.Column="1">
                                                            <Border Width="1" Background="{StaticResource TimelineBrush}" HorizontalAlignment="Center" Margin="0,14,0,0" />
                                                            <Ellipse Width="10" Height="10" Fill="{StaticResource AccentSoftBrush}" Stroke="#9FB7AA" StrokeThickness="1" VerticalAlignment="Top" Margin="0,4,0,0" />
                                                        </Grid>
                                                        <Border Grid.Column="2" Style="{StaticResource ListItemBorderStyle}">
                                                            <StackPanel>
                                                                <WrapPanel>
                                                                    <Border Background="#EEF2EE" CornerRadius="9" Padding="8,2" Margin="0,0,8,8">
                                                                        <TextBlock Text="{Binding TypeLabel}" Foreground="#55665D" FontWeight="SemiBold" FontSize="11" />
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,1,0,0" />
                                                                </WrapPanel>
                                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,0" LineHeight="20">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Description}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}" Margin="0,0,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="快捷回复" Style="{StaticResource SectionHeaderTextStyle}" />
                                        </DockPanel>
                                        <ListBox ItemsSource="{Binding ReplyTemplates}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                            <TextBlock Text="{Binding Content}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" MaxHeight="58" Margin="0,6,0,10" LineHeight="20" />
                                                            <Button Content="复制话术" Command="{Binding DataContext.CopyTemplateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource ToolbarPrimaryButtonStyle}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=客户/订单}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <!-- 搜索 + 状态筛选 -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="客户 / 订单" Style="{StaticResource SectionHeaderTextStyle}" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Style="{StaticResource CountBadgeBorderStyle}" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding CustomersCountText}" Style="{StaticResource CaptionTextStyle}" />
                                    </Border>
                                    <Border Style="{StaticResource CountBadgeBorderStyle}">
                                        <TextBlock Text="{Binding OrdersCountText}" Style="{StaticResource CaptionTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBox DockPanel.Dock="Left"
                                         Width="200"
                                         Margin="0,0,8,0"
                                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.AutomationId="Input_SearchKeyword" />
                                <ComboBox Width="200"
                                          Margin="0,0,8,0"
                                          ItemsSource="{Binding SearchFilterOptions}"
                                          SelectedItem="{Binding SelectedStatusFilter}"
                                          AutomationProperties.AutomationId="Combo_SearchFilter">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="AutomationProperties.AutomationId" Value="{Binding Kind, StringFormat=Filter_\{0\}}" />
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                                <Button x:Name="Btn_ClearFilters"
                                        AutomationProperties.AutomationId="Btn_ClearFilters"
                                        Content="清空" Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                        Padding="10,4" Margin="0,0,0,0"
                                        Command="{Binding ClearSearchAndFiltersCommand}" />
                            </DockPanel>
                        </StackPanel>

                        <!-- 快捷筛选 Chip 行 -->
                        <WrapPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,0">
                            <TextBlock Text="快捷：" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,6" />
                            <Button Content="全部" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="All"
                                    AutomationProperties.AutomationId="Chip_All" />
                            <Button Content="今日跟进" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="TodayFollowUp"
                                    AutomationProperties.AutomationId="Chip_TodayFollowUp" />
                            <Button Content="逾期跟进" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="OverdueFollowUp"
                                    AutomationProperties.AutomationId="Chip_OverdueFollowUp" />
                            <Button Content="明日跟进" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="TomorrowFollowUp"
                                    AutomationProperties.AutomationId="Chip_TomorrowFollowUp" />
                            <Button Content="待处理订单" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="PendingOrders"
                                    AutomationProperties.AutomationId="Chip_PendingOrders" />
                            <Button Content="已成交订单" Style="{StaticResource ChipButtonStyle}"
                                    Click="QuickFilter_Click"
                                    Tag="WonOrders"
                                    AutomationProperties.AutomationId="Chip_WonOrders" />
                        </WrapPanel>

                        <!-- 状态消息面板 -->
                        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Style="{StaticResource StatusPanelStyle}" Margin="18,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding StatusMessageTitle}" Style="{StaticResource StatusMessageTitleTextStyle}" />
                                <TextBlock Text="{Binding StatusMessage}" Margin="0,5,0,0" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="客户列表" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <TextBlock Text="查看客户状态、优先级和最近联系情况" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                    <TextBlock Text="{Binding CustomersCountText}" Style="{StaticResource CaptionTextStyle}" />
                                </Border>
                            </DockPanel>

                            <TextBlock Text="{Binding CustomersEmptyStateText}"
                                       Style="{StaticResource HasItemsEmptyStateTextStyle}"
                                       Tag="{Binding HasCustomers}" />

                            <ListBox ItemsSource="{Binding Customers}"
                                     SelectedItem="{Binding SelectedCustomer}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Style="{StaticResource HasItemsListBoxStyle}"
                                     Tag="{Binding HasCustomers}"
                                     ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="CustomerListItemTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="订单列表" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <TextBlock Text="聚焦客户、需求摘要、状态、金额和跟进时间" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                    <TextBlock Text="{Binding OrdersCountText}" Style="{StaticResource CaptionTextStyle}" />
                                </Border>
                            </DockPanel>

                            <TextBlock Text="{Binding OrdersEmptyStateText}"
                                       Style="{StaticResource HasItemsEmptyStateTextStyle}"
                                       Tag="{Binding HasOrders}" />

                            <ListBox ItemsSource="{Binding Orders}"
                                     SelectedItem="{Binding SelectedOrderItem}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Style="{StaticResource HasItemsListBoxStyle}"
                                     Tag="{Binding HasOrders}"
                                     ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="OrderListItemTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- 订单履约 -->
            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=订单履约}">
                <Grid.RowDefinitions>
                    <!-- 0. Custom Header -->
                    <RowDefinition Height="Auto" />
                    <!-- 1. Statistics Cards -->
                    <RowDefinition Height="Auto" />
                    <!-- 2. Search & Filters -->
                    <RowDefinition Height="Auto" />
                    <!-- 3. List & Detail Content Area -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 0. Custom Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="订单履约" FontSize="26" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                        <TextBlock Text="管理订单履约全流程，实现高效的备货、制作、包装与发货操作" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Sync timestamp -->
                        <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="12" Padding="12,6" Margin="0,0,12,0" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" />
                                <TextBlock Text="同步时间：" Foreground="{StaticResource PrimaryBrush}" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding StringNarrationStatsCalculatedAtText}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        
                        <!-- Refresh Buttons -->
                        <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="36" Height="36" Padding="0" Command="{Binding LoadOrders}" ToolTip="刷新订单列表" Margin="0,0,8,0">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="36" Height="36" Padding="0" Command="{Binding LoadStats}" ToolTip="刷新履约统计" Margin="0,0,8,0">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        
                        <!-- Notification Bell -->
                        <Grid Margin="4,0,0,0">
                            <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="36" Height="36" Padding="0" ToolTip="通知消息">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                            <Border Background="{StaticResource DangerTextBrush}" Width="8" Height="8" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,4,0" IsHitTestVisible="False" />
                        </Grid>
                    </StackPanel>
                </DockPanel>

                <!-- 1. Statistics Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: 已支付待确认 -->
                    <Border Grid.Column="0" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.03" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource BlueSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BlueTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="已支付待确认" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.PaidPendingConfirmCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                    <TextBlock Text="+8 ↑" FontSize="10" Foreground="{StaticResource DangerTextBrush}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="6,0,0,2" HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Card 2: 待制作 -->
                    <Border Grid.Column="2" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.03" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource WarmSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource WarmTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="待制作" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.PendingMakeCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                    <TextBlock Text="+4 ↑" FontSize="10" Foreground="{StaticResource DangerTextBrush}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="6,0,0,2" HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Card 3: 制作中 -->
                    <Border Grid.Column="4" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.03" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PurpleSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PurpleTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="制作中" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.MakingCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                    <TextBlock Text="+3 ↑" FontSize="10" Foreground="{StaticResource DangerTextBrush}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="6,0,0,2" HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Card 4: 待发货 -->
                    <Border Grid.Column="6" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.03" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource BlueSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BlueTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="待发货" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ReadyToShipCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                    <TextBlock Text="-2 ↓" FontSize="10" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="6,0,0,2" HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Card 5: 已发货 -->
                    <Border Grid.Column="8" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.03" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PrimaryLightBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="已发货" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ShippedCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                    <TextBlock Text="+12 ↑" FontSize="10" Foreground="{StaticResource DangerTextBrush}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="6,0,0,2" HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Card 6: 异常 -->
                    <Border Grid.Column="10" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Direction="270" Color="#111216" Opacity="0.03" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource DangerSoftBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource DangerTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="异常" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Stats.ExceptionCount, FallbackValue=0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Bottom" />
                                    <TextBlock Text="-1 ↓" FontSize="10" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="6,0,0,2" HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2. Search & Filters -->
                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="14,10" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <ComboBox Grid.Column="0" Width="160" Margin="0,0,10,0" Height="36"
                                  ItemsSource="{Binding StringNarrationFulfillmentStatusFilterOptions}"
                                  SelectedItem="{Binding FulfillmentStatus}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource FulfillmentStatusLabelConverter}}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <Grid Grid.Column="1" Margin="0,0,10,0">
                            <TextBox Height="36" Padding="32,0,10,0" VerticalContentAlignment="Center"
                                     Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.AutomationId="Input_FulfillmentSearchKeyword" />
                            <TextBlock Text="🔍" Foreground="{StaticResource CaptionTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False" />
                            <TextBlock Text="搜索订单号/客户昵称/收件人姓名/微信号..." Foreground="{StaticResource CaptionTextBrush}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Keyword}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Keyword}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button x:Name="Btn_SelectDateRange" Content="选择时间范围" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="36" Padding="12,0" Click="Btn_SelectDateRange_Click" />
                            <Popup x:Name="Popup_DateRangePicker" PlacementTarget="{Binding ElementName=Btn_SelectDateRange}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Direction="270" Color="#111216" Opacity="0.08" />
                                    </Border.Effect>
                                    <StackPanel Width="280">
                                        <TextBlock Text="选择过滤时间范围" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,12" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <DatePicker SelectedDate="{Binding StartAt, Converter={StaticResource TimestampToDateTimeConverter}, Mode=TwoWay}" Height="32" Width="120" Grid.Column="0" />
                                            <TextBlock Text="至" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="6,0" Grid.Column="1" />
                                            <DatePicker SelectedDate="{Binding EndAt, Converter={StaticResource TimestampToDateTimeConverter}, Mode=TwoWay}" Height="32" Width="120" Grid.Column="2" />
                                        </Grid>
                                        <DockPanel>
                                            <Button Content="清空时间" Style="{StaticResource DialogSecondaryButtonStyle}" Height="30" Padding="12,0" HorizontalAlignment="Left" Click="Btn_ClearDateRange_Click" />
                                            <Button Content="确认应用" Style="{StaticResource DialogPrimaryButtonStyle}" Height="30" Padding="12,0" HorizontalAlignment="Right" Click="Btn_ApplyDateRange_Click" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <Button Content="重置筛选" Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="36" Padding="14,0" Command="{Binding LoadOrders}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 3. List & Detail Content Area -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Orders List -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                        <DockPanel>
                            <!-- Paging footer -->
                            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="共 " Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding StringNarrationOrders.Count, FallbackValue=0}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text=" 条数据" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="&lt;" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="28" Height="28" Padding="0" IsEnabled="False" Margin="0,0,4,0" />
                                        <Button Content="1" Style="{StaticResource DialogPrimaryButtonStyle}" Width="28" Height="28" Padding="0" Margin="0,0,4,0" />
                                        <Button Content="&gt;" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="28" Height="28" Padding="0" IsEnabled="False" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="20 条/页" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- List Box -->
                            <ListBox ItemsSource="{Binding StringNarrationOrders}"
                                     SelectedItem="{Binding SelectedStringNarrationOrder}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="1" Direction="270" Color="#111216" Opacity="0.02" />
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                
                                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                        <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="20" Height="20" Padding="0" Margin="0,0,6,0"
                                                                Command="{Binding DataContext.CopyStringNarrationOrderFieldCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="orderNo" ToolTip="复制订单号">
                                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                                        </Button>
                                                        <TextBlock Text="{Binding OrderNoText}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    
                                                    <Border DockPanel.Dock="Right" CornerRadius="8" Padding="8,4" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                                        <Setter Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                                        <Setter Property="Background" Value="{StaticResource WarmSoftBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                                                        <Setter Property="Background" Value="{StaticResource PurpleSoftBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                                                        <Setter Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding FulfillmentStatusLabel}" FontSize="11" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                                            <Setter Property="Foreground" Value="{StaticResource BlueTextBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                                            <Setter Property="Foreground" Value="{StaticResource WarmTextBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                                                            <Setter Property="Foreground" Value="{StaticResource PurpleTextBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                                                            <Setter Property="Foreground" Value="{StaticResource BlueTextBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                                                            <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DockPanel>
                                                
                                                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding TitleSnapshotText}" FontSize="13" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                
                                                <DockPanel Grid.Row="2">
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                        <TextBlock Text="👤" Foreground="{StaticResource CaptionTextBrush}" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding ReceiverSummaryText}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" MaxWidth="160" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding AmountText}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding CreatedAtText}" FontSize="11" Foreground="{StaticResource CaptionTextBrush}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Right: Selected Order Detail Panel -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Width="450" Padding="18" Margin="0"
                            Visibility="{Binding HasSelectedStringNarrationOrderDetail, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Header -->
                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="订单详情" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="订单号：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.OrderNoText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                                <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="20" Height="20" Padding="0" Margin="6,0,0,0"
                                                        Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="orderNo" ToolTip="复制订单号">
                                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="32" Height="32" Padding="0" VerticalAlignment="Top"
                                                Click="CloseDetails_Click" ToolTip="关闭详情">
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Stepper -->
                                <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="12" Padding="14,12" Margin="0,0,0,14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Node 1: 待确认 -->
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center" Background="{StaticResource PrimaryLightBrush}" BorderBrush="{StaticResource PrimaryBrush}">
                                                <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="待确认" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <!-- Line 1-2 -->
                                        <Rectangle Grid.Column="1" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 2: 待制作 -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="待制作" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <!-- Line 2-3 -->
                                        <Rectangle Grid.Column="3" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 3: 制作中 -->
                                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="制作中" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <!-- Line 3-4 -->
                                        <Rectangle Grid.Column="5" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 4: 待发货 -->
                                        <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="4" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="待发货" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <!-- Line 4-5 -->
                                        <Rectangle Grid.Column="7" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 5: 已发货 -->
                                        <StackPanel Grid.Column="8" HorizontalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="5" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="已发货" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <!-- Line 5-6 -->
                                        <Rectangle Grid.Column="9" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 6: 已完成 -->
                                        <StackPanel Grid.Column="10" HorizontalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" /><Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="6" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="已完成" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Overview Grid -->
                                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="订单概览" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,10" />
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="1" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="1" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Row 0: Nickname, Amount, Count -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="4,8">
                                                <TextBlock Text="客户昵称" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverName, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            
                                            <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource BorderBrushSoft}" Width="1" VerticalAlignment="Stretch" />
                                            
                                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,8">
                                                <TextBlock Text="订单金额" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.AmountText, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            
                                            <Border Grid.Row="0" Grid.Column="3" Background="{StaticResource BorderBrushSoft}" Width="1" VerticalAlignment="Stretch" />
                                            
                                            <StackPanel Grid.Row="0" Grid.Column="4" Margin="10,8">
                                                <TextBlock Text="商品数量" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ItemCountText, FallbackValue='-'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            
                                            <!-- Horizontal Divider -->
                                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Background="{StaticResource BorderBrushSoft}" Height="1" HorizontalAlignment="Stretch" />
                                            
                                            <!-- Row 2: CreatedAt, PaidAt, Channel -->
                                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="4,8">
                                                <TextBlock Text="下单时间" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.CreatedAtText, FallbackValue='-'}" FontSize="11" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            
                                            <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource BorderBrushSoft}" Width="1" VerticalAlignment="Stretch" />
                                            
                                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="10,8">
                                                <TextBlock Text="支付时间" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.PaidAtText, FallbackValue='-'}" FontSize="11" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            
                                            <Border Grid.Row="2" Grid.Column="3" Background="{StaticResource BorderBrushSoft}" Width="1" VerticalAlignment="Stretch" />
                                            
                                            <StackPanel Grid.Row="2" Grid.Column="4" Margin="10,8">
                                                <TextBlock Text="支付通道" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                <TextBlock Text="微信支付" FontSize="11" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Product snap list -->
                                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="商品快照" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,10" />
                                        <ItemsControl ItemsSource="{Binding SelectedStringNarrationOrderDetail.ItemsSnapshot}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="56" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="8" Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" ClipToBounds="True">
                                                            <Image Source="{Binding Cover}" Stretch="UniformToFill" Margin="2" />
                                                        </Border>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding TitleText}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" MaxHeight="36" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding DesignIdText}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                                                        </StackPanel>
                                                        
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding CountText}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Production Order section -->
                                <Grid Margin="0,0,0,14">
                                    <!-- Case A: Production Order Exists -->
                                    <Border Padding="14">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.HasData}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock Text="生产工单信息" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                                <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="8" Padding="6,2" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.StatusText}" FontSize="11" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                                                </Border>
                                            </DockPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="工单单号：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.ProductionOrderNoText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="制作来源：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.SourceText}" Foreground="{StaticResource HeadingBrush}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="制作备注：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.RemarkText}" Foreground="{StaticResource HeadingBrush}" FontSize="12" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Case B: Generate Production Order Button -->
                                    <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Background="Transparent" Padding="0" Cursor="Hand" Height="64">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.ProductionOrder.HasData}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Button Command="{Binding GenerateStringNarrationProductionOrderCommand}" Background="Transparent" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Rectangle Stroke="{StaticResource BorderBrushSoft}" StrokeThickness="1" StrokeDashArray="4 2" RadiusX="12" RadiusY="12" Fill="#FAFBFD" />
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                            <TextBlock Text="生成制作单" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Border>
                                </Grid>

                                <!-- Shipping Info -->
                                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="收货人与物流信息" FontSize="14" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" VerticalAlignment="Center" />
                                            <Button Style="{StaticResource ToolbarSecondaryButtonStyle}" Height="24" Padding="8,0" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="receiverInfo" ToolTip="复制完整收货信息">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="复制整单" FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </DockPanel>
                                        
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="收件人" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverName}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="联系电话" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverPhone}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="20" Height="20" Padding="0"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="phone" ToolTip="复制电话">
                                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                            </Button>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="详细地址" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Top" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.FullAddressText}" Foreground="{StaticResource HeadingBrush}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="20" Height="20" Padding="0" VerticalAlignment="Top"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="address" ToolTip="复制地址">
                                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                            </Button>
                                        </Grid>
                                        
                                        <Border Background="{StaticResource SurfaceSoftBrush}" Height="1" Margin="0,0,0,12" HorizontalAlignment="Stretch" />
                                        
                                        <!-- Logistics details inputs -->
                                        <StackPanel>
                                            <TextBlock Text="发货快递公司与单号" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,8" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0">
                                                    <TextBox Height="32" Padding="8,0" FontSize="12" Text="{Binding StringNarrationCarrierInput, Mode=TwoWay}"
                                                             AutomationProperties.AutomationId="Input_FulfillmentCarrier" />
                                                    <TextBlock Text="快递公司 (如 顺丰)" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StringNarrationCarrierInput}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StringNarrationCarrierInput}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                                <Grid Grid.Column="2">
                                                    <TextBox Height="32" Padding="8,0" FontSize="12" Text="{Binding StringNarrationTrackingNoInput, Mode=TwoWay}"
                                                             AutomationProperties.AutomationId="Input_FulfillmentTrackingNo" />
                                                    <TextBlock Text="快递单号" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StringNarrationTrackingNoInput}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StringNarrationTrackingNoInput}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                            
                                            <Grid Margin="0,0,0,10">
                                                <TextBox Height="32" Padding="8,0" FontSize="12" Text="{Binding StringNarrationAdminRemarkInput, Mode=TwoWay}"
                                                         AutomationProperties.AutomationId="Input_FulfillmentAdminRemark" />
                                                <TextBlock Text="后台备注 (如 加急制作)" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationAdminRemarkInput}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationAdminRemarkInput}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <ComboBox Grid.Column="0" Height="32" FontSize="12"
                                                          ItemsSource="{Binding StringNarrationFulfillmentStatusOptions}"
                                                          SelectedItem="{Binding StringNarrationFulfillmentStatusInput}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource FulfillmentStatusLabelConverter}}" VerticalAlignment="Center" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                
                                                <Button Grid.Column="2" Content="保存履约信息" Style="{StaticResource DialogPrimaryButtonStyle}" Height="32" Padding="14,0" Command="{Binding UpdateStringNarrationFulfillmentCommand}" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Bottom Action buttons -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Button Content="联系客户" Style="{StaticResource DialogSecondaryButtonStyle}" Height="36" Padding="14,0" Margin="0,0,8,0" />
                                        <Button Content="异常处理" Style="{StaticResource DialogSecondaryButtonStyle}" Height="36" Padding="14,0" Foreground="{StaticResource DangerTextBrush}" Tag="exception" Click="QuickFulfillmentUpdate_Click" />
                                    </StackPanel>
                                    
                                    <Grid Grid.Column="1">
                                        <!-- paid_pending_confirm -> Confirm demand -->
                                        <Button Content="确认需求" Height="36" Padding="16,0" Tag="pending_make" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="paid_pending_confirm">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- pending_make -> Generate Production Order / Mark Making -->
                                        <Button Content="生成工单并制作" Background="#FF8800" Height="36" Padding="16,0" Tag="making" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- making -> Finish Making (Ready to ship) -->
                                        <Button Content="制作完成" Height="36" Padding="16,0" Tag="ready_to_ship" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- ready_to_ship -> Confirm Ship (Shipped) -->
                                        <Button Content="确认发货" Background="#1F7A5A" Height="36" Padding="16,0" Tag="shipped" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- shipped -> Completed -->
                                        <Button Content="完成订单" Height="36" Padding="16,0" Tag="completed" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=话术库}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="快捷回复话术库" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                    <ListView ItemsSource="{Binding ReplyTemplates}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="标题" DisplayMemberBinding="{Binding Title}" Width="180" />
                                <GridViewColumn Header="场景" DisplayMemberBinding="{Binding Scene}" Width="120" />
                                <GridViewColumn Header="平台" DisplayMemberBinding="{Binding SourcePlatform}" Width="100" />
                                <GridViewColumn Header="内容" DisplayMemberBinding="{Binding Content}" Width="560" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=设置}">
                <StackPanel>
                    <TextBlock Text="基础设置" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="{Binding DatabasePath, StringFormat=数据库：{0}}" Margin="0,16,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Preferences.MainHotkey, StringFormat=主窗口快捷键：{0}}" Margin="0,10,0,0" />
                    <TextBlock Text="{Binding Preferences.FloatingHotkey, StringFormat=悬浮窗快捷键：{0}}" Margin="0,6,0,0" />
                    <Border Style="{StaticResource SummaryMetricCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="本地备份" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                            <TextBlock Text="仅支持本地 JSON 导出 / 校验 / 受控恢复；不接云端、不接平台同步。" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button x:Name="Btn_ExportBackup"
                                        AutomationProperties.AutomationId="Btn_ExportBackup"
                                        Content="导出备份"
                                        Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                        Command="{Binding ExportBackupCommand}" />
                                <Button x:Name="Btn_SelectBackupFile"
                                        AutomationProperties.AutomationId="Btn_SelectBackupFile"
                                        Content="选择备份文件"
                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                        Margin="10,0,0,0"
                                        Command="{Binding SelectBackupFileCommand}" />
                                <Button x:Name="Btn_ValidateBackup"
                                        AutomationProperties.AutomationId="Btn_ValidateBackup"
                                        Content="生成恢复预览"
                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                        Margin="10,0,0,0"
                                        Command="{Binding ValidateBackupCommand}" />
                                <Button x:Name="Btn_RestoreBackup"
                                        AutomationProperties.AutomationId="Btn_RestoreBackup"
                                        Content="恢复到空库/QA库"
                                        Style="{StaticResource ToolbarSecondaryButtonStyle}"
                                        Margin="10,0,0,0"
                                        Command="{Binding RestoreBackupCommand}" />
                            </WrapPanel>
                            <TextBlock Text="仅支持空库或测试库恢复，不覆盖已有生产数据。" Foreground="{StaticResource WarmTextBrush}" TextWrapping="Wrap" Margin="0,14,0,0" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedBackupPath, StringFormat=已选备份：{0}}" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" Margin="0,10,0,0" />
                            <Border Background="#F8F6F0" CornerRadius="10" Padding="14" Margin="0,16,0,0" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="恢复预览" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                    <TextBlock Text="先看摘要、目标库状态和风险提示，再决定是否恢复。" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="备份文件名" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RestorePreviewFileName}" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="1" Text="exportedAt" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RestorePreviewExportedAtText}" Margin="0,8,0,0" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="2" Text="schemaVersion" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RestorePreviewSchemaVersionText}" Margin="0,8,0,0" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="3" Text="checksum" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RestorePreviewChecksumText}" Margin="0,8,0,0" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="4" Text="checksum 状态" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RestorePreviewChecksumStatusText}" Margin="0,8,0,0" />

                                        <TextBlock Grid.Row="5" Text="备份表数量" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RestorePreviewCountsText}" Margin="0,8,0,0" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="6" Text="目标库状态" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding RestorePreviewTargetStateCodeText}" Margin="0,8,0,0" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="7" Text="目标库说明" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding RestorePreviewTargetStateText}" Margin="0,8,0,0" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="8" Text="目标库数量摘要" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding RestorePreviewTargetCountsText}" Margin="0,8,0,0" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="9" Text="是否会清理 QA 数据" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding RestorePreviewWillClearQaDataText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </Grid>

                                    <TextBlock Text="允许恢复" FontWeight="SemiBold" Margin="0,14,0,0" />
                                    <TextBlock Text="{Binding RestorePreviewCanRestoreText}" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />

                                    <TextBlock Text="拒绝原因" FontWeight="SemiBold" Margin="0,12,0,0" />
                                    <TextBlock Text="{Binding RestorePreviewRefuseReasonText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />

                                    <TextBlock Text="风险提示" FontWeight="SemiBold" Margin="0,12,0,0" />
                                    <TextBlock Text="{Binding RestoreRiskPromptText}" Foreground="{StaticResource WarmTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />

                                    <CheckBox x:Name="Chk_RestoreRiskConfirm"
                                              AutomationProperties.AutomationId="Chk_RestoreRiskConfirm"
                                              Content="{Binding RestoreRiskConfirmationText}"
                                              IsChecked="{Binding IsRestoreRiskConfirmed}"
                                              IsEnabled="{Binding CanConfirmRestoreRisk}"
                                              Margin="0,14,0,0" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="恢复状态" FontWeight="SemiBold" Margin="0,16,0,0" />
                            <TextBlock Text="{Binding RestoreStatusText}" Foreground="{StaticResource HeadingBrush}" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding RestoreDetailText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <TextBlock Text="最近备份状态" FontWeight="SemiBold" Margin="0,16,0,0" />
                            <TextBlock Text="{Binding RecentBackupStatusText}" Foreground="{StaticResource HeadingBrush}" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding RecentBackupDetailText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="扩展位：AI 助手、微信/闲鱼同步、OCR、自动回复已保留接口，第一版不接真实后端。" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,18,0,0" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
