                                                            <Setter TargetName="DealItemCard" Property="BorderBrush" Value="#D5E4DA" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="跟进 FollowUps" Style="{StaticResource SectionHeaderTextStyle}" />
                                            <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                                <TextBlock Text="{Binding FollowUpsCount, StringFormat={}{0} 条}" Style="{StaticResource CaptionTextStyle}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Text="当前客户还没有跟进记录" Margin="0,6,0,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasFollowUps}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ListBox ItemsSource="{Binding FollowUps}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasFollowUps}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemBorderStyle}" AutomationProperties.AutomationId="{Binding RemoteId}">
