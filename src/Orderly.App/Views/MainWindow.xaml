                                                        <DataTrigger Binding="{Binding HasAiSuggestions}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ListBox ItemsSource="{Binding AiSuggestions}"
                                                 SelectedItem="{Binding SelectedAiSuggestion}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
