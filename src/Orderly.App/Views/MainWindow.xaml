                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="3" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="制作中" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <!-- Line 3-4 -->
                                        <Rectangle Grid.Column="5" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource PrimaryBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 4: 待发货 -->
                                        <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="#D0D4D9" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship">
                                                                <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
