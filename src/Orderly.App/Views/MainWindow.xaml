                                                                </Border>
                                                                <TextBlock Text="{Binding EstimatedAmount, StringFormat=预计金额 ¥{0:N0}}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
