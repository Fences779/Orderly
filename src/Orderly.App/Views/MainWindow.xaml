                                            <TextBlock Text="已发货" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <!-- Line 5-6 -->
                                        <Rectangle Grid.Column="9" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
