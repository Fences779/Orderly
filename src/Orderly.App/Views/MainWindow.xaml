                                                <StackPanel>
                                                    <TextBlock Text="支付通道" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="微信支付" FontSize="11" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <!-- Product snap list -->
                                <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,14">
