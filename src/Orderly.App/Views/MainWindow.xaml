                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="显示/隐藏主窗口" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="激活并让工作台恢复至屏幕最前" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding MainWindowHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_MainWindowHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 2. 悬浮窗 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="显示/隐藏桌面悬浮窗" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="呼出右上角的悬浮按钮面板" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding FloatingWindowHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_FloatingWindowHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 3. 全局搜索 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="全局客户与订单搜索" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="一键聚焦搜索文本框" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding GlobalSearchHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_GlobalSearchHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 4. 工作台 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="导航至今日工作台" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="快速切换至今日待办面板" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding TodayWorkbenchHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_TodayWorkbenchHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 5. 一键复制摘要 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="一键复制订单摘要" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="复制当前选中的订单核心规格" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding CopyOrderSummaryHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_CopyOrderSummaryHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 6. 待制作工单 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="打开待制作工单" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="快速查看已生成未开工的待确认工单" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding OpenProductionSheetHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_OpenProductionSheetHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 7. 标记异常 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="标记当前订单异常" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="将处理卡壳的订单快速进行挂起预警" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding MarkOrderExceptionHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_MarkOrderExceptionHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 8. 快速推进履约 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="快速推进订单履约" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="对选中订单流转到下一个工序阶段" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding AdvanceFulfillmentHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_AdvanceFulfillmentHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 9. 客户档案 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="快速打开客户档案" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="呼出高亮客户的跟进日志与联系明细" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding OpenCustomerProfileHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_OpenCustomerProfileHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 10. 创建跟进备忘 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="快速新建客户跟进备忘" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="激活当前客户的备忘输入焦点" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding NewCustomerNoteHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_NewCustomerNoteHotkey" />
                                        </Grid>
                                    </Border>

                                    <!-- 11. 复制客户偏好 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="复制客户偏好摘要" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="导出该客户的常用规格、口味及过往成交总结" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="160"
                                                     Text="{Binding CopyCustomerPreferenceSummaryHotkeyInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_CopyCustomerPreferenceSummaryHotkey" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 快捷键保存与校验结果卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="快捷键绑定状态与自检" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="快捷键校验结果" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding HotkeyValidationStatusText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="热键冲突检测" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding HotkeyRuntimeStatusText}" Style="{StaticResource SettingsItemDescStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 保存配置按钮 -->
                            <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0" Margin="0,16,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="保存热键配置" Style="{StaticResource SettingsItemTitleStyle}" />
                                        <TextBlock Text="保存当前全局快捷键并测试应用热键" Style="{StaticResource SettingsItemDescStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="保存并应用" 
                                            Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="36" Padding="16,0" VerticalAlignment="Center"
                                            Command="{Binding SaveP0SettingsCommand}"
                                            AutomationProperties.AutomationId="Btn_SavePreferences_Hotkeys" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                </TabItem>
            </TabControl>

            <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
