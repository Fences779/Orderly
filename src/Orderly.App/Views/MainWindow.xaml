                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20" />
                                        <Border Background="#F8F6F0" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="手动 OCR 入口" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
