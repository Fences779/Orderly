                                                            <WrapPanel Margin="0,8,0,0">
                                                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="9" Padding="8,2" Margin="0,0,8,6">
                                                                    <TextBlock Text="{Binding Status, Converter={StaticResource EnumLabelConverter}}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                                                </Border>
                                                                <TextBlock Text="{Binding Reason, StringFormat=原因：{0}}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionBlockBorderStyle}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10">
