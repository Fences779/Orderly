                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2" Duration="0">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE72C;" 
                                                   FontFamily="Segoe MDL2 Assets" 
                                                   FontSize="30" 
                                                   FontWeight="Bold"
                                                   Foreground="Black" 
                                                   HorizontalAlignment="Center" 
                                                   RenderTransformOrigin="0.5,0.5" 
                                                   Margin="0,0,0,12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsStringNarrationGeneratingProductionOrder}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="RotateStoryboard1">
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                         From="0" To="360" Duration="0:0:1"
                                                                                         RepeatBehavior="Forever" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="RotateStoryboard1" />
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                        <TextBlock Text="{Binding StringNarrationStatusMessage}" 
                                                   FontSize="13" 
                                                   FontWeight="Bold"
                                                   Foreground="Black"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   MaxWidth="360"
                                                   HorizontalAlignment="Center" />
                                        <Button Content="关闭"
                                                Command="{Binding DismissStringNarrationProductionOrderErrorCommand}"
                                                Width="220"
                                                HorizontalAlignment="Center"
                                                Height="34"
                                                Padding="18,0"
                                                Margin="0,16,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsStringNarrationProductionOrderErrorVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SettingsGroupCardStyle}" Padding="16" Margin="0"
                            Visibility="{Binding IsStringNarrationListExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="共 " Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding StringNarrationTotalCount, FallbackValue=0}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text=" 条数据" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="15" Height="30" Padding="1,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateStringNarrationPrevPageCommand}" ToolTip="上一页">
                                                <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Button>
                                            <Border Padding="10,0" Background="Transparent" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StringNarrationPageLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                            </Border>
                                            <Button Style="{StaticResource CapsulePageButtonStyle}" Command="{Binding NavigateStringNarrationNextPageCommand}" ToolTip="下一页">
                                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ToggleButton x:Name="Btn_PageSizeSelectorExpanded"
                                                      Style="{StaticResource PageSizeSelectorToggleButtonStyle}"
                                                      IsChecked="{Binding IsStringNarrationPageSizePopupExpandedOpen, Mode=TwoWay}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StringNarrationPageSize, StringFormat={}{0} 条/页}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text=" ▾"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,0,0"/>
                                            </StackPanel>
                                        </ToggleButton>
                                        <Popup x:Name="Popup_PageSizeSelectorExpanded"
                                               PlacementTarget="{Binding ElementName=Btn_PageSizeSelectorExpanded}"
                                               Placement="Top"
                                               IsOpen="{Binding IsStringNarrationPageSizePopupExpandedOpen, Mode=TwoWay}"
                                               StaysOpen="False"
                                               AllowsTransparency="True">
                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="4"
                                                    Margin="0,0,0,4">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Direction="90" Color="#111216" Opacity="0.08" />
                                                </Border.Effect>
                                                <StackPanel Width="90">
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="10 条/页"
                                                            Command="{Binding ChangeStringNarrationPageSizeCommand}"
                                                            CommandParameter="10"/>
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="16 条/页"
                                                            Command="{Binding ChangeStringNarrationPageSizeCommand}"
                                                            CommandParameter="16"/>
                                                    <Button Style="{StaticResource PageSizeMenuButtonStyle}"
                                                            Content="20 条/页"
                                                            Command="{Binding ChangeStringNarrationPageSizeCommand}"
                                                            CommandParameter="20"/>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid>
                                <!-- Empty state UI -->
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasStringNarrationOrders}" Value="False" />
                                                        <Condition Binding="{Binding IsStringNarrationLoading}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <MultiDataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </MultiDataTrigger.EnterActions>
                                                    <MultiDataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15" Duration="0">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </MultiDataTrigger.ExitActions>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource SurfaceSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{StaticResource CaptionTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center" Margin="0,0,0,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="暂无订单数据" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="paid_pending_confirm">
                                                            <Setter Property="Text" Value="暂无已支付待确认的订单" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="pending_make">
                                                            <Setter Property="Text" Value="暂无待制作订单" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="making">
                                                            <Setter Property="Text" Value="暂无制作中订单" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="ready_to_ship">
                                                            <Setter Property="Text" Value="暂无待发货订单" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="shipped">
                                                            <Setter Property="Text" Value="暂无已发货订单" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="exception">
                                                            <Setter Property="Text" Value="暂无异常订单" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FulfillmentStatus}" Value="completed">
                                                            <Setter Property="Text" Value="暂无已完成订单" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="切换分类卡片或重置筛选条件试试" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <ListBox ItemsSource="{Binding StringNarrationOrders}"
                                         SelectedItem="{Binding SelectedStringNarrationOrder}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         MouseDoubleClick="StringNarrationOrdersList_MouseDoubleClick"
                                         ItemContainerStyle="{StaticResource StringNarrationOrderCardListItemStyle}"
                                         ItemTemplate="{StaticResource StringNarrationOrderCardTemplate}"
                                         Padding="2,4,2,2"
                                         ClipToBounds="False">
                                    <ListBox.Style>
                                        <Style TargetType="ListBox">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasStringNarrationOrders}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Style>
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>

                                <!-- Loading Overlay -->
                                <Grid x:Name="LoadingOverlay2" Visibility="Collapsed">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStringNarrationBusy_Disabled}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2" Duration="0">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE72C;" 
                                                   FontFamily="Segoe MDL2 Assets" 
                                                   FontSize="30" 
                                                   FontWeight="Bold"
                                                   Foreground="Black" 
                                                   HorizontalAlignment="Center" 
                                                   RenderTransformOrigin="0.5,0.5" 
                                                   Margin="0,0,0,12">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=LoadingOverlay2, Path=Visibility}" Value="Visible">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="RotateStoryboard2">
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                         From="0" To="360" Duration="0:0:1"
                                                                                         RepeatBehavior="Forever" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="RotateStoryboard2" />
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding StringNarrationStatusMessage}" 
                                                   FontSize="13" 
                                                   FontWeight="Bold"
                                                   Foreground="Black" 
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <!-- Right: Selected Order Detail Panel -->
                    <Border x:Name="DetailPanel" Grid.Column="1" Padding="18" Margin="0" RenderTransformOrigin="0.5,0.5"
                            Visibility="{Binding IsStringNarrationDetailPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.RenderTransform>
                            <TranslateTransform X="40" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource SettingsGroupCardStyle}">
                                <Style.Triggers>
                                    <Trigger Property="Visibility" Value="Visible">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="40" To="0" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Header -->
                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="订单详情" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="订单号：" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SelectedStringNarrationOrderDetail.OrderNoText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                                <Button Style="{StaticResource IconCopyButtonStyle}" Width="20" Height="20" Padding="0" Margin="6,0,0,2" VerticalAlignment="Center"
                                                        Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="orderNo" ToolTip="复制订单号">
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="32" Height="32" Padding="0" VerticalAlignment="Top"
                                                Click="CloseDetails_Click" ToolTip="关闭详情">
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Stepper -->
                                <Border Background="{StaticResource SurfaceSoftBrush}" CornerRadius="12" Padding="14,12" Margin="0,0,0,14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Node 1: 待确认 -->
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Cursor="Hand" Tag="paid_pending_confirm" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为待确认状态">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceSoftBrush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource HeadingBrush}" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource HeadingBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="paid_pending_confirm">
                                                                <Setter Property="Background" Value="{StaticResource BlueSoftBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource BlueTextBrush}" />
                                                                <Setter Property="TextElement.Foreground" Value="{StaticResource BlueTextBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="1" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="待确认" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="paid_pending_confirm">
                                                                <Setter Property="Foreground" Value="{StaticResource BlueTextBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Foreground" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Line 1-2 -->
                                        <Rectangle Grid.Column="1" Height="2" Width="16" Fill="{StaticResource BorderBrushSoft}" VerticalAlignment="Center" Margin="-4,0,-4,12">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="completed"><Setter Property="Fill" Value="{StaticResource HeadingBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Node 2: 待制作 -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Cursor="Hand" Tag="pending_make" MouseLeftButtonDown="StepperNode_MouseLeftButtonDown" ToolTip="点击标记为待制作状态">
                                            <Border Width="24" Height="24" CornerRadius="12" BorderThickness="2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderBrush" Value="#D0D4D9" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make">
                                                                <Setter Property="Background" Value="{StaticResource WarmSoftBrush}" />
