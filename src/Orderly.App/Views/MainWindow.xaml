                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="收件人" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverName}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="联系电话" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.ReceiverPhone}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="20" Height="20" Padding="0"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="phone" ToolTip="复制电话">
                                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                            </Button>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="详细地址" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Top" />
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedStringNarrationOrderDetail.Address.FullAddressText}" Foreground="{StaticResource HeadingBrush}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Style="{StaticResource ToolbarSecondaryButtonStyle}" Width="20" Height="20" Padding="0" VerticalAlignment="Top"
                                                    Command="{Binding CopyStringNarrationOrderFieldCommand}" CommandParameter="address" ToolTip="复制地址">
                                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                            </Button>
                                        </Grid>
                                        
                                        <Border Background="{StaticResource SurfaceSoftBrush}" Height="1" Margin="0,0,0,12" HorizontalAlignment="Stretch" />
                                        
                                        <!-- Logistics details inputs -->
                                        <StackPanel>
                                            <TextBlock Text="发货快递公司与单号" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,8" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0">
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationCarrierInput, Mode=TwoWay}"
                                                             AutomationProperties.AutomationId="Input_FulfillmentCarrier" />
                                                    <TextBlock Text="快递公司 (如 顺丰)" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StringNarrationCarrierInput}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StringNarrationCarrierInput}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                                <Grid Grid.Column="2">
                                                    <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationTrackingNoInput, Mode=TwoWay}"
                                                             AutomationProperties.AutomationId="Input_FulfillmentTrackingNo" />
                                                    <TextBlock Text="快递单号" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StringNarrationTrackingNoInput}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StringNarrationTrackingNoInput}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                            
                                            <Grid Margin="0,0,0,10">
                                                <TextBox Style="{StaticResource FulfillmentInputTextBoxStyle}" Text="{Binding StringNarrationAdminRemarkInput, Mode=TwoWay}"
                                                         AutomationProperties.AutomationId="Input_FulfillmentAdminRemark" />
                                                <TextBlock Text="后台备注 (如 加急制作)" Foreground="{StaticResource CaptionTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StringNarrationAdminRemarkInput}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StringNarrationAdminRemarkInput}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <ComboBox Grid.Column="0" Height="36" Style="{StaticResource FulfillmentInputComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource FulfillmentComboBoxItemStyle}"
                                                          ItemsSource="{Binding StringNarrationFulfillmentStatusOptions}"
                                                          SelectedItem="{Binding StringNarrationFulfillmentStatusInput}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource FulfillmentStatusLabelConverter}}" VerticalAlignment="Center" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                
                                                <Button Grid.Column="2" Content="保存履约信息" Style="{StaticResource DialogPrimaryButtonStyle}" Height="36" Padding="14,0" Command="{Binding UpdateStringNarrationFulfillmentCommand}" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Bottom Action buttons -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Button Content="联系客户" Style="{StaticResource DialogSecondaryButtonStyle}" Height="36" Padding="14,0" Margin="0,0,8,0" />
                                        <Button Content="异常处理" Style="{StaticResource DialogSecondaryButtonStyle}" Height="36" Padding="14,0" Foreground="{StaticResource DangerTextBrush}" Tag="exception" Click="QuickFulfillmentUpdate_Click" />
                                    </StackPanel>
                                    
                                    <Grid Grid.Column="1">
                                        <!-- paid_pending_confirm -> Confirm demand -->
                                        <Button Content="确认需求" Height="36" Padding="16,0" Tag="pending_make" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="paid_pending_confirm">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- pending_make -> Generate Production Order / Mark Making -->
                                        <Button Content="生成工单并制作" Background="#FF8800" Height="36" Padding="16,0" Tag="making" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="pending_make">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- making -> Finish Making (Ready to ship) -->
                                        <Button Content="制作完成" Height="36" Padding="16,0" Tag="ready_to_ship" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="making">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- ready_to_ship -> Confirm Ship (Shipped) -->
                                        <Button Content="确认发货" Background="#1F7A5A" Height="36" Padding="16,0" Tag="shipped" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="ready_to_ship">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- shipped -> Completed -->
                                        <Button Content="完成订单" Height="36" Padding="16,0" Tag="completed" Click="QuickFulfillmentUpdate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedStringNarrationOrderDetail.FulfillmentStatus}" Value="shipped">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <TabControl Grid.Row="1" Style="{StaticResource SettingsTabControlStyle}" 
                        Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=设置}">
                
                <!-- Tab 1: 应用与外观 -->
                <TabItem Header="应用与外观" Style="{StaticResource SettingsTabItemStyle}" Tag="&#xE713;">
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Stretch">
                            <!-- 外观卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="个性化外观" Style="{StaticResource SettingsGroupTitleStyle}" />
                                    
                                    <!-- 主题模式 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="主题模式" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="应用外观主题设定" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding ThemeModeOptions}"
                                                     SelectedItem="{Binding ThemeModeInput}"
                                                     AutomationProperties.AutomationId="List_ThemeMode" />
                                        </Grid>
                                    </Border>

                                    <!-- 字号大小 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="字号预设" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="调整系统界面文本大小" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding FontPresetOptions}"
                                                     SelectedItem="{Binding FontSizePresetInput}"
                                                     AutomationProperties.AutomationId="List_FontSizePreset" />
                                        </Grid>
                                    </Border>

                                    <!-- 强调色行 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="应用强调色" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="选择或自定义符合您品牌的主题强调色" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ListBox Style="{StaticResource SettingsColorSwatchListStyle}"
                                                         ItemContainerStyle="{StaticResource SettingsColorSwatchItemStyle}"
                                                         ItemsSource="{Binding AccentColorOptions}"
                                                         SelectedItem="{Binding AccentColorInput}"
                                                         AutomationProperties.AutomationId="List_AccentColor" />
                                                <Button Style="{StaticResource SettingsRowCustomColorButtonStyle}"
                                                        ToolTip="自定义强调色..."
                                                        Command="{Binding ChooseCustomAccentColorCommand}"
                                                        AutomationProperties.AutomationId="Btn_ChooseCustomColor" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 启动与显示配置卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="启动与显示" Style="{StaticResource SettingsGroupTitleStyle}" />
                                    
                                    <!-- 默认启动页面 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="默认启动页" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="打开应用时默认聚焦的板块" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding StartupSectionOptions}"
                                                     SelectedItem="{Binding StartupDefaultSectionInput}"
                                                     AutomationProperties.AutomationId="List_StartupDefaultSection" />
                                        </Grid>
                                    </Border>

                                    <!-- 默认窗口模式 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="默认窗口模式" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="启动应用时的窗口状态" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding WindowModeOptions}"
                                                     SelectedItem="{Binding DefaultWindowModeInput}"
                                                     AutomationProperties.AutomationId="List_DefaultWindowMode" />
                                        </Grid>
                                    </Border>

                                    <!-- 记住上次停留页 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="记住上次停留页" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="启动时恢复至上次关闭前的导航页面" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding RememberLastSectionInput}"
                                                      AutomationProperties.AutomationId="Chk_RememberLastSection" />
                                        </Grid>
                                    </Border>

                                    <!-- 开机自启 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="随系统开机启动" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在系统登录后自动后台启动工作台" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding StartWithWindowsInput}"
                                                      AutomationProperties.AutomationId="Chk_StartWithWindows" />
                                        </Grid>
                                    </Border>

                                    <!-- 启动后自动显示悬浮窗 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="启动时显示悬浮窗" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="应用开启后自动在桌面右上角显示快捷悬浮工具栏" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding ShowFloatingWindowOnStartupInput}"
                                                      AutomationProperties.AutomationId="Chk_ShowFloatingWindow" />
                                        </Grid>
                                    </Border>

                                    <!-- 启动默认最小化到系统托盘 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="启动最小化至托盘" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="开启后自动隐藏在后台，双击右下角图标打开" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding StartMinimizedToTrayInput}"
                                                      AutomationProperties.AutomationId="Chk_StartMinimizedToTray" />
                                        </Grid>
                                    </Border>

                                    <!-- 记住主窗口位置和大小 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="记住窗口位置" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动记录并恢复上次关闭时的窗口几何大小与位置" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding RememberWindowBoundsInput}"
                                                      AutomationProperties.AutomationId="Chk_RememberWindowBounds" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 保存应用配置按钮 -->
                            <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0" Margin="0,16,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="保存基本配置" Style="{StaticResource SettingsItemTitleStyle}" />
                                        <TextBlock Text="保存当前应用外观及启动策略设置" Style="{StaticResource SettingsItemDescStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="保存并应用" 
                                            Style="{StaticResource ToolbarPrimaryButtonStyle}" Height="36" Padding="16,0" VerticalAlignment="Center"
                                            Command="{Binding SaveP0SettingsCommand}"
                                            AutomationProperties.AutomationId="Btn_SavePreferences" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                </TabItem>

                <!-- Tab 2: 数据与安全 -->
                <TabItem Header="数据与安全" Style="{StaticResource SettingsTabItemStyle}" Tag="&#xE8B5;">
                    <ScrollViewer Style="{StaticResource SettingsScrollViewerStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="10*" MaxWidth="900" MinWidth="450" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Stretch">
                            <!-- 数据备份卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="本地备份策略" Style="{StaticResource SettingsGroupTitleStyle}" />
                                    
                                    <!-- 自动数据备份 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动数据备份" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="开启后系统将按照设定频率自动保存本地备份文件" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AutoBackupEnabledInput}"
                                                      AutomationProperties.AutomationId="Chk_AutoBackupEnabled" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动备份频率 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动备份频率" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="自动备份的执行周期" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding AutoBackupFrequencyOptions}"
                                                     SelectedItem="{Binding AutoBackupFrequencyInput}"
                                                     AutomationProperties.AutomationId="List_AutoBackupFrequency" />
                                        </Grid>
                                    </Border>

                                    <!-- 备份保留最大份数 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="备份保留最大份数" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="超出设定份数后将自动清理最旧的备份" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsRowTextBoxStyle}" Width="80"
                                                     Text="{Binding BackupRetentionCountInput, UpdateSourceTrigger=PropertyChanged}"
                                                     LostFocus="SettingsTextInput_LostFocus"
                                                     AutomationProperties.AutomationId="Txt_BackupRetentionCount" />
                                        </Grid>
                                    </Border>

                                    <!-- 备份存储目录 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
