                    <!-- Card 4: 待发货 -->
                    <Button Grid.Column="6"
                            Command="{Binding ApplyStringNarrationFulfillmentFilterCommand}"
                            CommandParameter="ready_to_ship">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FulfillmentStatsCardButtonStyle}">
