<Window x:Class="Orderly.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orderly 商家工作台"
        Width="1240"
        Height="760"
        MinWidth="1040"
        MinHeight="680"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FBFAF6" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0" Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Orderly" FontSize="26" FontWeight="Bold" Foreground="#17211D" />
                    <TextBlock Text="本地商家工作台" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,20" />

                    <Button x:Name="Tab_Dashboard" AutomationProperties.AutomationId="Tab_Dashboard" Content="工作台" Command="{Binding SelectSectionCommand}" CommandParameter="工作台">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="工作台">
                                        <Setter Property="Background" Value="#EAF2EF" />
                                        <Setter Property="Foreground" Value="#2B7A5C" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Fulfillment" AutomationProperties.AutomationId="Tab_Fulfillment" Content="订单履约" Command="{Binding SelectSectionCommand}" CommandParameter="订单履约">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="订单履约">
                                        <Setter Property="Background" Value="#EAF2EF" />
                                        <Setter Property="Foreground" Value="#2B7A5C" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_ExceptionOrders" AutomationProperties.AutomationId="Tab_ExceptionOrders" Content="异常处理" Command="{Binding SelectSectionCommand}" CommandParameter="异常处理">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="异常处理">
                                        <Setter Property="Background" Value="#EAF2EF" />
                                        <Setter Property="Foreground" Value="#2B7A5C" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="Tab_Settings" AutomationProperties.AutomationId="Tab_Settings" Content="设置" Command="{Binding SelectSectionCommand}" CommandParameter="设置">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="设置">
                                        <Setter Property="Background" Value="#EAF2EF" />
                                        <Setter Property="Foreground" Value="#2B7A5C" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="全局快捷键" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Preferences.MainHotkey, StringFormat=主窗口：{0}}" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                    <TextBlock Text="{Binding Preferences.FloatingHotkey, StringFormat=悬浮窗：{0}}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,18">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding SelectedSection}" FontSize="29" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" />
                    <TextBlock Text="客户、订单、跟进和快捷回复集中处理" Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="AddCustomerButton" Content="+ 新增客户" Style="{StaticResource ToolbarPrimaryButtonStyle}" Command="{Binding AddCustomerCommand}" AutomationProperties.AutomationId="Btn_AddCustomer" />
                    <Button x:Name="AddOrderButton" Content="+ 创建订单" Style="{StaticResource ToolbarPrimaryButtonStyle}" Command="{Binding AddOrderCommand}" AutomationProperties.AutomationId="Btn_AddOrder" />
                    <Border Style="{StaticResource SummaryMetricCardStyle}" Margin="10,0,0,0" MinWidth="108">
                        <StackPanel>
                            <TextBlock Text="待处理" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding PendingCount}" Style="{StaticResource MetricValueTextStyle}" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryMetricCardStyle}" Margin="10,0,0,0" MinWidth="108">
                        <StackPanel>
                            <TextBlock Text="已成交" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding WonCount}" Style="{StaticResource MetricValueTextStyle}" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryMetricCardStyle}" Margin="10,0,0,0" MinWidth="148">
                        <StackPanel>
                            <TextBlock Text="订单金额" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding TotalAmount, StringFormat=¥{0:N0}}" Style="{StaticResource MetricValueTextStyle}" Margin="0,3,0,0" Foreground="{StaticResource WarmTextBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=工作台}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="330" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="今日行动" Style="{StaticResource SectionHeaderTextStyle}" />
                                    <TextBlock Text="只读推导当前待处理项" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="刷新" Style="{StaticResource ToolbarSecondaryButtonStyle}" Padding="10,4" Margin="0,0,8,0" Command="{Binding RefreshWorkbenchTasksCommand}" />
                                    <Border Style="{StaticResource CountBadgeBorderStyle}">
                                        <TextBlock Text="{Binding WorkbenchTasks.Count, StringFormat={}{0} 项}" Style="{StaticResource CaptionTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </DockPanel>

                            <TextBlock Text="当前没有待处理工作台任务。">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasWorkbenchTasks}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ListBox x:Name="WorkbenchTasksList"
                                     AutomationProperties.AutomationId="WorkbenchTasksList"
                                     ItemsSource="{Binding WorkbenchTasks}"
                                     SelectedItem="{Binding SelectedWorkbenchTask}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MaxHeight="280"
                                     ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasWorkbenchTasks}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="WorkbenchTaskCard" Padding="12" Margin="0,0,0,10" Background="{StaticResource SurfaceSoftBrush}" BorderBrush="#ECE5D9" BorderThickness="1" CornerRadius="8">
                                            <StackPanel>
                                                <DockPanel>
                                                    <WrapPanel>
                                                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="9" Padding="8,2" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding TypeText}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                                        </Border>
                                                        <Border Background="{StaticResource WarmSoftBrush}" CornerRadius="9" Padding="8,2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasPipelineStage}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding PipelineStageText}" Foreground="{StaticResource WarmTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                                        </Border>
                                                    </WrapPanel>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding OccurredAtText}" Foreground="{StaticResource SecondaryTextBrush}" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                                <TextBlock Text="{Binding Summary}" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                <TextBlock Text="{Binding RelatedContextText}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding PriorityText}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter TargetName="WorkbenchTaskCard" Property="Background" Value="#EEF4F0" />
                                                <Setter TargetName="WorkbenchTaskCard" Property="BorderBrush" Value="#D5E4DA" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="客户/订单列表" Style="{StaticResource SectionHeaderTextStyle}" />
                                <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                    <TextBlock Text="{Binding Orders.Count, StringFormat={}{0} 条}" Style="{StaticResource CaptionTextStyle}" />
                                </Border>
                            </DockPanel>
                            <ListBox ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrderItem}" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="OrderListItemCard" Padding="12" Margin="0,0,0,10" Background="{StaticResource SurfaceSoftBrush}" BorderBrush="#ECE5D9" BorderThickness="1" CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding CustomerName}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                                                <DockPanel Margin="0,8,0,0">
                                                    <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="9" Padding="8,2">
                                                        <TextBlock Text="{Binding StatusLabel}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                                    </Border>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding AmountText}" HorizontalAlignment="Right" Foreground="{StaticResource WarmTextBrush}" FontWeight="SemiBold" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding FollowUpText}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter TargetName="OrderListItemCard" Property="Background" Value="#EEF4F0" />
                                                <Setter TargetName="OrderListItemCard" Property="BorderBrush" Value="#D5E4DA" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="1" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="280" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="当前处理对象" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedCustomerNameText}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedOrderHeadline}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />
                                <WrapPanel Margin="0,12,0,0">
                                    <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding SelectedOrderStatusText}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                    </Border>
                                    <Border Background="{StaticResource WarmSoftBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding CurrentDealStage, StringFormat=阶段 {0}}" Foreground="{StaticResource WarmTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                    </Border>
                                    <Border Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="10,4" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding SelectedSourcePlatformText}" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" FontSize="11" />
                                    </Border>
                                </WrapPanel>
                                <TextBlock Text="{Binding SelectedOrderRequirementSummary}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" LineHeight="20" Margin="0,12,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="24,0,0,0">
                                <UniformGrid Columns="2" Margin="0,0,0,12">
                                    <Border Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="订单状态" Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Text="{Binding SelectedOrderStatusText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource SummaryMetricCardStyle}" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="订单金额" Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Text="{Binding SelectedOrderAmountText}" Foreground="{StaticResource WarmTextBrush}" FontSize="20" FontWeight="Bold" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                                <Border Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="下次跟进" Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Text="{Binding SelectedNextFollowUpText}" Foreground="{StaticResource HeadingBrush}" FontWeight="SemiBold" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatusPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding StatusMessageTitle}" Style="{StaticResource StatusMessageTitleTextStyle}" />
                                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,5,0,0" Foreground="{StaticResource HeadingBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="主操作" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                <TextBlock Text="围绕当前客户和订单快速推进" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="新增备注" Style="{StaticResource ToolbarPrimaryButtonStyle}" Command="{Binding DataContext.AddNoteCommand, RelativeSource={RelativeSource AncestorType=Window}}" AutomationProperties.AutomationId="Btn_AddNote" />
                                    <Button Content="新增跟进" Style="{StaticResource ToolbarPrimaryButtonStyle}" Command="{Binding DataContext.AddFollowUpCommand, RelativeSource={RelativeSource AncestorType=Window}}" AutomationProperties.AutomationId="Btn_AddFollowUp" />
                                    <Button Content="新增改价" Style="{StaticResource ToolbarPrimaryButtonStyle}" Command="{Binding DataContext.AddPriceAdjustmentCommand, RelativeSource={RelativeSource AncestorType=Window}}" AutomationProperties.AutomationId="Btn_AddPriceAdjustment" />
                                    <Button Content="推进阶段" Style="{StaticResource ToolbarPrimaryButtonStyle}" Command="{Binding DataContext.ChangeDealStageCommand, RelativeSource={RelativeSource AncestorType=Window}}" AutomationProperties.AutomationId="Btn_ChangeDealStage" />
                                </WrapPanel>
                                <!-- 状态切换区：显示当前状态 + ComboBox 选择 + 操作按钮 -->
                                <Border Background="#F8F6F0" CornerRadius="8" Padding="10,8" Margin="0,4,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- 客户状态 -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="客户状态" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                                            <WrapPanel>
                                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="6" Padding="8,3" Margin="0,0,6,6">
                                                    <TextBlock Text="{Binding CustomerStatusLabel, StringFormat=当前：{0}}" Foreground="{StaticResource AccentTextBrush}" FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                            </WrapPanel>
                                            <DockPanel Margin="0,4,0,0">
                                                <ComboBox x:Name="Input_CustomerStatus"
                                                          AutomationProperties.AutomationId="Input_CustomerStatus"
                                                          Width="120"
                                                          Margin="0,0,6,0"
                                                          ItemsSource="{Binding CustomerStatusOptions}"
                                                          SelectedItem="{Binding SelectedCustomerStatusInput}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource EnumLabelConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <Button x:Name="Btn_ChangeCustomerStatus"
                                                        AutomationProperties.AutomationId="Btn_ChangeCustomerStatus"
                                                        Content="更新" Style="{StaticResource ToolbarSecondaryButtonStyle}" Padding="10,4" Margin="0"
                                                        Command="{Binding ChangeCustomerStatusCommand}" />
                                            </DockPanel>
                                        </StackPanel>
                                        <!-- 订单状态 -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="订单状态" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                                            <WrapPanel>
                                                <Border Background="{StaticResource WarmSoftBrush}" CornerRadius="6" Padding="8,3" Margin="0,0,6,6">
                                                    <TextBlock Text="{Binding SelectedOrderStatusText, StringFormat=当前：{0}}" Foreground="{StaticResource WarmTextBrush}" FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                            </WrapPanel>
                                            <DockPanel Margin="0,4,0,0">
                                                <ComboBox x:Name="Input_OrderStatus"
                                                          AutomationProperties.AutomationId="Input_OrderStatus"
                                                          Width="140"
                                                          Margin="0,0,6,0"
                                                          ItemsSource="{Binding OrderStatusOptions}"
                                                          SelectedItem="{Binding SelectedOrderStatusInput}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource EnumLabelConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <Button x:Name="Btn_ChangeOrderStatus"
                                                        AutomationProperties.AutomationId="Btn_ChangeOrderStatus"
                                                        Content="更新" Style="{StaticResource ToolbarSecondaryButtonStyle}" Padding="10,4" Margin="0"
                                                        Command="{Binding ChangeOrderStatusCommand}" />
                                            </DockPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="辅助操作" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                <TextBlock Text="重新加载本地数据" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="刷新" Style="{StaticResource ToolbarSecondaryButtonStyle}" Command="{Binding DataContext.RefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="订单详情" Style="{StaticResource SectionHeaderTextStyle}" />
                                <TextBlock Text="当前订单的需求、阶段和辅助信息" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding OrderDetailsEmptyMessage}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSelectedOrder}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Margin="0,14,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSelectedOrder}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <WrapPanel Margin="0,0,0,18">
                                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="14" Padding="10,4" Margin="0,0,8,8">
                                            <TextBlock Text="{Binding SelectedOrderStatusText}" Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Background="{StaticResource WarmSoftBrush}" CornerRadius="14" Padding="10,4" Margin="0,0,8,8">
                                            <TextBlock Text="{Binding CurrentDealStage, StringFormat=阶段：{0}}" Foreground="{StaticResource WarmTextBrush}" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Background="{StaticResource SurfaceSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="0,0,8,8">
                                            <TextBlock Text="{Binding SelectedSourcePlatformText}" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" />
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock Text="需求记录" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" />
                                    <TextBlock Text="{Binding SelectedOrderRequirementText}" TextWrapping="Wrap" LineHeight="22" Margin="0,8,0,18" Foreground="{StaticResource HeadingBrush}" />

                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}" Margin="0,0,8,0">
