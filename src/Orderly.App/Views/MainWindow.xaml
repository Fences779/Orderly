                                            <Border DockPanel.Dock="Right" Style="{StaticResource CountBadgeBorderStyle}">
                                                <TextBlock Text="{Binding AiSuggestionsCount, StringFormat={}{0} 条}" Style="{StaticResource CaptionTextStyle}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Text="默认使用 Local Stub；已预留 DeepSeek / OpenAI-compatible Provider；复制草稿只写入系统剪贴板，本软件不会自动发送，请手动粘贴到微信/闲鱼等平台。"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20" />
                                        <Border Background="#F8F6F0" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedConversationContextText}" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                                                <Button x:Name="Btn_GenerateAiSuggestion"
                                                        AutomationProperties.AutomationId="Btn_GenerateAiSuggestion"
