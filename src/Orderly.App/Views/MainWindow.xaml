                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockPhoneInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockPhone" />
                                        </Grid>
                                    </Border>

                                    <!-- 屏蔽完整收货地址 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动遮蔽收货地址" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="向 AI 上下文推送数据时自动隐藏具体物理门牌号" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockFullAddressInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockFullAddress" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动屏蔽交易单号 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动遮蔽支付交易单号" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="在 AI 通信报文中自动遮蔽第三方平台的流水与交易ID" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiBlockPaymentTransactionIdInput}"
                                                      AutomationProperties.AutomationId="Chk_AiBlockPaymentTransactionId" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI 回复偏好卡片 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="AI 回复偏好配置" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <!-- 语气设定 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 回复语气控制" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="设定 AI 推荐话术的感情色彩倾向" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding AiReplyToneOptions}"
                                                     SelectedItem="{Binding AiReplyToneInput}"
                                                     AutomationProperties.AutomationId="List_AiReplyTone" />
                                        </Grid>
                                    </Border>

                                    <!-- 长度控制 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 回复字数长度" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="精简回复或提供详实的客服分析模板" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <ListBox Grid.Column="1" Style="{StaticResource SettingsSegmentedControlStyle}"
                                                     ItemContainerStyle="{StaticResource SettingsSegmentedItemStyle}"
                                                     ItemsSource="{Binding AiReplyLengthOptions}"
                                                     SelectedItem="{Binding AiReplyLengthInput}"
                                                     AutomationProperties.AutomationId="List_AiReplyLength" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动生成订单摘要 -->
                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动填充生成订单摘要" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="允许 AI 助手对长对话生成一键订单概要填充" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" Style="{StaticResource SettingsRowCheckBoxStyle}"
                                                      IsChecked="{Binding AiAutoGenerateOrderSummaryInput}"
                                                      AutomationProperties.AutomationId="Chk_AiAutoGenerateOrderSummary" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI 环境诊断 -->
                            <Border Style="{StaticResource SettingsGroupCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="AI Provider 环境状态" Style="{StaticResource SettingsGroupTitleStyle}" />

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="核心运行框架" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding AiRuntimeProviderText}" Style="{StaticResource SettingsStatusTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="服务链接状态" Style="{StaticResource SettingsItemTitleStyle}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding AiConnectionCheckStatusText}" Style="{StaticResource SettingsStatusTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsRowItemBorder}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="AI 接入服务自检" Style="{StaticResource SettingsItemTitleStyle}" />
                                                <TextBlock Text="{Binding AiModelPreferenceStatusText}" Style="{StaticResource SettingsItemDescStyle}" />
                                            </StackPanel>
