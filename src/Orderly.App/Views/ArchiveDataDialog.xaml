<Window x:Class="Orderly.App.Views.ArchiveDataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Sections="clr-namespace:Orderly.App.Views.Sections"
        Title="归档数据"
        Width="950"
        Height="650"
        MinWidth="800"
        MinHeight="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PageBackgroundBrush}"
        AutomationProperties.AutomationId="ArchiveDataDialog">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="归档数据"
                   FontSize="{DynamicResource UiFontSize24}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource HeadingBrush}"
                   Margin="0,0,0,16" />

        <Sections:ArchiveView Grid.Row="1" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="关闭"
                    Width="100"
                    Height="34"
                    Style="{StaticResource UiSecondaryButtonStyle}"
                    IsCancel="True"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
