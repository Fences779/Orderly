<Window x:Class="Orderly.App.Views.SnoozeFollowUpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="延期跟进"
        Width="440"
        Height="220"
        MinWidth="400"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource PageBackgroundBrush}"
        AutomationProperties.AutomationId="SnoozeFollowUpDialog">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/AppContentScrollResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题区 -->
        <Border Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="22,18,22,16">
            <StackPanel>
                <TextBlock Text="延期跟进" Style="{StaticResource DialogSectionTitleStyle}" Margin="0" />
                <TextBlock Text="重新安排这次跟进的时间" Foreground="{StaticResource MutedBrush}" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <Grid Grid.Row="1" Margin="22,18,22,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource DialogFieldLabelStyle}">
                <Run Text="新的跟进时间" />
                <Run Text="（格式：2026-04-28 14:30）" Foreground="{StaticResource MutedBrush}" FontWeight="Normal" />
            </TextBlock>
            <TextBox x:Name="ScheduledAtTextBox"
                     Grid.Row="1"
                     AutomationProperties.AutomationId="SnoozeFollowUpDialog_ScheduledAt" />
        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2"
                Background="#FFFDF8"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Style="{StaticResource DialogSecondaryButtonStyle}"
                        IsCancel="True"
                        Margin="0,0,10,0"
                        AutomationProperties.AutomationId="SnoozeFollowUpDialog_Cancel" />
                <Button Content="确认延期"
                        Style="{StaticResource DialogPrimaryButtonStyle}"
                        IsDefault="True"
                        Click="ConfirmButton_Click"
                        AutomationProperties.AutomationId="SnoozeFollowUpDialog_Confirm" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
