<UserControl x:Class="Orderly.App.Views.LoginSignInPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Opacity="1"
             FocusManager.FocusedElement="{Binding ElementName=TxtSignInUsername}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.B.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.C.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform X="0" />
        </Grid.RenderTransform>
        <Grid Margin="0,26,0,30">
            <StackPanel Width="320" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18"
                            Visibility="{Binding IsCloudLoginAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="本地登录"
                            Style="{StaticResource LinkButtonStyle}"
                            Click="BtnSwitchToLocal_Click" />
                    <TextBlock Text=" / " VerticalAlignment="Center" Foreground="#C7C7CC" Margin="6,0" />
                    <Button Content="云登录"
                            Style="{StaticResource LinkButtonStyle}"
                            Click="BtnSwitchToCloud_Click" />
                </StackPanel>

                <StackPanel x:Name="LocalSignInSection"
                            Visibility="{Binding IsLocalLoginMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel x:Name="SignInAccountBlock" Margin="0,0,0,22">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="SignInAccountBlockTranslateTransform" Y="0" />
                    </StackPanel.RenderTransform>
                    <TextBlock Text="账号"
                               Style="{StaticResource FieldLabel}"
                               FontWeight="Bold"
                               Foreground="#1D1D1F"
                               Margin="0,0,0,8" />
                    <Grid x:Name="SignInAccountSection"
                          Width="320"
                          HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="TxtSignInUsername"
                                 Grid.Row="0"
                                 HorizontalAlignment="Stretch"
                                 PreviewMouseLeftButtonDown="TxtSignInUsername_PreviewMouseLeftButtonDown"
                                 GotKeyboardFocus="TxtSignInUsername_GotKeyboardFocus"
                                 KeyDown="TxtSignInUsername_KeyDown"
                                 TextChanged="TxtSignInUsername_TextChanged"
                                 LostKeyboardFocus="TxtSignInUsername_LostKeyboardFocus" />
                        <Border x:Name="RecentAccountsDropdown"
                                Grid.Row="1"
                                Margin="0,10,0,0"
                                Padding="6"
                                Background="#FFFFFF"
                                BorderBrush="#DCE1E9"
                                BorderThickness="1"
                                CornerRadius="16"
                                SnapsToDevicePixels="True"
                                Visibility="Collapsed"
                                Opacity="0"
                                MaxHeight="0"
                                RenderTransformOrigin="0.5,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="RecentAccountsDropdownScaleTransform" ScaleY="0.96" />
                                    <TranslateTransform x:Name="RecentAccountsDropdownTranslateTransform" Y="-8" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  ShadowDepth="4"
                                                  Direction="270"
                                                  Color="#111216"
                                                  Opacity="0.04" />
                            </Border.Effect>
                            <ListBox x:Name="LstRecentSignInAccounts"
                                     ItemsSource="{Binding FilteredSignInAccounts}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     MaxHeight="168"
                                     SelectionChanged="LstRecentSignInAccounts_SelectionChanged"
                                     ItemContainerStyle="{StaticResource RecentSignInAccountItemContainerStyle}"
                                     ItemTemplate="{StaticResource RecentSignInAccountItemTemplate}" />
                        </Border>
                    </Grid>
                    <TextBlock x:Name="TxtSignInAccountHint"
                               Margin="2,8,0,0"
                               Foreground="#D14B4B"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                </StackPanel>

                <Grid x:Name="SignInCredentialSection"
                      Width="320"
                      HorizontalAlignment="Left"
                      MaxHeight="0"
                      Opacity="0"
                      ClipToBounds="True"
                      IsHitTestVisible="False">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsQuickLoginMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" FontWeight="Bold" Foreground="#1D1D1F" />
                            <PasswordBox x:Name="TxtSignInPassword" Width="320" HorizontalAlignment="Left" KeyDown="TxtSignInPassword_KeyDown" />
                            <CheckBox Margin="0,12,0,0"
                                      Content="开机后允许快速登录（PIN / Windows Hello）"
                                      IsChecked="{Binding EnableQuickLoginThisBoot}"
                                      Visibility="{Binding ShouldShowQuickLoginOptIn, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      AutomationProperties.AutomationId="Chk_EnableQuickLoginThisBoot" />

                            <Button Content="进入系统"
                                    Width="320"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource PremiumButtonStyle}"
                                    Margin="0,14,0,0"
                                    Click="BtnSignIn_Click" />
                            <Button Content="使用 PIN / Windows Hello"
                                    Style="{StaticResource LinkButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0"
                                    Visibility="{Binding QuickLoginAvailableThisBoot, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Click="BtnUseQuickLogin_Click" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsWindowsHelloQuickLoginMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="使用 Windows Hello 登录"
                                    Width="320"
                                    Style="{StaticResource PremiumButtonStyle}"
                                    Margin="0,8,0,0"
                                    Click="BtnWindowsHello_Click" />
                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="使用 PIN"
                                        Height="38"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="BtnUsePinQuickLogin_Click" />
                                <Button Grid.Column="2"
                                        Content="使用主密码"
                                        Height="38"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="BtnUsePassword_Click" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsPinQuickLoginMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="PIN 快速登录" Style="{StaticResource FieldLabel}" FontWeight="Bold" Foreground="#1D1D1F" />
                            <PasswordBox x:Name="TxtQuickLoginPin" Width="320" MaxLength="6" KeyDown="TxtQuickLoginPin_KeyDown" />
                            <Button Content="使用 PIN 登录"
                                    Width="320"
                                    Style="{StaticResource PremiumButtonStyle}"
                                    Margin="0,14,0,0"
                                    Click="BtnQuickLoginPin_Click" />
                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="改用 Hello"
                                        Height="38"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="{Binding IsWindowsHelloAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="BtnUseWindowsHelloQuickLogin_Click" />
                                <Button Grid.Column="2"
                                        Content="改用主密码"
                                        Height="38"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="BtnUsePassword_Click" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Width="320" Margin="0,22,0,0" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnOpenPasswordRecovery"
                            Grid.Column="0"
                            Content="忘记密码"
                            Style="{StaticResource LinkButtonStyle}"
                            Click="BtnOpenPasswordRecovery_Click" />
                    <Button x:Name="BtnOpenAccountManagement"
                            Grid.Column="2"
                            Content="账户管理"
                            Style="{StaticResource LinkButtonStyle}"
                            HorizontalAlignment="Right"
                            Click="BtnOpenAccountManagement_Click" />
                </Grid>
                </StackPanel>

                <StackPanel x:Name="CloudSignInSection"
                            Visibility="{Binding IsCloudLoginSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Width="320">
                    <TextBlock Text="云服务器地址" Style="{StaticResource FieldLabel}" FontWeight="Bold" Foreground="#1D1D1F" />
                    <TextBox Text="{Binding CloudBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                    <TextBlock Text="云账号" Style="{StaticResource FieldLabel}" FontWeight="Bold" Foreground="#1D1D1F" />
                    <TextBox Text="{Binding CloudUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                    <TextBlock Text="密码" Style="{StaticResource FieldLabel}" FontWeight="Bold" Foreground="#1D1D1F" />
                    <PasswordBox x:Name="TxtCloudPassword" Margin="0,0,0,14" KeyDown="TxtCloudPassword_KeyDown" />

                    <TextBlock Text="{Binding CloudLoginErrorMessage}"
                               Foreground="#FF3B30"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Visibility="{Binding HasCloudLoginErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Button Content="进入系统"
                            Width="320"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PremiumButtonStyle}"
                            Margin="0,4,0,0"
                            Click="BtnCloudSignIn_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
