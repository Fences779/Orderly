<Window x:Class="Orderly.App.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="420"
        SizeToContent="Height"
        MinHeight="170">
    <Window.Resources>
        <!-- 自定义提示框主按钮样式，契合系统主色调 -->
        <Style x:Key="MessageDialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryDisabledBrush}" />
                                <Setter Property="Foreground" Value="#8F959E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 退出动画：淡出并向下偏移 + 缩小 -->
        <Storyboard x:Key="CloseStoryboard">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="WindowScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="0.96" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WindowScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="0.96" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WindowTranslate"
                             Storyboard.TargetProperty="Y"
                             To="8" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- 弹窗载入触发器：淡入并向上平移 + 放大 -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.2" />
                    <DoubleAnimation Storyboard.TargetName="WindowScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.96" To="1" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="WindowScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.96" To="1" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="WindowTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="8" To="0" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    
    <Border x:Name="MainBorder"
            Background="{DynamicResource SurfaceRaisedBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="10"
            Opacity="0"
            MouseLeftButtonDown="Border_MouseLeftButtonDown"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WindowScale" ScaleX="0.96" ScaleY="0.96" />
                <TranslateTransform x:Name="WindowTranslate" Y="8" />
            </TransformGroup>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Color="#121214" Opacity="0.15" />
        </Border.Effect>
        <Grid>
            <!-- 右上角关闭按钮 -->
            <Button x:Name="CloseButton"
                    Content="&#xE10A;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="10"
                    Width="28"
                    Height="28"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,8,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource CaptionTextBrush}"
                    Click="CloseButton_Click"
                    Cursor="Hand"
                    Panel.ZIndex="10">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F2F2F5" />
                                <Setter Property="Foreground" Value="{DynamicResource HeadingBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E2E2E5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Grid Margin="20,24,20,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 上部：图标 + 文字内容 -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 图标展示区 -->
                    <Border x:Name="IconBorder"
                            Grid.Column="0"
                            Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="{DynamicResource AccentSoftBrush}"
                            BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1"
                            Margin="0,0,16,0"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="IconText"
                                   Text="&#xE73E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- 文字展示区 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,2,0,0">
                        <TextBlock x:Name="TitleText"
                                   Text="提示"
                                   Style="{StaticResource DialogSectionTitleStyle}"
                                   Margin="0,0,16,8"
                                   FontSize="16" />
                        <TextBlock x:Name="MessageText"
                                   Text="操作成功！"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource HeadingBrush}"
                                   FontSize="{DynamicResource UiFontSize14}"
                                   FontWeight="Medium"
                                   LineHeight="20" />
                    </StackPanel>
                </Grid>

                <!-- 底部操作按钮 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                    <Button x:Name="ConfirmButton"
                            Content="确定"
                            Style="{StaticResource MessageDialogButtonStyle}"
                            Width="84"
                            IsDefault="True"
                            Click="ConfirmButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
