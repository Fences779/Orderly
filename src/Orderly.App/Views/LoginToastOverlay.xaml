<UserControl x:Class="Orderly.App.Views.LoginToastOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <Grid>
        <Border x:Name="ErrorToastOverlay"
                Visibility="Collapsed"
                Opacity="0"
                Padding="22,16"
                Background="#FFF6F5"
                BorderBrush="#F4C7C3"
                BorderThickness="1"
                CornerRadius="18"
                MaxWidth="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,126,0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ErrorToastTranslateTransform" Y="10" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="8"
                                  Direction="270"
                                  Color="#101114"
                                  Opacity="0.12" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="28"
                        Height="28"
                        Background="#FDE8E6"
                        CornerRadius="14"
                        Grid.Column="0"
                        VerticalAlignment="Top">
                    <Grid>
                        <Path Data="M8,8 L20,20 M20,8 L8,20"
                              Width="12"
                              Height="12"
                              Stretch="Fill"
                              Stroke="#D92D20"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,0,0,0" />
                    </Grid>
                </Border>
                <TextBlock x:Name="TxtErrorToast"
                           Grid.Column="2"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#B42318"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="520" />
            </Grid>
        </Border>

        <Border x:Name="SuccessToastOverlay"
                Visibility="Collapsed"
                Opacity="0"
                Padding="22,16"
                Background="#FDFDFE"
                BorderBrush="#E2E6ED"
                BorderThickness="1"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,126,0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SuccessToastTranslateTransform" Y="10" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="8"
                                  Direction="270"
                                  Color="#101114"
                                  Opacity="0.12" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="28"
                        Height="28"
                        Background="#E8F7EE"
                        CornerRadius="14"
                        Margin="0,0,12,0">
                    <Grid>
                        <Path Data="M7,14 L12,19 L21,9"
                              Width="14"
                              Height="10"
                              Stretch="Fill"
                              Stroke="#18864B"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,-1,0,0" />
                    </Grid>
                </Border>
                <TextBlock x:Name="TxtSuccessToast"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#1D1D1F"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
