<UserControl x:Class="Orderly.App.Views.LoginAccountManagementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Opacity="0">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.B.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.C.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform X="0" />
        </Grid.RenderTransform>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Center"
                      Margin="0,0,0,0">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  MaxWidth="612">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="账户管理"
                               FontWeight="Bold"
                               FontSize="24"
                               Foreground="#1D1D1F"
                               VerticalAlignment="Center" />
                    <Button x:Name="BtnBackFromAccountManagement"
                            Grid.Column="1"
                            Style="{StaticResource BackIconButtonStyle}"
                            Click="BtnBackFromAccountManagement_Click" />
                </Grid>

                <Border Grid.Row="1"
                        Background="#F5F5F7"
                        CornerRadius="18"
                        Padding="18">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1D1D1F">
                            <Run Text="已有账户" />
                            <Run Text=" " />
                            <Run Text="{Binding AccountDirectory.Count, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock Text="{Binding AccountManagementStatus}"
                                   Margin="0,8,0,0"
                                   Foreground="#86868B"
                                   FontSize="12"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAccountManagementStatus}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox x:Name="LstAccountDirectory"
                                 ItemsSource="{Binding AccountDirectory}"
                                 Margin="0,12,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MaxHeight="220"
                                 ItemContainerStyle="{StaticResource AccountDirectoryItemContainerStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="AccountCard"
                                            Background="#FFFFFF"
                                            BorderBrush="#E5E5EA"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1D1D1F" />
                                                <TextBlock Text="{Binding Username, Mode=OneWay, StringFormat=@{0}}"
                                                           Margin="0,6,0,0"
                                                           Foreground="#6E6E73"
                                                           FontSize="12" />
                                            </StackPanel>
                                            <Grid Grid.Column="1"
                                                  Margin="12,0,0,0">
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top">
                                                    <Border Padding="8,2"
                                                            Background="#E7F1FF"
                                                            CornerRadius="10"
                                                            Margin="0,0,8,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMostRecentlyLoggedIn, Mode=OneWay}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="最近登录"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#175CD3" />
                                                    </Border>
                                                    <Border Padding="8,2"
                                                            Background="#F1F2F6"
                                                            CornerRadius="10"
                                                            Margin="0,0,8,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Role, Mode=OneWay}" Value="Owner">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#4A4A52">
                                                            <Run Text="主账号" />
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Padding="8,2"
                                                            Background="#FCE8E8"
                                                            CornerRadius="10">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEnabled, Mode=OneWay}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="已禁用"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#B42318" />
                                                    </Border>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="删除账户"
                                                        Tag="{Binding AccountId}"
                                                        Width="84"
                                                        Height="30"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Background="#FCE8E8"
                                                        Foreground="#B42318"
                                                        BorderBrush="#F6C7C7"
                                                        Click="BtnRequestDeleteAccount_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role, Mode=OneWay}" Value="Owner">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                            <Setter TargetName="AccountCard" Property="BorderBrush" Value="#E5E5EA" />
                                            <Setter TargetName="AccountCard" Property="Background" Value="#FFFFFF" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </StackPanel>
                </Border>

                <Button x:Name="BtnCreateManagedAccount"
                        Grid.Row="2"
                        Content="创建新账号"
                        Style="{StaticResource PremiumButtonStyle}"
                        Height="52"
                        Width="208"
                        HorizontalAlignment="Center"
                        Margin="0,28,0,0"
                        Click="BtnCreateManagedAccount_Click" />

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
