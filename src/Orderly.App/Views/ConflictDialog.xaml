<Window x:Class="Orderly.App.Views.ConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据冲突"
        Width="480"
        Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        AutomationProperties.AutomationId="ConflictDialog">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="数据已被他人修改"
                   FontSize="{DynamicResource UiFontTitle}"
                   FontFamily="{StaticResource UiFontFamilyCjk}"
                   FontWeight="{StaticResource UiFontWeightBold}"
                   Foreground="{DynamicResource HeadingBrush}"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="1"
                   x:Name="DetailText"
                   TextWrapping="Wrap"
                   FontSize="{DynamicResource UiFontBody}"
                   FontFamily="{StaticResource UiFontFamilyCjk}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Margin="0,0,0,16" />

        <TextBlock Grid.Row="2"
                   x:Name="HintText"
                   Text="你的修改没有覆盖对方内容。请刷新后重新确认。"
                   TextWrapping="Wrap"
                   FontSize="{DynamicResource UiFontCaption}"
                   FontFamily="{StaticResource UiFontFamilyCjk}"
                   Foreground="{DynamicResource SecondaryTextBrush}" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="查看最新数据"
                    AutomationProperties.AutomationId="ConflictDialog_ViewLatest"
                    Style="{StaticResource UiSecondaryButtonStyle}"
                    Margin="0,0,12,0"
                    Click="ViewLatestButton_Click" />
            <Button Content="取消"
                    AutomationProperties.AutomationId="ConflictDialog_Cancel"
                    Style="{StaticResource UiSecondaryButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click" />
            <Button Content="刷新"
                    AutomationProperties.AutomationId="ConflictDialog_Refresh"
                    Style="{StaticResource UiPrimaryButtonStyle}"
                    IsDefault="True"
                    Click="RefreshButton_Click" />
        </StackPanel>
    </Grid>
</Window>
