<UserControl x:Class="Orderly.App.Views.LoginBrandPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="SilkWavePrimaryTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="-14"
                                     To="18"
                                     Duration="0:0:12" />
                    <DoubleAnimation Storyboard.TargetName="SilkWavePrimaryTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="-8"
                                     To="10"
                                     Duration="0:0:14" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="SilkWaveSecondaryTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="12"
                                     To="-18"
                                     Duration="0:0:10" />
                    <DoubleAnimation Storyboard.TargetName="SilkWaveSecondaryTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="6"
                                     To="-12"
                                     Duration="0:0:13" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <!-- 左侧品牌展示�?(深邃的高级感) -->
    <Border x:Name="BrandSurface"
            Background="#F7F7F9"
            BorderBrush="#ECEEF3"
            BorderThickness="0,0,1,0"
            CornerRadius="24,0,0,24"
            ClipToBounds="True">
        <Grid>
            <Canvas IsHitTestVisible="False" ClipToBounds="True">
                <Ellipse Width="320"
                         Height="520"
                         Canvas.Left="-112"
                         Canvas.Top="-126"
                         Opacity="0.42">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.42,0.35" Center="0.5,0.5" RadiusX="0.72" RadiusY="0.72">
                            <GradientStop Color="#FFFFFFFF" Offset="0" />
                            <GradientStop Color="#F7F8FB" Offset="0.46" />
                            <GradientStop Color="#00F7F8FB" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="SilkWavePrimaryTranslate" X="0" Y="0" />
                            <RotateTransform Angle="-16" CenterX="160" CenterY="260" />
                        </TransformGroup>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="286"
                         Height="432"
                         Canvas.Left="74"
                         Canvas.Top="134"
                         Opacity="0.26">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.58,0.48" Center="0.5,0.5" RadiusX="0.76" RadiusY="0.76">
                            <GradientStop Color="#FFFFFFFF" Offset="0" />
                            <GradientStop Color="#F0F2F7" Offset="0.52" />
                            <GradientStop Color="#00F0F2F7" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="SilkWaveSecondaryTranslate" X="0" Y="0" />
                            <RotateTransform Angle="18" CenterX="143" CenterY="216" />
                        </TransformGroup>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="88" Height="88" Background="#FFFFFF" CornerRadius="26" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="8" Direction="270" Color="#121317" Opacity="0.12" />
                    </Border.Effect>
                    <Image Source="{StaticResource OrderlyBrandLogoImage}"
                           Width="58"
                           Height="58"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Orderly" FontSize="29" FontWeight="Bold" Foreground="#1D1D1F" HorizontalAlignment="Center" />
                <TextBlock Text="String Narration" FontSize="11" Foreground="#7D8390" HorizontalAlignment="Center" Margin="0,10,0,0" Opacity="0.82" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
