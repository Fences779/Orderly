<UserControl x:Class="Orderly.App.Views.LoginCreateAccountPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Opacity="0">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.A.xaml" />
                <ResourceDictionary Source="/Orderly.App;component/Views/Resources/LoginResources.B.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform X="0" />
        </Grid.RenderTransform>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Center">
            <Grid Margin="0,26,0,30"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  MaxWidth="612">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="创建新账号"
                                       FontWeight="Bold"
                                       FontSize="24"
                                       Foreground="#1D1D1F" />
                            <TextBlock Text="先验证管理员账号，再创建新的成员账号。"
                                       Foreground="#86868B"
                                       FontSize="14"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="BtnBackFromCreateManagedAccount"
                                Grid.Column="1"
                                Style="{StaticResource BackIconButtonStyle}"
                                VerticalAlignment="Top"
                                Click="BtnBackFromCreateManagedAccount_Click" />
                    </Grid>

                    <Border Background="#F5F5F7"
                            CornerRadius="18"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="管理员验证"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1D1D1F" />
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="主账号" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="TxtCreateOwnerUsername"
                                             TextChanged="TxtCreateOwnerUsername_TextChanged" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                                    <PasswordBox x:Name="TxtCreateOwnerPin"
                                                 MaxLength="6"
                                                 PasswordChanged="TxtCreateOwnerPin_PasswordChanged" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" />
                                <PasswordBox x:Name="TxtCreateOwnerPassword"
                                             PasswordChanged="TxtCreateOwnerPassword_PasswordChanged" />
                            </StackPanel>

                            <Border BorderBrush="#E5E5EA"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16"
                                    Margin="0,18,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F3F4F7" />
                                        <Setter Property="Opacity" Value="0.72" />
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanEditCreateManagedAccountFields}" Value="True">
                                                <Setter Property="Background" Value="#FFFFFF" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="IsEnabled" Value="True" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="新账号信息"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="#1D1D1F" />
                                    <TextBlock Text="新账号会创建独立业务库，并使用自己的主密码和 PIN。"
                                               Margin="0,8,0,0"
                                               Foreground="#86868B"
                                               FontSize="12"
                                               TextWrapping="Wrap" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="用户名" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="TxtCreateMemberUsername" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="昵称" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="TxtCreateMemberDisplayName" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="主密码" Style="{StaticResource FieldLabel}" />
                                            <PasswordBox x:Name="TxtCreateMemberPassword" />
                                            <TextBlock Text="至少8位，包含大小写字母和数字，不能含空白或首尾空格。"
                                                       Margin="0,6,0,0"
                                                       Foreground="#86868B"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="PIN" Style="{StaticResource FieldLabel}" />
                                            <PasswordBox x:Name="TxtCreateMemberPin" MaxLength="6" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Button x:Name="BtnSubmitCreateManagedAccount"
                                    Content="{Binding CreateManagedAccountPrimaryActionLabel}"
                                    Style="{StaticResource PremiumButtonStyle}"
                                    Width="220"
                                    Height="52"
                                    HorizontalAlignment="Center"
                                    Margin="0,22,0,0"
                                    Click="BtnSubmitCreateManagedAccount_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
