<view class="page">
  <view class="page-title">SKU 管理</view>
  <view class="page-subtitle">报价页可直接选择启用 SKU，仍可二次调整价格。</view>

  <glass-card>
    <view class="grid-2">
      <view class="field"><text class="field-label">名称</text><input class="input" value="{{form.name}}" data-field="name" bindinput="onInput" /></view>
      <view class="field"><text class="field-label">分类</text><input class="input" value="{{form.category}}" data-field="category" bindinput="onInput" /></view>
      <view class="field"><text class="field-label">基础价</text><input class="input" type="number" value="{{form.basePrice}}" data-field="basePrice" bindinput="onInput" /></view>
      <view class="field"><text class="field-label">成本价</text><input class="input" type="number" value="{{form.costPrice}}" data-field="costPrice" bindinput="onInput" /></view>
    </view>
    <view class="field"><text class="field-label">规格 schema</text><input class="input" value="{{form.specSchema}}" data-field="specSchema" bindinput="onInput" /></view>
    <view class="field"><text class="field-label">标签</text><input class="input" value="{{form.tags}}" data-field="tags" bindinput="onInput" /></view>
    <button class="primary-btn" bindtap="save">保存 SKU</button>
  </glass-card>

  <glass-card>
    <view wx:for="{{skus}}" wx:key="_id" class="sku-row">
      <view>
        <view class="name">{{item.name}}</view>
        <view class="muted">{{item.category}} · ¥{{item.basePrice}} · {{item.tags}}</view>
      </view>
      <view class="row-actions">
        <button data-index="{{index}}" bindtap="edit">编辑</button>
        <button data-index="{{index}}" bindtap="toggle">{{item.enabled ? '停用' : '启用'}}</button>
      </view>
    </view>
    <empty-state wx:if="{{!skus.length}}" title="暂无 SKU"></empty-state>
  </glass-card>
</view>
