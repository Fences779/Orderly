.item-row {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
}

.item-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 120rpx;
  gap: 12rpx;
  margin-top: 12rpx;
}

.mini {
  min-height: 78rpx;
  font-size: 22rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}
