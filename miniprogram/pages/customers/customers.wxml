<view class="page">
  <view class="page-title">客户</view>
  <view class="search-row">
    <input class="input search" value="{{keyword}}" placeholder="搜索昵称 / 联系线索" bindinput="onSearch" />
    <picker range="{{platforms}}" range-key="label" bindchange="pickPlatform">
      <view class="filter">{{platform || '全部'}}</view>
    </picker>
  </view>
  <customer-chip wx:for="{{customers}}" wx:key="_id" customer="{{item}}" bind:select="open"></customer-chip>
  <empty-state wx:if="{{!customers.length}}" title="暂无客户" desc="确认 capture 或极速新建后会生成客户档案。"></empty-state>
</view>
