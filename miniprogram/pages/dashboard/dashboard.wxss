.hero {
  align-items: flex-start;
}

.scan-btn {
  min-width: 112rpx;
  min-height: 68rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #1f7a5a;
  font-size: 24rpx;
  font-weight: 700;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 26rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.action-card {
  min-height: 104rpx;
  padding: 0 12rpx;
  border-radius: 24rpx;
  color: #17211d;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  box-shadow: 0 12rpx 30rpx rgba(42, 67, 55, 0.06);
  font-size: 25rpx;
  font-weight: 700;
}
