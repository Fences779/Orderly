.preview {
  width: 100%;
  height: 360rpx;
  margin-top: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.confidence {
  color: #1f7a5a;
  font-size: 38rpx;
  font-weight: 800;
}

.summary {
  margin-top: 12rpx;
  color: #46534d;
  line-height: 1.5;
}
