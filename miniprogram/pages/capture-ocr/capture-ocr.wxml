<view class="page">
  <view class="page-title">OCR 录入</view>
  <view class="page-subtitle">选择聊天截图，OCR 不可用时仍可手动粘贴文字继续。</view>

  <glass-card>
    <button class="primary-btn" bindtap="chooseImage">选择截图并识别</button>
    <image wx:if="{{imagePath}}" class="preview" src="{{imagePath}}" mode="aspectFill"></image>
    <view class="field section-gap">
      <text class="field-label">OCR 文本</text>
      <textarea class="textarea" value="{{ocrText}}" placeholder="OCR 结果会显示在这里，也可以直接粘贴修正后的文字。" bindinput="onInput"></textarea>
    </view>
    <view class="actions">
      <button class="secondary-btn" bindtap="parse">解析文本</button>
      <button class="primary-btn" bindtap="goConfirm">确认入库</button>
    </view>
  </glass-card>

  <glass-card wx:if="{{parserResult}}">
    <view class="confidence">可信度 {{parserResult.confidenceScore}}</view>
    <view class="summary">{{parserResult.demandSummary}}</view>
  </glass-card>
</view>
