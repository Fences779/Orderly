.status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #1f7a5a;
  background: rgba(31, 122, 90, 0.1);
  font-weight: 700;
}

.quote-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(23, 33, 29, 0.06);
}

.note {
  margin: 18rpx 0;
  padding: 18rpx;
  border-radius: 18rpx;
  color: #46534d;
  background: rgba(255, 255, 255, 0.72);
  line-height: 1.5;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}
