.raw {
  margin-top: 12rpx;
  min-height: 360rpx;
}

.ghost-small {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #1f7a5a;
  background: rgba(31, 122, 90, 0.1);
  font-size: 22rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.confidence {
  color: #1f7a5a;
  font-size: 42rpx;
  font-weight: 800;
}

.summary {
  margin: 12rpx 0 18rpx;
  color: #46534d;
  line-height: 1.5;
}
