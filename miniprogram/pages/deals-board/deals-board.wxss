.toolbar {
  display: flex;
  gap: 14rpx;
  margin: 24rpx 0;
}

.tool {
  min-height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #405048;
  background: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
}

.active {
  color: #ffffff;
  background: #1f7a5a;
}

.board {
  width: 100%;
  white-space: nowrap;
}

.columns {
  display: flex;
  gap: 18rpx;
  padding-bottom: 24rpx;
}

.column {
  display: inline-block;
  width: 610rpx;
  min-height: 70vh;
  padding: 18rpx;
  border-radius: 28rpx;
  vertical-align: top;
  background: rgba(255, 255, 255, 0.48);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.column-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  color: #17211d;
  font-size: 28rpx;
  font-weight: 800;
}
