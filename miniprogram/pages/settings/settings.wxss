.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(23, 33, 29, 0.06);
}

.info-row text:first-child {
  color: #7a817c;
}

.info-row text:last-child {
  color: #17211d;
  font-weight: 700;
}

.result {
  color: #46534d;
  line-height: 1.5;
}
