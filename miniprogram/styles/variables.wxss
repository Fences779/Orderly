.safe-area-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.glass {
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.62);
  box-shadow: 0 18rpx 46rpx rgba(42, 67, 55, 0.08);
  backdrop-filter: blur(18px);
}

.text-strong {
  color: #17211d;
  font-weight: 700;
}

.text-muted {
  color: #7a817c;
}
