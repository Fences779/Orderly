<view class="template">
  <view class="row-between">
    <view class="title">{{template.title || '未命名模板'}}</view>
    <text class="use">使用 {{template.useCount || 0}}</text>
  </view>
  <view class="content">{{preview || template.content}}</view>
  <view class="actions">
    <button bindtap="onCopy">复制</button>
    <button bindtap="onEdit">编辑</button>
  </view>
</view>
