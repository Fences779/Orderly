.deal-card {
  margin-bottom: 16rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(23, 33, 29, 0.06);
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.title {
  flex: 1;
  min-width: 0;
  color: #17211d;
  font-size: 29rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary {
  margin-top: 12rpx;
  color: #46534d;
  font-size: 24rpx;
  line-height: 1.45;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
  color: #6f746f;
  font-size: 21rpx;
}

.meta text {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(31, 122, 90, 0.08);
}

.footer {
  margin-top: 18rpx;
}

.time {
  color: #8a908b;
  font-size: 21rpx;
}

.mini-btn {
  min-width: 92rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #1f7a5a;
  background: rgba(31, 122, 90, 0.1);
  font-size: 22rpx;
  font-weight: 600;
}
