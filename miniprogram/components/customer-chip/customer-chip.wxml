<view class="customer {{selected ? 'selected' : ''}}" bindtap="onTap">
  <view class="avatar">{{avatarText}}</view>
  <view class="body">
    <view class="name">{{customer.name || '未命名客户'}}</view>
    <view class="meta">{{platformText}} · {{customer.contactHandle || '无联系线索'}}</view>
  </view>
</view>
