.task {
  margin-bottom: 16rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.title {
  color: #17211d;
  font-size: 28rpx;
  font-weight: 700;
}

.meta {
  margin-top: 6rpx;
  color: #7a817c;
  font-size: 22rpx;
}

.score {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #1f7a5a;
  font-weight: 800;
}

.text {
  margin-top: 14rpx;
  color: #46534d;
  font-size: 24rpx;
  line-height: 1.5;
}

.actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.actions button {
  padding: 10rpx 0;
  border-radius: 999rpx;
  color: #1f7a5a;
  background: rgba(31, 122, 90, 0.1);
  font-size: 22rpx;
}
