# Local Docker Compose only. Copy to .env for manual runs.
ORDERLY_COMPOSE_PROJECT_NAME=orderly-cloud-local
TZ=Asia/Shanghai

# Local HTTP entry. No production domain or HTTPS is configured here.
ORDERLY_API_HTTP_PORT=18082
ORDERLY_PUBLIC_URL=http://127.0.0.1:18082
ORDERLY_ALLOWED_ORIGINS=http://127.0.0.1:18082

# PostgreSQL. Replace before use; do not commit .env.
POSTGRES_DB=orderly
POSTGRES_USER=orderly
POSTGRES_PASSWORD=replace-with-local-postgres-password

# Auth. Replace with local random values before use; do not commit .env.
ORDERLY_JWT_SIGNING_KEY=replace-with-at-least-32-random-characters
ORDERLY_BOOTSTRAP_ADMIN_TOKEN=
ORDERLY_BOOTSTRAP_ADMIN_PASSWORD=

# Local-only backup/export/blob directories inside containers.
ORDERLY_BACKUP_RETENTION_DAYS=30
ORDERLY_REQUIRE_PRE_MIGRATION_BACKUP=false
ORDERLY_REQUIRE_PRE_IMPORT_BACKUP=false
ORDERLY_RESTORE_DRILL_ENABLED=false
ORDERLY_RESTORE_DRILL_INTERVAL_HOURS=24
ORDERLY_LOCAL_EXPORT_DIR=/opt/orderly/exports
ORDERLY_LOCAL_BLOB_DIR=/opt/orderly/blobs
ORDERLY_EXPORT_RETENTION_HOURS=24
ORDERLY_EXPORT_MAX_RETRY_COUNT=2
ORDERLY_EXPORT_MAX_LOCAL_BYTES=2147483648

# Optional edge proxy only if docker compose is started with --profile edge.
ORDERLY_DOMAIN=localhost

# Optional OSS. Keep empty for local Docker Compose validation.
ORDERLY_OSS_ENDPOINT=
ORDERLY_OSS_BUCKET=
ORDERLY_OSS_ACCESS_KEY_ID=
ORDERLY_OSS_ACCESS_KEY_SECRET=
ORDERLY_OSS_BACKUP_PREFIX=backups/
ORDERLY_OSS_EXPORT_PREFIX=exports/
