# Copy this file to .env before running docker compose.
TZ=Asia/Shanghai

# Public HTTPS entry.
ORDERLY_DOMAIN=orderly.example.com
ORDERLY_PUBLIC_URL=https://orderly.example.com
ORDERLY_ALLOWED_ORIGINS=https://orderly.example.com

# PostgreSQL.
POSTGRES_DB=orderly
POSTGRES_USER=orderly
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# Auth. Use long random values in production.
ORDERLY_JWT_SIGNING_KEY=replace-with-at-least-32-random-characters
ORDERLY_BOOTSTRAP_ADMIN_TOKEN=replace-with-one-time-bootstrap-token

# Backups.
ORDERLY_BACKUP_RETENTION_DAYS=30
ORDERLY_REQUIRE_PRE_MIGRATION_BACKUP=true

# Optional Aliyun OSS for backups and exports.
ORDERLY_OSS_ENDPOINT=
ORDERLY_OSS_BUCKET=
ORDERLY_OSS_ACCESS_KEY_ID=
ORDERLY_OSS_ACCESS_KEY_SECRET=
ORDERLY_OSS_BACKUP_PREFIX=backups/
ORDERLY_OSS_EXPORT_PREFIX=exports/
